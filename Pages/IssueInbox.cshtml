@page
@model IssueInboxModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "My Assigned Issues";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="issue-list-screen">
    <div class="issue-list-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Assigned Issue Reports</div>
        <h2 class="page-title">My Assigned Issues</h2>
        <p class="page-subtitle">Open issue reports assigned directly to you for action and closure.</p>

        <div class="list-actions">
            <a class="menu-btn equipment-btn" href="/IssueReports">View All Open Issues</a>
        </div>

        @if (!Model.OpenIssues.Any())
        {
            <div class="empty-panel">No open issue reports assigned to you.</div>
        }
        else
        {
            <div class="issue-list">
                @foreach (var issue in Model.OpenIssues)
                {
                    <div class="issue-row">
                        <a class="issue-card" href="/IssueReportAction?issueId=@issue.Id">
                            <div class="issue-title">@issue.Module - @issue.IssueType</div>
                            <div class="issue-meta">
                                <div>Reported by: @issue.ReportedByName</div>
                                <div>Severity: @(issue.Severity ?? "Not set")</div>
                                <div>Related: @(issue.RelatedItem ?? "Not set")</div>
                                <div>Location: @(issue.Location ?? "Not set")</div>
                                <div>Notification: @issue.NotificationMethod</div>
                                <div>Created: @issue.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            </div>
                            <div class="issue-message">@issue.Description</div>
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-issueId="@issue.Id">
                            <button class="issue-delete" type="submit" aria-label="Delete issue" title="Delete issue">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 6h18" />
                                    <path d="M8 6V4h8v2" />
                                    <path d="M19 6l-1 14H6L5 6" />
                                    <path d="M10 11v5" />
                                    <path d="M14 11v5" />
                                </svg>
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
.issue-list-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.issue-list-inner { width: 100%; max-width: 980px; margin: 0 auto; text-align: center; padding: 40px 20px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 30px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(680px, 94%); margin: 0 auto 20px auto; font-size: 16px; font-weight: 600; color: #6b7280; }
.list-actions { width: min(860px, 94%); margin: 0 auto 20px auto; display: flex; justify-content: center; }
.list-actions .menu-btn { min-width: 260px; }
.empty-panel { width: min(760px, 94%); margin: 0 auto; padding: 22px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.68); font-weight: 800; color: #52606d; }
.issue-list { display: grid; gap: 16px; width: min(860px, 94%); margin: 0 auto; text-align: left; }
.issue-row { display: grid; grid-template-columns: minmax(0, 1fr) 52px; gap: 12px; align-items: stretch; }
.issue-row form { margin: 0; }
.issue-card { display: block; padding: 18px 20px; border: 1px solid rgba(47,128,168,.26); border-radius: 8px; background: rgba(255,255,255,.78); text-decoration: none; color: #1f2937; box-shadow: 0 14px 28px rgba(47,128,168,.10); }
.issue-card:hover { color: #1f2937; border-color: rgba(47,128,168,.52); }
.issue-delete { width: 52px; min-height: 52px; height: 100%; border: 1px solid rgba(148, 57, 57, 0.22); border-radius: 8px; background: rgba(255,255,255,.78); color: #943939; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 14px 28px rgba(148,57,57,.08); }
.issue-delete:hover { background: rgba(148,57,57,.08); border-color: rgba(148,57,57,.42); }
.issue-delete svg { width: 22px; height: 22px; fill: none; stroke: currentColor; stroke-width: 2.1; stroke-linecap: round; stroke-linejoin: round; }
.issue-title { margin-bottom: 8px; font-size: 18px; font-weight: 900; }
.issue-meta { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px 16px; font-size: 13px; font-weight: 700; color: #52606d; }
.issue-message { margin-top: 12px; font-size: 14px; font-weight: 700; color: #425466; }
@@media (max-width: 700px) { .issue-row { grid-template-columns: minmax(0, 1fr) 48px; } .issue-meta { grid-template-columns: 1fr; } }
</style>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <script>
        window.VectorActionConfirmation?.show({
            message: @Json.Serialize(Model.SuccessMessage),
            redirectUrl: "/IssueInbox",
            delay: 1300
        });
    </script>
}
