@page
@model DailyVehicleChecklistModel
@using System.Text.Json
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = Model.InspectionTitle;
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
    var schematicReferenceImagesJson = JsonSerializer.Serialize(
        VehicleSchematicLibrary.Published.ToDictionary(
            schematic => schematic.Key,
            schematic => schematic.Views.ToDictionary(view => view.Key, view => view.AssetPath)));
}

@functions {
    private static string? DateStatusFieldForChecklistField(string? heading, string? responseKey)
    {
        var context = $"{heading} {responseKey}".ToLowerInvariant();

        if (context.Contains("cpd", StringComparison.OrdinalIgnoreCase))
        {
            return "cpd";
        }

        if (context.Contains("licence", StringComparison.OrdinalIgnoreCase) ||
            context.Contains("license", StringComparison.OrdinalIgnoreCase))
        {
            return "licence";
        }

        if (context.Contains("expiry", StringComparison.OrdinalIgnoreCase) ||
            context.Contains("expiration", StringComparison.OrdinalIgnoreCase) ||
            context.Contains("expires", StringComparison.OrdinalIgnoreCase) ||
            context.Contains("valid until", StringComparison.OrdinalIgnoreCase) ||
            context.Contains("use by", StringComparison.OrdinalIgnoreCase))
        {
            return "expiry";
        }

        if (context.Contains("next service", StringComparison.OrdinalIgnoreCase) ||
            context.Contains("service due", StringComparison.OrdinalIgnoreCase) ||
            context.Contains("service date", StringComparison.OrdinalIgnoreCase))
        {
            return "service";
        }

        return null;
    }
}

<div class="inspection-screen">
    <div class="inspection-inner">
        <header class="inspection-header">
            <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
            <div class="client-line">Client: @companyName</div>
            <div class="home-label">@Model.FrequencyLabel</div>
            <h2 class="page-title">@Model.InspectionTitle</h2>
            <p class="page-subtitle">The selected vehicle loads only its active published checklist from Checklist Management.</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <form method="post" class="inspection-form">
            <input asp-for="Frequency" type="hidden" />
            <input asp-for="SameAsPreviousShift" id="sameAsPreviousShiftInput" type="hidden" />
            <input asp-for="PreviousVehicleReportId" id="previousVehicleReportIdInput" type="hidden" />
            <input asp-for="SchematicMarkData" id="schematicMarkDataInput" type="hidden" />
            <div id="vehicleDraftStatus" class="draft-status" aria-live="polite"></div>

            <section class="inspection-section">
                <div class="section-heading">
                    <span>1</span>
                    <div>
                        <h3>Select Vehicle</h3>
                        <p>Select the registration first. The callsign is pulled from the register but can be adjusted for this check.</p>
                    </div>
                </div>

                @if (Model.VehicleRegisterOptions.Count == 0)
                {
                    <div id="checklistTemplateName" class="template-loaded-note unavailable empty-check-state">
                        <strong>No vehicles are available for daily checks.</strong>
                        <span>Management must add active vehicles to the Vehicle Register, then build and publish the correct checklist before crews can start daily checks.</span>
                        <div class="empty-check-actions">
                            <a class="empty-check-action" href="/VehicleRegister">Open Vehicle Register</a>
                            <a class="empty-check-action primary" href="/EditChecklist?view=register">Open Checklist Register</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="vehicle-register-grid vehicle-selection-grid">
                        <label class="registration-field">
                            Registration number
                            <select asp-for="Registration" id="registrationSelect">
                                <option value="">Select registration</option>
                                @foreach (var vehicle in Model.VehicleRegisterOptions)
                                {
                                    <option value="@vehicle.Registration"
                                            data-callsign="@vehicle.Callsign"
                                            data-type="@vehicle.VehicleType"
                                            data-schematic-name="@vehicle.SchematicName"
                                            data-schematic-key="@vehicle.SchematicKey"
                                            data-next-service="@vehicle.NextServiceDate"
                                            data-license-number="@vehicle.LicenseNumber"
                                            data-template-id="@vehicle.PublishedChecklistTemplateId"
                                            data-template-name="@vehicle.PublishedChecklistTemplateName"
                                            data-template-configured="@vehicle.PublishedChecklistHasConfiguredContent.ToString().ToLowerInvariant()"
                                            data-previous-report-id="@vehicle.PreviousSourceReportId"
                                            data-previous-performer="@vehicle.PreviousSourcePerformer">
                                        @vehicle.Registration - @vehicle.Callsign
                                    </option>
                                }
                            </select>
                        </label>
                        <label>Callsign<input asp-for="Callsign" id="callsignInput" type="text" placeholder="Assigned callsign" /></label>
                    </div>

                    <div class="vehicle-selection-actions">
                        <button id="selectVehicleButton" class="menu-btn vehicle-btn select-vehicle-btn" type="button">Select Vehicle</button>
                    </div>
                }

                @if (Model.HasSelectedVehicle)
                {
                    <input asp-for="VehicleType" id="vehicleTypeInput" type="hidden" />
                    <input asp-for="LicenseNumber" id="licenseNumberInput" type="hidden" />
                    <input asp-for="NextServiceDate" id="nextServiceDateInput" type="hidden" data-skip-date-status="true" />
                    @if (Model.HasAssignedChecklist && Model.AssignedChecklistHasConfiguredContent)
                    {
                        <div id="checklistTemplateName" class="template-loaded-note">Loaded checklist template: @Model.AssignedChecklistName.</div>
                    }
                    else if (Model.HasAssignedChecklist)
                    {
                        <div id="checklistTemplateName" class="template-loaded-note unavailable">Assigned checklist has no configured fields yet.</div>
                    }
                    else
                    {
                        <div id="checklistTemplateName" class="template-loaded-note unavailable">No assigned checklist available for this vehicle.</div>
                    }
                }
                else
                {
                    @if (Model.VehicleRegisterOptions.Count > 0)
                    {
                        <div id="checklistTemplateName" class="template-loaded-note">Select a registration, confirm the callsign, then select the vehicle to load the active checklist.</div>
                    }
                }
            </section>

            @if (Model.HasSelectedVehicle && Model.HasAssignedChecklist && Model.AssignedChecklistHasConfiguredContent)
            {
                <section class="inspection-section live-checklist-panel">
                    <div class="section-heading">
                        <span>2</span>
                        <div>
                            <h3>Assigned Checklist</h3>
                            <p>These fields are loaded from the published checklist register template only.</p>
                        </div>
                    </div>

                    @foreach (var checklistSection in Model.AssignedChecklistSections)
                    {
                        <div class="live-checklist-section">
                            <div class="live-checklist-section-title">@checklistSection.Name</div>
                            @foreach (var item in checklistSection.Items.Where(row => !row.IsSchematicView))
                            {
                                if (item.IsSchematicBlock)
                                {
                                    var schematic = Model.ResolveSchematicForItem(item);
                                    var schematicViews = schematic?.Views ?? Array.Empty<VehicleSchematicViewDefinition>();
                                    var firstSchematicView = schematicViews.FirstOrDefault();
                                    var schematicViewItems = checklistSection.Items
                                        .Where(row => row.ParentChecklistItemId == item.Id && row.IsSchematicView)
                                        .ToList();
                                    <div class="live-checklist-schematic-block">
                                        <div class="live-schematic-heading">
                                            <div>
                                                <strong>@item.Prompt</strong>
                                                <span id="schematicName">@(schematic is null ? "No unit schematic assigned to this vehicle." : $"Loaded schematic: {schematic.DisplayName}")</span>
                                            </div>
                                        </div>

                                        @if (schematicViews.Count > 0)
                                        {
                                            <div class="schematic-tabs" role="tablist" aria-label="Unit schematic views">
                                                @foreach (var view in schematicViews)
                                                {
                                                    var isActive = firstSchematicView is not null && view.Key == firstSchematicView.Key;
                                                    <button class="schematic-tab @(isActive ? "active" : string.Empty)" type="button" data-schematic-view="@view.Key" aria-selected="@isActive.ToString().ToLowerInvariant()">@view.Label</button>
                                                }
                                            </div>
                                        }

                                        <div class="schematic-workspace">
                                            <div id="vehicleSchematic"
                                                 class="vehicle-schematic @(schematic is null ? "missing-reference" : "has-reference")"
                                                 data-schematic="@(schematic?.Key ?? string.Empty)"
                                                 data-view="@(firstSchematicView?.Key ?? "left")">
                                                <img id="schematicReferenceImage"
                                                     class="schematic-reference-image"
                                                     src="@(firstSchematicView?.AssetPath ?? string.Empty)"
                                                     alt="@(schematic is null ? "No unit schematic" : $"{schematic.DisplayName} {firstSchematicView?.Label} view")" />
                                                <canvas id="schematicMarkCanvas" class="schematic-mark-canvas"></canvas>
                                                <div class="schematic-placeholder-message">No unit schematic is assigned to this vehicle. Assign one in the Unit Schematic Library.</div>
                                            </div>
                                            <div class="schematic-mark-actions">
                                                <span>Mark damage directly on the selected vehicle view. Use a mouse, finger, or device pen.</span>
                                                <div>
                                                    <button id="undoSchematicMarkButton" type="button">Undo Mark</button>
                                                    <button id="clearSchematicMarksButton" type="button">Clear View</button>
                                                </div>
                                            </div>
                                        </div>

                                        @if (schematicViewItems.Count > 0)
                                        {
                                            <div class="schematic-view-response-list">
                                                @foreach (var viewItem in schematicViewItems)
                                                {
                                                    var responseViewKey = viewItem.Prompt.Trim().ToLowerInvariant();
                                                    var isActiveResponseView = firstSchematicView is not null
                                                        && string.Equals(responseViewKey, firstSchematicView.Key, StringComparison.OrdinalIgnoreCase);
                                                    <details class="schematic-view-response"
                                                             data-schematic-response-view="@responseViewKey"
                                                             @(isActiveResponseView ? "open" : string.Empty)
                                                             @(isActiveResponseView ? string.Empty : "hidden")>
                                                        <summary>@viewItem.Prompt view checks</summary>
                                                        <div class="live-checklist-fields">
                                                            @foreach (var field in viewItem.Fields)
                                                            {
                                                                var currentValue = Model.ChecklistResponses.TryGetValue(field.ResponseKey, out var savedResponse)
                                                                    ? savedResponse
                                                                    : string.Empty;
                                                                var responseType = field.ResponseType ?? string.Empty;
                                                                <label class="live-checklist-field">
                                                                    <span>
                                                                        @field.Heading
                                                                        @if (field.IsRequired)
                                                                        {
                                                                            <strong>Required</strong>
                                                                        }
                                                                    </span>
                                                                    @if (field.IsSchematicMarkup)
                                                                    {
                                                                        <input name="ChecklistResponses[@field.ResponseKey]" type="hidden" value="@currentValue" />
                                                                        <span class="schematic-field-hint">Use the image above to mark this view.</span>
                                                                    }
                                                                    else if (responseType.Contains("Date", StringComparison.OrdinalIgnoreCase))
                                                                    {
                                                                        var dateStatusField = DateStatusFieldForChecklistField(field.Heading, field.ResponseKey);
                                                                        <input name="ChecklistResponses[@field.ResponseKey]"
                                                                               type="date"
                                                                               value="@currentValue"
                                                                               data-date-status-field="@dateStatusField"
                                                                               data-skip-date-status="@(dateStatusField is null ? "true" : null)" />
                                                                    }
                                                                    else if (responseType.Contains("Number", StringComparison.OrdinalIgnoreCase) ||
                                                                             responseType.Contains("Numeric", StringComparison.OrdinalIgnoreCase))
                                                                    {
                                                                        <input name="ChecklistResponses[@field.ResponseKey]" type="number" value="@currentValue" inputmode="numeric" />
                                                                    }
                                                                    else if (responseType.Contains("Text", StringComparison.OrdinalIgnoreCase) ||
                                                                             responseType.Contains("Note", StringComparison.OrdinalIgnoreCase))
                                                                    {
                                                                        <textarea name="ChecklistResponses[@field.ResponseKey]" rows="2">@currentValue</textarea>
                                                                    }
                                                                    else
                                                                    {
                                                                        <select name="ChecklistResponses[@field.ResponseKey]">
                                                                            <option value="">Select</option>
                                                                            @foreach (var option in Model.GetChecklistResponseOptions(field))
                                                                            {
                                                                                if (string.Equals(currentValue, option, StringComparison.OrdinalIgnoreCase))
                                                                                {
                                                                                    <option value="@option" selected>@option</option>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <option value="@option">@option</option>
                                                                                }
                                                                            }
                                                                        </select>
                                                                    }
                                                                </label>
                                                            }
                                                        </div>
                                                    </details>
                                                }
                                            </div>
                                        }
                                    </div>
                                    continue;
                                }
                                <div class="live-checklist-row @(item.IsSubItem ? "subitem-row" : string.Empty)">
                                    <div class="live-checklist-item-name">@item.Prompt</div>
                                    <div class="live-checklist-fields">
                                        @foreach (var field in item.Fields)
                                        {
                                            var currentValue = Model.ChecklistResponses.TryGetValue(field.ResponseKey, out var savedResponse)
                                                ? savedResponse
                                                : string.Empty;
                                            var responseType = field.ResponseType ?? string.Empty;
                                            <label class="live-checklist-field">
                                                <span>
                                                    @field.Heading
                                                    @if (field.IsRequired)
                                                    {
                                                        <strong>Required</strong>
                                                    }
                                                </span>
                                                @if (field.IsSchematicMarkup)
                                                {
                                                    <input name="ChecklistResponses[@field.ResponseKey]" type="hidden" value="@currentValue" />
                                                    <span class="schematic-field-hint">Use the unit schematic drawing area for this response.</span>
                                                }
                                                else if (responseType.Contains("Date", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    var dateStatusField = DateStatusFieldForChecklistField(field.Heading, field.ResponseKey);
                                                    <input name="ChecklistResponses[@field.ResponseKey]"
                                                           type="date"
                                                           value="@currentValue"
                                                           data-date-status-field="@dateStatusField"
                                                           data-skip-date-status="@(dateStatusField is null ? "true" : null)" />
                                                }
                                                else if (responseType.Contains("Number", StringComparison.OrdinalIgnoreCase) ||
                                                         responseType.Contains("Numeric", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <input name="ChecklistResponses[@field.ResponseKey]" type="number" value="@currentValue" inputmode="numeric" />
                                                }
                                                else if (responseType.Contains("Text", StringComparison.OrdinalIgnoreCase) ||
                                                         responseType.Contains("Note", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <textarea name="ChecklistResponses[@field.ResponseKey]" rows="2">@currentValue</textarea>
                                                }
                                                else
                                                {
                                                    <select name="ChecklistResponses[@field.ResponseKey]">
                                                        <option value="">Select</option>
                                                        @foreach (var option in Model.GetChecklistResponseOptions(field))
                                                        {
                                                            if (string.Equals(currentValue, option, StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <option value="@option" selected>@option</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@option">@option</option>
                                                            }
                                                        }
                                                    </select>
                                                }
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </section>

                <div class="save-bar">
                    <button class="menu-btn vehicle-btn save-btn" type="submit">Save Daily Check</button>
                </div>
            }
            else if (Model.HasSelectedVehicle && Model.HasAssignedChecklist)
            {
                <section class="inspection-section unavailable-checklist-panel">
                    <div class="section-heading">
                        <span>2</span>
                        <div>
                            <h3>Assigned Checklist Has No Configured Fields</h3>
                            <p>The selected vehicle has a published checklist shell, but no saved rows or fields.</p>
                        </div>
                    </div>
                    <p>Open Checklist Management, add the required checklist rows/items, and publish again before this vehicle can be checked.</p>
                </section>
            }
            else if (Model.HasSelectedVehicle)
            {
                <section class="inspection-section unavailable-checklist-panel">
                    <div class="section-heading">
                        <span>2</span>
                        <div>
                            <h3>No Assigned Checklist Available</h3>
                            <p>This vehicle has no live published checklist assigned to its vehicle type, area, or callsign.</p>
                        </div>
                    </div>
                    <p>Ask senior management to publish a checklist in Checklist Management before this vehicle can be checked.</p>
                </section>
            }
        </form>
    </div>
</div>

<style>
.inspection-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.inspection-inner { width: 100%; max-width: 980px; margin: 0 auto; padding: 32px 20px 120px 20px; box-sizing: border-box; }
.inspection-header { text-align: center; }
.page-logo { width: 280px; max-width: 70%; max-height: 150px; object-fit: contain; margin: 0 auto 10px auto; display: block; }
.client-line { margin-bottom: 12px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 8px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 28px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(680px, 94%); margin: 0 auto 22px auto; font-size: 15px; font-weight: 600; color: #6b7280; }
.status-message { width: min(820px, 100%); margin: 0 auto 18px auto; padding: 12px 16px; border: 1px solid rgba(14, 94, 122, 0.24); border-radius: 8px; background: rgba(14, 94, 122, 0.08); color: #0E5E7A; font-weight: 700; text-align: center; }
.draft-status { width: min(820px, 100%); margin: -4px auto 0 auto; color: #64748b; font-size: 12px; font-weight: 800; text-align: center; }
.inspection-form { display: flex; flex-direction: column; gap: 18px; }
.inspection-section { width: 100%; padding: 18px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.68); box-sizing: border-box; }
.section-heading { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; text-align: left; }
.section-heading span { width: 30px; height: 30px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; background: #334155; color: #ffffff; font-size: 13px; font-weight: 800; flex: 0 0 auto; }
.section-heading h3 { margin: 0 0 4px 0; font-size: 18px; font-weight: 800; color: #1f2937; }
.section-heading p { margin: 0; font-size: 13px; font-weight: 600; color: #6b7280; }
.vehicle-register-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
.registration-field { grid-column: 1 / -1; }
.vehicle-selection-actions { display: flex; justify-content: flex-end; margin-top: 14px; }
.select-vehicle-btn { min-width: 220px; border: none; text-align: center; }
.vehicle-register-grid label { display: flex; flex-direction: column; gap: 8px; text-align: left; font-size: 13px; font-weight: 800; color: #52606d; }
.vehicle-register-grid input, .vehicle-register-grid select { width: 100%; min-height: 46px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 14px; font-size: 15px; background: #ffffff; color: #1f2937; box-sizing: border-box; }
.template-loaded-note { margin-top: 14px; padding: 10px 12px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.72); color: #52606d; font-size: 13px; font-weight: 800; text-align: left; }
.template-loaded-note.unavailable,
.unavailable-checklist-panel { border-color: rgba(155, 59, 59, 0.22); background: rgba(155, 59, 59, 0.07); color: #7f2f2f; }
.unavailable-checklist-panel p { margin: 0; color: #7f2f2f; font-size: 14px; font-weight: 800; text-align: left; }
.empty-check-state { display: grid; gap: 10px; justify-items: start; }
.empty-check-state strong { color: #102a3a; font-size: 15px; }
.empty-check-state span { color: #52606d; line-height: 1.4; }
.empty-check-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 2px; }
.empty-check-action { display: inline-flex; align-items: center; justify-content: center; min-height: 36px; padding: 0 12px; border: 1px solid rgba(18,108,132,.24); border-radius: 8px; color: #0E5E7A; background: rgba(255,255,255,.78); font-size: 12px; font-weight: 900; text-decoration: none; }
.empty-check-action.primary { color: #fff; background: #126C84; border-color: #126C84; }
.live-checklist-panel { display: flex; flex-direction: column; gap: 12px; }
.live-checklist-section { border: 1px solid rgba(66, 84, 102, 0.14); border-radius: 8px; overflow: hidden; background: #ffffff; }
.live-checklist-section-title { padding: 10px 12px; background: #334155; color: #ffffff; font-size: 12px; font-weight: 900; letter-spacing: .9px; text-transform: uppercase; text-align: left; }
.live-checklist-row { display: grid; grid-template-columns: minmax(170px, 240px) minmax(0, 1fr); gap: 12px; align-items: stretch; padding: 10px 12px; border-top: 1px solid rgba(66, 84, 102, 0.12); }
.live-checklist-row:first-of-type { border-top: 0; }
.live-checklist-row.subitem-row .live-checklist-item-name { padding-left: 18px; color: #52606d; }
.live-checklist-item-name { display: flex; align-items: center; min-height: 42px; color: #1f2937; font-size: 14px; font-weight: 900; text-align: left; }
.live-checklist-fields { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px; }
.live-checklist-field { display: flex; flex-direction: column; gap: 6px; text-align: left; color: #52606d; font-size: 12px; font-weight: 900; }
.live-checklist-field span { display: flex; align-items: center; gap: 8px; min-height: 18px; }
.live-checklist-field strong { display: inline-flex; align-items: center; min-height: 18px; padding: 0 6px; border-radius: 999px; background: rgba(155, 59, 59, .1); color: #7f2f2f; font-size: 10px; text-transform: uppercase; }
.live-checklist-field input,
.live-checklist-field select,
.live-checklist-field textarea { width: 100%; min-height: 42px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 12px; box-sizing: border-box; background: #ffffff; color: #1f2937; font-size: 14px; font-weight: 700; }
.live-checklist-field textarea { padding-top: 10px; resize: vertical; }
.live-checklist-schematic-block { padding: 12px; border-top: 1px solid rgba(66, 84, 102, 0.12); background: #ffffff; }
.live-schematic-heading { display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; margin-bottom: 10px; text-align: left; }
.live-schematic-heading strong { display: block; color: #1f2937; font-size: 15px; font-weight: 900; }
.live-schematic-heading span { display: block; margin-top: 3px; color: #64748b; font-size: 12px; font-weight: 800; }
.schematic-view-response-list { display: grid; gap: 8px; margin-top: 12px; }
.schematic-view-response { border: 1px solid rgba(66, 84, 102, 0.14); border-radius: 8px; background: #f8fafc; overflow: hidden; }
.schematic-view-response summary { display: flex; align-items: center; min-height: 38px; padding: 0 12px; color: #334155; cursor: default; list-style: none; font-size: 13px; font-weight: 900; }
.schematic-view-response summary::-webkit-details-marker { display: none; }
.schematic-view-response summary::after { content: "Selected view"; margin-left: auto; color: #0E5E7A; font-size: 11px; font-weight: 900; text-transform: uppercase; }
.schematic-view-response[open] summary { border-bottom: 1px solid rgba(66, 84, 102, 0.12); }
.schematic-view-response[open] summary::after { content: "Selected view"; }
.schematic-view-response .live-checklist-fields { padding: 10px; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); }
.schematic-field-hint { min-height: 42px; display: flex !important; align-items: center; padding: 0 12px; border: 1px dashed rgba(14,94,122,.28); border-radius: 8px; background: rgba(14,94,122,.06); color: #0E5E7A !important; font-size: 12px !important; font-weight: 900 !important; }
.schematic-tabs { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; margin-bottom: 14px; }
.schematic-tab { min-height: 38px; border: 1px solid rgba(66, 84, 102, 0.18); border-radius: 8px; background: #ffffff; color: #334155; font-size: 13px; font-weight: 800; }
.schematic-tab.active { background: #0E5E7A; color: #ffffff; border-color: #0E5E7A; }
.schematic-workspace { border: 1px dashed rgba(66, 84, 102, 0.34); border-radius: 8px; background: #f8fafc; padding: 16px; margin-bottom: 16px; }
.vehicle-schematic { position: relative; height: 300px; border-radius: 8px; background: #ffffff; border: 1px solid rgba(66, 84, 102, 0.16); overflow: hidden; touch-action: none; }
.schematic-reference-image { position: absolute; inset: 8px; z-index: 1; width: calc(100% - 16px); height: calc(100% - 16px); object-fit: contain; object-position: center; display: none; pointer-events: none; }
.schematic-mark-canvas { position: absolute; inset: 0; z-index: 4; width: 100%; height: 100%; cursor: crosshair; touch-action: none; }
.vehicle-schematic.has-reference .schematic-reference-image { display: block; }
.schematic-placeholder-message { position: absolute; inset: 0; z-index: 2; display: none; align-items: center; justify-content: center; padding: 18px; color: #64748b; font-size: 14px; font-weight: 900; text-align: center; box-sizing: border-box; }
.vehicle-schematic.missing-reference .schematic-placeholder-message { display: flex; }
.vehicle-schematic.missing-reference .schematic-mark-canvas { pointer-events: none; }
.schematic-mark-actions { display: flex; justify-content: space-between; gap: 12px; align-items: center; margin-top: 10px; }
.schematic-mark-actions span { color: #64748b; font-size: 12px; font-weight: 800; text-align: left; }
.schematic-mark-actions div { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
.schematic-mark-actions button { min-height: 34px; padding: 0 10px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: #ffffff; color: #334155; font-size: 12px; font-weight: 900; cursor: pointer; }
.schematic-mark-actions button:hover { background: rgba(14,94,122,.07); border-color: rgba(14,94,122,.28); color: #0E5E7A; }
.previous-shift-panel { display: grid; grid-template-columns: minmax(220px, 280px) minmax(0, 1fr); gap: 12px; align-items: center; padding: 12px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.72); }
.same-shift-button { min-height: 44px; border: 1px solid rgba(14, 94, 122, 0.28); border-radius: 8px; background: #ffffff; color: #0E5E7A; font-size: 14px; font-weight: 900; }
.same-shift-button:hover:not(:disabled) { background: rgba(14, 94, 122, 0.08); }
.same-shift-button:disabled { cursor: not-allowed; opacity: 0.56; color: #64748b; border-color: rgba(100, 116, 139, 0.26); }
.previous-shift-panel p { margin: 0; color: #52606d; font-size: 13px; font-weight: 700; text-align: left; }
.previous-shift-panel.applied { border-color: rgba(31, 111, 91, 0.36); background: rgba(31, 111, 91, 0.07); }
.save-bar { position: sticky; bottom: 0; z-index: 10; padding: 14px 0 0 0; background: linear-gradient(180deg, rgba(244, 247, 251, 0), #F4F7FB 42%); }
.save-btn { width: 100%; border: none; text-align: center; }
.disabled-link { pointer-events: none; opacity: .58; filter: grayscale(.2); }
@@media (max-width: 760px) { .inspection-inner { padding: 24px 14px 120px 14px; } .page-title { font-size: 24px; } .vehicle-register-grid, .previous-shift-panel, .live-checklist-row { grid-template-columns: 1fr; } .live-checklist-fields { grid-template-columns: 1fr; } .schematic-tabs { grid-template-columns: repeat(2, minmax(0, 1fr)); } .vehicle-schematic { height: 240px; } .schematic-mark-actions { align-items: stretch; flex-direction: column; } .schematic-mark-actions div { justify-content: stretch; } .schematic-mark-actions button { flex: 1 1 auto; } .inspection-section { padding: 14px; } }
</style>

<script>
    (function () {
        const registrationSelect = document.getElementById("registrationSelect");
        const selectVehicleButton = document.getElementById("selectVehicleButton");
        const frequencyInput = document.querySelector("input[name='Frequency']");
        const callsignInput = document.getElementById("callsignInput");
        const vehicleTypeInput = document.getElementById("vehicleTypeInput");
        const licenseNumberInput = document.getElementById("licenseNumberInput");
        const nextServiceDateInput = document.getElementById("nextServiceDateInput");
        const checklistTemplateName = document.getElementById("checklistTemplateName");
        const vehicleSchematic = document.getElementById("vehicleSchematic");
        const schematicReferenceImage = document.getElementById("schematicReferenceImage");
        const schematicMarkCanvas = document.getElementById("schematicMarkCanvas");
        const schematicMarkDataInput = document.getElementById("schematicMarkDataInput");
        const undoSchematicMarkButton = document.getElementById("undoSchematicMarkButton");
        const clearSchematicMarksButton = document.getElementById("clearSchematicMarksButton");
        const schematicName = document.getElementById("schematicName");
        const schematicTabs = document.querySelectorAll(".schematic-tab[data-schematic-view]");
        const sameAsPreviousShiftButton = document.getElementById("sameAsPreviousShiftButton");
        const sameAsPreviousShiftStatus = document.getElementById("sameAsPreviousShiftStatus");
        const sameAsPreviousShiftInput = document.getElementById("sameAsPreviousShiftInput");
        const previousVehicleReportIdInput = document.getElementById("previousVehicleReportIdInput");
        const previousShiftPanel = sameAsPreviousShiftButton?.closest(".previous-shift-panel");
        const sameShiftSettingKey = @Json.Serialize($"{Model.CompanyStorageKeyPrefix}:vectorAllowSameAsPreviousVehicleInspection");
        let schematicMarks = {};
        let activeSchematicStroke = null;
        let schematicIsDrawing = false;
        const schematicReferenceImages = @Html.Raw(schematicReferenceImagesJson);

        function setValue(input, value, force) {
            if (!input || !value) {
                return;
            }

            if (force || !input.value) {
                input.value = value;
            }
        }

        function syncSchematicResponsePanel(view) {
            const normalizedView = (view || "").toLowerCase();
            document.querySelectorAll(".schematic-view-response[data-schematic-response-view]").forEach(function (panel) {
                const isActive = panel.dataset.schematicResponseView === normalizedView;
                panel.hidden = !isActive;
                panel.open = isActive;
            });
        }

        function setSchematicView(view) {
            if (!vehicleSchematic || !view) {
                return;
            }

            vehicleSchematic.dataset.view = view;
            schematicTabs.forEach(function (tab) {
                const isActive = tab.dataset.schematicView === view;
                tab.classList.toggle("active", isActive);
                tab.setAttribute("aria-selected", String(isActive));
            });
            updateSchematicReference();
            resizeSchematicCanvas();
            drawSchematicMarks();
            syncSchematicResponsePanel(view);
        }

        function updateSchematicReference() {
            if (!vehicleSchematic || !schematicReferenceImage) {
                return;
            }

            const schematicKey = vehicleSchematic.dataset.schematic || "";
            const view = vehicleSchematic.dataset.view || "left";
            const imagePath = schematicReferenceImages[schematicKey]?.[view];

            if (imagePath) {
                schematicReferenceImage.src = imagePath;
                vehicleSchematic.classList.add("has-reference");
                vehicleSchematic.classList.remove("missing-reference");
                resizeSchematicCanvas();
                drawSchematicMarks();
                return;
            }

            schematicReferenceImage.removeAttribute("src");
            vehicleSchematic.classList.remove("has-reference");
            vehicleSchematic.classList.add("missing-reference");
            resizeSchematicCanvas();
            drawSchematicMarks();
        }

        function currentSchematicMarkKey() {
            const registration = registrationSelect?.value || "unselected";
            const schematicKey = vehicleSchematic?.dataset.schematic || "unknown";
            const view = vehicleSchematic?.dataset.view || "left";
            return `${registration}:${schematicKey}:${view}`;
        }

        function loadSchematicMarksFromInput() {
            if (!schematicMarkDataInput?.value) {
                schematicMarks = {};
                return;
            }

            try {
                const parsed = JSON.parse(schematicMarkDataInput.value);
                schematicMarks = parsed && typeof parsed === "object" ? parsed : {};
            } catch {
                schematicMarks = {};
            }
        }

        function saveSchematicMarks() {
            if (!schematicMarkDataInput) {
                return;
            }

            schematicMarkDataInput.value = JSON.stringify(schematicMarks);
        }

        function resizeSchematicCanvas() {
            if (!schematicMarkCanvas || !vehicleSchematic) {
                return;
            }

            const rect = vehicleSchematic.getBoundingClientRect();
            if (rect.width <= 0 || rect.height <= 0) {
                return;
            }

            const ratio = window.devicePixelRatio || 1;
            const width = Math.round(rect.width * ratio);
            const height = Math.round(rect.height * ratio);
            if (schematicMarkCanvas.width !== width || schematicMarkCanvas.height !== height) {
                schematicMarkCanvas.width = width;
                schematicMarkCanvas.height = height;
                schematicMarkCanvas.style.width = `${rect.width}px`;
                schematicMarkCanvas.style.height = `${rect.height}px`;
            }

            const context = schematicMarkCanvas.getContext("2d");
            context.setTransform(ratio, 0, 0, ratio, 0, 0);
        }

        function pointFromPointer(event) {
            const rect = schematicMarkCanvas.getBoundingClientRect();
            return {
                x: Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width)),
                y: Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height))
            };
        }

        function drawStroke(context, stroke, rect) {
            if (!stroke?.points?.length) {
                return;
            }

            context.strokeStyle = "#b4232c";
            context.fillStyle = "rgba(180, 35, 44, 0.14)";
            context.lineWidth = 3;
            context.lineCap = "round";
            context.lineJoin = "round";

            if (stroke.points.length === 1) {
                const point = stroke.points[0];
                const x = point.x * rect.width;
                const y = point.y * rect.height;
                context.beginPath();
                context.arc(x, y, 9, 0, Math.PI * 2);
                context.fill();
                context.stroke();
                return;
            }

            context.beginPath();
            stroke.points.forEach(function (point, index) {
                const x = point.x * rect.width;
                const y = point.y * rect.height;
                if (index === 0) {
                    context.moveTo(x, y);
                } else {
                    context.lineTo(x, y);
                }
            });
            context.stroke();
        }

        function drawSchematicMarks(extraStroke) {
            if (!schematicMarkCanvas || !vehicleSchematic) {
                return;
            }

            resizeSchematicCanvas();
            const rect = schematicMarkCanvas.getBoundingClientRect();
            const context = schematicMarkCanvas.getContext("2d");
            context.clearRect(0, 0, rect.width, rect.height);

            const marks = schematicMarks[currentSchematicMarkKey()] || [];
            marks.forEach(function (stroke) {
                drawStroke(context, stroke, rect);
            });

            if (extraStroke) {
                drawStroke(context, extraStroke, rect);
            }
        }

        function beginSchematicMark(event) {
            if (!schematicMarkCanvas) {
                return;
            }

            event.preventDefault();
            schematicIsDrawing = true;
            activeSchematicStroke = { points: [pointFromPointer(event)] };
            schematicMarkCanvas.setPointerCapture?.(event.pointerId);
            drawSchematicMarks(activeSchematicStroke);
        }

        function continueSchematicMark(event) {
            if (!schematicIsDrawing || !activeSchematicStroke) {
                return;
            }

            event.preventDefault();
            activeSchematicStroke.points.push(pointFromPointer(event));
            drawSchematicMarks(activeSchematicStroke);
        }

        function finishSchematicMark(event) {
            if (!schematicIsDrawing || !activeSchematicStroke) {
                return;
            }

            event.preventDefault();
            const key = currentSchematicMarkKey();
            schematicMarks[key] = schematicMarks[key] || [];
            schematicMarks[key].push(activeSchematicStroke);
            activeSchematicStroke = null;
            schematicIsDrawing = false;
            saveSchematicMarks();
            drawSchematicMarks();
            markManualInspectionChange();
        }

        function undoSchematicMark() {
            const key = currentSchematicMarkKey();
            if (!schematicMarks[key]?.length) {
                return;
            }

            schematicMarks[key].pop();
            if (schematicMarks[key].length === 0) {
                delete schematicMarks[key];
            }
            saveSchematicMarks();
            drawSchematicMarks();
            markManualInspectionChange();
        }

        function clearSchematicMarksForView() {
            const key = currentSchematicMarkKey();
            if (!schematicMarks[key]?.length) {
                return;
            }

            delete schematicMarks[key];
            saveSchematicMarks();
            drawSchematicMarks();
            markManualInspectionChange();
        }

        function applyVehicle(option, force) {
            if (!option || !option.value) {
                updateEquipmentLink(null);
                return;
            }

            setValue(callsignInput, option.dataset.callsign, force);
            setValue(vehicleTypeInput, option.dataset.type, force);
            setValue(licenseNumberInput, option.dataset.licenseNumber, force);
            setValue(nextServiceDateInput, option.dataset.nextService, force);
            if (vehicleSchematic) {
                vehicleSchematic.dataset.schematic = option.dataset.schematicKey || "";
                updateSchematicReference();
                drawSchematicMarks();
            }
            if (schematicName) {
                schematicName.textContent = option.dataset.schematicKey
                    ? "Loaded schematic: " + option.dataset.schematicName
                    : "No unit schematic assigned to this vehicle.";
            }
            if (checklistTemplateName) {
                if (!option.dataset.templateName) {
                    checklistTemplateName.textContent = "No assigned checklist available for this vehicle.";
                    checklistTemplateName.classList.add("unavailable");
                } else if (option.dataset.templateConfigured !== "true") {
                    checklistTemplateName.textContent = "Assigned checklist has no configured fields yet.";
                    checklistTemplateName.classList.add("unavailable");
                } else {
                    checklistTemplateName.textContent = "Loaded checklist template: " + option.dataset.templateName + ".";
                    checklistTemplateName.classList.remove("unavailable");
                }
            }
        }

        function clearPreviousShiftSelection() {
            if (sameAsPreviousShiftInput) {
                sameAsPreviousShiftInput.value = "false";
            }
            if (previousVehicleReportIdInput) {
                previousVehicleReportIdInput.value = "";
            }

            previousShiftPanel?.classList.remove("applied");
        }

        function clearInspectionCarryForwardFields() {
            document.querySelectorAll("input[name^='ChecklistResponses'], select[name^='ChecklistResponses'], textarea[name^='ChecklistResponses']").forEach(function (input) {
                input.value = "";
            });
        }

        function markManualInspectionChange() {
            if (!previousShiftPanel?.classList.contains("applied")) {
                return;
            }

            clearPreviousShiftSelection();
            if (sameAsPreviousShiftStatus && !sameAsPreviousShiftButton?.disabled) {
                sameAsPreviousShiftStatus.textContent = "Manual change recorded. This inspection is no longer marked as same as previous shift.";
            }
        }

        function configurePreviousShiftButton() {
            if (!sameAsPreviousShiftButton || !sameAsPreviousShiftStatus) {
                return;
            }

            const storedSetting = localStorage.getItem(sameShiftSettingKey);
            const defaultAllowed = sameAsPreviousShiftButton.dataset.defaultAllowed === "true";
            const isAllowed = storedSetting === null ? defaultAllowed : storedSetting === "true";

            sameAsPreviousShiftButton.disabled = !isAllowed;
            sameAsPreviousShiftStatus.textContent = isAllowed
                ? "Fresh inspection is the default. Use this only when the last checklist for this vehicle by another profile is unchanged."
                : "Same as previous shift is disabled by senior management.";
        }

        function applyPreviousShift() {
            const option = registrationSelect?.selectedOptions[0];
            if (!option || !option.value) {
                if (sameAsPreviousShiftStatus) {
                    sameAsPreviousShiftStatus.textContent = "Select a registration before using Same as previous shift.";
                }
                return;
            }

            if (!option.dataset.previousReportId) {
                clearPreviousShiftSelection();
                if (sameAsPreviousShiftStatus) {
                    sameAsPreviousShiftStatus.textContent = "No previous checklist from another profile is available for this vehicle.";
                }
                return;
            }

            if (sameAsPreviousShiftInput) {
                sameAsPreviousShiftInput.value = "true";
            }
            if (previousVehicleReportIdInput) {
                previousVehicleReportIdInput.value = option.dataset.previousReportId;
            }

            previousShiftPanel?.classList.add("applied");
            if (sameAsPreviousShiftStatus) {
                sameAsPreviousShiftStatus.textContent = "Previous checklist from " + (option.dataset.previousPerformer || "another profile") + " is linked to this submission. Complete only fields that changed.";
            }
        }

        if (!registrationSelect) {
            return;
        }

        selectVehicleButton?.addEventListener("click", function () {
            const option = registrationSelect.selectedOptions[0];
            if (!option || !option.value) {
                if (checklistTemplateName) {
                    checklistTemplateName.textContent = "Select a registration before loading the checklist.";
                }
                return;
            }

            setValue(callsignInput, option.dataset.callsign, false);
            const frequency = frequencyInput?.value || "daily";
            const callsign = callsignInput?.value || option.dataset.callsign || "";
            window.location.href = `/DailyVehicleChecklist?frequency=${encodeURIComponent(frequency)}&registration=${encodeURIComponent(option.value)}&callsign=${encodeURIComponent(callsign)}`;
        });

        registrationSelect.addEventListener("change", function () {
            applyVehicle(registrationSelect.selectedOptions[0], true);
            clearPreviousShiftSelection();
            clearInspectionCarryForwardFields();
            if (sameAsPreviousShiftStatus && !sameAsPreviousShiftButton?.disabled) {
                sameAsPreviousShiftStatus.textContent = "Fresh inspection started for this registration.";
            }
        });
        callsignInput?.addEventListener("input", function () {
            updateEquipmentLink(registrationSelect.selectedOptions[0]);
        });

        sameAsPreviousShiftButton?.addEventListener("click", applyPreviousShift);
        schematicTabs.forEach(function (tab) {
            tab.addEventListener("click", function () {
                setSchematicView(tab.dataset.schematicView);
            });
        });
        schematicMarkCanvas?.addEventListener("pointerdown", beginSchematicMark);
        schematicMarkCanvas?.addEventListener("pointermove", continueSchematicMark);
        schematicMarkCanvas?.addEventListener("pointerup", finishSchematicMark);
        schematicMarkCanvas?.addEventListener("pointercancel", finishSchematicMark);
        schematicMarkCanvas?.addEventListener("pointerleave", finishSchematicMark);
        undoSchematicMarkButton?.addEventListener("click", undoSchematicMark);
        clearSchematicMarksButton?.addEventListener("click", clearSchematicMarksForView);
        document.querySelectorAll(".schematic-view-response summary").forEach(function (summary) {
            summary.addEventListener("click", function (event) {
                event.preventDefault();
            });
        });
        schematicReferenceImage?.addEventListener("load", function () {
            resizeSchematicCanvas();
            drawSchematicMarks();
        });
        window.addEventListener("resize", function () {
            resizeSchematicCanvas();
            drawSchematicMarks();
        });
        document.querySelectorAll("input[name^='ChecklistResponses'], select[name^='ChecklistResponses'], textarea[name^='ChecklistResponses']").forEach(function (input) {
            input?.addEventListener("change", markManualInspectionChange);
            input?.addEventListener("input", markManualInspectionChange);
        });

        configurePreviousShiftButton();
        loadSchematicMarksFromInput();
        setSchematicView(vehicleSchematic?.dataset.view || "left");
        applyVehicle(registrationSelect.selectedOptions[0], false);
        const bindVehicleDraft = function () {
            window.VectorShiftDrafts?.bindForm(document.querySelector(".inspection-form"), {
                key: @Json.Serialize(Model.DraftStorageKey),
                statusElement: document.getElementById("vehicleDraftStatus"),
                onAfterRestore: function () {
                    loadSchematicMarksFromInput();
                    applyVehicle(registrationSelect.selectedOptions[0], false);
                    drawSchematicMarks();
                }
            });
        };

        if (window.VectorShiftDrafts) {
            bindVehicleDraft();
        } else {
            window.VectorPendingShiftDraftBindings = window.VectorPendingShiftDraftBindings || [];
            window.VectorPendingShiftDraftBindings.push(bindVehicleDraft);
        }
    })();
</script>

@if (Model.ActionSaved)
{
    <script>
        window.VectorDraftKeysToClear = window.VectorDraftKeysToClear || [];
        window.VectorDraftKeysToClear.push(@Json.Serialize(Model.DraftStorageKey));
        window.VectorPendingConfirmations = window.VectorPendingConfirmations || [];
        window.VectorPendingConfirmations.push({
            message: @Json.Serialize($"{Model.InspectionTitle} saved."),
            redirectUrl: @Json.Serialize(Model.FreshChecklistUrl),
            delay: 1300
        });
    </script>
}
