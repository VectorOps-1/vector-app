@page
@model DailyVehicleChecklistModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = Model.InspectionTitle;
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="inspection-screen">
    <div class="inspection-inner">
        <header class="inspection-header">
            <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
            <div class="client-line">Client: @companyName</div>
            <div class="home-label">@Model.FrequencyLabel</div>
            <h2 class="page-title">@Model.InspectionTitle</h2>
            <p class="page-subtitle">Saved inspections will link to the signed-in profile and create an audit record.</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <form method="post" class="inspection-form">
            <input asp-for="Frequency" type="hidden" />
            <input asp-for="SameAsPreviousShift" id="sameAsPreviousShiftInput" type="hidden" />

            <section class="inspection-section">
                <div class="section-heading">
                    <span>1</span>
                    <div>
                        <h3>Vehicle Details</h3>
                        <p>Select the vehicle and capture readiness values.</p>
                    </div>
                </div>

                <div class="vehicle-register-grid">
                    <label class="registration-field">
                        Registration number
                        <select asp-for="Registration" id="registrationSelect">
                            <option value="">Select registration</option>
                            @foreach (var vehicle in Model.VehicleRegisterOptions)
                            {
                                <option value="@vehicle.Registration"
                                        data-callsign="@vehicle.Callsign"
                                        data-type="@vehicle.VehicleType"
                                        data-schematic-name="@vehicle.SchematicName"
                                        data-schematic-key="@vehicle.SchematicKey"
                                        data-next-service="@vehicle.NextServiceDate"
                                        data-previous-kilometres="@vehicle.PreviousKilometres"
                                        data-previous-fuel-level="@vehicle.PreviousFuelLevel"
                                        data-previous-vehicle-status="@vehicle.PreviousVehicleStatus"
                                        data-previous-lights-status="@vehicle.PreviousLightsStatus"
                                        data-previous-siren-status="@vehicle.PreviousSirenStatus"
                                        data-previous-warning-lights-status="@vehicle.PreviousWarningLightsStatus"
                                        data-previous-tyres-status="@vehicle.PreviousTyresStatus"
                                        data-previous-ops-radio-status="@vehicle.PreviousOpsRadioStatus"
                                        data-previous-damage-type="@vehicle.PreviousDamageType"
                                        data-previous-damage-severity="@vehicle.PreviousDamageSeverity"
                                        data-previous-damage-notes="@vehicle.PreviousDamageNotes"
                                        data-previous-checklist-notes="@vehicle.PreviousChecklistNotes">
                                    @vehicle.Registration - @vehicle.Callsign
                                </option>
                            }
                        </select>
                    </label>
                    <label>Vehicle / callsign<input asp-for="Callsign" id="callsignInput" type="text" placeholder="Assigned callsign" /></label>
                    <label>Vehicle type<input asp-for="VehicleType" id="vehicleTypeInput" type="text" placeholder="Vehicle type" /></label>
                    <label>Next service date<input asp-for="NextServiceDate" id="nextServiceDateInput" type="date" /></label>
                </div>
            </section>

            <div class="previous-shift-panel">
                <button id="sameAsPreviousShiftButton"
                        class="same-shift-button"
                        type="button"
                        data-default-allowed="@Model.AllowSameAsPreviousShift.ToString().ToLowerInvariant()">
                    Same as previous shift
                </button>
                <p id="sameAsPreviousShiftStatus">Fresh inspection is the default. Use this only when the operational checks, schematic, damage, and notes are unchanged.</p>
            </div>

            <section class="inspection-section">
                <div class="section-heading">
                    <span>2</span>
                    <div>
                        <h3>Operational Checks</h3>
                        <p>Complete these fields fresh unless Same as previous shift is selected.</p>
                    </div>
                </div>

                <div class="operational-grid">
                    <label>Current kilometres<input asp-for="Kilometres" id="kilometresInput" type="number" min="0" placeholder="Enter current odometer reading" inputmode="numeric" /></label>
                    <label>Fuel level<select asp-for="FuelLevel" id="fuelLevelInput"><option value="">Select fuel level</option><option>Full</option><option>3/4</option><option>1/2</option><option>1/4</option><option>Empty</option></select></label>
                    <label>Vehicle condition<select asp-for="VehicleStatus" id="vehicleStatusInput"><option value="">Select condition</option><option>Operational</option><option>Operational with notes</option><option>Out of service</option></select></label>
                    <label>Lights<select asp-for="LightsStatus" id="lightsStatusInput"><option value="">Select status</option><option>Pass</option><option>Issue</option><option>Fail</option><option>N/A</option></select></label>
                    <label>Sirens<select asp-for="SirenStatus" id="sirenStatusInput"><option value="">Select status</option><option>Pass</option><option>Issue</option><option>Fail</option><option>N/A</option></select></label>
                    <label>Warning lights<select asp-for="WarningLightsStatus" id="warningLightsStatusInput"><option value="">Select status</option><option>Pass</option><option>Issue</option><option>Fail</option><option>N/A</option></select></label>
                    <label>Tyres<select asp-for="TyresStatus" id="tyresStatusInput"><option value="">Select status</option><option>Pass</option><option>Issue</option><option>Fail</option><option>N/A</option></select></label>
                    <label>Ops radio connectivity<select asp-for="OpsRadioStatus" id="opsRadioStatusInput"><option value="">Select status</option><option>Pass</option><option>Issue</option><option>Fail</option><option>N/A</option></select></label>
                </div>
            </section>

            <section class="inspection-section schematic-section">
                <div class="section-heading">
                    <span>3</span>
                    <div>
                        <h3>Vehicle Schematic</h3>
                        <p>Mark damage against the correct vehicle view.</p>
                    </div>
                </div>

                <div class="schematic-tabs" role="tablist" aria-label="Vehicle views">
                    <button type="button" class="schematic-tab active">Left</button>
                    <button type="button" class="schematic-tab">Right</button>
                    <button type="button" class="schematic-tab">Front</button>
                    <button type="button" class="schematic-tab">Rear</button>
                    <button type="button" class="schematic-tab">Top</button>
                </div>

                <div class="schematic-workspace">
                    <div id="vehicleSchematic" class="vehicle-schematic" data-schematic="ambulance" aria-label="Vehicle outline placeholder">
                        <div class="schematic-roof"></div>
                        <div class="schematic-body"></div>
                        <div class="schematic-cab"></div>
                        <div class="schematic-window front-window"></div>
                        <div class="schematic-window rear-window"></div>
                        <div class="schematic-wheel front-wheel"></div>
                        <div class="schematic-wheel rear-wheel"></div>
                        <div class="damage-marker marker-one"></div>
                        <div class="damage-marker marker-two"></div>
                    </div>
                    <p id="schematicName" class="schematic-note">Select a registration to load the published vehicle schematic.</p>
                </div>

                <div class="damage-grid">
                    <label>Damage type<select asp-for="DamageType" id="damageTypeInput"><option value="">Select damage type</option><option>Dent</option><option>Scratch</option><option>Crack</option><option>Missing item</option><option>Fluid leak</option><option>Other</option></select></label>
                    <label>Damage severity<select asp-for="DamageSeverity" id="damageSeverityInput"><option value="">Select severity</option><option>Minor</option><option>Moderate</option><option>Severe</option></select></label>
                </div>

                <label class="notes-field">Damage notes<textarea asp-for="DamageNotes" id="damageNotesInput" rows="4" placeholder="Describe location and details of visible damage"></textarea></label>
            </section>

            <section class="inspection-section">
                <div class="section-heading">
                    <span>4</span>
                    <div>
                        <h3>Notes / Issue</h3>
                        <p>Record anything that requires follow-up.</p>
                    </div>
                </div>

                <label class="notes-field wide-notes">Inspection notes<textarea asp-for="ChecklistNotes" id="checklistNotesInput" rows="5" placeholder="Additional notes, issues, or action required"></textarea></label>
            </section>

            <div class="save-bar two-actions">
                <button class="menu-btn vehicle-btn save-btn" type="submit">Save Inspection</button>
                <a class="menu-btn equipment-btn save-btn" href="@Model.EquipmentChecklistUrl">Next: Equipment Checklist</a>
            </div>
        </form>
    </div>
</div>

<style>
.inspection-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.inspection-inner { width: 100%; max-width: 980px; margin: 0 auto; padding: 32px 20px 120px 20px; box-sizing: border-box; }
.inspection-header { text-align: center; }
.page-logo { width: 280px; max-width: 70%; max-height: 150px; object-fit: contain; margin: 0 auto 10px auto; display: block; }
.client-line { margin-bottom: 12px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 8px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 28px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(680px, 94%); margin: 0 auto 22px auto; font-size: 15px; font-weight: 600; color: #6b7280; }
.status-message { width: min(820px, 100%); margin: 0 auto 18px auto; padding: 12px 16px; border: 1px solid rgba(14, 94, 122, 0.24); border-radius: 8px; background: rgba(14, 94, 122, 0.08); color: #0E5E7A; font-weight: 700; text-align: center; }
.inspection-form { display: flex; flex-direction: column; gap: 18px; }
.inspection-section { width: 100%; padding: 18px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.68); box-sizing: border-box; }
.section-heading { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; text-align: left; }
.section-heading span { width: 30px; height: 30px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; background: #334155; color: #ffffff; font-size: 13px; font-weight: 800; flex: 0 0 auto; }
.section-heading h3 { margin: 0 0 4px 0; font-size: 18px; font-weight: 800; color: #1f2937; }
.section-heading p { margin: 0; font-size: 13px; font-weight: 600; color: #6b7280; }
.vehicle-register-grid, .damage-grid, .operational-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
.registration-field { grid-column: 1 / -1; }
.vehicle-register-grid label, .damage-grid label, .operational-grid label, .notes-field { display: flex; flex-direction: column; gap: 8px; text-align: left; font-size: 13px; font-weight: 800; color: #52606d; }
.vehicle-register-grid input, .vehicle-register-grid select, .damage-grid select, .operational-grid input, .operational-grid select, .notes-field textarea { width: 100%; min-height: 46px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 14px; font-size: 15px; background: #ffffff; color: #1f2937; box-sizing: border-box; }
.notes-field textarea { padding-top: 12px; resize: vertical; }
.schematic-tabs { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 8px; margin-bottom: 14px; }
.schematic-tab { min-height: 38px; border: 1px solid rgba(66, 84, 102, 0.18); border-radius: 8px; background: #ffffff; color: #334155; font-size: 13px; font-weight: 800; }
.schematic-tab.active { background: #0E5E7A; color: #ffffff; border-color: #0E5E7A; }
.schematic-workspace { border: 1px dashed rgba(66, 84, 102, 0.34); border-radius: 8px; background: #f8fafc; padding: 16px; margin-bottom: 16px; }
.vehicle-schematic { position: relative; height: 240px; border-radius: 8px; background: #ffffff; border: 1px solid rgba(66, 84, 102, 0.16); overflow: hidden; }
.schematic-body { position: absolute; left: 9%; right: 8%; bottom: 64px; height: 70px; border: 4px solid #334155; border-radius: 24px 18px 16px 16px; }
.schematic-roof { position: absolute; left: 22%; right: 24%; bottom: 132px; height: 44px; border: 4px solid #334155; border-bottom: 0; border-radius: 34px 34px 0 0; }
.schematic-cab { position: absolute; right: 13%; bottom: 96px; width: 18%; height: 72px; border-left: 4px solid #334155; transform: skewX(-18deg); }
.schematic-window { position: absolute; bottom: 116px; height: 36px; border: 3px solid #52606d; border-radius: 8px; }
.front-window { right: 18%; width: 15%; transform: skewX(-14deg); }
.rear-window { left: 28%; width: 27%; }
.schematic-wheel { position: absolute; bottom: 38px; width: 44px; height: 44px; border: 5px solid #1f2937; border-radius: 50%; background: #ffffff; }
.front-wheel { right: 18%; }
.rear-wheel { left: 18%; }
.damage-marker { position: absolute; width: 18px; height: 18px; border-radius: 50%; border: 3px solid #8F3A3A; background: rgba(143, 58, 58, 0.14); }
.marker-one { left: 42%; bottom: 104px; }
.marker-two { right: 28%; bottom: 88px; }
.schematic-note { margin: 12px 0 0 0; color: #6b7280; font-size: 13px; font-weight: 700; text-align: center; }
.vehicle-schematic[data-schematic="rapid-response"] .schematic-body { left: 16%; right: 14%; bottom: 72px; height: 54px; border-radius: 34px 34px 18px 18px; }
.vehicle-schematic[data-schematic="rapid-response"] .schematic-roof { left: 34%; right: 31%; bottom: 126px; height: 38px; border-radius: 24px 24px 0 0; }
.vehicle-schematic[data-schematic="rapid-response"] .schematic-cab { right: 20%; bottom: 100px; width: 16%; height: 56px; }
.vehicle-schematic[data-schematic="rapid-response"] .rear-window { left: 38%; width: 18%; }
.vehicle-schematic[data-schematic="rapid-response"] .front-window { right: 25%; width: 12%; }
.previous-shift-panel { display: grid; grid-template-columns: minmax(220px, 280px) minmax(0, 1fr); gap: 12px; align-items: center; padding: 12px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.72); }
.same-shift-button { min-height: 44px; border: 1px solid rgba(14, 94, 122, 0.28); border-radius: 8px; background: #ffffff; color: #0E5E7A; font-size: 14px; font-weight: 900; }
.same-shift-button:hover:not(:disabled) { background: rgba(14, 94, 122, 0.08); }
.same-shift-button:disabled { cursor: not-allowed; opacity: 0.56; color: #64748b; border-color: rgba(100, 116, 139, 0.26); }
.previous-shift-panel p { margin: 0; color: #52606d; font-size: 13px; font-weight: 700; text-align: left; }
.previous-shift-panel.applied { border-color: rgba(31, 111, 91, 0.36); background: rgba(31, 111, 91, 0.07); }
.damage-grid { margin-bottom: 14px; }
.save-bar { position: sticky; bottom: 0; z-index: 10; padding: 14px 0 0 0; background: linear-gradient(180deg, rgba(244, 247, 251, 0), #F4F7FB 42%); }
.two-actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.save-btn { width: 100%; border: none; text-align: center; }
@@media (max-width: 760px) { .inspection-inner { padding: 24px 14px 120px 14px; } .page-title { font-size: 24px; } .vehicle-register-grid, .damage-grid, .operational-grid, .two-actions, .previous-shift-panel { grid-template-columns: 1fr; } .schematic-tabs { grid-template-columns: repeat(3, minmax(0, 1fr)); } .vehicle-schematic { height: 210px; } .inspection-section { padding: 14px; } }
</style>

<script>
    (function () {
        const registrationSelect = document.getElementById("registrationSelect");
        const callsignInput = document.getElementById("callsignInput");
        const vehicleTypeInput = document.getElementById("vehicleTypeInput");
        const kilometresInput = document.getElementById("kilometresInput");
        const fuelLevelInput = document.getElementById("fuelLevelInput");
        const nextServiceDateInput = document.getElementById("nextServiceDateInput");
        const vehicleStatusInput = document.getElementById("vehicleStatusInput");
        const lightsStatusInput = document.getElementById("lightsStatusInput");
        const sirenStatusInput = document.getElementById("sirenStatusInput");
        const warningLightsStatusInput = document.getElementById("warningLightsStatusInput");
        const tyresStatusInput = document.getElementById("tyresStatusInput");
        const opsRadioStatusInput = document.getElementById("opsRadioStatusInput");
        const vehicleSchematic = document.getElementById("vehicleSchematic");
        const schematicName = document.getElementById("schematicName");
        const sameAsPreviousShiftButton = document.getElementById("sameAsPreviousShiftButton");
        const sameAsPreviousShiftStatus = document.getElementById("sameAsPreviousShiftStatus");
        const sameAsPreviousShiftInput = document.getElementById("sameAsPreviousShiftInput");
        const previousShiftPanel = sameAsPreviousShiftButton?.closest(".previous-shift-panel");
        const damageTypeInput = document.getElementById("damageTypeInput");
        const damageSeverityInput = document.getElementById("damageSeverityInput");
        const damageNotesInput = document.getElementById("damageNotesInput");
        const checklistNotesInput = document.getElementById("checklistNotesInput");
        const sameShiftSettingKey = "vectorAllowSameAsPreviousShift";

        function setValue(input, value, force) {
            if (!input || !value) {
                return;
            }

            if (force || !input.value) {
                input.value = value;
            }
        }

        function applyVehicle(option, force) {
            if (!option || !option.value) {
                return;
            }

            setValue(callsignInput, option.dataset.callsign, force);
            setValue(vehicleTypeInput, option.dataset.type, force);
            setValue(nextServiceDateInput, option.dataset.nextService, force);
            if (vehicleSchematic && option.dataset.schematicKey) {
                vehicleSchematic.dataset.schematic = option.dataset.schematicKey;
            }
            if (schematicName && option.dataset.schematicName) {
                schematicName.textContent = "Loaded schematic: " + option.dataset.schematicName;
            }
        }

        function clearPreviousShiftSelection() {
            if (sameAsPreviousShiftInput) {
                sameAsPreviousShiftInput.value = "false";
            }

            previousShiftPanel?.classList.remove("applied");
        }

        function clearInspectionCarryForwardFields() {
            [
                kilometresInput,
                fuelLevelInput,
                vehicleStatusInput,
                lightsStatusInput,
                sirenStatusInput,
                warningLightsStatusInput,
                tyresStatusInput,
                opsRadioStatusInput,
                damageTypeInput,
                damageSeverityInput,
                damageNotesInput,
                checklistNotesInput
            ].forEach(function (input) {
                if (input) {
                    input.value = "";
                }
            });
        }

        function markManualInspectionChange() {
            if (!previousShiftPanel?.classList.contains("applied")) {
                return;
            }

            clearPreviousShiftSelection();
            if (sameAsPreviousShiftStatus && !sameAsPreviousShiftButton?.disabled) {
                sameAsPreviousShiftStatus.textContent = "Manual change recorded. This inspection is no longer marked as same as previous shift.";
            }
        }

        function configurePreviousShiftButton() {
            if (!sameAsPreviousShiftButton || !sameAsPreviousShiftStatus) {
                return;
            }

            const storedSetting = localStorage.getItem(sameShiftSettingKey);
            const defaultAllowed = sameAsPreviousShiftButton.dataset.defaultAllowed === "true";
            const isAllowed = storedSetting === null ? defaultAllowed : storedSetting === "true";

            sameAsPreviousShiftButton.disabled = !isAllowed;
            sameAsPreviousShiftStatus.textContent = isAllowed
                ? "Fresh inspection is the default. Use this only when the schematic, damage, and notes are unchanged."
                : "Same as previous shift is disabled by senior management.";
        }

        function applyPreviousShift() {
            const option = registrationSelect?.selectedOptions[0];
            if (!option || !option.value) {
                if (sameAsPreviousShiftStatus) {
                    sameAsPreviousShiftStatus.textContent = "Select a registration before using Same as previous shift.";
                }
                return;
            }

            setValue(kilometresInput, option.dataset.previousKilometres, true);
            setValue(fuelLevelInput, option.dataset.previousFuelLevel, true);
            setValue(vehicleStatusInput, option.dataset.previousVehicleStatus, true);
            setValue(lightsStatusInput, option.dataset.previousLightsStatus, true);
            setValue(sirenStatusInput, option.dataset.previousSirenStatus, true);
            setValue(warningLightsStatusInput, option.dataset.previousWarningLightsStatus, true);
            setValue(tyresStatusInput, option.dataset.previousTyresStatus, true);
            setValue(opsRadioStatusInput, option.dataset.previousOpsRadioStatus, true);
            setValue(damageTypeInput, option.dataset.previousDamageType, true);
            setValue(damageSeverityInput, option.dataset.previousDamageSeverity, true);
            setValue(damageNotesInput, option.dataset.previousDamageNotes, true);
            setValue(checklistNotesInput, option.dataset.previousChecklistNotes, true);

            if (sameAsPreviousShiftInput) {
                sameAsPreviousShiftInput.value = "true";
            }

            previousShiftPanel?.classList.add("applied");
            if (sameAsPreviousShiftStatus) {
                sameAsPreviousShiftStatus.textContent = "Previous shift schematic, damage, and notes have been applied. Edit any field if something changed.";
            }
        }

        if (!registrationSelect) {
            return;
        }

        registrationSelect.addEventListener("change", function () {
            applyVehicle(registrationSelect.selectedOptions[0], true);
            clearPreviousShiftSelection();
            clearInspectionCarryForwardFields();
            if (sameAsPreviousShiftStatus && !sameAsPreviousShiftButton?.disabled) {
                sameAsPreviousShiftStatus.textContent = "Fresh inspection started for this registration.";
            }
        });

        sameAsPreviousShiftButton?.addEventListener("click", applyPreviousShift);
        [
            kilometresInput,
            fuelLevelInput,
            vehicleStatusInput,
            lightsStatusInput,
            sirenStatusInput,
            warningLightsStatusInput,
            tyresStatusInput,
            opsRadioStatusInput,
            damageTypeInput,
            damageSeverityInput,
            damageNotesInput,
            checklistNotesInput
        ].forEach(function (input) {
            input?.addEventListener("change", markManualInspectionChange);
            input?.addEventListener("input", markManualInspectionChange);
        });

        configurePreviousShiftButton();
        applyVehicle(registrationSelect.selectedOptions[0], false);
    })();
</script>
