@page
@model DailyVehicleChecklistModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Daily Vehicle Inspection";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="inspection-screen">
    <div class="inspection-inner">
        <header class="inspection-header">
            <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
            <div class="client-line">Client: @companyName</div>
            <div class="home-label">Daily Checklist</div>
            <h2 class="page-title">Daily Vehicle Inspection</h2>
            <p class="page-subtitle">Saved inspections will link to the signed-in profile and create an audit record.</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <form method="post" class="inspection-form">
            <section class="inspection-section">
                <div class="section-heading">
                    <span>1</span>
                    <div>
                        <h3>Vehicle Details</h3>
                        <p>Select the vehicle and capture readiness values.</p>
                    </div>
                </div>

                <div class="form-grid">
                    <label>Vehicle / callsign<input asp-for="Callsign" type="text" placeholder="Callsign or fleet number" /></label>
                    <label>Registration<input asp-for="Registration" type="text" placeholder="Registration number" /></label>
                    <label>Current kilometres<input asp-for="Kilometres" type="number" min="0" placeholder="Km reading" inputmode="numeric" /></label>
                    <label>Fuel level<select asp-for="FuelLevel"><option value="">Select fuel level</option><option>Full</option><option>3/4</option><option>1/2</option><option>1/4</option><option>Empty</option></select></label>
                    <label>Next service date<input asp-for="NextServiceDate" type="date" /></label>
                    <label>Vehicle condition<select asp-for="VehicleStatus"><option value="">Select condition</option><option>Operational</option><option>Operational with notes</option><option>Out of service</option></select></label>
                </div>
            </section>

            <section class="inspection-section schematic-section">
                <div class="section-heading">
                    <span>2</span>
                    <div>
                        <h3>Vehicle Schematic</h3>
                        <p>Mark damage against the correct vehicle view.</p>
                    </div>
                </div>

                <div class="schematic-tabs" role="tablist" aria-label="Vehicle views">
                    <button type="button" class="schematic-tab active">Left</button>
                    <button type="button" class="schematic-tab">Right</button>
                    <button type="button" class="schematic-tab">Front</button>
                    <button type="button" class="schematic-tab">Rear</button>
                    <button type="button" class="schematic-tab">Top</button>
                </div>

                <div class="schematic-workspace">
                    <div class="vehicle-schematic" aria-label="Vehicle outline placeholder">
                        <div class="schematic-roof"></div>
                        <div class="schematic-body"></div>
                        <div class="schematic-cab"></div>
                        <div class="schematic-window front-window"></div>
                        <div class="schematic-window rear-window"></div>
                        <div class="schematic-wheel front-wheel"></div>
                        <div class="schematic-wheel rear-wheel"></div>
                        <div class="damage-marker marker-one"></div>
                        <div class="damage-marker marker-two"></div>
                    </div>
                    <p class="schematic-note">Drawing and tap-to-mark will be connected to this area in the next build step.</p>
                </div>

                <div class="damage-grid">
                    <label>Damage type<select asp-for="DamageType"><option value="">Select damage type</option><option>Dent</option><option>Scratch</option><option>Crack</option><option>Missing item</option><option>Fluid leak</option><option>Other</option></select></label>
                    <label>Damage severity<select asp-for="DamageSeverity"><option value="">Select severity</option><option>Minor</option><option>Moderate</option><option>Severe</option></select></label>
                </div>

                <label class="notes-field">Damage notes<textarea asp-for="DamageNotes" rows="4" placeholder="Describe location and details of visible damage"></textarea></label>
            </section>

            <section class="inspection-section">
                <div class="section-heading">
                    <span>3</span>
                    <div>
                        <h3>Notes / Issue</h3>
                        <p>Record anything that requires follow-up.</p>
                    </div>
                </div>

                <label class="notes-field wide-notes">Inspection notes<textarea asp-for="ChecklistNotes" rows="5" placeholder="Additional notes, issues, or action required"></textarea></label>
            </section>

            <div class="save-bar two-actions">
                <button class="menu-btn vehicle-btn save-btn" type="submit">Save Inspection</button>
                <a class="menu-btn equipment-btn save-btn" href="@Model.EquipmentChecklistUrl">Next: Equipment Checklist</a>
            </div>
        </form>
    </div>
</div>

<style>
.inspection-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.inspection-inner { width: 100%; max-width: 980px; margin: 0 auto; padding: 32px 20px 120px 20px; box-sizing: border-box; }
.inspection-header { text-align: center; }
.page-logo { width: 280px; max-width: 70%; max-height: 150px; object-fit: contain; margin: 0 auto 10px auto; display: block; }
.client-line { margin-bottom: 12px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 8px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 28px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(680px, 94%); margin: 0 auto 22px auto; font-size: 15px; font-weight: 600; color: #6b7280; }
.status-message { width: min(820px, 100%); margin: 0 auto 18px auto; padding: 12px 16px; border: 1px solid rgba(14, 94, 122, 0.24); border-radius: 8px; background: rgba(14, 94, 122, 0.08); color: #0E5E7A; font-weight: 700; text-align: center; }
.inspection-form { display: flex; flex-direction: column; gap: 18px; }
.inspection-section { width: 100%; padding: 18px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.68); box-sizing: border-box; }
.section-heading { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; text-align: left; }
.section-heading span { width: 30px; height: 30px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; background: #334155; color: #ffffff; font-size: 13px; font-weight: 800; flex: 0 0 auto; }
.section-heading h3 { margin: 0 0 4px 0; font-size: 18px; font-weight: 800; color: #1f2937; }
.section-heading p { margin: 0; font-size: 13px; font-weight: 600; color: #6b7280; }
.form-grid, .damage-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
.form-grid label, .damage-grid label, .notes-field { display: flex; flex-direction: column; gap: 8px; text-align: left; font-size: 13px; font-weight: 800; color: #52606d; }
.form-grid input, .form-grid select, .damage-grid select, .notes-field textarea { width: 100%; min-height: 46px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 14px; font-size: 15px; background: #ffffff; color: #1f2937; box-sizing: border-box; }
.notes-field textarea { padding-top: 12px; resize: vertical; }
.schematic-tabs { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 8px; margin-bottom: 14px; }
.schematic-tab { min-height: 38px; border: 1px solid rgba(66, 84, 102, 0.18); border-radius: 8px; background: #ffffff; color: #334155; font-size: 13px; font-weight: 800; }
.schematic-tab.active { background: #0E5E7A; color: #ffffff; border-color: #0E5E7A; }
.schematic-workspace { border: 1px dashed rgba(66, 84, 102, 0.34); border-radius: 8px; background: #f8fafc; padding: 16px; margin-bottom: 16px; }
.vehicle-schematic { position: relative; height: 240px; border-radius: 8px; background: #ffffff; border: 1px solid rgba(66, 84, 102, 0.16); overflow: hidden; }
.schematic-body { position: absolute; left: 9%; right: 8%; bottom: 64px; height: 70px; border: 4px solid #334155; border-radius: 24px 18px 16px 16px; }
.schematic-roof { position: absolute; left: 22%; right: 24%; bottom: 132px; height: 44px; border: 4px solid #334155; border-bottom: 0; border-radius: 34px 34px 0 0; }
.schematic-cab { position: absolute; right: 13%; bottom: 96px; width: 18%; height: 72px; border-left: 4px solid #334155; transform: skewX(-18deg); }
.schematic-window { position: absolute; bottom: 116px; height: 36px; border: 3px solid #52606d; border-radius: 8px; }
.front-window { right: 18%; width: 15%; transform: skewX(-14deg); }
.rear-window { left: 28%; width: 27%; }
.schematic-wheel { position: absolute; bottom: 38px; width: 44px; height: 44px; border: 5px solid #1f2937; border-radius: 50%; background: #ffffff; }
.front-wheel { right: 18%; }
.rear-wheel { left: 18%; }
.damage-marker { position: absolute; width: 18px; height: 18px; border-radius: 50%; border: 3px solid #8F3A3A; background: rgba(143, 58, 58, 0.14); }
.marker-one { left: 42%; bottom: 104px; }
.marker-two { right: 28%; bottom: 88px; }
.schematic-note { margin: 12px 0 0 0; color: #6b7280; font-size: 13px; font-weight: 700; text-align: center; }
.damage-grid { margin-bottom: 14px; }
.save-bar { position: sticky; bottom: 0; z-index: 10; padding: 14px 0 0 0; background: linear-gradient(180deg, rgba(244, 247, 251, 0), #F4F7FB 42%); }
.two-actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.save-btn { width: 100%; border: none; text-align: center; }
@@media (max-width: 760px) { .inspection-inner { padding: 24px 14px 120px 14px; } .page-title { font-size: 24px; } .form-grid, .damage-grid, .two-actions { grid-template-columns: 1fr; } .schematic-tabs { grid-template-columns: repeat(3, minmax(0, 1fr)); } .vehicle-schematic { height: 210px; } .inspection-section { padding: 14px; } }
</style>
