@page
@model ManagerAreasModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Manager Area Assignment";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
    var returnUrl = Url.Page("/ManagerAreas", new { managerUserId = Model.ManagerUserId });
}

<div class="module-screen">
    <div class="module-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Master Setup</div>
        <h2 class="page-title">Manager Area Assignment</h2>
        <p class="page-subtitle">Link operational managers to the bases and regions they are responsible for.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <section class="form-panel">
            <div class="section-label">Select Manager</div>
            @if (Model.ManagerOptions.Count == 0)
            {
                <div class="empty-state">No active operational managers exist yet.</div>
            }
            else
            {
                <form class="manager-picker" method="get">
                    <select class="text-input" asp-for="ManagerUserId" asp-items="Model.ManagerOptions"></select>
                    <button class="menu-btn equipment-btn picker-btn" type="submit">Load Manager</button>
                </form>
            }
        </section>

        @if (Model.SelectedManager is not null)
        {
            <form class="setup-form" method="post">
                <input type="hidden" asp-for="ManagerUserId" />
                <section class="form-panel">
                    <div class="manager-summary">
                        <div>
                            <strong>@Model.SelectedManager.FullName</strong>
                            <span>@Model.SelectedManager.Email</span>
                        </div>
                        <span class="role-pill">@Model.SelectedManager.RoleName</span>
                    </div>

                    <div class="section-label area-section-label">Assigned Areas</div>
                    @if (Model.AreaOptions.Count == 0)
                    {
                        <div class="empty-state">Create operational areas before assigning managers.</div>
                    }
                    else
                    {
                        <div class="assignment-grid">
                            @foreach (var area in Model.AreaOptions)
                            {
                                <label class="assignment-card">
                                    <input type="checkbox" name="SelectedAreaIds" value="@area.Id" checked="@area.IsAssigned" />
                                    <span>
                                        <strong>@area.Name</strong>
                                        <em>@area.AreaType@(string.IsNullOrWhiteSpace(area.Address) ? string.Empty : $" - {area.Address}")</em>
                                    </span>
                                </label>
                            }
                        </div>
                    }
                </section>

                <div class="action-row">
                    <a class="menu-btn staff-btn" href="/OperationalAreas">Operational Areas</a>
                    <button class="menu-btn equipment-btn" type="submit" disabled="@(Model.AreaOptions.Count == 0)">Save Area Access</button>
                </div>
            </form>
        }
    </div>
</div>

<style>
.module-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.module-inner { width: 100%; max-width: 1100px; margin: 0 auto; text-align: center; padding: 40px 20px 30px 20px; box-sizing: border-box; }
.page-logo { width: 320px; max-width: 72%; max-height: 180px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 30px; font-weight: 800; color: #1f2937; }
.page-subtitle { margin: 0 auto 28px auto; max-width: 760px; font-size: 16px; font-weight: 600; color: #6b7280; }
.setup-form { display: flex; flex-direction: column; gap: 22px; margin-top: 22px; }
.form-panel { padding: 22px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: rgba(255,255,255,.72); text-align: left; }
.section-label { margin-bottom: 16px; font-size: 13px; font-weight: 900; letter-spacing: 1.1px; text-transform: uppercase; color: #5f6b7a; }
.area-section-label { margin-top: 22px; }
.manager-picker { display: grid; grid-template-columns: minmax(240px, 1fr) 180px; gap: 14px; align-items: center; }
.text-input { width: 100%; min-height: 48px; padding: 0 14px; border: 1px solid rgba(66,84,102,.24); border-radius: 8px; background: #fff; color: #111827; font-size: 15px; font-weight: 700; box-sizing: border-box; }
.picker-btn { width: 100%; min-width: 0; border: none; }
.manager-summary { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 16px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: #fff; }
.manager-summary strong { display: block; color: #102a3a; font-size: 18px; font-weight: 900; }
.manager-summary span { display: block; margin-top: 4px; color: #52606d; font-size: 13px; font-weight: 700; }
.role-pill { display: inline-flex; min-height: 32px; align-items: center; padding: 0 12px; border-radius: 8px; background: rgba(18,108,132,.12); color: #126C84; font-size: 12px; font-weight: 900; }
.assignment-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
.assignment-card { display: grid; grid-template-columns: 24px 1fr; gap: 12px; align-items: flex-start; min-height: 86px; padding: 16px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: #fff; cursor: pointer; }
.assignment-card input { width: 18px; height: 18px; margin-top: 2px; accent-color: #126C84; }
.assignment-card strong { display: block; color: #102a3a; font-size: 17px; font-weight: 900; }
.assignment-card em { display: block; margin-top: 4px; color: #52606d; font-style: normal; font-size: 13px; font-weight: 700; }
.action-row { display: flex; justify-content: center; gap: 18px; flex-wrap: wrap; }
.action-row .menu-btn { min-width: 230px; border: none; }
.action-row .menu-btn:disabled { cursor: not-allowed; opacity: .58; transform: none; filter: none; }
.status-message { width: min(760px, 94%); margin: 0 auto 20px auto; padding: 12px 16px; border: 1px solid rgba(66,84,102,.22); border-radius: 8px; background: rgba(14,94,122,.08); color: #0E5E7A; font-weight: 800; }
.empty-state { padding: 18px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: #fff; color: #52606d; font-weight: 800; }
@@media (max-width: 780px) { .manager-picker, .assignment-grid { grid-template-columns: 1fr; } .manager-summary { align-items: flex-start; flex-direction: column; } }
</style>

@if (Model.ActionSaved)
{
    <script>
        window.VectorActionConfirmation?.show({
            message: @Json.Serialize(Model.StatusMessage ?? "Manager area access saved."),
            redirectUrl: @Json.Serialize(returnUrl),
            delay: 1300
        });
    </script>
}
