@page
@model OnboardingModel
@{
    ViewData["Title"] = "Onboarding";
}

<div class="company-login-screen">
    <div class="company-login-inner">
        <div class="home-label">AcuityOps Onboarding</div>

        <img src="/acuityops-app-icon-light.png" class="company-login-logo" alt="AcuityOps" />

        <h2 class="page-title">Company Login</h2>
        <p class="page-subtitle">Senior management workspace setup and company access</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="login-error">@Model.StatusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.WorkspaceLoginUrl))
        {
            <div class="workspace-card">
                <label for="workspaceLink">Company workspace link</label>
                <input id="workspaceLink" value="@Model.WorkspaceLoginUrl" readonly />

                <label for="companyAccessCode">Company access code</label>
                <input id="companyAccessCode" value="@Model.CompanyAccessCode" readonly />

                <a class="menu-btn equipment-btn" href="@Model.WorkspaceLoginUrl">Open Company Login</a>
            </div>
        }

        <p class="security-note">Share the workspace link with the company. Keep the company access code with the owner or chosen senior management. Individual staff and manager logins remain separate.</p>
    </div>
</div>

<style>
.company-login-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.company-login-inner {
    width: 100%;
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.company-login-logo {
    width: 170px;
    max-width: 42%;
    margin: 0 auto 12px auto;
    display: block;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.workspace-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: min(100%, 460px);
    margin: 0 auto;
    text-align: left;
}

.workspace-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: min(100%, 520px);
    margin: 0 auto;
    text-align: left;
}

.workspace-form label,
.workspace-card label {
    font-size: 13px;
    font-weight: 700;
    color: #52606d;
}

.workspace-form input,
.workspace-card input {
    width: 100%;
    min-height: 48px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 0 14px;
    font-size: 15px;
    background: #ffffff;
    color: #1f2937;
    box-sizing: border-box;
}

.workspace-card input[readonly] {
    background: #f8fafc;
    font-weight: 800;
}

.workspace-form .menu-btn,
.workspace-card .menu-btn {
    width: 100%;
    margin-top: 8px;
    border: 0;
    text-align: center;
}

.login-error {
    width: min(520px, 100%);
    margin: 0 auto 16px auto;
    padding: 12px 14px;
    border: 1px solid rgba(148, 57, 57, 0.22);
    border-radius: 8px;
    background: rgba(148, 57, 57, 0.07);
    color: #943939;
    font-size: 13px;
    font-weight: 800;
    text-align: left;
}

.security-note {
    margin: 22px auto 0 auto;
    max-width: 460px;
    font-size: 12px;
    line-height: 1.5;
    color: #6b7280;
}
</style>
