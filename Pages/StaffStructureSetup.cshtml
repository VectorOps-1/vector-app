@page
@model StaffStructureSetupModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Staff Structure Setup";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
}

<div class="staff-structure-screen">
    <div class="staff-structure-inner">
        <img class="page-logo" src="@branding.LogoPath" alt="Company logo" />
        <div class="client-line">Client: @Model.ClientName</div>
        <div class="home-label">Setup Wizard</div>
        <h2 class="page-title">Staff Structure</h2>
        <p class="page-subtitle">Create the clinical qualification and scope options used by this company. This is separate from app access level, role, or manager permissions.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message" data-action-status data-confirmation-duration="1800">@Model.StatusMessage</div>
        }

        <section class="setup-card">
            <div class="section-label">Clinical qualification / scope options</div>
            <p class="section-help">Examples may include local clinical scopes, professional grades, non-clinical support, dispatch, or driver-only categories. Add only the options this client actually uses.</p>
            <form method="post" asp-page-handler="AddQualification" class="setup-form">
                <label>
                    Qualification or scope name
                    <input asp-for="QualificationName" type="text" placeholder="Example: Advanced Life Support" />
                    <span asp-validation-for="QualificationName"></span>
                </label>
                <label>
                    Notes
                    <input asp-for="QualificationNotes" type="text" placeholder="Optional internal note" />
                </label>
                <button type="submit">Add Option</button>
            </form>
        </section>

        <section class="setup-card">
            <div class="section-label">Staff source-of-truth rules</div>
            <p class="section-help">These settings control what managers must maintain on staff profiles. They do not grant app access permissions.</p>
            <form method="post" asp-page-handler="SaveRules" class="rules-form">
                <label class="span-two">
                    Staff ID format
                    <input asp-for="StaffIdFormat" type="text" placeholder="Example: EMS-{0000}, XM-{ROLE}-{000}" />
                </label>

                <label class="toggle-row">
                    <input asp-for="PractitionerNumberRequired" type="checkbox" />
                    <span>Practitioner number is required for clinical staff</span>
                </label>
                <label class="toggle-row">
                    <input asp-for="AnnualLicenseExpiryRequired" type="checkbox" />
                    <span>Annual licence expiry must be tracked</span>
                </label>
                <label class="toggle-row">
                    <input asp-for="CpdTrackingRequired" type="checkbox" />
                    <span>CPD compliance and expiry must be tracked</span>
                </label>

                <div class="default-fields span-two">
                    <div class="section-label">Default profile fields</div>
                    <p class="section-help">Choose the fields this client expects on normal staff profiles.</p>
                    <div class="field-checkbox-grid">
                        @foreach (var field in Model.AvailableDefaultProfileFields)
                        {
                            <label>
                                <input type="checkbox" name="DefaultProfileFields" value="@field" checked="@Model.DefaultProfileFields.Contains(field, StringComparer.OrdinalIgnoreCase)" />
                                <span>@field</span>
                            </label>
                        }
                    </div>
                </div>

                <button class="span-two" type="submit">Save Staff Rules</button>
            </form>
        </section>

        <section class="setup-card">
            <div class="section-heading-row">
                <div>
                    <div class="section-label">Configured staff structure</div>
                    <p class="section-help">This list feeds staff add/edit profile dropdowns and staff-register grouping.</p>
                </div>
                <strong>@Model.QualificationRows.Count option@(Model.QualificationRows.Count == 1 ? "" : "s")</strong>
            </div>

            @if (Model.QualificationRows.Count == 0)
            {
                <div class="empty-state">No clinical qualification/scope options have been configured yet.</div>
            }
            else
            {
                <div class="list-table">
                    <div class="list-head">
                        <span>Sort</span>
                        <span>Clinical qualification / scope</span>
                    </div>
                    @foreach (var row in Model.QualificationRows)
                    {
                        <div class="list-row">
                            <span>@row.SortOrder</span>
                            <strong>@row.Name</strong>
                        </div>
                    }
                </div>
            }
        </section>

        <form method="post" asp-page-handler="CompleteStep" class="complete-form">
            <a class="secondary-btn" asp-page="/SetupWizard">Back to Setup Wizard</a>
            <button class="primary-btn" type="submit">Complete Staff Structure Step</button>
        </form>
    </div>
</div>

<style>
.staff-structure-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.staff-structure-inner { width: 100%; max-width: 1120px; margin: 0 auto; padding: 36px 20px 70px; text-align: center; box-sizing: border-box; }
.page-logo { display: block; width: 260px; max-width: 72%; max-height: 150px; margin: 0 auto 12px; object-fit: contain; }
.client-line { margin-bottom: 14px; color: #6b7280; font-size: 12px; font-weight: 800; }
.home-label, .section-label { color: #52606d; font-size: 12px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
.home-label { margin-bottom: 10px; }
.page-title { margin: 0 0 8px; color: #10233f; font-size: 32px; font-weight: 900; }
.page-subtitle { width: min(820px, 96%); margin: 0 auto 22px; color: #5f6b7a; font-size: 16px; font-weight: 700; line-height: 1.45; }
.status-message { width: min(820px, 96%); margin: 0 auto 16px; padding: 12px 16px; border: 1px solid rgba(31,111,91,.24); border-radius: 8px; background: rgba(31,111,91,.08); color: #1f6f5b; font-weight: 900; }
.setup-card { margin: 0 auto 16px; padding: 18px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.8); text-align: left; box-sizing: border-box; }
.section-help { margin: 6px 0 14px; color: #64748b; font-size: 13px; font-weight: 800; line-height: 1.45; }
.setup-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)) auto; gap: 12px; align-items: end; }
.rules-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; align-items: start; }
.setup-form label, .rules-form label { display: flex; flex-direction: column; gap: 7px; color: #52606d; font-size: 12px; font-weight: 900; }
.setup-form input, .rules-form input[type="text"] { width: 100%; min-height: 42px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 12px; color: #10233f; background: #fff; font-size: 14px; box-sizing: border-box; }
.setup-form button, .rules-form button, .primary-btn, .secondary-btn { min-height: 42px; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; font-weight: 900; text-decoration: none; white-space: nowrap; }
.setup-form button, .rules-form button, .primary-btn { border: none; background: #126C84; color: #fff; padding: 0 16px; }
.secondary-btn { border: 1px solid rgba(47,128,168,.24); background: #fff; color: #126C84; padding: 0 16px; }
.span-two { grid-column: 1 / -1; }
.toggle-row { min-height: 48px; flex-direction: row !important; align-items: center; gap: 10px !important; border: 1px solid rgba(66,84,102,.14); border-radius: 8px; padding: 10px 12px; background: #fff; }
.toggle-row input, .field-checkbox-grid input { width: 18px; height: 18px; flex: 0 0 auto; }
.default-fields { border: 1px dashed rgba(66,84,102,.2); border-radius: 8px; padding: 14px; background: rgba(248,250,252,.8); }
.field-checkbox-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
.field-checkbox-grid label { flex-direction: row; align-items: center; gap: 8px; border: 1px solid rgba(66,84,102,.14); border-radius: 8px; padding: 10px; background: #fff; }
.section-heading-row { display: flex; justify-content: space-between; gap: 14px; align-items: flex-start; }
.section-heading-row strong { color: #52606d; font-size: 13px; font-weight: 900; }
.empty-state { border: 1px dashed rgba(66,84,102,.24); border-radius: 8px; padding: 14px; color: #64748b; font-weight: 900; text-align: center; }
.list-table { overflow-x: auto; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; }
.list-head, .list-row { display: grid; grid-template-columns: 110px minmax(260px, 1fr); min-width: 520px; align-items: center; }
.list-head { background: #334155; color: #fff; font-size: 12px; font-weight: 900; letter-spacing: .8px; text-transform: uppercase; }
.list-head span, .list-row span, .list-row strong { padding: 10px 12px; }
.list-row { border-top: 1px solid rgba(66,84,102,.14); color: #425466; font-size: 14px; font-weight: 800; }
.list-row strong { color: #10233f; }
.complete-form { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 18px; }
@@media (max-width: 860px) {
    .setup-form,
    .rules-form,
    .complete-form,
    .field-checkbox-grid { grid-template-columns: 1fr; }
    .setup-card { padding: 14px; }
}
</style>

@if (Model.ActionSaved)
{
    <script>
        window.VectorActionConfirmation?.show({
            message: @Json.Serialize(Model.StatusMessage ?? "Staff structure saved."),
            delay: 1300
        });
    </script>
}
