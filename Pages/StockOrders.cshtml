@page
@model StockOrdersModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Stock Orders";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="stock-order-screen">
    <div class="stock-order-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Stock Control</div>
        <h2 class="page-title">Stock Orders</h2>
        <p class="page-subtitle">Supplier orders, senior approval, supplier confirmation, register entry, and allocation.</p>

        <div class="action-row">
            <a class="menu-btn equipment-btn" href="/PlaceStockOrder">Place Stock Order</a>
            <a class="menu-btn staff-btn" href="/SupplierConfirmations">Supplier Confirmations</a>
            <a class="menu-btn vehicle-btn" href="/EnterStockRegister">Enter Stock Into Register</a>
            <a class="menu-btn equipment-btn" href="/AllocateStock">Allocate Stock</a>
        </div>

        @if (!Model.Orders.Any())
        {
            <div class="empty-panel">No stock orders have been created yet.</div>
        }
        else
        {
            <div class="order-list">
                @foreach (var order in Model.Orders)
                {
                    <a class="order-card" href="/StockOrderAction?orderId=@order.Id">
                        <div class="order-title">Order #@order.Id - @order.SupplierName</div>
                        <div class="order-meta">
                            <div>Status: @order.Status</div>
                            <div>Requested by: @order.RequestedByName</div>
                            <div>Supplier email: @order.SupplierEmail</div>
                            <div>Created: @order.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            <div>Lines: @order.LineCount</div>
                            <div>Total quantity requested: @order.QuantityRequested</div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

<style>
.stock-order-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.stock-order-inner { width: 100%; max-width: 1060px; margin: 0 auto; text-align: center; padding: 40px 20px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 30px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(720px, 94%); margin: 0 auto 24px auto; font-size: 16px; font-weight: 600; color: #6b7280; }
.action-row { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin: 0 auto 24px auto; width: min(980px, 100%); }
.action-row .menu-btn { min-width: 0; }
.empty-panel { width: min(780px, 94%); margin: 0 auto; padding: 22px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.68); font-weight: 800; color: #52606d; }
.order-list { display: grid; gap: 16px; width: min(900px, 94%); margin: 0 auto; text-align: left; }
.order-card { display: block; padding: 18px 20px; border: 1px solid rgba(47,128,168,.24); border-radius: 8px; background: rgba(255,255,255,.78); color: #1f2937; text-decoration: none; box-shadow: 0 14px 28px rgba(47,128,168,.10); }
.order-card:hover { color: #1f2937; border-color: rgba(47,128,168,.52); }
.order-title { margin-bottom: 10px; font-size: 18px; font-weight: 900; }
.order-meta { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px 16px; font-size: 13px; font-weight: 700; color: #52606d; }
@@media (max-width: 850px) { .action-row, .order-meta { grid-template-columns: 1fr; } }
</style>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <script>
        window.VectorActionConfirmation?.show({
            message: @Json.Serialize(Model.SuccessMessage),
            delay: 1300
        });
    </script>
}
