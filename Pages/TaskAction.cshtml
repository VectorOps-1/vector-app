@page
@model TaskActionModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Assigned Task";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
    var task = Model.TaskDetails;
    var actionUrl = task?.ActionType switch
    {
        "Complete Checklist" => "/CompleteChecklist",
        "Report Issue" => "/ReportIssue?module=general",
        "Upload Personal Documents" => "/PersonalDocuments",
        "Add New Vehicle" => "/AddItem?type=vehicle",
        "Add New Equipment" => "/AddItem?type=equipment",
        "Add New Stock Item" => "/AddItem?type=stock",
        "Add Medication" => "/AddItem?type=medication",
        "Receive Stock" => "/Stock",
        "Issue / Allocate Stock" => "/Stock",
        "Batch Number Tracking" => "/Stock",
        "Expiry / Compliance Check" => "/Stock",
        _ => "/TaskFeedback"
    };
    var separator = actionUrl.Contains('?') ? "&" : "?";
}

<div class="task-action-screen">
    <div class="task-action-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Task-Only Access</div>

        @if (task is null)
        {
            <h2 class="page-title">No Open Task</h2>
            <p class="page-subtitle">There is no open assigned action available for this task.</p>
        }
        else
        {
            <h2 class="page-title">@task.ActionType</h2>
            <p class="page-subtitle">@(string.IsNullOrWhiteSpace(task.InstructionMessage) ? "No instruction entered." : task.InstructionMessage)</p>
        }

        <section class="access-panel">
            <div class="section-label">Access Window</div>
            <div class="access-grid">
                <div><strong>Access:</strong> This assigned action only</div>
                <div><strong>Expires:</strong> @(task?.ExpiresAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "Manager-selected expiry")</div>
                <div><strong>Assigned by:</strong> @(task?.AssignedByName ?? "Manager")</div>
                <div><strong>Recipient:</strong> @(task?.AssignedToName ?? "Current user")</div>
            </div>
        </section>

        @if (task is not null)
        {
            <div class="action-row">
                <a class="menu-btn equipment-btn" href="@(actionUrl + separator + "taskId=" + task.Id + "&taskAccess=true")">Open Assigned Action</a>
                <a class="menu-btn staff-btn" href="/TaskFeedback?taskId=@task.Id">Submit Feedback / Confirmation</a>
            </div>
        }

        <div class="task-note">After completing the assigned action, submit feedback so the task can be closed and recorded.</div>
    </div>
</div>

<style>
.task-action-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.task-action-inner { width: 100%; max-width: 940px; margin: 0 auto; text-align: center; padding: 40px 20px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 30px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(700px, 94%); margin: 0 auto 24px auto; font-size: 16px; font-weight: 600; color: #6b7280; }
.access-panel { width: min(820px, 94%); margin: 0 auto 24px auto; padding: 20px; border: 1px solid rgba(47,128,168,.24); border-radius: 8px; background: rgba(255,255,255,.72); text-align: left; }
.section-label { margin-bottom: 14px; font-size: 13px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; color: #52606d; }
.access-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px 18px; font-size: 14px; font-weight: 700; color: #425466; }
.action-row { display: flex; justify-content: center; gap: 22px; flex-wrap: wrap; }
.action-row .menu-btn { min-width: 260px; }
.task-note { width: min(680px, 94%); margin: 22px auto 0 auto; padding: 12px 14px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.58); font-size: 13px; font-weight: 700; color: #52606d; }
@@media (max-width: 700px) { .access-grid { grid-template-columns: 1fr; } }
</style>
