@using vector_app_local.Services
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var currentAccessView = Context.Session.GetString(CurrentUserService.AccessViewSessionKey);
    var hasCompanySession = Context.Session.GetInt32(CurrentUserService.CompanyIdSessionKey).HasValue;
    var currentUserId = Context.Session.GetInt32(CurrentUserService.UserIdSessionKey);
    var hasAccessLogin = currentUserId.HasValue
        && !string.IsNullOrWhiteSpace(currentAccessView);
    var hideHomeNavPages = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "/Index",
        "/Workspace",
        "/CompanyLogin",
        "/AccessLogin",
        "/Access",
        "/RoleLogin",
        "/LoginSplash"
    };
    var showHomeNav = hasAccessLogin && !hideHomeNavPages.Contains(currentPage);
    var showPageIndex = hasAccessLogin && !hideHomeNavPages.Contains(currentPage);
    var showNotifications = showPageIndex && !string.Equals(currentPage, "/RoleLogin", StringComparison.OrdinalIgnoreCase);
    var currentClientRole = string.IsNullOrWhiteSpace(currentAccessView)
        ? null
        : CurrentUserService.AccessViewToClientRole(currentAccessView);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AcuityOps</title>

    <link rel="icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <link rel="shortcut icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/vector_app_local.styles.css" asp-append-version="true" />

    <script>
        window.VectorPendingConfirmations = window.VectorPendingConfirmations || [];
        window.VectorActionConfirmation = window.VectorActionConfirmation || {
            show: function (options) {
                window.VectorPendingConfirmations.push(options || {});
            },
            getReturnUrl: function (fallbackUrl) {
                return fallbackUrl || null;
            }
        };
    </script>

    <style>
        html, body {
            margin: 0;
            padding: 0;
            min-height: 100%;
        }

        body {
            background: #F4F7FB;
        }

        .top-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 70px;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            padding: 0 28px;
            box-sizing: border-box;
            z-index: 1000;
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        }

        .top-bar.no-page-index {
            justify-content: flex-end;
        }

        .page-index-wrap {
            display: grid;
            grid-template-columns: auto minmax(150px, 0.85fr) minmax(170px, 1fr) minmax(220px, 1.15fr);
            align-items: end;
            gap: 8px;
            min-width: 0;
            flex: 1 1 auto;
            overflow-x: auto;
            padding-bottom: 2px;
        }

        .page-index-label {
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #52606d;
            white-space: nowrap;
            padding-bottom: 9px;
        }

        .page-index-field {
            display: flex;
            flex-direction: column;
            gap: 3px;
            min-width: 0;
            margin: 0;
        }

        .page-index-field span {
            font-size: 10px;
            font-weight: 900;
            letter-spacing: 0.7px;
            text-transform: uppercase;
            color: #64748b;
        }

        .page-index-select {
            width: 100%;
            min-width: 0;
            height: 34px;
            border: 1px solid rgba(66, 84, 102, 0.24);
            border-radius: 8px;
            background: #ffffff;
            color: #1f2937;
            font-size: 13px;
            font-weight: 700;
            padding: 0 10px;
        }

        .top-nav {
            display: flex;
            align-items: center;
            gap: 24px;
            flex: 0 0 auto;
        }

        .top-nav a {
            text-decoration: none;
            font-size: 17px;
            font-weight: 600;
            color: #111;
            transition: opacity 0.15s ease;
        }

        .top-nav a:hover {
            opacity: 0.65;
        }

        .app-footer {
            position: fixed;
            right: 22px;
            bottom: 18px;
            z-index: 1050;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 12px;
            border: 1px solid rgba(66, 84, 102, 0.14);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.86);
            box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
            backdrop-filter: blur(8px);
        }

        .app-footer a {
            color: #52606d;
            text-decoration: none;
            font-size: 12px;
            font-weight: 800;
        }

        .app-footer a:hover {
            color: #0E5E7A;
        }

        .page-shell {
            min-height: 100vh;
            padding-top: 70px;
            padding-bottom: 56px;
            box-sizing: border-box;
        }

        main {
            min-height: calc(100vh - 70px);
        }

        .container {
            max-width: 100% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .notification-stack {
            position: fixed;
            left: 22px;
            bottom: 22px;
            z-index: 1100;
            display: flex;
            flex-direction: column;
            gap: 12px;
            align-items: flex-start;
        }

        .task-notification,
        .issue-notification,
        .variance-notification,
        .readiness-alert-notification,
        .expiry-notification,
        .scoring-notification {
            position: relative;
            width: 58px;
            height: 58px;
            border-radius: 50%;
            color: #ffffff;
            display: none;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
        }

        .task-notification {
            background: #2f80a8;
            box-shadow: 0 16px 34px rgba(47, 128, 168, 0.28);
        }

        .issue-notification {
            background: #9B2C2C;
            box-shadow: 0 16px 34px rgba(155, 44, 44, 0.3);
        }

        .variance-notification {
            background: #B4711C;
            box-shadow: 0 16px 34px rgba(180, 113, 28, 0.28);
        }

        .readiness-alert-notification {
            background: #C2410C;
            box-shadow: 0 16px 34px rgba(194, 65, 12, 0.28);
        }

        .expiry-notification {
            background: #7A5A12;
            box-shadow: 0 16px 34px rgba(122, 90, 18, 0.28);
        }

        .scoring-notification {
            background: #17624f;
            box-shadow: 0 16px 34px rgba(23, 98, 79, 0.28);
        }

        .task-notification.visible,
        .issue-notification.visible,
        .variance-notification.visible,
        .readiness-alert-notification.visible,
        .expiry-notification.visible,
        .scoring-notification.visible {
            display: flex;
        }

        .task-notification:hover {
            color: #ffffff;
            background: #276f93;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(47, 128, 168, 0.34);
        }

        .issue-notification:hover {
            color: #ffffff;
            background: #7f1d1d;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(155, 44, 44, 0.38);
        }

        .variance-notification:hover {
            color: #ffffff;
            background: #935d17;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(180, 113, 28, 0.36);
        }

        .readiness-alert-notification:hover {
            color: #ffffff;
            background: #9A3412;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(194, 65, 12, 0.36);
        }

        .expiry-notification:hover {
            color: #ffffff;
            background: #60460E;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(122, 90, 18, 0.36);
        }

        .scoring-notification:hover {
            color: #ffffff;
            background: #115040;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(23, 98, 79, 0.36);
        }

        .task-notification svg,
        .issue-notification svg,
        .variance-notification svg,
        .readiness-alert-notification svg,
        .expiry-notification svg,
        .scoring-notification svg {
            width: 26px;
            height: 26px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .issue-notification svg {
            width: 30px;
            height: 30px;
            stroke-width: 2.6;
        }

        .task-count,
        .issue-count,
        .variance-count,
        .readiness-alert-count,
        .expiry-count,
        .scoring-count {
            position: absolute;
            top: -4px;
            right: -4px;
            min-width: 22px;
            height: 22px;
            padding: 0 6px;
            border-radius: 999px;
            background: #f2b84b;
            color: #102a3a;
            border: 2px solid #ffffff;
            font-size: 12px;
            font-weight: 800;
            line-height: 18px;
            text-align: center;
        }

        .issue-count {
            background: #ffffff;
            color: #7f1d1d;
        }

        .variance-count {
            background: #ffffff;
            color: #935d17;
        }

        .readiness-alert-count {
            background: #ffffff;
            color: #9A3412;
        }

        .expiry-count {
            background: #ffffff;
            color: #60460E;
        }

        .scoring-count {
            background: #ffffff;
            color: #115040;
        }

        .action-confirmation {
            position: fixed;
            inset: 0;
            z-index: 1500;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: rgba(15, 23, 42, 0.28);
            box-sizing: border-box;
            opacity: 0;
            transition: opacity 180ms ease;
        }

        .action-confirmation.visible {
            display: flex;
            opacity: 1;
        }

        .action-confirmation.leaving {
            opacity: 0;
        }

        .confirmation-card {
            width: min(420px, 94vw);
            padding: 28px 24px;
            border-radius: 8px;
            background: #ffffff;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
            text-align: center;
        }

        .confirmation-mark {
            width: 58px;
            height: 58px;
            margin: 0 auto 16px auto;
            border-radius: 50%;
            background: #2f80a8;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            font-weight: 900;
        }

        .confirmation-title {
            margin: 0 0 8px 0;
            font-size: 22px;
            font-weight: 900;
            color: #1f2937;
        }

        .confirmation-message {
            margin: 0;
            font-size: 15px;
            font-weight: 700;
            color: #52606d;
        }

        .in-app-confirm-modal {
            position: fixed;
            inset: 0;
            z-index: 1600;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 18px;
            background: rgba(15, 23, 42, 0.36);
            box-sizing: border-box;
            opacity: 0;
            transition: opacity 180ms ease;
        }

        .in-app-confirm-modal.visible {
            display: flex;
            opacity: 1;
        }

        .in-app-confirm-modal.leaving {
            opacity: 0;
        }

        .in-app-confirm-card {
            width: min(460px, 94vw);
            border-radius: 8px;
            background: #ffffff;
            box-shadow: 0 24px 70px rgba(15, 23, 42, 0.28);
            padding: 22px;
            box-sizing: border-box;
            display: grid;
            grid-template-columns: 48px 1fr;
            gap: 14px;
            align-items: start;
        }

        .in-app-confirm-icon {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #9B2C2C;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: 900;
        }

        .in-app-confirm-copy h2 {
            margin: 0 0 8px 0;
            font-size: 20px;
            font-weight: 900;
            color: #1f2937;
        }

        .in-app-confirm-copy p {
            margin: 0;
            color: #52606d;
            font-size: 14px;
            font-weight: 700;
            line-height: 1.45;
        }

        .in-app-confirm-actions {
            grid-column: 1 / -1;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding-top: 6px;
        }

        .in-app-confirm-cancel,
        .in-app-confirm-accept {
            min-height: 40px;
            min-width: 112px;
            border-radius: 8px;
            padding: 0 16px;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
        }

        .in-app-confirm-cancel {
            border: 1px solid rgba(66, 84, 102, 0.22);
            background: #ffffff;
            color: #1f2937;
        }

        .in-app-confirm-accept {
            border: 1px solid #9B2C2C;
            background: #9B2C2C;
            color: #ffffff;
        }

        .in-app-confirm-cancel:hover {
            background: rgba(66, 84, 102, 0.06);
        }

        .in-app-confirm-accept:hover {
            background: #7f2424;
        }

        @@media (max-width: 780px) {
            .top-bar {
                height: auto;
                min-height: 70px;
                align-items: stretch;
                flex-direction: column;
                padding: 10px 14px;
            }

            .top-bar.no-page-index {
                align-items: flex-end;
            }

            .page-index-wrap {
                width: 100%;
                min-width: 0;
                grid-template-columns: auto minmax(150px, 0.85fr) minmax(170px, 1fr) minmax(220px, 1.15fr);
            }

            .page-index-label {
                padding-bottom: 0;
            }

            .top-nav {
                width: 100%;
                justify-content: space-between;
                gap: 12px;
                flex-wrap: wrap;
            }

            .top-bar.no-page-index .top-nav {
                width: 100%;
            }

            .top-nav a {
                font-size: 15px;
                line-height: 1.2;
            }

            .page-shell {
                padding-top: 124px;
                padding-bottom: 92px;
            }

            .top-bar.no-page-index + .page-shell {
                padding-top: 70px;
            }

            main {
                min-height: calc(100vh - 124px);
            }

            .top-bar.no-page-index + .page-shell main {
                min-height: calc(100vh - 70px);
            }

            .notification-stack {
                left: 16px;
                bottom: 72px;
                gap: 10px;
            }

            .task-notification,
            .issue-notification,
            .variance-notification,
            .readiness-alert-notification,
            .expiry-notification,
            .scoring-notification {
                width: 54px;
                height: 54px;
            }

            .app-footer {
                left: 16px;
                right: 16px;
                bottom: 12px;
                gap: 10px;
                justify-content: flex-end;
                flex-wrap: wrap;
            }

            .in-app-confirm-card {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .in-app-confirm-actions {
                display: grid;
                grid-template-columns: 1fr;
            }

            .in-app-confirm-cancel,
            .in-app-confirm-accept {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <header class="top-bar @(showPageIndex ? string.Empty : "no-page-index")">
        @if (showPageIndex)
        {
            <div class="page-index-wrap">
                <div class="page-index-label">Page Index</div>
                <label class="page-index-field" for="pageIndexMain">
                    <span>1 Home</span>
                    <select id="pageIndexMain" class="page-index-select" aria-label="Home entry" autocomplete="off" data-skip-na disabled>
                        <option value="0" selected>Home</option>
                    </select>
                </label>
                <label class="page-index-field" for="pageIndexSub">
                    <span>2 Module</span>
                    <select id="pageIndexSub" class="page-index-select" aria-label="Module inside Home" autocomplete="off" data-skip-na disabled>
                        <option value="">Select module...</option>
                    </select>
                </label>
                <label class="page-index-field action-field" for="pageIndexAction">
                    <span>3 Action</span>
                    <select id="pageIndexAction" class="page-index-select action-select" aria-label="Action" autocomplete="off" data-skip-na disabled>
                        <option value="">Select action...</option>
                    </select>
                </label>
            </div>
        }

        <nav class="top-nav">
            <a href="javascript:history.back()">Back</a>
            @if (showHomeNav)
            {
                <a asp-area="" asp-page="/Home" onclick="try { sessionStorage.setItem('acuityopsSplashShown', 'true'); } catch (e) { }">Home</a>
            }
        </nav>
    </header>

    <div class="page-shell">
        <div class="container">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="app-footer" aria-label="Application footer">
        @if (hasCompanySession)
        {
            <a asp-area="" asp-page="/AccessLogin" onclick="try { sessionStorage.setItem('acuityopsSplashShown', 'true'); sessionStorage.removeItem('vectorAccessRole'); } catch (e) { }">Access Login Page</a>
        }
        <a asp-area="" asp-page="/Privacy">Privacy</a>
    </footer>

    @if (showNotifications)
    {
        <div class="notification-stack" aria-label="Assigned work notifications">
            <a id="taskNotification" class="task-notification" href="/TaskInbox" aria-label="Open assigned tasks" title="Open assigned tasks">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 6h11" />
                    <path d="M8 12h11" />
                    <path d="M8 18h11" />
                    <path d="M4 6h.01" />
                    <path d="M4 12h.01" />
                    <path d="M4 18h.01" />
                </svg>
                <span id="taskCount" class="task-count"></span>
            </a>

            <a id="issueNotification" class="issue-notification" href="/IssueInbox" aria-label="Open assigned issues" title="Open assigned issues">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 8v5" />
                    <path d="M12 17h.01" />
                    <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
                </svg>
                <span id="issueCount" class="issue-count"></span>
            </a>

            <a id="varianceNotification" class="variance-notification" href="/ChecklistVarianceAlerts" aria-label="Open checklist variance alerts" title="Open checklist variance alerts">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M7 7h10" />
                    <path d="m14 4 3 3-3 3" />
                    <path d="M17 17H7" />
                    <path d="m10 14-3 3 3 3" />
                    <path d="M12 11v2" />
                    <path d="M12 16h.01" />
                </svg>
                <span id="varianceCount" class="variance-count"></span>
            </a>

            <a id="readinessAlertNotification" class="readiness-alert-notification" href="/ReadinessAlerts" aria-label="Open readiness alerts" title="Open readiness alerts">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 3a9 9 0 1 0 9 9" />
                    <path d="M12 8v4" />
                    <path d="M12 16h.01" />
                    <path d="m16 8 3-3" />
                    <path d="M19 5v4" />
                    <path d="M15 5h4" />
                </svg>
                <span id="readinessAlertCount" class="readiness-alert-count"></span>
            </a>

            <a id="expiryNotification" class="expiry-notification" href="/ExpiryNotifications" aria-label="Open expiry and service notifications" title="Open expiry and service notifications">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 2v4" />
                    <path d="M16 2v4" />
                    <path d="M3 10h18" />
                    <path d="M5 4h14a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" />
                    <path d="M12 14v3" />
                    <path d="M12 19h.01" />
                </svg>
                <span id="expiryCount" class="expiry-count"></span>
            </a>

            <a id="scoringNotification" class="scoring-notification" href="/ReadinessEngine" aria-label="Open readiness scoring requests" title="Open readiness scoring requests">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 7h16" />
                    <path d="M4 17h16" />
                    <path d="M8 4v6" />
                    <path d="M16 14v6" />
                    <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                    <path d="M16 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                </svg>
                <span id="scoringCount" class="scoring-count"></span>
            </a>
        </div>
    }

    <div id="actionConfirmation" class="action-confirmation" role="status" aria-live="polite" aria-hidden="true">
        <div class="confirmation-card">
            <div class="confirmation-mark">✓</div>
            <h2 class="confirmation-title">Action Confirmed</h2>
            <p id="confirmationMessage" class="confirmation-message">Your action has been completed.</p>
        </div>
    </div>

    <div id="inAppConfirmModal" class="in-app-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="inAppConfirmTitle" aria-describedby="inAppConfirmMessage" aria-hidden="true">
        <div class="in-app-confirm-card" role="document">
            <div class="in-app-confirm-icon" aria-hidden="true">!</div>
            <div class="in-app-confirm-copy">
                <h2 id="inAppConfirmTitle">Confirm action</h2>
                <p id="inAppConfirmMessage">Confirm this action?</p>
            </div>
            <div class="in-app-confirm-actions">
                <button id="inAppConfirmCancel" type="button" class="in-app-confirm-cancel">Cancel</button>
                <button id="inAppConfirmAccept" type="button" class="in-app-confirm-accept">Confirm</button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        const vectorQueuedConfirmations = window.VectorPendingConfirmations || [];

        window.VectorActionConfirmation = (function () {
            function getReturnUrl(fallbackUrl) {
                if (fallbackUrl) {
                    return fallbackUrl;
                }

                if (document.referrer) {
                    try {
                        const referrer = new URL(document.referrer);
                        if (referrer.origin === window.location.origin && referrer.pathname !== window.location.pathname) {
                            return referrer.pathname + referrer.search;
                        }
                    } catch { }
                }

                const role = window.VectorCurrentRole || sessionStorage.getItem("vectorAccessRole");
                if (role === "staff") {
                    return "/Home";
                }
                if (role === "manager") {
                    return "/Home";
                }
                if (role === "senior") {
                    return "/Home";
                }

                return "/Index";
            }

            function show(options) {
                const settings = options || {};
                const overlay = document.getElementById("actionConfirmation");
                const message = document.getElementById("confirmationMessage");
                const redirectUrl = settings.redirectUrl === null
                    ? null
                    : getReturnUrl(settings.redirectUrl);

                if (!overlay || !message) {
                    if (redirectUrl) {
                        window.location.href = redirectUrl;
                    }
                    return;
                }

                message.textContent = settings.message || "Your action has been completed.";
                overlay.classList.remove("leaving");
                overlay.classList.add("visible");
                overlay.setAttribute("aria-hidden", "false");

                window.setTimeout(function () {
                    overlay.classList.add("leaving");
                    window.setTimeout(function () {
                        overlay.classList.remove("visible", "leaving");
                        overlay.setAttribute("aria-hidden", "true");
                        if (redirectUrl) {
                            window.location.href = redirectUrl;
                        }
                    }, Number(settings.fadeDelay || 220));
                }, settings.delay || 1250);
            }

            return { show: show, getReturnUrl: getReturnUrl };
        })();

        vectorQueuedConfirmations.forEach(function (options) {
            window.VectorActionConfirmation.show(options);
        });
        window.VectorPendingConfirmations = [];

        document.addEventListener("click", function (event) {
            const trigger = event.target.closest("[data-action-confirmation]");
            if (!trigger) {
                return;
            }

            event.preventDefault();

            window.VectorActionConfirmation?.show({
                message: trigger.dataset.confirmationMessage || "Action saved.",
                redirectUrl: trigger.dataset.confirmationRedirectUrl || window.VectorActionConfirmation.getReturnUrl(),
                delay: Number(trigger.dataset.confirmationDelay || 1300)
            });
        });
    </script>

    @if (showPageIndex)
    {
        <script>
            (function () {
                const serverRole = @Json.Serialize(currentClientRole);
                window.VectorCurrentRole = serverRole || null;

                const accessFromUrl = new URLSearchParams(window.location.search).get("access");
                if (serverRole) {
                    sessionStorage.setItem("vectorAccessRole", serverRole);
                } else if (accessFromUrl) {
                    const role = accessFromUrl === "senior-management"
                        ? "senior"
                        : accessFromUrl === "staff"
                            ? "staff"
                            : "manager";
                    sessionStorage.setItem("vectorAccessRole", role);
                }

                const mainSelect = document.getElementById("pageIndexMain");
                const subSelect = document.getElementById("pageIndexSub");
                const actionSelect = document.getElementById("pageIndexAction");
                const myProfileUrl = @Json.Serialize(currentUserId.HasValue ? $"/StaffRecordsSearch?staffUserId={currentUserId.Value}" : "/MyProfile");
                function normalizeRole(role) {
                    if (!role) {
                        return null;
                    }

                    const value = String(role).toLowerCase();
                    if (value.includes("senior") || value.includes("owner")) {
                        return "senior";
                    }

                    if (value.includes("staff")) {
                        return "staff";
                    }

                    if (value.includes("manager") || value.includes("operational")) {
                        return "manager";
                    }

                    return value;
                }

                const currentRole = normalizeRole(serverRole || sessionStorage.getItem("vectorAccessRole"));

                const pageTree = [
                    {
                        module: "Home",
                        areas: [
                            { name: "Dashboard", actions: [
                                { label: "Home Dashboard", url: "/Home", access: "all" },
                                { label: "Button And Term Guide", url: "/AppGuide", access: "staff,manager,senior" }
                            ] },
                            { name: "Daily Work", actions: [
                                { label: "Daily Vehicle & Equipment Check", url: "/DailyVehicleChecklist", access: "staff,manager,senior" },
                                { label: "My Profile", url: myProfileUrl, access: "staff,manager,senior", aliases: ["/MyProfile", "/PersonalDocuments"] }
                            ] },
                            { name: "Tasks & Issues", actions: [
                                { label: "Tasks & Issues Module", url: "/TasksIssues", access: "manager,senior" },
                                { label: "My Tasks", url: "/TaskInbox", access: "staff,manager,senior", aliases: ["/TaskAction"] },
                                { label: "Task Feedback", url: "/TaskFeedback", access: "staff,manager,senior" },
                                { label: "Send Task", url: "/SendTask", access: "manager,senior" },
                                { label: "Report Issue", url: "/ReportIssue?module=general", access: "staff,manager,senior" },
                                { label: "My Assigned Issues", url: "/IssueInbox", access: "manager,senior" },
                                { label: "All Open Issues", url: "/IssueReports", access: "manager,senior", aliases: ["/IssueReportAction"] }
                            ] },
                            { name: "Readiness", actions: [
                                { label: "Readiness Module", url: "/Readiness", access: "manager,senior" },
                                { label: "Shift Readiness Dashboard", url: "/ReadinessDashboard", access: "manager,senior" },
                                { label: "Readiness Alerts", url: "/ReadinessAlerts", access: "manager,senior", aliases: ["/ReadinessMetric", "/ReadinessMetricDetail"] },
                                { label: "Expiry Notifications", url: "/ExpiryNotifications", access: "staff,manager,senior" },
                                { label: "Variance Alerts", url: "/ChecklistVarianceAlerts", access: "manager,senior" },
                                { label: "Operational Reports", url: "/OperationsReports", access: "manager,senior" },
                                { label: "Readiness Engine", url: "/ReadinessEngine", access: "manager,senior" }
                            ] },
                            { name: "Checklist Management", actions: [
                                { label: "Checklist Management", url: "/EditChecklist", access: "manager,senior" },
                                { label: "Checklist Register", url: "/EditChecklist?view=register", access: "manager,senior", aliases: ["/ChecklistTemplateView"] },
                                { label: "Build New Checklist", url: "/EditVehicleChecklist?checklist=daily-vehicle&mode=build", access: "manager,senior" },
                                { label: "Edit Checklist Matrix", url: "/EditChecklist?view=register", access: "manager,senior", aliases: ["/EditVehicleChecklist"] },
                                { label: "Publish Checklist", url: "/EditChecklist?view=register", access: "senior", aliases: ["/PublishChecklist"] },
                                { label: "Checklist Reports", url: "/ChecklistReports", access: "manager,senior", aliases: ["/ChecklistReportDetail"] },
                                { label: "Upload Existing Checklist", url: "/UploadChecklist", access: "senior", aliases: ["/ChecklistPreview"] },
                                { label: "Checklist Approvals", url: "/ChecklistApproval", access: "senior" },
                                { label: "Unit Schematic Library", url: "/VehicleSchematicLibrary", access: "senior" }
                            ] },
                            { name: "Vehicles", actions: [
                                { label: "Vehicle Module", url: "/Vehicles", access: "manager,senior" },
                                { label: "Vehicle Register", url: "/VehicleRegister", access: "manager,senior", aliases: ["/EditVehicle"] },
                                { label: "Add Vehicle", url: "/AddItem?type=vehicle", access: "manager,senior" },
                                { label: "Reassign Callsign", url: "/ReassignVehicleCallsign", access: "manager,senior" },
                                { label: "Move / Reallocate Vehicle", url: "/MoveAsset?asset=vehicle", access: "manager,senior" },
                                { label: "Report Vehicle Issue", url: "/ReportIssue?module=vehicle", access: "staff,manager,senior" }
                            ] },
                            { name: "Equipment", actions: [
                                { label: "Equipment Module", url: "/Equipment", access: "manager,senior" },
                                { label: "Equipment Register", url: "/EquipmentRegister?view=register", access: "manager,senior", aliases: ["/EquipmentRegister", "/EditEquipmentItem"] },
                                { label: "Add Equipment", url: "/AddItem?type=equipment", access: "manager,senior" },
                                { label: "Update Service Dates", url: "/EquipmentService", access: "manager,senior" },
                                { label: "Move / Reallocate Equipment", url: "/MoveAsset?asset=equipment", access: "manager,senior" },
                                { label: "Report Equipment Issue", url: "/ReportIssue?module=equipment", access: "staff,manager,senior" }
                            ] },
                            { name: "Staff", actions: [
                                { label: "Staff Module", url: "/Staff", access: "manager,senior" },
                                { label: "Staff Register", url: "/StaffRegister", access: "manager,senior", aliases: ["/StaffRecordsSearch", "/EditStaffProfile", "/StaffFiles", "/StaffFilesPreview", "/UploadStaffFiles"] },
                                { label: "Add Staff Profile", url: "/AddItem?type=staff", access: "manager,senior" }
                            ] },
                            { name: "Stock", actions: [
                                { label: "Stock Module", url: "/Stock", access: "manager,senior" },
                                { label: "Stock Register", url: "/StockRegister?view=register", access: "manager,senior", aliases: ["/StockRegister", "/EditStockItem"] },
                                { label: "Stock Orders & Distribution", url: "/StockOrders", access: "manager,senior", aliases: ["/StockOrderAction", "/PlaceStockOrder", "/SupplierDetails"] },
                                { label: "Add Stock Item", url: "/AddItem?type=stock", access: "manager,senior" },
                                { label: "Move / Reallocate Stock", url: "/MoveAsset?asset=stock", access: "manager,senior" },
                                { label: "Report Stock Issue", url: "/ReportIssue?module=stock", access: "staff,manager,senior" }
                            ] },
                            { name: "Medication", actions: [
                                { label: "Medication Module", url: "/Medication", access: "manager,senior" },
                                { label: "Medication Register", url: "/MedicationRegister?view=register", access: "manager,senior", aliases: ["/MedicationRegister", "/EditMedicationItem"] },
                                { label: "Add Medication", url: "/AddItem?type=medication", access: "manager,senior" },
                                { label: "Move / Reallocate Medication", url: "/MoveAsset?asset=medication", access: "manager,senior" },
                                { label: "Report Medication Issue", url: "/ReportIssue?module=medication", access: "staff,manager,senior" }
                            ] },
                            { name: "System Setup", actions: [
                                { label: "Master Setup", url: "/MasterSetup", access: "senior", aliases: ["/UploadVehicleRegister", "/VehicleRegisterPreview", "/UploadEquipmentRegister", "/EquipmentRegisterPreview", "/UploadStaffRegister", "/StaffRegisterPreview", "/UploadStockRegister", "/StockRegisterPreview", "/UploadMedicationRegister", "/MedicationRegisterPreview"] },
                                { label: "Company Profile", url: "/CompanyProfile", access: "senior", aliases: ["/CompanyName", "/LogoUpload"] },
                                { label: "Area / Manager Control", url: "/AreaManagerControl", access: "senior", aliases: ["/OperationalAreas", "/CreateManagerAccess", "/CreateOperationalStaffAccess"] },
                                { label: "Task Communication", url: "/TaskCommunicationSetup", access: "senior" },
                                { label: "Audit Log", url: "/AuditLog", access: "senior" }
                            ] }
                        ]
                    }
                ];

                function canUse(action) {
                    if (!action.access || action.access === "all") {
                        return true;
                    }

                    return currentRole && action.access.split(",").includes(currentRole);
                }

                function cleanTree(tree) {
                    return tree.map(function (module) {
                        const areas = module.areas.map(function (area) {
                            return {
                                name: area.name,
                                actions: area.actions.filter(canUse)
                            };
                        }).filter(function (area) {
                            return area.actions.length > 0;
                        });

                        return {
                            module: module.module,
                            areas: areas
                        };
                    }).filter(function (module) {
                        return module.areas.length > 0;
                    });
                }

                const visibleTree = cleanTree(pageTree);

                function resetSelect(select, placeholder) {
                    select.innerHTML = "";
                    const option = document.createElement("option");
                    option.value = "";
                    option.textContent = placeholder;
                    select.appendChild(option);
                    select.disabled = true;
                }

                function addOption(select, value, label) {
                    const option = document.createElement("option");
                    option.value = value;
                    option.textContent = label;
                    select.appendChild(option);
                }

                function populateMain() {
                    mainSelect.innerHTML = "";
                    addOption(mainSelect, "0", visibleTree[0]?.module || "Home");
                    mainSelect.value = "0";
                    mainSelect.disabled = true;
                }

                function populateSub(moduleIndex) {
                    resetSelect(subSelect, "Select module...");
                    resetSelect(actionSelect, "Select action...");

                    const module = visibleTree[moduleIndex];
                    if (!module) {
                        return;
                    }

                    module.areas.forEach(function (area, areaIndex) {
                        addOption(subSelect, String(areaIndex), area.name);
                    });
                    subSelect.disabled = false;
                }

                function populateActions(moduleIndex, areaIndex) {
                    resetSelect(actionSelect, "Select action...");

                    const area = visibleTree[moduleIndex]?.areas[areaIndex];
                    if (!area) {
                        return;
                    }

                    area.actions.forEach(function (action, actionIndex) {
                        addOption(actionSelect, String(actionIndex), action.label);
                    });
                    actionSelect.disabled = false;
                }

                function scoreUrl(actionUrl, currentUrl) {
                    let optionUrl;
                    try {
                        optionUrl = new URL(actionUrl, window.location.origin);
                    } catch {
                        return -1;
                    }

                    if (optionUrl.pathname.toLowerCase() !== currentUrl.pathname.toLowerCase()) {
                        return -1;
                    }

                    let paramsMatch = true;
                    let score = 1;
                    optionUrl.searchParams.forEach(function (value, key) {
                        if (currentUrl.searchParams.get(key) !== value) {
                            paramsMatch = false;
                        }
                        score += 10;
                    });

                    if (!paramsMatch) {
                        return -1;
                    }

                    if (optionUrl.search === currentUrl.search) {
                        score += 100;
                    }

                    return score;
                }

                function scoreAction(action, currentUrl) {
                    const candidateUrls = [action.url].concat(action.aliases || []);
                    return candidateUrls.reduce(function (bestScore, candidateUrl) {
                        return Math.max(bestScore, scoreUrl(candidateUrl, currentUrl));
                    }, -1);
                }

                function selectCurrentPage() {
                    const currentUrl = new URL(window.location.href);
                    let best = null;
                    let bestScore = -1;

                    visibleTree.forEach(function (module, moduleIndex) {
                        module.areas.forEach(function (area, areaIndex) {
                            area.actions.forEach(function (action, actionIndex) {
                                const score = scoreAction(action, currentUrl);
                                if (score > bestScore) {
                                    best = { moduleIndex, areaIndex, actionIndex };
                                    bestScore = score;
                                }
                            });
                        });
                    });

                    if (!best || bestScore < 0) {
                        mainSelect.value = "0";
                        populateSub(0);
                        resetSelect(actionSelect, "Select action...");
                        return;
                    }

                    mainSelect.value = String(best.moduleIndex);
                    populateSub(best.moduleIndex);
                    subSelect.value = String(best.areaIndex);
                    populateActions(best.moduleIndex, best.areaIndex);
                    actionSelect.value = String(best.actionIndex);
                }

                if (mainSelect && subSelect && actionSelect) {
                    populateMain();
                    populateSub(0);
                    resetSelect(actionSelect, "Select action...");
                    selectCurrentPage();
                    window.requestAnimationFrame(selectCurrentPage);
                    window.setTimeout(selectCurrentPage, 80);
                    window.addEventListener("pageshow", selectCurrentPage);

                    mainSelect.addEventListener("change", function () {
                        if (mainSelect.value === "") {
                            resetSelect(subSelect, "Select module...");
                            resetSelect(actionSelect, "Select action...");
                            return;
                        }

                        populateSub(Number(mainSelect.value));
                    });

                    subSelect.addEventListener("change", function () {
                        if (mainSelect.value === "" || subSelect.value === "") {
                            resetSelect(actionSelect, "Select action...");
                            return;
                        }

                        populateActions(Number(mainSelect.value), Number(subSelect.value));
                    });

                    actionSelect.addEventListener("change", function () {
                        if (mainSelect.value === "" || subSelect.value === "" || actionSelect.value === "") {
                            return;
                        }

                        const action = visibleTree[Number(mainSelect.value)]?.areas[Number(subSelect.value)]?.actions[Number(actionSelect.value)];
                        if (action?.url) {
                            window.location.href = action.url;
                        }
                    });
                }

            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
