@using vector_app_local.Services
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var showPageIndex = !string.Equals(currentPage, "/Index", StringComparison.OrdinalIgnoreCase);
    var showTaskNotification = showPageIndex && !string.Equals(currentPage, "/RoleLogin", StringComparison.OrdinalIgnoreCase);
    var currentAccessView = Context.Session.GetString(CurrentUserService.AccessViewSessionKey);
    var currentClientRole = string.IsNullOrWhiteSpace(currentAccessView)
        ? null
        : CurrentUserService.AccessViewToClientRole(currentAccessView);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - vector_app_local</title>

    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="shortcut icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/vector_app_local.styles.css" asp-append-version="true" />

    <script>
        window.VectorPendingConfirmations = window.VectorPendingConfirmations || [];
        window.VectorActionConfirmation = window.VectorActionConfirmation || {
            show: function (options) {
                window.VectorPendingConfirmations.push(options || {});
            },
            getReturnUrl: function (fallbackUrl) {
                return fallbackUrl || null;
            }
        };
    </script>

    <style>
        html, body {
            margin: 0;
            padding: 0;
            min-height: 100%;
        }

        body {
            background: #F4F7FB;
        }

        .top-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 70px;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            padding: 0 28px;
            box-sizing: border-box;
            z-index: 1000;
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        }

        .top-bar.no-page-index {
            justify-content: flex-end;
        }

        .page-index-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 260px;
        }

        .page-index-label {
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color: #52606d;
            white-space: nowrap;
        }

        .page-index-select {
            min-width: 220px;
            max-width: 320px;
            height: 40px;
            border: 1px solid rgba(66, 84, 102, 0.24);
            border-radius: 8px;
            background: #ffffff;
            color: #1f2937;
            font-size: 14px;
            font-weight: 700;
            padding: 0 12px;
        }

        .top-nav {
            display: flex;
            align-items: center;
            gap: 24px;
            flex: 0 0 auto;
        }

        .top-nav a {
            text-decoration: none;
            font-size: 17px;
            font-weight: 600;
            color: #111;
            transition: opacity 0.15s ease;
        }

        .top-nav a:hover {
            opacity: 0.65;
        }

        .page-shell {
            min-height: 100vh;
            padding-top: 70px;
            box-sizing: border-box;
        }

        main {
            min-height: calc(100vh - 70px);
        }

        .container {
            max-width: 100% !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .task-notification {
            position: fixed;
            left: 22px;
            bottom: 22px;
            z-index: 1100;
            width: 58px;
            height: 58px;
            border-radius: 50%;
            background: #2f80a8;
            color: #ffffff;
            display: none;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            box-shadow: 0 16px 34px rgba(47, 128, 168, 0.28);
            transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
        }

        .task-notification.visible {
            display: flex;
        }

        .task-notification:hover {
            color: #ffffff;
            background: #276f93;
            transform: translateY(-2px);
            box-shadow: 0 20px 40px rgba(47, 128, 168, 0.34);
        }

        .task-notification svg {
            width: 26px;
            height: 26px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .task-count {
            position: absolute;
            top: -4px;
            right: -4px;
            min-width: 22px;
            height: 22px;
            padding: 0 6px;
            border-radius: 999px;
            background: #f2b84b;
            color: #102a3a;
            border: 2px solid #ffffff;
            font-size: 12px;
            font-weight: 800;
            line-height: 18px;
            text-align: center;
        }

        .action-confirmation {
            position: fixed;
            inset: 0;
            z-index: 1500;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: rgba(15, 23, 42, 0.28);
            box-sizing: border-box;
        }

        .action-confirmation.visible {
            display: flex;
        }

        .confirmation-card {
            width: min(420px, 94vw);
            padding: 28px 24px;
            border-radius: 8px;
            background: #ffffff;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
            text-align: center;
        }

        .confirmation-mark {
            width: 58px;
            height: 58px;
            margin: 0 auto 16px auto;
            border-radius: 50%;
            background: #2f80a8;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            font-weight: 900;
        }

        .confirmation-title {
            margin: 0 0 8px 0;
            font-size: 22px;
            font-weight: 900;
            color: #1f2937;
        }

        .confirmation-message {
            margin: 0;
            font-size: 15px;
            font-weight: 700;
            color: #52606d;
        }

        @@media (max-width: 780px) {
            .top-bar {
                height: auto;
                min-height: 70px;
                align-items: stretch;
                flex-direction: column;
                padding: 12px 16px;
            }

            .top-bar.no-page-index {
                align-items: flex-end;
            }

            .page-index-wrap {
                width: 100%;
                min-width: 0;
            }

            .page-index-select {
                width: 100%;
                min-width: 0;
                max-width: none;
            }

            .top-nav {
                width: 100%;
                justify-content: space-between;
                gap: 14px;
            }

            .top-bar.no-page-index .top-nav {
                width: auto;
            }

            .page-shell {
                padding-top: 124px;
            }

            .top-bar.no-page-index + .page-shell {
                padding-top: 70px;
            }

            main {
                min-height: calc(100vh - 124px);
            }

            .top-bar.no-page-index + .page-shell main {
                min-height: calc(100vh - 70px);
            }

            .task-notification {
                left: 16px;
                bottom: 16px;
                width: 54px;
                height: 54px;
            }
        }
    </style>
</head>
<body>
    <header class="top-bar @(showPageIndex ? string.Empty : "no-page-index")">
        @if (showPageIndex)
        {
            <div class="page-index-wrap">
                <label class="page-index-label" for="pageIndex">Page Index</label>
                <select id="pageIndex" class="page-index-select" aria-label="Page index">
                    <option value="">Go to page...</option>

                    <option value="/Index" data-access="all">Access Level</option>
                    <option value="/Home" data-access="all">Home</option>
                    <option value="/Privacy" data-access="all">Privacy</option>

                    <option value="/TaskInbox" data-access="staff,manager,senior">Task Inbox</option>
                    <option value="/CompleteChecklist" data-access="staff,manager,senior">Complete Checklist</option>
                    <option value="/DailyChecklist" data-access="staff,manager,senior">Daily Checklist</option>
                    <option value="/DailyVehicleChecklist" data-access="staff,manager,senior">Daily Vehicle Inspection</option>
                    <option value="/DailyEquipmentChecklist" data-access="staff,manager,senior">Daily Equipment Checklist</option>
                    <option value="/MonthlyChecklist" data-access="staff,manager,senior">Monthly Checklist</option>
                    <option value="/TaskFeedback" data-access="staff,manager,senior">Task Feedback</option>
                    <option value="/PersonalDocuments" data-access="staff,manager,senior">Personal Documents</option>
                    <option value="/ReportIssue?module=general" data-access="staff,manager,senior">Report Issue</option>

                    <option value="/Vehicles" data-access="manager,senior">Vehicles</option>
                    <option value="/Equipment" data-access="manager,senior">Equipment</option>
                    <option value="/Stock" data-access="manager,senior">Stock</option>
                    <option value="/Staff" data-access="manager,senior">Staff Records</option>
                    <option value="/Medication" data-access="manager,senior">Medication</option>
                    <option value="/SendTask" data-access="manager,senior">Send Task</option>
                    <option value="/EditChecklist" data-access="manager,senior">Edit Checklist</option>
                    <option value="/EditVehicleChecklist?checklist=daily-vehicle" data-access="manager,senior">Edit Daily Vehicle Checklist</option>
                    <option value="/EditVehicleChecklist?checklist=monthly-vehicle" data-access="manager,senior">Edit Monthly Vehicle Checklist</option>
                    <option value="/EditEquipmentChecklist" data-access="manager,senior">Edit Equipment Checklist</option>
                    <option value="/AddItem?type=vehicle" data-access="manager,senior">Add Vehicle</option>
                    <option value="/AddItem?type=equipment" data-access="manager,senior">Add Equipment</option>
                    <option value="/AddItem?type=stock" data-access="manager,senior">Add Stock Item</option>
                    <option value="/AddItem?type=medication" data-access="manager,senior">Add Medication</option>
                    <option value="/UploadStaffFiles" data-access="manager,senior">Staff Files / Folders</option>
                    <option value="/StaffRecordsSearch" data-access="manager,senior">Search Staff Records</option>

                    <option value="/MasterSetup" data-access="senior">Master Setup</option>
                    <option value="/CompanyProfile" data-access="senior">Company Profile</option>
                    <option value="/CompanyName" data-access="senior">Company Name</option>
                    <option value="/LogoUpload" data-access="senior">Logo Upload</option>
                    <option value="/SupplierDetails" data-access="senior">Supplier Details</option>
                    <option value="/UploadChecklist" data-access="senior">Upload Existing Checklist</option>
                    <option value="/UploadVehicleRegister" data-access="senior">Upload Vehicle Register</option>
                    <option value="/VehicleSchematicLibrary" data-access="senior">Vehicle Schematic Library</option>
                    <option value="/UploadEquipmentRegister" data-access="senior">Upload Equipment Register</option>
                    <option value="/UploadStockRegister" data-access="senior">Upload Stock Register</option>
                    <option value="/CreateManagerAccess" data-access="senior">Create Manager Access</option>
                    <option value="/CreateOperationalStaffAccess" data-access="senior">Create Staff Access</option>
                    <option value="/TaskCommunicationSetup" data-access="senior">Task Communication Setup</option>
                    <option value="/AuditLog" data-access="senior">Audit Log</option>
                    <option value="/Onboarding" data-access="senior">Onboarding</option>
                    <option value="/CompanyLogin" data-access="senior">Company Login</option>
                </select>
            </div>
        }

        <nav class="top-nav">
            <a href="javascript:history.back()">Back</a>
            <a asp-area="" asp-page="/Index">Home</a>
            <a asp-area="" asp-page="/Privacy">Privacy</a>
        </nav>
    </header>

    <div class="page-shell">
        <div class="container">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    @if (showTaskNotification)
    {
        <a id="taskNotification" class="task-notification" href="/TaskInbox" aria-label="Open assigned tasks" title="Open assigned tasks">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 6h11" />
                <path d="M8 12h11" />
                <path d="M8 18h11" />
                <path d="M4 6h.01" />
                <path d="M4 12h.01" />
                <path d="M4 18h.01" />
            </svg>
            <span id="taskCount" class="task-count"></span>
        </a>
    }

    <div id="actionConfirmation" class="action-confirmation" role="status" aria-live="polite" aria-hidden="true">
        <div class="confirmation-card">
            <div class="confirmation-mark">✓</div>
            <h2 class="confirmation-title">Action Confirmed</h2>
            <p id="confirmationMessage" class="confirmation-message">Your action has been completed.</p>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        const vectorQueuedConfirmations = window.VectorPendingConfirmations || [];

        window.VectorActionConfirmation = (function () {
            function getReturnUrl(fallbackUrl) {
                if (fallbackUrl) {
                    return fallbackUrl;
                }

                if (document.referrer) {
                    try {
                        const referrer = new URL(document.referrer);
                        if (referrer.origin === window.location.origin && referrer.pathname !== window.location.pathname) {
                            return referrer.pathname + referrer.search;
                        }
                    } catch { }
                }

                const role = window.VectorCurrentRole || sessionStorage.getItem("vectorAccessRole");
                if (role === "staff") {
                    return "/Home";
                }
                if (role === "manager") {
                    return "/Home";
                }
                if (role === "senior") {
                    return "/Home";
                }

                return "/Index";
            }

            function show(options) {
                const settings = options || {};
                const overlay = document.getElementById("actionConfirmation");
                const message = document.getElementById("confirmationMessage");
                const redirectUrl = getReturnUrl(settings.redirectUrl);

                if (!overlay || !message) {
                    window.location.href = redirectUrl;
                    return;
                }

                message.textContent = settings.message || "Your action has been completed.";
                overlay.classList.add("visible");
                overlay.setAttribute("aria-hidden", "false");

                window.setTimeout(function () {
                    window.location.href = redirectUrl;
                }, settings.delay || 1250);
            }

            return { show: show, getReturnUrl: getReturnUrl };
        })();

        vectorQueuedConfirmations.forEach(function (options) {
            window.VectorActionConfirmation.show(options);
        });
        window.VectorPendingConfirmations = [];

        document.addEventListener("click", function (event) {
            const trigger = event.target.closest("[data-action-confirmation]");
            if (!trigger) {
                return;
            }

            event.preventDefault();

            window.VectorActionConfirmation?.show({
                message: trigger.dataset.confirmationMessage || "Action saved.",
                redirectUrl: trigger.dataset.confirmationRedirectUrl || window.VectorActionConfirmation.getReturnUrl(),
                delay: Number(trigger.dataset.confirmationDelay || 1300)
            });
        });
    </script>

    @if (showPageIndex)
    {
        <script>
            (function () {
                const serverRole = @Json.Serialize(currentClientRole);
                window.VectorCurrentRole = serverRole || null;

                const accessFromUrl = new URLSearchParams(window.location.search).get("access");
                if (serverRole) {
                    sessionStorage.setItem("vectorAccessRole", serverRole);
                } else if (accessFromUrl) {
                    const role = accessFromUrl === "senior-management"
                        ? "senior"
                        : accessFromUrl === "staff"
                            ? "staff"
                            : "manager";
                    sessionStorage.setItem("vectorAccessRole", role);
                }

                const select = document.getElementById("pageIndex");
                const currentRole = serverRole || sessionStorage.getItem("vectorAccessRole");

                if (select) {
                    const options = Array.from(select.options);

                    options.forEach(function (option) {
                        const access = option.dataset.access;
                        if (!access || access === "all") {
                            return;
                        }

                        const allowedRoles = access.split(",");
                        if (!currentRole || !allowedRoles.includes(currentRole)) {
                            option.remove();
                        }
                    });

                    const currentPath = window.location.pathname.toLowerCase();
                    Array.from(select.options).forEach(function (option) {
                        const optionPath = (option.value || "").split("?")[0].toLowerCase();
                        if (optionPath && optionPath === currentPath) {
                            select.value = option.value;
                        }
                    });

                    select.addEventListener("change", function () {
                        if (select.value) {
                            window.location.href = select.value;
                        }
                    });
                }

            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
