@page
@model AccessModelSetupModel
@using vector_app_local.Services
@{
    ViewData["Title"] = "Access Model Setup";
}

<div class="access-model-screen">
    <div class="access-model-inner">
        <div class="client-line">Client: @Model.ClientName</div>
        <div class="home-label">Setup Wizard</div>
        <h2 class="page-title">Access Model</h2>
        <p class="page-subtitle">Set the default permissions each access level receives before real staff start using the app. Individual users can still be adjusted later in Access Setup.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message" data-action-status>@Model.StatusMessage</div>
        }

        <section class="form-panel summary-panel">
            <div>
                <div class="section-label">Company owner defaults</div>
                <h3>Full control, protected from lockout</h3>
                <p>The company owner keeps all permissions by default. This setup step saves that baseline, but does not allow the wizard to remove owner control.</p>
            </div>
            <strong>@Model.CompanyOwnerPermissionKeys.Count permissions</strong>
        </section>

        <form method="post" asp-page-handler="SaveDefaults" class="access-model-form">
            <section class="form-panel">
                <div class="section-heading-row">
                    <div>
                        <div class="section-label">Operational manager behavior</div>
                        <h3>Scope and core powers</h3>
                    </div>
                    <span>@Model.OperationalManagerPermissionKeySet.Count permissions</span>
                </div>

                <div class="form-grid">
                    <label class="field-group">
                        <span class="field-label">Manager scope behavior</span>
                        <select class="text-input" asp-for="OperationalManagerScopeBehavior" asp-items="Model.ScopeBehaviorOptions" data-skip-na></select>
                    </label>

                    <label class="toggle-row important">
                        <input asp-for="OperationalManagersRequestOnlyMode" />
                        <span>
                            <strong>Request-only mode</strong>
                            <small>Operational managers can view, report, and request changes, but cannot directly edit registers, draft checklists, approve stock, or change setup.</small>
                        </span>
                    </label>
                </div>

                <div class="capability-grid">
                    <label class="capability-card">
                        <input asp-for="OperationalManagersCanDraftChecklistChanges" />
                        <span>
                            <strong>Can draft checklist changes</strong>
                            <small>Allows checklist build/edit. Publishing still requires the checklist publish permission.</small>
                        </span>
                    </label>
                    <label class="capability-card">
                        <input asp-for="OperationalManagersCanEditRegisters" />
                        <span>
                            <strong>Can edit registers</strong>
                            <small>Allows source-of-truth register edits, asset movement, and service/expiry updates within scope.</small>
                        </span>
                    </label>
                    <label class="capability-card">
                        <input asp-for="OperationalManagersCanApproveStockOrders" />
                        <span>
                            <strong>Can approve stock orders</strong>
                            <small>Allows stock order approval where the stock workflow permits manager approval.</small>
                        </span>
                    </label>
                </div>

                <div class="permission-preview">
                    <strong>Operational manager permission preview</strong>
                    <span>@Model.OperationalManagerPermissionSummary</span>
                </div>
            </section>

            <section class="form-panel permissions-panel">
                <div class="section-heading-row">
                    <div>
                        <div class="section-label">Senior management defaults</div>
                        <h3>Default saved permissions</h3>
                    </div>
                    <span>@Model.SeniorManagerPermissionKeySet.Count permissions</span>
                </div>
                <p class="source-note">Senior management defaults should remain broad. Use this only to define the saved permission baseline for future senior users.</p>
                @foreach (var permissionGroup in Model.PermissionGroups)
                {
                    <div class="permission-group">
                        <h4>@permissionGroup.Name</h4>
                        <div class="permission-grid">
                            @foreach (var permission in permissionGroup.Options)
                            {
                                <label class="permission-item">
                                    <input type="checkbox"
                                           name="SeniorManagerPermissionKeys"
                                           value="@permission.Key"
                                           checked="@Model.SeniorManagerPermissionKeySet.Contains(permission.Key)" />
                                    <span>
                                        <strong>@permission.Name</strong>
                                        <small>@permission.Description</small>
                                    </span>
                                </label>
                            }
                        </div>
                    </div>
                }
                <div class="permission-preview">
                    <strong>Senior manager preview</strong>
                    <span>@Model.SeniorManagerPermissionSummary</span>
                </div>
            </section>

            <section class="form-panel permissions-panel">
                <div class="section-heading-row">
                    <div>
                        <div class="section-label">Staff defaults</div>
                        <h3>Default saved permissions</h3>
                    </div>
                    <span>@Model.StaffPermissionKeySet.Count permissions</span>
                </div>
                <p class="source-note">Staff defaults should stay focused on crew-facing work unless a company explicitly chooses otherwise.</p>
                @foreach (var permissionGroup in Model.PermissionGroups)
                {
                    <div class="permission-group">
                        <h4>@permissionGroup.Name</h4>
                        <div class="permission-grid">
                            @foreach (var permission in permissionGroup.Options)
                            {
                                <label class="permission-item">
                                    <input type="checkbox"
                                           name="StaffPermissionKeys"
                                           value="@permission.Key"
                                           checked="@Model.StaffPermissionKeySet.Contains(permission.Key)" />
                                    <span>
                                        <strong>@permission.Name</strong>
                                        <small>@permission.Description</small>
                                    </span>
                                </label>
                            }
                        </div>
                    </div>
                }
                <div class="permission-preview">
                    <strong>Staff permission preview</strong>
                    <span>@Model.StaffPermissionSummary</span>
                </div>
            </section>

            <div class="button-row">
                <button class="menu-btn vehicle-btn" type="submit">Save Access Defaults</button>
            </div>
        </form>

        <form method="post" asp-page-handler="CompleteStep" class="completion-form">
            <button class="menu-btn equipment-btn" type="submit">Complete Access Model Step</button>
        </form>
    </div>
</div>

<style>
.access-model-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.access-model-inner {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 40px 20px 30px;
    text-align: center;
    box-sizing: border-box;
}

.client-line,
.home-label,
.section-label {
    color: #5f6b7a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.home-label {
    margin: 14px 0 10px;
}

.page-title {
    margin: 0 0 8px;
    color: #10233f;
    font-size: 32px;
    font-weight: 900;
}

.page-subtitle {
    max-width: 820px;
    margin: 0 auto 22px;
    color: #5f6b7a;
    font-size: 17px;
    font-weight: 700;
}

.form-panel {
    margin-bottom: 16px;
    padding: 18px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.82);
    text-align: left;
}

.summary-panel,
.section-heading-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
}

.summary-panel h3,
.section-heading-row h3 {
    margin: 0;
    color: #10233f;
    font-size: 20px;
    font-weight: 900;
}

.summary-panel p,
.source-note,
.permission-preview span,
.capability-card small,
.toggle-row small {
    color: #5f6b7a;
    font-size: 13px;
    font-weight: 700;
}

.form-grid {
    display: grid;
    grid-template-columns: minmax(260px, .8fr) minmax(280px, 1.2fr);
    gap: 14px;
    align-items: stretch;
    margin: 14px 0;
}

.field-label {
    display: block;
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 800;
    color: #425466;
}

.text-input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #fff;
    color: #111827;
    font-size: 15px;
    box-sizing: border-box;
}

.toggle-row,
.capability-card,
.permission-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-radius: 8px;
    background: #fff;
}

.toggle-row {
    padding: 12px;
}

.toggle-row input,
.capability-card input,
.permission-item input {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    accent-color: #0f7890;
}

.capability-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
}

.capability-card {
    padding: 12px;
}

.capability-card strong,
.toggle-row strong,
.permission-item strong {
    display: block;
    color: #10233f;
    font-size: 14px;
    font-weight: 900;
}

.permission-group {
    margin-top: 14px;
}

.permission-group h4 {
    margin: 0 0 8px;
    color: #334155;
    font-size: 14px;
    font-weight: 900;
}

.permission-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
}

.permission-item {
    min-height: 58px;
    padding: 10px;
}

.permission-preview {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 14px;
    padding: 12px;
    border-radius: 8px;
    background: rgba(15, 120, 144, 0.08);
}

.permission-preview strong {
    color: #075a6d;
    font-size: 13px;
    font-weight: 900;
    text-transform: uppercase;
}

.button-row,
.completion-form {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
}

.menu-btn {
    min-height: 42px;
    padding: 0 18px;
}

@@media (max-width: 780px) {
    .form-grid,
    .capability-grid,
    .permission-grid {
        grid-template-columns: 1fr;
    }

    .summary-panel,
    .section-heading-row {
        flex-direction: column;
    }
}
</style>
