@page
@model EquipmentRegisterPreviewModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Equipment Register Preview";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
}

<div class="preview-screen">
    <div class="preview-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Generated Equipment Register Preview</div>
        <h2 class="page-title">Review Equipment Records</h2>
        <p class="page-subtitle">Source file: @Model.FileName</p>

        <div class="preview-layout">
            <section class="register-panel">
                <div class="table-wrap">
                    <table class="register-table">
                        <thead>
                            <tr>
                                <th>Asset ID / Internal ID</th>
                                <th>Equipment Type</th>
                                <th>Make / Model</th>
                                <th>Serial Number</th>
                                <th>Location</th>
                                <th>Status</th>
                                <th>Next Service</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><input value="AST-001" /></td>
                                <td><input value="Monitor Defibrillator" /></td>
                                <td><input value="Example Model" /></td>
                                <td><input value="SN-0001" /></td>
                                <td>
                                    <select>
                                        <option value="">Select location</option>
                                        @foreach (var location in Model.LocationOptions)
                                        {
                                            <option value="@location.Value">@location.Text</option>
                                        }
                                    </select>
                                </td>
                                <td><input value="Operational" /></td>
                                <td><input type="date" /></td>
                            </tr>
                            <tr>
                                <td><input value="AST-002" /></td>
                                <td><input value="Ventilator" /></td>
                                <td><input value="Example Model" /></td>
                                <td><input value="SN-0002" /></td>
                                <td>
                                    <select>
                                        <option value="">Select location</option>
                                        @foreach (var location in Model.LocationOptions)
                                        {
                                            <option value="@location.Value">@location.Text</option>
                                        }
                                    </select>
                                </td>
                                <td><input value="Service Due" /></td>
                                <td><input type="date" /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <aside class="mapping-panel">
                <div class="mapping-title">Detected fields</div>
                <div class="mapping-item">Asset ID / Internal ID</div>
                <div class="mapping-item">Equipment Type</div>
                <div class="mapping-item">Make / Model</div>
                <div class="mapping-item">Serial Number</div>
                <div class="mapping-item">Location</div>
                <div class="mapping-item">Status</div>
                <div class="mapping-item">Next Service Date</div>
            </aside>
        </div>

        <div class="action-row">
            <a class="menu-btn vehicle-btn" href="/UploadEquipmentRegister">Upload Different File</a>
            <a class="menu-btn equipment-btn" href="/EquipmentRegister?view=register">Open Equipment Register</a>
        </div>
    </div>
</div>

<style>
.preview-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.preview-inner {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 300px;
    max-width: 72%;
    max-height: 170px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.preview-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 24px;
    align-items: start;
    text-align: left;
}

.register-panel,
.mapping-panel {
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.58);
    padding: 22px;
}

.table-wrap {
    overflow-x: auto;
}

.register-table {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
}

.register-table th {
    padding: 12px 10px;
    border-bottom: 1px solid rgba(66, 84, 102, 0.24);
    font-size: 13px;
    font-weight: 800;
    color: #425466;
    text-align: left;
}

.register-table td {
    padding: 12px 10px;
    border-bottom: 1px solid rgba(66, 84, 102, 0.12);
}

.register-table input {
    width: 100%;
    min-width: 120px;
    padding: 10px 12px;
    border: 1px solid rgba(66, 84, 102, 0.22);
    border-radius: 8px;
    font-size: 14px;
    color: #111827;
    box-sizing: border-box;
}

.mapping-title {
    margin-bottom: 14px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.mapping-item {
    padding: 12px 0;
    border-bottom: 1px solid rgba(66, 84, 102, 0.14);
    font-size: 14px;
    font-weight: 700;
    color: #425466;
}

.action-row {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    flex-wrap: wrap;
}

.action-row .menu-btn {
    min-width: 260px;
    border: none;
}

@@media (max-width: 860px) {
    .preview-layout {
        grid-template-columns: 1fr;
    }
}
</style>
