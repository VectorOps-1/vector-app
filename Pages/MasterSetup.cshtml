@page
@model MasterSetupModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Master Setup";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
}

<div class="setup-screen">
    <div class="setup-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Senior Management</div>
        <h2 class="page-title">Master Setup</h2>
        <p class="page-subtitle">Company onboarding and editable setup records</p>

        <div class="setup-section-title">Source Uploads</div>
        @if (!Model.GuidedImportAvailable)
        {
            <div class="inline-notice">Guided Excel and CSV importing is available on Pro and Premium. Existing imported records remain available after a downgrade.</div>
        }
        <div class="setup-grid">
            <a class="module-card primary @(Model.GuidedImportAvailable ? "" : "locked")" href="@(Model.GuidedImportAvailable ? "/UploadVehicleRegister" : "#")" aria-disabled="@(!Model.GuidedImportAvailable)">
                <strong>Upload Vehicle Register</strong>
                <span>Import registration numbers, callsigns, service dates, locations, and unit schematic mapping</span>
            </a>

            <a class="module-card @(Model.GuidedImportAvailable ? "" : "locked")" href="@(Model.GuidedImportAvailable ? "/UploadEquipmentRegister" : "#")" aria-disabled="@(!Model.GuidedImportAvailable)">
                <strong>Upload Equipment Register</strong>
                <span>Import equipment names, S/N or asset IDs, service dates, and current locations</span>
            </a>

            <a class="module-card @(Model.GuidedImportAvailable ? "" : "locked")" href="@(Model.GuidedImportAvailable ? "/UploadStaffRegister" : "#")" aria-disabled="@(!Model.GuidedImportAvailable)">
                <strong>Upload Staff Register</strong>
                <span>Import staff names, access level, contact detail, and assigned areas</span>
            </a>

            <a class="module-card @(Model.GuidedImportAvailable ? "" : "locked")" href="@(Model.GuidedImportAvailable ? "/UploadStockRegister" : "#")" aria-disabled="@(!Model.GuidedImportAvailable)">
                <strong>Upload Stock Register</strong>
                <span>Import stock item names, quantities, batch numbers, and storage locations</span>
            </a>

            <a class="module-card @(Model.GuidedImportAvailable ? "" : "locked")" href="@(Model.GuidedImportAvailable ? "/UploadMedicationRegister" : "#")" aria-disabled="@(!Model.GuidedImportAvailable)">
                <strong>Upload Medication Register</strong>
                <span>Import medication names, schedules, quantities, batches, expiry dates, and locations</span>
            </a>

            <a class="module-card @(Model.GuidedImportAvailable ? "" : "locked")" href="@(Model.GuidedImportAvailable ? "/ImportHistory" : "#")" aria-disabled="@(!Model.GuidedImportAvailable)">
                <strong>Import History</strong>
                <span>Review completed imports, mapping activity, and safe rollback status</span>
            </a>
        </div>

        <div class="setup-section-title">Setup Management</div>
        <div class="setup-grid">
            <a class="module-card primary" href="/SetupWizard?mode=progress">
                <strong>Setup Wizard / Setup Progress</strong>
                <span>Review completed setup, deferred items, and the next setup actions without duplicating Master Setup records</span>
            </a>

            <a class="module-card primary" href="/CompanyProfile">
                <strong>Company Profile</strong>
                <span>Manage logo, company name, and supplier details</span>
            </a>

            <a class="module-card" href="/ReadinessEngine">
                <strong>Readiness Engine</strong>
                <span>Configure score weightings, hard blockers, manager alerts, and scoring change approvals</span>
            </a>
        </div>
    </div>
</div>

<style>
.setup-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.setup-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.setup-grid {
    gap: 24px;
    row-gap: 24px;
}

.setup-section-title {
    margin: 28px 0 16px 0;
    color: #5f6b7a;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 1.3px;
    text-transform: uppercase;
}

.setup-grid .menu-btn {
    min-width: 260px;
}

.inline-notice {
    margin: 0 0 16px;
    padding: 12px 14px;
    border-left: 4px solid #17768c;
    background: #eef7f9;
    color: #35465e;
    text-align: left;
    font-weight: 700;
}

.module-card.locked {
    pointer-events: none;
    opacity: .58;
    border-style: dashed;
}
</style>
