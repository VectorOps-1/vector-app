@page
@model MasterSetupModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Master Setup";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="setup-screen">
    <div class="setup-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Senior Management</div>
        <h2 class="page-title">Master Setup</h2>
        <p class="page-subtitle">Company onboarding and editable setup records</p>

        <div class="setup-grid">
            <a class="module-card primary" href="/CompanyProfile">
                <strong>Company Profile</strong>
                <span>Manage logo, company name, and supplier details</span>
            </a>

            <a class="module-card" href="/EditChecklist">
                <strong>Checklist Builder</strong>
                <span>Create, edit, and publish checklist templates manually</span>
            </a>

            <a class="module-card" href="/VehicleRegister">
                <strong>Vehicle Register</strong>
                <span>Review vehicle records, registration numbers, and setup details</span>
            </a>

            <a class="module-card" href="/VehicleSchematicLibrary">
                <strong>Vehicle Schematic Library</strong>
                <span>Store schematic types for ambulances, response, and rescue vehicles</span>
            </a>

            <a class="module-card" href="/OperationalAreas">
                <strong>Operational Areas / Bases</strong>
                <span>Create the bases, stores, stations, and operating areas used for allocation</span>
            </a>

            <a class="module-card" href="/EquipmentRegister">
                <strong>Equipment Register</strong>
                <span>Review equipment inventory and linked readiness records</span>
            </a>

            <a class="module-card" href="/StockRegister">
                <strong>Stock Register</strong>
                <span>Review stock records, quantities, locations, and batch details</span>
            </a>

            <a class="module-card" href="/MedicationRegister">
                <strong>Medication Register</strong>
                <span>Review medication records, schedules, quantities, batch numbers, locations, and expiry dates</span>
            </a>

            <a class="module-card" href="/UploadStaffFiles">
                <strong>Upload Staff Files</strong>
                <span>Add staff documents, certificates, and support records</span>
            </a>

            <a class="module-card" href="/StaffRecordsSearch">
                <strong>Search Staff Records</strong>
                <span>Find staff files and related record areas</span>
            </a>

            <a class="module-card" href="/CreateManagerAccess">
                <strong>Create Manager Access</strong>
                <span>Issue senior or operational management access</span>
            </a>

            <a class="module-card" href="/CreateOperationalStaffAccess">
                <strong>Create Staff Access</strong>
                <span>Issue operational staff login access</span>
            </a>

            <a class="module-card" href="/TaskCommunicationSetup">
                <strong>Task Communication Setup</strong>
                <span>Configure how task communications are handled</span>
            </a>

            <a class="module-card" href="/AuditLog">
                <strong>Audit Log / Activity History</strong>
                <span>Review recorded activity and accountability history</span>
            </a>
        </div>
    </div>
</div>

<style>
.setup-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.setup-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.setup-grid {
    gap: 24px;
    row-gap: 24px;
}

.setup-grid .menu-btn {
    min-width: 260px;
}
</style>
