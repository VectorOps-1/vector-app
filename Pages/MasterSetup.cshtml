@page
@model MasterSetupModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Master Setup";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="setup-screen">
    <div class="setup-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Senior Management</div>
        <h2 class="page-title">Master Setup</h2>
        <p class="page-subtitle">Company onboarding and editable setup records</p>

        <div class="menu-row setup-grid">
            <a class="menu-btn equipment-btn" href="/CompanyProfile">Company Profile</a>
            <a class="menu-btn vehicle-btn" href="/UploadChecklist">Upload Existing Checklists</a>
            <a class="menu-btn equipment-btn" href="/UploadEquipmentRegister">Upload Equipment Register</a>
            <a class="menu-btn vehicle-btn" href="/UploadVehicleRegister">Upload Vehicle Register</a>
            <a class="menu-btn stock-btn" href="#">Upload Stock Register</a>
            <a class="menu-btn staff-btn" href="#">Upload Staff Files</a>
            <a class="menu-btn staff-btn" href="#">Create Manager Access</a>
            <a class="menu-btn equipment-btn" href="#">Create Operational Staff Access</a>
        </div>
    </div>
</div>

<style>
.setup-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.setup-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.setup-grid {
    gap: 24px;
    row-gap: 24px;
}

.setup-grid .menu-btn {
    min-width: 260px;
}
</style>
