@page
@model ReadinessDashboardModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Readiness Dashboard";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
}

<div class="readiness-screen">
    <div class="readiness-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Shift Readiness</div>
        <h2 class="page-title">Readiness Dashboard</h2>
        <p class="page-subtitle">Latest readiness evidence for vehicles, equipment checks, and open issue reports.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        @if (Model.HasAreaScope)
        {
            <form class="scope-toolbar" method="get">
                <select class="filter-input" asp-for="OperationalAreaId" asp-items="Model.AreaOptions"></select>
                <button class="menu-btn equipment-btn toolbar-btn" type="submit">View Dashboard</button>
                @if (Model.IsSeniorOverview)
                {
                    <a class="menu-btn staff-btn toolbar-btn" href="/CreateManagerAccess">Access Setup</a>
                }
            </form>

            <section class="summary-panel">
                @if (Model.Summary.TotalVehicles == 0)
                {
                    <div class="empty-readiness-state">
                        <strong>No vehicles are available for readiness scoring.</strong>
                        <span>Add real vehicles, assign them to operational areas, publish checklists, and submit daily checks before readiness can calculate operational activity.</span>
                        @if (Model.IsSeniorOverview)
                        {
                            <a class="empty-readiness-action" href="/AddItem?type=vehicle">Add Vehicle</a>
                        }
                    </div>
                }
                else
                {
                    <div class="score-ring @Model.Summary.ScoreClass" style="background: conic-gradient(var(--score-color) @(Model.Summary.ScorePercent)%, #e5e7eb 0);">
                        <div class="score-core">
                            <strong>@Model.Summary.ScorePercent%</strong>
                            <span>@Model.ScopeLabel</span>
                        </div>
                    </div>

                    <div class="summary-grid">
                        <a class="summary-tile" asp-page="/ReadinessMetric" asp-route-metric="ready-vehicles" asp-route-operationalAreaId="@Model.OperationalAreaId">
                            <strong>@Model.Summary.ReadyVehicles / @Model.Summary.TotalVehicles</strong>
                            <span>Ready vehicles</span>
                        </a>
                        <div class="summary-tile passive-tile" aria-label="Vehicles with saved or submitted daily readiness evidence">
                            <strong>@Model.Summary.CheckedVehicles</strong>
                            <span>Daily checks complete</span>
                        </div>
                        <div class="summary-tile warning-tile passive-tile" aria-label="Vehicles without saved or submitted daily readiness evidence">
                            <strong>@Model.Summary.MissingChecks</strong>
                            <span>Missing checks</span>
                        </div>
                        <div class="summary-tile danger-tile passive-tile" aria-label="Vehicles currently not ready">
                            <strong>@Model.Summary.UnavailableVehicles</strong>
                            <span>Not ready</span>
                        </div>
                        <a class="summary-tile warning-tile" asp-page="/ReadinessMetric" asp-route-metric="equipment-alerts" asp-route-operationalAreaId="@Model.OperationalAreaId">
                            <strong>@Model.Summary.EquipmentWarnings</strong>
                            <span>Equipment alerts</span>
                        </a>
                        <a class="summary-tile danger-tile" asp-page="/ReadinessMetric" asp-route-metric="open-issues" asp-route-operationalAreaId="@Model.OperationalAreaId">
                            <strong>@Model.Summary.OpenIssues</strong>
                            <span>Open issues</span>
                        </a>
                    </div>
                }
            </section>

        }
    </div>
</div>

<style>
.readiness-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.readiness-inner { width: 100%; max-width: 1220px; margin: 0 auto; text-align: center; padding: 40px 20px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 30px; font-weight: 900; color: #1f2937; }
.page-subtitle { width: min(860px, 94%); margin: 0 auto 22px auto; font-size: 16px; font-weight: 600; color: #6b7280; }
.status-message { width: min(820px, 94%); margin: 0 auto 20px auto; padding: 12px 16px; border: 1px solid rgba(66,84,102,.22); border-radius: 8px; background: rgba(14,94,122,.08); color: #0E5E7A; font-weight: 800; }
.scope-toolbar { width: min(760px, 100%); margin: 0 auto 20px auto; display: grid; grid-template-columns: minmax(240px, 1fr) 160px 160px; gap: 12px; }
.filter-input { width: 100%; min-height: 46px; border: 1px solid rgba(66,84,102,.24); border-radius: 8px; padding: 0 14px; background: #fff; color: #1f2937; font-size: 15px; font-weight: 700; box-sizing: border-box; }
.toolbar-btn { min-width: 0; border: none; }
.summary-panel { display: flex; flex-direction: column; gap: 22px; align-items: center; width: min(1120px, 100%); margin: 0 auto 18px auto; padding: 22px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: rgba(255,255,255,.72); box-sizing: border-box; }
.empty-readiness-state { display: grid; gap: 10px; justify-items: center; width: min(720px, 100%); padding: 22px; border: 1px dashed rgba(66,84,102,.24); border-radius: 8px; background: rgba(248,250,252,.8); box-sizing: border-box; color: #52606d; font-weight: 800; }
.empty-readiness-state strong { color: #102a3a; font-size: 18px; }
.empty-readiness-state span { max-width: 620px; line-height: 1.45; }
.empty-readiness-action { display: inline-flex; min-height: 38px; align-items: center; justify-content: center; padding: 0 16px; border-radius: 8px; background: #126C84; color: #fff; text-decoration: none; font-size: 13px; font-weight: 900; }
.score-ring { --score-color: #9B3B3B; width: 220px; aspect-ratio: 1; margin: 0 auto; border-radius: 50%; display: grid; place-items: center; }
.score-green { --score-color: #207A63; }
.score-teal { --score-color: #126C84; }
.score-amber { --score-color: #B7791F; }
.score-red { --score-color: #9B3B3B; }
.score-core { width: 152px; aspect-ratio: 1; border-radius: 50%; background: #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; box-shadow: inset 0 0 0 1px rgba(66,84,102,.14); }
.score-core strong { color: #102a3a; font-size: 40px; font-weight: 900; line-height: 1; }
.score-core span { width: 120px; margin-top: 8px; color: #52606d; font-size: 12px; font-weight: 900; line-height: 1.2; }
.summary-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 12px; width: 100%; }
.summary-tile { display: block; min-height: 82px; padding: 12px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: #fff; box-sizing: border-box; text-align: center; text-decoration: none; transition: border-color .16s ease, transform .16s ease, box-shadow .16s ease; }
.summary-tile:hover { border-color: rgba(14,94,122,.36); box-shadow: 0 10px 24px rgba(15,35,55,.08); transform: translateY(-1px); }
.summary-tile.passive-tile { cursor: default; }
.summary-tile.passive-tile:hover { border-color: rgba(66,84,102,.16); box-shadow: none; transform: none; }
.summary-tile strong { display: block; color: #102a3a; font-size: 24px; font-weight: 900; }
.summary-tile span { display: block; margin-top: 4px; color: #52606d; font-size: 12px; font-weight: 800; }
.warning-tile strong { color: #8A5A13; }
.danger-tile strong { color: #8A2C2C; }
@@media (max-width: 1050px) { .summary-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
@@media (max-width: 700px) { .scope-toolbar, .summary-grid { grid-template-columns: 1fr; } }
</style>
