@page
@model AppGuideModel
@{
    ViewData["Title"] = "Button And Term Guide";
    var canViewManagementGuide = Model.CanViewManagementGuide;
    var isSeniorManagement = Model.IsSeniorManagement;
}

<div class="guide-screen">
    <div class="guide-inner">
        <img class="page-logo" src="@Model.CompanyLogoPath" alt="@Model.ClientName logo" />
        <div class="client-line">Client: @Model.ClientName</div>
        <div class="home-label">App Reference</div>
        <h1 class="page-title">Button And Term Guide</h1>
        <p class="page-subtitle">@Model.GuideScope. Search only the buttons, terms, and functions available to this access level.</p>

        <div class="guide-search-panel">
            <label class="search-label" for="guideSearch">Search terms and functions</label>
            <input id="guideSearch" class="guide-search" type="search" placeholder="Search: readiness, move, checklist, S/N, task, issue..." autocomplete="off" />
            <div id="guideResultCount" class="guide-result-count" aria-live="polite"></div>
        </div>

        <div class="guide-groups" id="guideGroups">
            <section class="guide-group">
                <h2>Home And Daily Work</h2>
                <div class="term-grid">
                    <article class="term-card" data-search="home dashboard operations dashboard home screen main options role profile">
                        <h3>Home Dashboard</h3>
                        <p>The main page after login. It shows the actions available to the signed-in person for their access level.</p>
                    </article>
                    <article class="term-card" data-search="daily vehicle equipment check daily check readiness checklist vehicle equipment">
                        <h3>Daily Vehicle & Equipment Check</h3>
                        <p>The live crew checklist for getting a vehicle and its carried equipment ready for the shift.</p>
                    </article>
                    <article class="term-card" data-search="my tasks task inbox assigned task action instruction feedback">
                        <h3>My Tasks</h3>
                        <p>Tasks assigned to the signed-in user. Tasks must be actioned, completed, or fed back through the normal task loop.</p>
                    </article>
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="my assigned issues issue inbox assigned issue resolved action taken">
                            <h3>My Assigned Issues</h3>
                            <p>Issues sent to a manager or user for action. The receiver records what was done and marks the issue resolved when appropriate.</p>
                        </article>
                    }
                    <article class="term-card" data-search="my profile my documents personal documents staff files certificates accreditation medical fitness id passport edit own details">
                        <h3>My Profile</h3>
                        <p>The signed-in user's own profile. It shows personal details and linked documents, with actions to edit details or upload documents.</p>
                    </article>
                    <article class="term-card" data-search="report issue fault problem incident vehicle equipment stock medication staff general">
                        <h3>Report Issue</h3>
                        <p>Creates an operational issue report and sends it to the selected manager or management queue for follow-up.</p>
                    </article>
                </div>
            </section>

            <section class="guide-group">
                <h2>Readiness And Checklists</h2>
                <div class="term-grid">
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="shift readiness dashboard wheel score percentage ready not ready metrics">
                            <h3>Shift Readiness Dashboard</h3>
                            <p>Shows the live readiness picture for the shift. Senior managers see the full operation; operations managers see their assigned areas.</p>
                        </article>
                        <article class="term-card" data-search="checklist reports pdf evidence completed check submitted by time downloadable">
                            <h3>Checklist Reports</h3>
                            <p>Completed checklist evidence, including who submitted it, when it was submitted, and the captured checklist data.</p>
                        </article>
                    }
                    @if (isSeniorManagement)
                    {
                        <article class="term-card" data-search="readiness engine scoring rules severity hard blocker minor major weight score reduction">
                            <h3>Readiness Engine</h3>
                            <p>The scoring rules behind the readiness percentage. Senior management controls what lowers readiness and by how much.</p>
                        </article>
                        <article class="term-card" data-search="checklist management build new checklist checklist register publish saved templates">
                            <h3>Checklist Management</h3>
                            <p>The central place to build new checklists, open the checklist register, manage saved templates, publish active versions, and review checklist reports.</p>
                        </article>
                        <article class="term-card" data-search="checklist register saved checklists templates vehicle type function daily full audit publish edit delete">
                            <h3>Checklist Register</h3>
                            <p>The list of saved checklist templates. Open a checklist to view what crews see, or use Edit when management needs to change the template.</p>
                        </article>
                        <article class="term-card" data-search="publish active checklist template vehicle type function area all areas">
                            <h3>Publish</h3>
                            <p>Makes a saved checklist active for real use. Published checklists are what crews complete during checks.</p>
                        </article>
                    }
                    <article class="term-card" data-search="same as previous shift copy previous check vehicle equipment senior approval">
                        <h3>Same As Previous Shift</h3>
                        <p>Copies approved previous-shift values when nothing changed. Senior management controls whether this is allowed for vehicle checks and equipment checks.</p>
                    </article>
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="variance alert changed serial number register mismatch equipment changed previous shift">
                            <h3>Variance Alert</h3>
                            <p>A warning that something in a completed checklist does not match the previous check or expected register data.</p>
                        </article>
                    }
                </div>
            </section>

            <section class="guide-group">
                <h2>Vehicles And Equipment</h2>
                <div class="term-grid">
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="home vehicles open vehicles vehicle module add vehicle reassign callsign issue">
                            <h3>Open Vehicles</h3>
                            <p>Opens vehicle-specific actions not already shown on Home, such as adding a vehicle, reassigning a callsign, or reporting a vehicle issue.</p>
                        </article>
                        <article class="term-card" data-search="home vehicles vehicle register search all vehicles source truth reg number callsign type area service readiness">
                            <h3>Vehicle Register</h3>
                            <p>The source of truth for vehicle registration numbers, callsigns, vehicle type, assigned area, service dates, and current status. Use the search field inside the register to narrow the list.</p>
                        </article>
                        <article class="term-card" data-search="home vehicles add vehicle new vehicle reg number vin chassis license disc unit schematic">
                            <h3>Add Vehicle</h3>
                            <p>Adds a new vehicle record with registration, callsign, vehicle type, assigned area, service details, VIN, chassis, licence, and unit schematic data.</p>
                        </article>
                        <article class="term-card" data-search="home vehicles reassign callsign move callsign different registration vehicle">
                            <h3>Reassign Callsign</h3>
                            <p>Moves an operational callsign to a different existing registration number when the callsign changes vehicles.</p>
                        </article>
                        <article class="term-card" data-search="home vehicles move reallocate vehicle movement base area location allocation task">
                            <h3>Move / Reallocate Vehicle</h3>
                            <p>Records that a vehicle moved to another base or operational area. It can be saved immediately or sent as a task.</p>
                        </article>
                    }
                    <article class="term-card" data-search="reg number registration number vehicle identifier">
                        <h3>Reg Number</h3>
                        <p>The vehicle registration number. Selecting it should pull the correct vehicle details into checks and registers.</p>
                    </article>
                    <article class="term-card" data-search="callsign unit call sign reassignment vehicle crew operational code">
                        <h3>Callsign</h3>
                        <p>The operational unit name used on shift. It can be reassigned to a different registered vehicle when operations require it.</p>
                    </article>
                    <article class="term-card" data-search="unit schematic schematic library ambulance response vehicle icu ambulance damage drawing">
                        <h3>Unit Schematic</h3>
                        <p>The saved vehicle schematic linked to a vehicle type or registration. It supports consistent damage and inspection capture.</p>
                    </article>
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="home equipment open equipment equipment module equipment buttons">
                            <h3>Open Equipment</h3>
                            <p>Opens equipment-specific actions not already shown on Home, such as adding equipment, updating service dates, or reporting an equipment issue.</p>
                        </article>
                        <article class="term-card" data-search="home equipment register search equipment all equipment source of truth serial sn service battery location status">
                            <h3>Equipment Register</h3>
                            <p>Opens the full equipment register. This is the source of truth for S/N or asset ID, model, service dates, battery requirements, location, and status. Use the search field inside the register to narrow the list.</p>
                        </article>
                        <article class="term-card" data-search="home equipment move reallocate equipment movement asset location area base store task">
                            <h3>Move / Reallocate Equipment</h3>
                            <p>Records that equipment has moved to another base, vehicle, store, or operational area. It can be saved immediately or sent as a task.</p>
                        </article>
                    }
                    <article class="term-card" data-search="s/n id serial asset id equipment identifier">
                        <h3>S/N / ID</h3>
                        <p>The serial number or asset ID for a specific equipment item. Companies may use either, so the field supports both.</p>
                    </article>
                    <article class="term-card" data-search="next service service date maintenance due equipment vehicle">
                        <h3>Next Service</h3>
                        <p>The next date an asset is due for maintenance or service. Updating this in the register updates the source data used elsewhere.</p>
                    </article>
                    <article class="term-card" data-search="operational yes no equipment check working fault less than operational">
                        <h3>Operational?</h3>
                        <p>A yes/no field showing whether the item is usable for service. If no, the user should describe the issue captured during the check.</p>
                    </article>
                </div>
            </section>

            <section class="guide-group">
                <h2>@(canViewManagementGuide ? "Stock, Medication, Staff, And Tasks" : "Task Terms")</h2>
                <div class="term-grid">
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="home stock open stock stock module orders distribution unified flow add stock issue">
                            <h3>Open Stock</h3>
                            <p>Opens stock-specific actions not already shown on Home. Orders, supplier confirmation, register entry, and allocation are handled inside Stock Orders &amp; Distribution.</p>
                        </article>
                        <article class="term-card" data-search="stock register search disposable stock batch expiry quantity location movement allocation">
                            <h3>Stock Register</h3>
                            <p>The searchable record of disposable stock, quantities, batch numbers, locations, and movement or allocation history. Use the search field inside the register to narrow the list.</p>
                        </article>
                        <article class="term-card" data-search="home stock move reallocate stock movement asset location base store vehicle kit task">
                            <h3>Move / Reallocate Stock</h3>
                            <p>Records stock movement between bases, stores, vehicles, kits, or operational areas. It can be saved immediately or sent as a task.</p>
                        </article>
                        <article class="term-card" data-search="add stock add new stock item manual register disposable item batch quantity">
                            <h3>Add New Stock Item</h3>
                            <p>Adds one stock item manually into the stock register when it is not coming through the order and supplier confirmation flow.</p>
                        </article>
                        <article class="term-card" data-search="home medication open medication medication module add medication task issue">
                            <h3>Open Medication</h3>
                            <p>Opens medication-specific actions not already shown on Home, such as adding medication, assigning a medication task, or reporting a medication issue.</p>
                        </article>
                        <article class="term-card" data-search="medication register search schedule quantity batch expiry location allocation">
                            <h3>Medication Register</h3>
                            <p>The controlled record for medication name, schedule, quantity, batch number, expiry date, location, and last allocation. Use the search field inside the register to narrow the list.</p>
                        </article>
                        <article class="term-card" data-search="home medication move reallocate medication movement location base store vehicle kit task">
                            <h3>Move / Reallocate Medication</h3>
                            <p>Records medication movement between bases, stores, vehicles, kits, or operational areas. It can be saved immediately or sent as a task.</p>
                        </article>
                        <article class="term-card" data-search="add medication add new medication item manual register schedule quantity batch expiry">
                            <h3>Add Medication</h3>
                            <p>Adds one medication item manually into the medication register, including schedule, quantity, batch, expiry, and location details.</p>
                        </article>
                        <article class="term-card" data-search="batch number batch stock medication expiry supplier received">
                            <h3>Batch Number</h3>
                            <p>The manufacturer or supplier batch reference for stock or medication. It supports expiry tracking and traceability.</p>
                        </article>
                        <article class="term-card" data-search="expiry date expiration stock medication disposable register">
                            <h3>Expiry Date</h3>
                            <p>The date after which stock or medication should no longer be used operationally.</p>
                        </article>
                        <article class="term-card" data-search="staff register staff profile staff files folders assigned area national id email cell number">
                            <h3>Staff Register</h3>
                            <p>The management view of staff profiles, assigned areas, contact details, staff IDs, and linked staff files.</p>
                        </article>
                        <article class="term-card" data-search="send task task communication assigned person action due feedback">
                            <h3>Send Task</h3>
                            <p>Sends a specific instruction to another user. The receiver gets it in My Tasks and completes the feedback loop.</p>
                        </article>
                    }
                    <article class="term-card" data-search="task feedback complete task action taken notes completed">
                        <h3>Task Feedback</h3>
                        <p>The response recorded after a task has been done. It closes the loop and creates an audit trail.</p>
                    </article>
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="stock orders distribution place order supplier confirmation register entry allocate stock supplier email quantity delivery batch expiry">
                            <h3>Stock Orders &amp; Distribution</h3>
                            <p>The stock order workflow from supplier request through confirmation, register entry, and allocation. Individual orders are opened from this page to continue the flow.</p>
                        </article>
                    }
                </div>
            </section>

            <section class="guide-group">
                <h2>Setup, Access, And System Terms</h2>
                <div class="term-grid">
                    @if (isSeniorManagement)
                    {
                        <article class="term-card" data-search="master setup senior management onboarding company setup registers areas bases">
                            <h3>Master Setup</h3>
                            <p>Senior management setup area for company-level configuration such as registers, operational areas, checklist setup, access, and system defaults.</p>
                        </article>
                        <article class="term-card" data-search="manager areas operational manager assigned region base dashboard filter">
                            <h3>Manager Areas</h3>
                            <p>Links operational managers to the areas they oversee, so dashboards and reports can be filtered correctly.</p>
                        </article>
                        <article class="term-card" data-search="access setup create manager access staff access permissions login user role">
                            <h3>Access Setup</h3>
                            <p>Creates user access for managers and staff. Access level controls what a person can view or change.</p>
                        </article>
                        <article class="term-card" data-search="senior management company owner master setup publish approve all areas">
                            <h3>Senior Management</h3>
                            <p>The highest operational access level. Senior managers can see all areas and control setup, publishing, approvals, and system rules.</p>
                        </article>
                        <article class="term-card" data-search="audit log history accountability who changed what when movement task issue checklist">
                            <h3>Audit Log</h3>
                            <p>The accountability history showing important actions, who performed them, when they happened, and what record was affected.</p>
                        </article>
                    }
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="operational areas bases regions locations stores vehicles storage dropdown">
                            <h3>Operational Areas / Bases</h3>
                            <p>Locations created during setup. They are used in dropdowns for vehicles, equipment, stock, medication, managers, and movements.</p>
                        </article>
                        <article class="term-card" data-search="operational management ops manager assigned area dashboard tasks issues">
                            <h3>Operational Management</h3>
                            <p>Manager access for assigned areas. Operations managers can manage daily operations, tasks, issues, and area-level readiness.</p>
                        </article>
                    }
                    <article class="term-card" data-search="staff access crew daily checks tasks documents report issue">
                        <h3>Staff</h3>
                        <p>Crew access. Staff complete checks, view assigned tasks, manage their own documents, and report issues.</p>
                    </article>
                    <article class="term-card" data-search="confirmation flag saved deleted submitted published moved temporary message">
                        <h3>Confirmation Flag</h3>
                        <p>A temporary in-app message confirming that an action such as save, delete, publish, submit, or move actually worked.</p>
                    </article>
                    @if (canViewManagementGuide)
                    {
                        <article class="term-card" data-search="delete trash remove record task issue checklist confirm">
                            <h3>Delete / Trash</h3>
                            <p>Removes or marks a record as deleted, depending on the record type. Management actions should be confirmed and logged.</p>
                        </article>
                    }
                </div>
            </section>
        </div>
    </div>
</div>

<style>
.guide-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.guide-inner { width: 100%; max-width: 1180px; margin: 0 auto; padding: 40px 20px 44px 20px; box-sizing: border-box; text-align: center; }
.page-logo { width: 280px; max-width: 70%; max-height: 150px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 12px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 32px; font-weight: 900; color: #1f2937; }
.page-subtitle { margin: 0 auto 22px auto; max-width: 720px; color: #52606d; font-size: 16px; font-weight: 700; }
.guide-search-panel { width: min(880px, 100%); margin: 0 auto 24px auto; padding: 16px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: #fff; box-shadow: 0 12px 24px rgba(15,23,42,.06); text-align: left; box-sizing: border-box; }
.search-label { display: block; margin-bottom: 8px; color: #425466; font-size: 12px; font-weight: 900; letter-spacing: .9px; text-transform: uppercase; }
.guide-search { width: 100%; min-height: 48px; padding: 0 14px; border: 1px solid rgba(66,84,102,.22); border-radius: 8px; background: #f8fafc; color: #111827; font-size: 16px; font-weight: 700; box-sizing: border-box; }
.guide-result-count { min-height: 20px; margin-top: 10px; color: #64748b; font-size: 13px; font-weight: 800; }
.guide-groups { display: grid; gap: 18px; text-align: left; }
.guide-group { padding: 18px; border: 1px solid rgba(66,84,102,.16); border-top: 6px solid #126C84; border-radius: 8px; background: rgba(255,255,255,.76); box-shadow: 0 14px 26px rgba(15,23,42,.07); }
.guide-group h2 { margin: 0 0 14px 0; color: #102a3a; font-size: 22px; font-weight: 900; }
.term-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
.term-card { min-height: 108px; padding: 14px; border: 1px solid rgba(66,84,102,.14); border-radius: 8px; background: #fff; box-sizing: border-box; }
.term-card h3 { margin: 0 0 8px 0; color: #102a3a; font-size: 17px; font-weight: 900; }
.term-card p { margin: 0; color: #425466; font-size: 14px; font-weight: 700; line-height: 1.45; }
.term-card.is-hidden { display: none; }
.guide-group.is-hidden { display: none; }
.no-results { width: min(760px, 100%); margin: 0 auto; padding: 18px; border: 1px solid rgba(155,59,59,.18); border-radius: 8px; background: rgba(155,59,59,.07); color: #7f2f2f; font-weight: 900; text-align: center; box-sizing: border-box; }
@@media (max-width: 820px) {
    .term-grid { grid-template-columns: 1fr; }
    .guide-inner { padding-left: 14px; padding-right: 14px; }
    .page-title { font-size: 28px; }
}
</style>

<script>
    (function () {
        const input = document.getElementById("guideSearch");
        const groups = Array.from(document.querySelectorAll(".guide-group"));
        const cards = Array.from(document.querySelectorAll(".term-card"));
        const count = document.getElementById("guideResultCount");
        const container = document.getElementById("guideGroups");
        const empty = document.createElement("div");
        empty.className = "no-results";
        empty.hidden = true;
        empty.textContent = "No matching terms found.";
        container.appendChild(empty);

        function normalise(value) {
            return String(value || "").trim().toLowerCase();
        }

        function cardText(card) {
            return normalise(card.innerText + " " + card.dataset.search);
        }

        function applySearch() {
            const query = normalise(input.value);
            let visibleCards = 0;

            cards.forEach(function (card) {
                const isVisible = !query || cardText(card).includes(query);
                card.classList.toggle("is-hidden", !isVisible);
                if (isVisible) {
                    visibleCards += 1;
                }
            });

            groups.forEach(function (group) {
                const hasVisibleCards = Boolean(group.querySelector(".term-card:not(.is-hidden)"));
                group.classList.toggle("is-hidden", !hasVisibleCards);
            });

            empty.hidden = visibleCards > 0;
            count.textContent = query
                ? `${visibleCards} matching term${visibleCards === 1 ? "" : "s"}`
                : `${visibleCards} terms available`;
        }

        input.addEventListener("input", applySearch);
        applySearch();
    })();
</script>
