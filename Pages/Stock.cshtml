@page
@model StockModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Stock";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
}

<div class="module-screen">
    <div class="module-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Operations Module</div>
        <h2 class="page-title">Stock</h2>
        <p class="page-subtitle">Choose the exact stock action from one place.</p>

        <div class="module-grid">
            <a class="module-card primary" href="/StockRegister?view=register">
                <strong>Stock Register</strong>
                <span>Open the full stock register by item, quantity, batch, location, and movement. Use the search field inside the register when needed.</span>
            </a>

            <a class="module-card primary" href="/StockOrders">
                <strong>Stock Orders &amp; Distribution</strong>
                <span>Place orders, track supplier confirmations, enter received stock, and allocate stock from one workflow</span>
            </a>

            <a class="module-card" href="/MoveAsset?asset=stock" data-move-asset="stock">
                <strong>Move / Reallocate</strong>
                <span>Move stock between stores, bases, vehicles, or operational areas</span>
            </a>

            <a class="module-card" href="/AddItem?type=stock">
                <strong>Add New Stock Item</strong>
                <span>Add one stock item manually into the register</span>
            </a>

            <a class="module-card danger" href="/ReportIssue?module=stock">
                <strong>Report Issue</strong>
                <span>Report shortages, damaged stock, expired items, or control problems</span>
            </a>
        </div>
    </div>
</div>

<style>
.module-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.module-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.module-grid {
    gap: 24px;
    row-gap: 24px;
}

.module-grid .menu-btn {
    min-width: 260px;
}
</style>
