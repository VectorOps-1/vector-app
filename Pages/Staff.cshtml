@page
@model StaffModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Staff";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
    var currentAccessView = HttpContext.Session.GetString(CurrentUserService.AccessViewSessionKey);
    var isSeniorManagement = currentAccessView == CurrentUserService.SeniorManagementAccess;
}

<div class="module-screen">
    <div class="module-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Operations Module</div>
        <h2 class="page-title">Staff</h2>
        <p class="page-subtitle">Staff register, files, folders, records, access, and management actions</p>

        <div class="module-grid">
            <a class="module-card primary" href="/StaffRegister">
                <strong>Staff Register</strong>
                <span>All staff, roles, status, and record access</span>
            </a>

            <a class="module-card" href="/StaffFiles">
                <strong>Files & Folders</strong>
                <span>Open staff document folders across the service</span>
            </a>

            <a class="module-card" href="/StaffRecordsSearch">
                <strong>Search Staff Records</strong>
                <span>Find a staff member and view linked record areas</span>
            </a>

            <a class="module-card" href="/UploadStaffFiles">
                <strong>Upload Staff Files</strong>
                <span>Add documents, certificates, CVs, and supporting files</span>
            </a>

            <a class="module-card" href="/AddItem?type=staff">
                <strong>Add Staff Profile</strong>
                <span>Create a manual staff profile record</span>
            </a>

            @if (isSeniorManagement)
            {
                <a class="module-card" href="/CreateOperationalStaffAccess">
                    <strong>Create Staff Access</strong>
                    <span>Issue operational staff access</span>
                </a>

                <a class="module-card" href="/CreateManagerAccess">
                    <strong>Create Manager Access</strong>
                    <span>Issue management access</span>
                </a>
            }
        </div>
    </div>
</div>

<style>
.module-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.module-inner {
    width: 100%;
    max-width: 1040px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.module-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    text-align: left;
}

.module-card {
    min-height: 116px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    padding: 18px;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
    color: #425466;
    text-decoration: none;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
}

.module-card:hover {
    color: #1f2937;
    border-color: rgba(47, 128, 168, 0.44);
}

.module-card strong {
    color: #1f2937;
    font-size: 18px;
    font-weight: 900;
}

.module-card span {
    color: #6b7280;
    font-size: 14px;
    font-weight: 700;
}

.module-card.primary {
    border-top: 6px solid #126C84;
}

@@media (max-width: 760px) {
    .module-grid {
        grid-template-columns: 1fr;
    }
}
</style>
