@page
@model VehiclesModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Vehicles";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="module-screen">
    <div class="module-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Operations Module</div>
        <h2 class="page-title">Vehicles</h2>
        <p class="page-subtitle">Vehicle register, readiness, movement, maintenance, and issue workflows</p>

        <div class="module-grid">
            <a class="module-card primary" href="/VehicleRegister">
                <strong>Search Vehicles</strong>
                <span>Find a vehicle by registration, callsign, status, or location</span>
            </a>

            <a class="module-card" href="/VehicleRegister">
                <strong>Vehicle Register</strong>
                <span>Open all vehicles with service, readiness, movement, and allocation details</span>
            </a>

            <a class="module-card" href="/DailyVehicleChecklist">
                <strong>Daily Vehicle Readiness</strong>
                <span>Start the vehicle and vehicle-carried equipment readiness report</span>
            </a>

            <a class="module-card" href="/AddItem?type=vehicle">
                <strong>Add New Vehicle</strong>
                <span>Add a vehicle record for registration and callsign setup</span>
            </a>

            <a class="module-card" href="/MoveAsset?asset=vehicle" data-move-asset="vehicle">
                <strong>Move / Reallocate</strong>
                <span>Update vehicle assignment, base, or operational allocation</span>
            </a>

            <a class="module-card danger" href="/ReportIssue?module=vehicle">
                <strong>Report Issue</strong>
                <span>Report damage, faults, missing equipment, or operational concerns</span>
            </a>
        </div>
    </div>
</div>
