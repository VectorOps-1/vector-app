@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="page-shell narrow-shell">
    <div class="section-label">Account Security</div>
    <h1 class="page-title">Set Your Password</h1>
    <p class="page-subtitle">Your temporary password must be replaced before you can use the app.</p>

    <form method="post" class="form-panel login-form">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label class="field-label" asp-for="CurrentPassword">Current temporary password</label>
        <input class="text-input" asp-for="CurrentPassword" type="password" autocomplete="current-password" />
        <span class="field-validation" asp-validation-for="CurrentPassword"></span>

        <label class="field-label" asp-for="NewPassword">New password</label>
        <input class="text-input" asp-for="NewPassword" type="password" autocomplete="new-password" />
        <span class="field-validation" asp-validation-for="NewPassword"></span>

        <label class="field-label" asp-for="ConfirmNewPassword">Confirm new password</label>
        <input class="text-input" asp-for="ConfirmNewPassword" type="password" autocomplete="new-password" />
        <span class="field-validation" asp-validation-for="ConfirmNewPassword"></span>

        <p class="source-note">Use at least 12 characters with uppercase, lowercase, a number, and a symbol.</p>
        <button class="menu-btn equipment-btn" type="submit">Save Password</button>
    </form>
</div>

<style>
.narrow-shell { max-width: 720px; margin: 0 auto; padding: 36px 18px; }
.login-form { display: grid; gap: 10px; text-align: left; }
.login-form .menu-btn { margin-top: 12px; border: 0; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
