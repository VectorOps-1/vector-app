        function readEquipmentColumns(section) {
            return Array.from((section || document).querySelectorAll("[data-equipment-column]")).map(function (column, index) {
                const label = column.querySelector('[data-name="Label"]')?.value || `Column ${index + 1}`;
                const source = resolveColumnSource(column);
                return {
                    key: normalizeColumnKey(label),
                    label,
                    type: column.querySelector('[data-name="Type"]')?.value || "Text",
                    source
                };
            });
        }

        function isRegisterSource(value) {
            return ["Vehicle register", "Equipment register", "Stock register", "Medication register"]
                .includes(value || "");
        }

        function resolveColumnSource(column) {
            const sourceSelect = column.querySelector('[data-name="Source"]');
            const customSource = column.querySelector("[data-custom-source]");
            const sourceValue = sourceSelect?.value || "Fresh entry";
            if (sourceValue === "Custom") {
                return customSource?.value?.trim() || "Custom";
            }

            return sourceValue || "Fresh entry";
        }

        function syncColumnSource(column) {
            if (!column) {
                return;
            }

            const sourceSelect = column.querySelector('[data-name="Source"]');
            const customSource = column.querySelector("[data-custom-source]");
            const resolvedSource = column.querySelector('[data-name="ResolvedSource"]');
            const registerLink = column.querySelector('[data-name="IsSystemLinked"]');
            const selectedSource = sourceSelect?.value || "Fresh entry";
            const isCustom = selectedSource === "Custom";
            const effectiveSource = isCustom
                ? (customSource?.value?.trim() || "Custom")
                : selectedSource;

            if (customSource) {
                customSource.hidden = !isCustom;
                customSource.disabled = !isCustom;
            }

            if (resolvedSource) {
                resolvedSource.value = effectiveSource || "Fresh entry";
            }

            if (registerLink) {
                if (isRegisterSource(selectedSource)) {
                    registerLink.checked = true;
                } else if (selectedSource === "Fresh entry") {
                    registerLink.checked = false;
                }
            }
        }

        function syncAllColumnSources(root) {
            (root || document).querySelectorAll("[data-equipment-column]").forEach(syncColumnSource);
        }

        function normalizeColumnKey(value) {
            return (value || "")
                .trim()
                .toLowerCase()
                .replace(/\//g, "")
                .replace(/\?/g, "")
                .replace(/\s+-\s+/g, "-")
                .replace(/\s+/g, "-");
        }

        function createAxisCheckCell(column, overrideMode) {
            const cell = document.createElement("div");
            cell.className = "axis-check-cell";
            cell.setAttribute("role", "cell");
            cell.dataset.columnKey = column.key;
            const label = document.createElement("span");
            const type = document.createElement("strong");
            const source = document.createElement("small");
            const columnIndexInput = document.createElement("input");
            const overrideLabel = document.createElement("label");
            const overrideSelect = document.createElement("select");
            label.textContent = column.label;
            type.textContent = column.type;
            source.textContent = column.source;
            columnIndexInput.type = "hidden";
            columnIndexInput.dataset.columnOverrideName = "ColumnIndex";
            overrideLabel.className = "column-override-label";
            overrideLabel.textContent = "Row setting";
            overrideSelect.dataset.columnOverrideName = "Mode";
            [
                ["Default", "Use default"],
                ["Required", "Required"],
                ["Optional", "Optional"],
                ["NotApplicable", "N/A for this row"]
            ].forEach(function (optionDefinition) {
                const option = document.createElement("option");
                option.value = optionDefinition[0];
                option.textContent = optionDefinition[1];
                option.selected = option.value === (overrideMode || "Default");
                overrideSelect.appendChild(option);
            });
            overrideLabel.appendChild(overrideSelect);
            cell.append(label, type, source, columnIndexInput, overrideLabel);
            return cell;
        }

        let isSyncingAxisScroll = false;

        function getAxisShells() {
            return Array.from(document.querySelectorAll("[data-axis-table-shell]"));
        }

        function updateAxisScrollProxy(shell) {
            const table = shell.querySelector("[data-axis-table]");
            const proxy = shell.querySelector("[data-axis-scroll-proxy]");
            const track = shell.querySelector("[data-axis-scroll-track]");
            const spacer = shell.querySelector("[data-axis-scroll-spacer]");
            if (!table || !proxy || !track || !spacer) {
                return;
            }

            const hasHorizontalOverflow = table.scrollWidth > table.clientWidth + 2;
            const rect = shell.getBoundingClientRect();
            const sectionIsActive = hasHorizontalOverflow && rect.top < window.innerHeight - 106 && rect.bottom > 112;
            if (!sectionIsActive) {
                proxy.classList.remove("is-active");
                return;
            }

            const left = Math.max(12, rect.left);
            const right = Math.min(window.innerWidth - 12, rect.right);
            proxy.style.left = `${left}px`;
            proxy.style.width = `${Math.max(180, right - left)}px`;
            spacer.style.width = `${table.scrollWidth}px`;
            proxy.classList.add("is-active");

            if (Math.abs(track.scrollLeft - table.scrollLeft) > 1) {
                track.scrollLeft = table.scrollLeft;
            }
        }

        function updateAxisScrollProxies() {
            getAxisShells().forEach(updateAxisScrollProxy);
        }

        function bindAxisScrollProxies() {
            getAxisShells().forEach(function (shell) {
                if (shell.dataset.axisScrollBound === "true") {
                    return;
                }

                const table = shell.querySelector("[data-axis-table]");
                const track = shell.querySelector("[data-axis-scroll-track]");
                if (!table || !track) {
                    return;
                }

                shell.dataset.axisScrollBound = "true";

                table.addEventListener("scroll", function () {
                    if (isSyncingAxisScroll) {
                        return;
                    }

                    isSyncingAxisScroll = true;
                    track.scrollLeft = table.scrollLeft;
                    isSyncingAxisScroll = false;
                    updateAxisScrollProxy(shell);
                }, { passive: true });

                track.addEventListener("scroll", function () {
                    if (isSyncingAxisScroll) {
                        return;
                    }

                    isSyncingAxisScroll = true;
                    table.scrollLeft = track.scrollLeft;
                    isSyncingAxisScroll = false;
                }, { passive: true });
            });

            updateAxisScrollProxies();
        }

        function syncAxisTable(section) {
            const targetSections = section
                ? [section]
                : Array.from(document.querySelectorAll(".checklist-section-editor[data-section-kind='EquipmentTable']"));

            targetSections.forEach(function (matrixSection) {
            const columns = readEquipmentColumns(matrixSection);
            const columnCount = Math.max(columns.length, 1);
            const gridTemplate = `minmax(190px, 1fr) repeat(${columnCount}, minmax(118px, .9fr))`;
            const minWidth = `${190 + columnCount * 118}px`;

            matrixSection.querySelectorAll(".axis-table-row").forEach(function (row) {
                row.style.gridTemplateColumns = gridTemplate;
                row.style.minWidth = minWidth;
            });

            matrixSection.querySelectorAll(".equipment-axis-row").forEach(function (row) {
                const overrideModesByKey = new Map();
                const overrideModesByIndex = [];

                Array.from(row.querySelectorAll(".axis-check-cell")).forEach(function (cell, index) {
                    const mode = cell.querySelector('[data-column-override-name="Mode"]')?.value || "Default";
                    const key = cell.dataset.columnKey || normalizeColumnKey(cell.querySelector("span")?.textContent);
                    if (key) {
                        overrideModesByKey.set(key, mode);
                    }
                    overrideModesByIndex[index] = mode;
                });

                row.querySelectorAll(".axis-check-cell").forEach(function (cell) {
                    cell.remove();
                });

                columns.forEach(function (column, index) {
                    row.appendChild(createAxisCheckCell(
                        column,
                        overrideModesByKey.get(column.key) || overrideModesByIndex[index] || "Default"));
                });
            });

            renumberSections();
            });
            bindAxisScrollProxies();
        }

        function renumberColumnOverrides(axisRow, prefix) {
            if (!axisRow) {
                return;
            }

            Array.from(axisRow.children)
                .filter(function (child) {
                    return child.classList.contains("axis-check-cell");
                })
                .forEach(function (cell, columnIndex) {
                    cell.querySelectorAll("[data-column-override-name]").forEach(function (input) {
                        const property = input.dataset.columnOverrideName;
                        input.name = `${prefix}[${columnIndex}].${property}`;
                        if (property === "ColumnIndex") {
                            input.value = String(columnIndex);
                        }
                    });
                });
        }

        function renumberEquipmentRows(section, sectionIndex) {
            const targetSections = section
                ? [{ section, sectionIndex }]
                : Array.from(document.querySelectorAll(".checklist-section-editor")).map(function (item, index) {
                    return { section: item, sectionIndex: index };
                });

            targetSections.forEach(function (target) {
            if (target.section?.dataset.sectionKind !== "EquipmentTable") {
                return;
            }

            target.section.querySelectorAll("[data-equipment-row]").forEach(function (row, index) {
                const label = row.querySelector(".axis-cell-toolbar span");
                if (label) {
                    label.textContent = `Item ${index + 1}`;
                }

                row.querySelectorAll("[data-name]").forEach(function (input) {
                    input.name = `VehicleChecklistSections[${target.sectionIndex}].MatrixRows[${index}].${input.dataset.name}`;
                });

                renumberColumnOverrides(
                    Array.from(row.children).find(function (child) {
                        return child.classList.contains("equipment-axis-row");
                    }),
                    `VehicleChecklistSections[${target.sectionIndex}].MatrixRows[${index}].ColumnOverrides`);

                row.querySelectorAll("[data-equipment-subitem]").forEach(function (subItem, subIndex) {
                    const subItemLabel = subItem.querySelector(".subitem-toolbar span");
                    if (subItemLabel) {
                        subItemLabel.textContent = `Subitem ${subIndex + 1}`;
                    }

                    subItem.querySelectorAll("[data-subitem-name]").forEach(function (input) {
                        input.name = `VehicleChecklistSections[${target.sectionIndex}].MatrixRows[${index}].SubItems[${subIndex}].${input.dataset.subitemName}`;
                    });

                    renumberColumnOverrides(
                        subItem,
                        `VehicleChecklistSections[${target.sectionIndex}].MatrixRows[${index}].SubItems[${subIndex}].ColumnOverrides`);
                });
            });
            });
        }

        function renumberEquipmentColumns(section, sectionIndex) {
            const targetSections = section
                ? [{ section, sectionIndex }]
                : Array.from(document.querySelectorAll(".checklist-section-editor")).map(function (item, index) {
                    return { section: item, sectionIndex: index };
                });

            targetSections.forEach(function (target) {
            if (target.section?.dataset.sectionKind !== "EquipmentTable") {
                return;
            }

            target.section.querySelectorAll("[data-equipment-column]").forEach(function (column, index) {
                const label = column.querySelector(".axis-cell-toolbar span");
                if (label) {
                    label.textContent = `X ${index + 1}`;
                }

                column.querySelectorAll("[data-name]").forEach(function (input) {
                    const propertyName = input.dataset.name === "ResolvedSource" ? "Source" : input.dataset.name;
                    if (input.dataset.name === "Source") {
                        input.removeAttribute("name");
                        return;
                    }
                    input.name = `VehicleChecklistSections[${target.sectionIndex}].MatrixColumns[${index}].${propertyName}`;
                });
            });
            });
        }

        renumberSections();
        syncAllSchematicConfigs();
        syncAllFieldSources();
        renumberEquipmentRows();
        renumberEquipmentColumns();
        syncAllColumnSources();
        syncAxisTable();

        if (vehicleToggle && !vehicleToggle.disabled) {
            localStorage.setItem(vehicleSameShiftSettingKey, String(vehicleToggle.checked));

            vehicleToggle.addEventListener("change", function () {
                localStorage.setItem(vehicleSameShiftSettingKey, String(vehicleToggle.checked));
            });
        }

        if (equipmentToggle && !equipmentToggle.disabled) {
            localStorage.setItem(equipmentSameShiftSettingKey, String(equipmentToggle.checked));

            equipmentToggle.addEventListener("change", function () {
                localStorage.setItem(equipmentSameShiftSettingKey, String(equipmentToggle.checked));
            });
        }

        templateSelect?.addEventListener("change", function () {
            const url = new URL(window.location.href);
            if (!templateSelect.value) {
                url.searchParams.delete("templateId");
                url.searchParams.set("mode", "build");
                window.location.href = url.toString();
                return;
            }

            url.searchParams.set("templateId", templateSelect.value);
            window.location.href = url.toString();
        });

        layoutBuilder?.addEventListener("click", function (event) {
            const button = event.target.closest("button[data-action]");
            if (!button) {
                return;
            }

            const action = button.dataset.action;
            const section = button.closest(".checklist-section-editor");
            const field = button.closest("[data-field-row], .builder-field");

            if (action === "toggle-section") {
                section?.classList.toggle("is-collapsed");
                syncSectionToggle(section);
                updateAxisScrollProxies();
                return;
            }

            if (action === "add-section-note") {
                const noteList = section?.querySelector("[data-section-note-list]");
                noteList?.appendChild(createSectionNote());
                renumberSections();
                return;
            }

            if (action === "remove-section-note") {
                button.closest("[data-section-note]")?.remove();
                renumberSections();
                return;
            }

            if (action === "add-matrix-section") {
                const title = getSectionTitleForNewMatrix();
                const newSection = createMatrixSection(title, getSectionHelperText(title));
                const addPanel = layoutBuilder.querySelector(".builder-add-section-panel");
                layoutBuilder.insertBefore(newSection, addPanel);
                renumberSections();
                syncAxisTable(newSection);
                if (window.VectorInitializeChecklistCollapsibles) {
                    window.VectorInitializeChecklistCollapsibles(newSection);
                }
                if (window.VectorEnsureUniversalNaControls) {
                    window.VectorEnsureUniversalNaControls();
                }
                return;
            }

            if (action === "add-field") {
                const sections = layoutBuilder.querySelectorAll(".checklist-section-editor [data-field-list]");
                const targetGrid = sections[sections.length - 1];
                targetGrid?.appendChild(createChecklistFieldRow());
                renumberSections();
                return;
            }

            if (action === "add-field-to-section") {
                if (section?.dataset.sectionKind === "EquipmentTable") {
                    const columnList = section.querySelector("[data-equipment-column-list]");
                    columnList?.appendChild(createEquipmentColumn());
                    renumberSections();
                    syncAllColumnSources(section);
                    syncAxisTable(section);
                    if (window.VectorEnsureUniversalNaControls) {
                        window.VectorEnsureUniversalNaControls();
                    }
                    return;
                }

                addFieldToSection(section);
                return;
            }

            if (action === "add-equipment-row") {
                section?.querySelector("[data-equipment-row-list]")?.appendChild(createEquipmentRow());
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "add-equipment-subitem") {
                button.closest("[data-equipment-row]")?.querySelector("[data-equipment-subitem-list]")?.appendChild(createEquipmentSubItem());
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "add-equipment-column") {
                section?.querySelector("[data-equipment-column-list]")?.appendChild(createEquipmentColumn());
                renumberSections();
                syncAllColumnSources(section);
                syncAxisTable(section);
                return;
            }

            const equipmentRow = button.closest("[data-equipment-row]");
            const equipmentSubItem = button.closest("[data-equipment-subitem]");
            const equipmentColumn = button.closest("[data-equipment-column]");

            if (action === "remove-equipment-subitem") {
                equipmentSubItem?.remove();
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "move-equipment-subitem-up" && equipmentSubItem?.previousElementSibling?.matches("[data-equipment-subitem]")) {
                equipmentSubItem.parentNode.insertBefore(equipmentSubItem, equipmentSubItem.previousElementSibling);
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "move-equipment-subitem-down" && equipmentSubItem?.nextElementSibling?.matches("[data-equipment-subitem]")) {
                equipmentSubItem.parentNode.insertBefore(equipmentSubItem.nextElementSibling, equipmentSubItem);
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "remove-equipment-row") {
                equipmentRow?.remove();
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "move-equipment-row-up" && equipmentRow?.previousElementSibling?.matches("[data-equipment-row]")) {
                equipmentRow.parentNode.insertBefore(equipmentRow, equipmentRow.previousElementSibling);
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "move-equipment-row-down" && equipmentRow?.nextElementSibling?.matches("[data-equipment-row]")) {
                equipmentRow.parentNode.insertBefore(equipmentRow.nextElementSibling, equipmentRow);
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "remove-equipment-column") {
                equipmentColumn?.remove();
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "move-equipment-column-up" && equipmentColumn?.previousElementSibling?.matches("[data-equipment-column]")) {
                equipmentColumn.parentNode.insertBefore(equipmentColumn, equipmentColumn.previousElementSibling);
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "move-equipment-column-down" && equipmentColumn?.nextElementSibling?.matches("[data-equipment-column]")) {
                equipmentColumn.parentNode.insertBefore(equipmentColumn.nextElementSibling, equipmentColumn);
                renumberSections();
                syncAxisTable(section);
                return;
            }

            if (action === "remove-section") {
                section?.remove();
                renumberSections();
                return;
            }

            if (action === "move-section-up" && section?.previousElementSibling?.classList.contains("checklist-section-editor")) {
                section.parentNode.insertBefore(section, section.previousElementSibling);
                renumberSections();
                return;
            }

            if (action === "move-section-down" && section?.nextElementSibling?.classList.contains("checklist-section-editor")) {
                section.parentNode.insertBefore(section.nextElementSibling, section);
                renumberSections();
                return;
            }

            if (action === "remove-field") {
                field?.remove();
                renumberSections();
                return;
            }

            if (action === "move-field-up" && field?.previousElementSibling?.matches("[data-field-row], .builder-field")) {
                field.parentNode.insertBefore(field, field.previousElementSibling);
                renumberSections();
                return;
            }

            if (action === "move-field-down" && field?.nextElementSibling?.matches("[data-field-row], .builder-field")) {
                field.parentNode.insertBefore(field.nextElementSibling, field);
                renumberSections();
            }
        });

        layoutBuilder?.addEventListener("input", function (event) {
            const matrixSection = event.target.closest(".checklist-section-editor[data-section-kind='EquipmentTable']");
            const matrixColumn = event.target.closest("[data-equipment-column]");
            const fieldRow = event.target.closest("[data-field-row]");
            if (event.target.matches("[data-field-custom-source]")) {
                syncFieldSource(fieldRow);
            }
            if (event.target.matches('[data-field-name="Label"]')) {
                syncSchematicConfig(fieldRow);
            }
            if (event.target.matches("[data-custom-source]")) {
                syncColumnSource(matrixColumn);
            }
            if (event.target.closest("[data-equipment-column]")) {
                syncAxisTable(matrixSection);
            }
        });

        layoutBuilder?.addEventListener("change", function (event) {
            const matrixSection = event.target.closest(".checklist-section-editor[data-section-kind='EquipmentTable']");
            const matrixColumn = event.target.closest("[data-equipment-column]");
            const fieldRow = event.target.closest("[data-field-row]");
            if (event.target.matches("[data-field-source-select]")) {
                syncFieldSource(fieldRow);
            }
            if (event.target.matches('[data-field-name="Type"], [data-field-name="Label"]')) {
                syncSchematicConfig(fieldRow);
            }
            if (event.target.matches('[data-name="Source"]')) {
                syncColumnSource(matrixColumn);
            }
            if (event.target.closest("[data-equipment-column]")) {
                syncAxisTable(matrixSection);
            }
        });

        window.addEventListener("scroll", updateAxisScrollProxies, { passive: true });
        window.addEventListener("resize", updateAxisScrollProxies);
    })();
</script>
