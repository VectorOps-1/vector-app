.editor-form { display: flex; flex-direction: column; gap: 18px; }
.editor-section, .layout-builder { padding: 18px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.68); text-align: left; }
.section-heading { margin-bottom: 6px; font-size: 14px; font-weight: 800; letter-spacing: .8px; text-transform: uppercase; color: #425466; }
