@page
@model EditVehicleChecklistModel
@using System.Text.Json
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Daily Vehicle & Equipment Check Setup";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
    var schematicOptions = Model.PublishedUnitSchematics
        .Select(schematic => new { schematic.Key, schematic.DisplayName })
        .ToList();
}

<div class="editor-screen">
    <div class="editor-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Management Action</div>
        <h2 class="page-title">Daily Vehicle & Equipment Check Setup</h2>
        <p class="page-subtitle">Edit the checklist from the same structure crews use in the live vehicle readiness flow.</p>
        <div class="authority-note">@Model.ChecklistAuthorityNote</div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <form method="post" class="editor-form" data-checklist-editor-form>
            <input asp-for="CreateAsNewTemplate" type="hidden" />
            <section class="editor-section setup-section">
                <div class="section-heading">Checklist Template</div>
                <div class="form-grid">
                    <label>
                        Available vehicle template (optional)
                        <select asp-for="SelectedTemplateId" id="templateSelect">
                            <option value="">Create new blank checklist</option>
                            @foreach (var template in Model.AvailableTemplates)
                            {
                                <option value="@template.Id" selected="@(Model.SelectedTemplateId == template.Id)">@template.DisplayName</option>
                            }
                        </select>
                    </label>

                    <label>
                        Checklist name
                        <select asp-for="ChecklistName"
                                id="checklistNameSelect"
                                data-manual-select="checklist-name"
                                disabled="@(Model.UseCustomChecklistName ? "disabled" : null)">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.ChecklistName))">Select checklist name</option>
                            @foreach (var checklistName in Model.ChecklistNameOptions)
                            {
                                <option value="@checklistName" selected="@(string.Equals(Model.ChecklistName, checklistName, StringComparison.OrdinalIgnoreCase))">@checklistName</option>
                            }
                        </select>
                    </label>

                    <label class="manual-entry-toggle">
                        <input asp-for="UseCustomChecklistName"
                               id="useCustomChecklistNameToggle"
                               data-manual-toggle="checklist-name"
                               type="checkbox" />
                        <span>Use manual checklist name</span>
                    </label>

                    <label class="manual-entry-field @(Model.UseCustomChecklistName ? "" : "is-hidden")" data-manual-field="checklist-name">
                        Manual checklist name
                        <input asp-for="CustomChecklistName"
                               id="customChecklistNameInput"
                               placeholder="Enter checklist name"
                               disabled="@(Model.UseCustomChecklistName ? null : "disabled")" />
                    </label>

                    <input asp-for="TargetVehicleType" type="hidden" id="targetVehicleTypeValue" />

                    <label>
                        Target vehicle function
                        <select asp-for="TargetVehicleFunction" id="targetVehicleFunctionSelect">
                            @foreach (var functionOption in Model.TargetVehicleFunctionOptions)
                            {
                                <option value="@functionOption.Value" selected="@functionOption.Selected">@functionOption.Text</option>
                            }
                        </select>
                    </label>

                    <label>
                        Target subtype
                        <select asp-for="TargetVehicleSubtype"
                                id="targetVehicleSubtypeSelect"
                                data-manual-select="target-vehicle-type"
                                disabled="@(Model.UseCustomTargetVehicleType ? "disabled" : null)">
                            <option value="">N/A / all subtypes</option>
                            @foreach (var subtypeOption in Model.TargetVehicleSubtypeOptions)
                            {
                                <option value="@subtypeOption.Subtype"
                                        data-function="@subtypeOption.Function"
                                        selected="@(string.Equals(Model.TargetVehicleSubtype, subtypeOption.Subtype, StringComparison.OrdinalIgnoreCase))">
                                    @subtypeOption.Label
                                </option>
                            }
                        </select>
                    </label>

                    <label class="manual-entry-toggle">
                        <input asp-for="UseCustomTargetVehicleType"
                               id="useCustomTargetVehicleTypeToggle"
                               data-manual-toggle="target-vehicle-type"
                               type="checkbox" />
                        <span>Use manual target subtype</span>
                    </label>

                    <label class="manual-entry-field @(Model.UseCustomTargetVehicleType ? "" : "is-hidden")" data-manual-field="target-vehicle-type">
                        Manual target subtype
                        <input asp-for="CustomTargetVehicleType"
                               id="customTargetVehicleTypeInput"
                               placeholder="Enter target subtype"
                               disabled="@(Model.UseCustomTargetVehicleType ? null : "disabled")" />
                    </label>

                    <label>
                        Checklist status
                        <select asp-for="ChecklistStatus">
                            <option>Draft</option>
                            <option>Under Review</option>
                            <option>Approved</option>
                            <option>Published</option>
                            <option>Archived</option>
                        </select>
                    </label>
                </div>
                <div class="template-note">
                    Published templates become the available checklist versions for matching vehicle functions and subtypes. Register vehicle function and subtype remain the source of truth.
                </div>
            </section>

            <section class="layout-builder">
                <div class="builder-toolbar">
                    <div>
                        <div class="section-heading">Live Layout Builder</div>
                        <p>@Model.LayoutBuilderSummary Staff-facing order: vehicle details, previous shift control, operational checks, schematic, carried equipment, notes.</p>
                    </div>
                    <div class="toolbar-actions fixed-blocks-note">
                        <span>@(Model.IsScratchBuildMode ? "Blank build: add the sections this checklist needs" : "Loaded template structure")</span>
                    </div>
                </div>

                @for (var sectionIndex = 0; sectionIndex < Model.VehicleChecklistSections.Count; sectionIndex++)
                {
                    var checklistSection = Model.VehicleChecklistSections[sectionIndex];
                    <article class="checklist-section-editor is-collapsed" data-section-kind="@checklistSection.Kind">
                        <input type="hidden" data-section-name="Kind" name="VehicleChecklistSections[@sectionIndex].Kind" value="@checklistSection.Kind" />
                        <div class="visual-section-heading">
                            <span>@(sectionIndex + 1)</span>
                            <div class="section-title-editor">
                                <label>
                                    Section heading
                                    <input data-section-name="Title"
                                           name="VehicleChecklistSections[@sectionIndex].Title"
                                           value="@checklistSection.Title"
                                           aria-label="@checklistSection.Title heading" />
                                </label>
                                <label>
                                    Staff helper text
                                    <input data-section-name="HelperText"
                                           name="VehicleChecklistSections[@sectionIndex].HelperText"
                                           value="@checklistSection.HelperText"
                                           aria-label="@checklistSection.Title helper text" />
                                </label>
                            </div>
                            <div class="section-controls" aria-label="@checklistSection.Title controls">
                                <button type="button" data-action="move-section-up">Up</button>
                                <button type="button" data-action="move-section-down">Down</button>
                                <button type="button" data-action="remove-section">Remove</button>
                                <button type="button" data-action="toggle-section" aria-expanded="false">Open Section</button>
                            </div>
                        </div>

                        <div class="section-body" data-section-body>
                            @if (checklistSection.Kind == ChecklistSectionKind.Action)
                            {
                                <div class="previous-shift-editor">
                                    <div>
                                        <label>
                                            Button label
                                            <input value="Same as previous shift" />
                                        </label>
                                        <p>Senior management controls vehicle carry-forward and equipment carry-forward separately.</p>
                                    </div>
                                    <div class="same-shift-toggle-group">
                                        <label class="toggle-row">
                                            <input asp-for="AllowSameAsPreviousVehicleInspection"
                                                   id="allowSameAsPreviousVehicleInspectionToggle"
                                                   type="checkbox"
                                                   disabled="@(!Model.IsSeniorChecklistPublisher)" />
                                            <span>Allow for vehicle inspection</span>
                                        </label>

                                        <label class="toggle-row">
                                            <input asp-for="AllowSameAsPreviousEquipmentCheck"
                                                   id="allowSameAsPreviousEquipmentCheckToggle"
                                                   type="checkbox"
                                                   disabled="@(!Model.IsSeniorChecklistPublisher)" />
                                            <span>Allow for equipment checks</span>
                                        </label>
                                    </div>
                                </div>
                            }
                            else if (checklistSection.Kind == ChecklistSectionKind.EquipmentTable)
                            {
                                var sectionMatrixColumnCount = Math.Max(checklistSection.MatrixColumns.Count, 1);
                                var sectionMatrixGridStyle = $"grid-template-columns: minmax(190px, 1fr) repeat({sectionMatrixColumnCount}, minmax(118px, .9fr)); min-width: {190 + sectionMatrixColumnCount * 118}px;";
                                <div class="axis-builder-note">
                                    <strong>Builder axes</strong>
                                    <span>X axis = checklist columns. Y axis = items and subitems. Register links are optional per column.</span>
                                </div>

                            <div class="axis-builder-actions">
                                <button class="small-action" type="button" data-action="add-equipment-row">Add Item Row</button>
                                <button class="small-action" type="button" data-action="add-equipment-column">Add Column</button>
                            </div>

                            <div class="axis-table-shell" data-axis-table-shell>
                                <div class="axis-table" data-axis-table role="table" aria-label="Equipment checklist visual builder">
                                    <div class="axis-table-row axis-header-row" role="row" style="@sectionMatrixGridStyle">
                                        <div class="axis-corner-cell" role="columnheader">
                                            <strong>Y Axis</strong>
                                            <span>Item / subitem</span>
                                        </div>
                                        <div class="axis-column-list" data-equipment-column-list>
                                            @for (var columnIndex = 0; columnIndex < checklistSection.MatrixColumns.Count; columnIndex++)
                                            {
                                                var field = checklistSection.MatrixColumns[columnIndex];
                                                <div class="axis-header-cell @(field.IsSystemLinked ? "system-linked" : string.Empty)" data-equipment-column role="columnheader">
                                                    <div class="axis-cell-toolbar">
                                                        <span>X @(columnIndex + 1)</span>
                                                        <div>
                                                            <button type="button" data-action="move-equipment-column-up">Left</button>
                                                            <button type="button" data-action="move-equipment-column-down">Right</button>
                                                            <button type="button" data-action="remove-equipment-column">Remove</button>
                                                        </div>
                                                    </div>
                                                    <label>
                                                        Column heading
                                                        <input data-name="Label" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].Label" value="@field.Label" aria-label="@field.Label label" />
                                                    </label>
                                                    <label>
                                                        Input type
                                                        <select data-name="Type" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].Type" aria-label="@field.Label type">
                                                            <option selected>@field.Type</option>
                                                            <option>Configured row</option>
                                                            <option>Text</option>
                                                            <option>Date</option>
                                                            <option>Dropdown</option>
                                                            <option>Checkbox</option>
                                                            <option>Yes/No</option>
                                                            <option>Photo Upload</option>
                                                        </select>
                                                    </label>
                                                    <label>
                                                        Data source
                                                        <select data-name="Source" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].Source" aria-label="@field.Label source">
                                                            <option value="Fresh entry" selected="@(string.IsNullOrWhiteSpace(field.Source) || string.Equals(field.Source, "Fresh entry", StringComparison.OrdinalIgnoreCase))">Fresh entry</option>
                                                            <option value="Vehicle register" selected="@(string.Equals(field.Source, "Vehicle register", StringComparison.OrdinalIgnoreCase))">Vehicle register</option>
                                                            <option value="Equipment register" selected="@(string.Equals(field.Source, "Equipment register", StringComparison.OrdinalIgnoreCase))">Equipment register</option>
                                                            <option value="Stock register" selected="@(string.Equals(field.Source, "Stock register", StringComparison.OrdinalIgnoreCase))">Stock register</option>
                                                            <option value="Medication register" selected="@(string.Equals(field.Source, "Medication register", StringComparison.OrdinalIgnoreCase))">Medication register</option>
                                                            <option value="Custom" selected="@(!string.IsNullOrWhiteSpace(field.Source) && !new[] { "Fresh entry", "Vehicle register", "Equipment register", "Stock register", "Medication register" }.Contains(field.Source, StringComparer.OrdinalIgnoreCase))">Custom</option>
                                                        </select>
                                                        <input class="custom-source-input"
                                                               data-custom-source
                                                               value="@field.Source"
                                                               placeholder="Custom source"
                                                               aria-label="@field.Label custom source"
                                                               hidden="@((string.IsNullOrWhiteSpace(field.Source) || new[] { "Fresh entry", "Vehicle register", "Equipment register", "Stock register", "Medication register" }.Contains(field.Source, StringComparer.OrdinalIgnoreCase)) ? "hidden" : null)" />
                                                        <input type="hidden" data-name="ResolvedSource" value="@field.Source" />
                                                    </label>
                                                    <div class="field-rule-row compact-rule-row">
                                                        <label><input type="checkbox" data-name="IsRequired" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].IsRequired" value="true" checked="@field.IsRequired" /> Required</label>
                                                        <label><input type="checkbox" data-name="IsEditable" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].IsEditable" value="true" checked="@field.IsEditable" /> Editable</label>
                                                        <label><input type="checkbox" data-name="IsSystemLinked" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].IsSystemLinked" value="true" checked="@field.IsSystemLinked" /> Register link</label>
                                                        <label><input type="checkbox" data-name="AffectsReadiness" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].AffectsReadiness" value="true" checked="@field.AffectsReadiness" /> Readiness</label>
                                                        <label><input type="checkbox" data-name="SameAsPreviousEligible" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].SameAsPreviousEligible" value="true" checked="@field.SameAsPreviousEligible" /> Previous</label>
                                                        <label><input type="checkbox" data-name="RequiresNoteWhenNotNormal" name="VehicleChecklistSections[@sectionIndex].MatrixColumns[@columnIndex].RequiresNoteWhenNotNormal" value="true" checked="@field.RequiresNoteWhenNotNormal" /> Note</label>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="axis-row-list" data-equipment-row-list>
                                        @for (var rowIndex = 0; rowIndex < checklistSection.MatrixRows.Count; rowIndex++)
                                        {
                                            var row = checklistSection.MatrixRows[rowIndex];
                                            <div class="equipment-axis-group" data-equipment-row>
                                                <div class="axis-table-row equipment-axis-row" role="row" style="@sectionMatrixGridStyle">
                                                    <div class="axis-item-cell" role="rowheader">
                                                        <div class="axis-cell-toolbar">
                                                            <span>Item @(rowIndex + 1)</span>
                                                            <div>
                                                                <button type="button" data-action="move-equipment-row-up">Up</button>
                                                                <button type="button" data-action="move-equipment-row-down">Down</button>
                                                                <button type="button" data-action="remove-equipment-row">Remove</button>
                                                            </div>
                                                        </div>
                                                        <label>
                                                            Item name
                                                            <input data-name="Name" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].Name" value="@row.Name" />
                                                        </label>
                                                        <label>
                                                            Equipment type
                                                            <input data-name="EquipmentType" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].EquipmentType" value="@row.EquipmentType" placeholder="Item type" />
                                                        </label>
                                                        <label>
                                                            Model / variant
                                                            <input data-name="Model" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].Model" value="@row.Model" placeholder="Optional model, variant, or size" />
                                                        </label>
                                                        <div class="field-rule-row compact-rule-row">
                                                            <label><input type="checkbox" data-name="IsRequired" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].IsRequired" value="true" checked="@row.IsRequired" /> Required</label>
                                                            <label><input type="checkbox" data-name="IsReadinessCritical" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].IsReadinessCritical" value="true" checked="@row.IsReadinessCritical" /> Readiness</label>
                                                            <label><input type="checkbox" data-name="AllowsSameAsPrevious" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].AllowsSameAsPrevious" value="true" checked="@row.AllowsSameAsPrevious" /> Previous</label>
                                                        </div>
                                                        <button class="small-action inline-add" type="button" data-action="add-equipment-subitem">Add Subitem</button>
                                                    </div>

                                                    @for (var columnIndex = 0; columnIndex < checklistSection.MatrixColumns.Count; columnIndex++)
                                                    {
                                                        var field = checklistSection.MatrixColumns[columnIndex];
                                                        var overrideMode = Model.GetColumnOverrideMode(row.ColumnOverrides, columnIndex);
                                                        <div class="axis-check-cell" role="cell">
                                                            <span>@field.Label</span>
                                                            <strong>@field.Type</strong>
                                                            <small>@(string.IsNullOrWhiteSpace(field.Source) ? "Fresh entry" : field.Source)</small>
                                                            <input type="hidden"
                                                                   data-column-override-name="ColumnIndex"
                                                                   name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].ColumnOverrides[@columnIndex].ColumnIndex"
                                                                   value="@columnIndex" />
                                                            <label class="column-override-label">
                                                                Row setting
                                                                <select data-column-override-name="Mode"
                                                                        name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].ColumnOverrides[@columnIndex].Mode"
                                                                        aria-label="@row.Name @field.Label row setting">
                                                                    <option value="@EquipmentColumnOverrideModes.Default" selected="@(overrideMode == EquipmentColumnOverrideModes.Default)">Use default</option>
                                                                    <option value="@EquipmentColumnOverrideModes.Required" selected="@(overrideMode == EquipmentColumnOverrideModes.Required)">Required</option>
                                                                    <option value="@EquipmentColumnOverrideModes.Optional" selected="@(overrideMode == EquipmentColumnOverrideModes.Optional)">Optional</option>
                                                                    <option value="@EquipmentColumnOverrideModes.NotApplicable" selected="@(overrideMode == EquipmentColumnOverrideModes.NotApplicable)">N/A for this row</option>
                                                                </select>
                                                            </label>
                                                        </div>
                                                    }
                                                </div>

                                                <div class="axis-subitem-list" data-equipment-subitem-list>
                                                    @for (var subIndex = 0; subIndex < row.SubItems.Count; subIndex++)
                                                    {
                                                        var subItem = row.SubItems[subIndex];
                                                        <div class="axis-table-row equipment-axis-row equipment-subitem-row" role="row" style="@sectionMatrixGridStyle" data-equipment-subitem>
                                                            <div class="axis-item-cell" role="rowheader">
                                                                <div class="axis-cell-toolbar subitem-toolbar">
                                                                    <span>Subitem @(subIndex + 1)</span>
                                                                    <div>
                                                                        <button type="button" data-action="move-equipment-subitem-up">Up</button>
                                                                        <button type="button" data-action="move-equipment-subitem-down">Down</button>
                                                                        <button type="button" data-action="remove-equipment-subitem">Remove</button>
                                                                    </div>
                                                                </div>
                                                                <label>
                                                                    Subitem name
                                                                    <input data-subitem-name="Name" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].Name" value="@subItem.Name" placeholder="SpO2 sensor, cable, 4 lead ECG" />
                                                                </label>
                                                                <label>
                                                                    Equipment type
                                                                    <input data-subitem-name="EquipmentType" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].EquipmentType" value="@subItem.EquipmentType" placeholder="Monitor accessory, cable, sensor" />
                                                                </label>
                                                                <label>
                                                                    Model / variant
                                                                    <input data-subitem-name="Model" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].Model" value="@subItem.Model" placeholder="Optional" />
                                                                </label>
                                                                <div class="field-rule-row compact-rule-row">
                                                                    <label><input type="checkbox" data-subitem-name="IsRequired" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].IsRequired" value="true" checked="@subItem.IsRequired" /> Required</label>
                                                                    <label><input type="checkbox" data-subitem-name="IsReadinessCritical" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].IsReadinessCritical" value="true" checked="@subItem.IsReadinessCritical" /> Readiness</label>
                                                                    <label><input type="checkbox" data-subitem-name="AllowsSameAsPrevious" name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].AllowsSameAsPrevious" value="true" checked="@subItem.AllowsSameAsPrevious" /> Previous</label>
                                                                </div>
                                                            </div>

                                                            @for (var columnIndex = 0; columnIndex < checklistSection.MatrixColumns.Count; columnIndex++)
                                                            {
                                                                var field = checklistSection.MatrixColumns[columnIndex];
                                                                var overrideMode = Model.GetColumnOverrideMode(subItem.ColumnOverrides, columnIndex);
                                                                <div class="axis-check-cell" role="cell">
                                                                    <span>@field.Label</span>
                                                                    <strong>@field.Type</strong>
                                                                    <small>@(string.IsNullOrWhiteSpace(field.Source) ? "Fresh entry" : field.Source)</small>
                                                                    <input type="hidden"
                                                                           data-column-override-name="ColumnIndex"
                                                                           name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].ColumnOverrides[@columnIndex].ColumnIndex"
                                                                           value="@columnIndex" />
                                                                    <label class="column-override-label">
                                                                        Row setting
                                                                        <select data-column-override-name="Mode"
                                                                                name="VehicleChecklistSections[@sectionIndex].MatrixRows[@rowIndex].SubItems[@subIndex].ColumnOverrides[@columnIndex].Mode"
                                                                                aria-label="@subItem.Name @field.Label row setting">
                                                                            <option value="@EquipmentColumnOverrideModes.Default" selected="@(overrideMode == EquipmentColumnOverrideModes.Default)">Use default</option>
                                                                            <option value="@EquipmentColumnOverrideModes.Required" selected="@(overrideMode == EquipmentColumnOverrideModes.Required)">Required</option>
                                                                            <option value="@EquipmentColumnOverrideModes.Optional" selected="@(overrideMode == EquipmentColumnOverrideModes.Optional)">Optional</option>
                                                                            <option value="@EquipmentColumnOverrideModes.NotApplicable" selected="@(overrideMode == EquipmentColumnOverrideModes.NotApplicable)">N/A for this row</option>
                                                                        </select>
                                                                    </label>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="axis-scroll-proxy" data-axis-scroll-proxy aria-label="Equipment checklist horizontal scroll">
                                    <div class="axis-scroll-proxy-track" data-axis-scroll-track tabindex="0">
                                        <div class="axis-scroll-proxy-spacer" data-axis-scroll-spacer></div>
                                    </div>
                                </div>
                            </div>
                            }
                            else
                            {
                                <div class="field-axis-table" data-field-list role="table" aria-label="@checklistSection.Title field builder">
                                    <div class="field-axis-row field-axis-header" role="row">
                                        <span role="columnheader">Y Axis: Vehicle Field</span>
                                        <span role="columnheader">Input Type</span>
                                        <span role="columnheader">Source</span>
                                        <span role="columnheader">Rules</span>
                                        <span role="columnheader">Actions</span>
                                    </div>
                                    @for (var fieldIndex = 0; fieldIndex < checklistSection.Fields.Count; fieldIndex++)
                                    {
                                        var field = checklistSection.Fields[fieldIndex];
                                        var isSchematicField = field.Type.Contains("Schematic", StringComparison.OrdinalIgnoreCase) || field.Label.Contains("Unit Schematic", StringComparison.OrdinalIgnoreCase);
                                        var selectedSchematicKey = field.UnitSchematicKey ?? string.Empty;
                                        <div class="field-axis-row @(field.IsSystemLinked ? "system-linked" : string.Empty)" data-field-row role="row">
                                            <label role="cell">
                                                Field name
                                                <input data-field-name="Label"
                                                       name="VehicleChecklistSections[@sectionIndex].Fields[@fieldIndex].Label"
                                                       value="@field.Label"
                                                       aria-label="@field.Label label" />
                                            </label>

                                            <label role="cell">
                                                Input type
                                                <select data-field-name="Type"
                                                        name="VehicleChecklistSections[@sectionIndex].Fields[@fieldIndex].Type"
                                                        aria-label="@field.Label type">
                                                    <option selected>@field.Type</option>
                                                    <option>Text</option>
                                                    <option>Number</option>
                                                    <option>Date</option>
                                                    <option>Dropdown</option>
                                                    <option>Checkbox</option>
                                                    <option>Photo Upload</option>
                                                    <option>Schematic Markup</option>
                                                    <option>Permissioned Action</option>
                                                </select>
                                            </label>

                                            <div class="field-source-cell" role="cell">
                                                <input type="hidden"
                                                       data-field-name="Source"
                                                       name="VehicleChecklistSections[@sectionIndex].Fields[@fieldIndex].Source"
                                                       value="@field.Source" />
                                                <select data-field-source-select aria-label="@field.Label source">
                                                    <option value="Fresh entry" selected="@(string.IsNullOrWhiteSpace(field.Source) || string.Equals(field.Source, "Fresh entry", StringComparison.OrdinalIgnoreCase))">Fresh entry</option>
                                                    <option value="Vehicle register" selected="@(string.Equals(field.Source, "Vehicle register", StringComparison.OrdinalIgnoreCase))">Vehicle register</option>
                                                    <option value="Equipment register" selected="@(string.Equals(field.Source, "Equipment register", StringComparison.OrdinalIgnoreCase))">Equipment register</option>
                                                    <option value="Stock register" selected="@(string.Equals(field.Source, "Stock register", StringComparison.OrdinalIgnoreCase))">Stock register</option>
                                                    <option value="Medication register" selected="@(string.Equals(field.Source, "Medication register", StringComparison.OrdinalIgnoreCase))">Medication register</option>
                                                    <option value="Staff register" selected="@(string.Equals(field.Source, "Staff register", StringComparison.OrdinalIgnoreCase))">Staff register</option>
                                                    <option value="Unit Schematic library" selected="@(string.Equals(field.Source, "Unit Schematic library", StringComparison.OrdinalIgnoreCase) || string.Equals(field.Source, "Unit Schematic", StringComparison.OrdinalIgnoreCase))">Unit Schematic library</option>
                                                    <option value="Senior setting" selected="@(string.Equals(field.Source, "Senior setting", StringComparison.OrdinalIgnoreCase))">Senior setting</option>
                                                    <option value="Custom" selected="@(!string.IsNullOrWhiteSpace(field.Source) && !new[] { "Fresh entry", "Vehicle register", "Equipment register", "Stock register", "Medication register", "Staff register", "Unit Schematic library", "Unit Schematic", "Senior setting" }.Contains(field.Source, StringComparer.OrdinalIgnoreCase))">Custom</option>
                                                </select>
                                                <input class="custom-source-input"
                                                       data-field-custom-source
                                                       value="@field.Source"
                                                       placeholder="Custom source"
                                                       aria-label="@field.Label custom source"
                                                       hidden="@((string.IsNullOrWhiteSpace(field.Source) || new[] { "Fresh entry", "Vehicle register", "Equipment register", "Stock register", "Medication register", "Staff register", "Unit Schematic library", "Unit Schematic", "Senior setting" }.Contains(field.Source, StringComparer.OrdinalIgnoreCase)) ? "hidden" : null)" />
                                                <div class="schematic-component-config @(isSchematicField ? string.Empty : "is-hidden")" data-schematic-config>
                                                    <label>
                                                        Saved schematic set
                                                        <select data-field-name="UnitSchematicKey" name="VehicleChecklistSections[@sectionIndex].Fields[@fieldIndex].UnitSchematicKey" aria-label="@field.Label saved schematic">
                                                            <option value="" selected="@string.IsNullOrWhiteSpace(selectedSchematicKey)">No schematic selected</option>
                                                            @foreach (var schematic in Model.PublishedUnitSchematics)
                                                            {
                                                                <option value="@schematic.Key" selected="@(string.Equals(selectedSchematicKey, schematic.Key, StringComparison.OrdinalIgnoreCase))">@schematic.DisplayName</option>
                                                            }
                                                        </select>
                                                    </label>
                                                    <div class="schematic-view-builder" aria-label="Unit schematic views">
                                                        <div class="schematic-view-card">
                                                            <strong>Left</strong>
                                                            <span>Damage present, position, severity, notes, photo, readiness impact</span>
                                                        </div>
                                                        <div class="schematic-view-card">
                                                            <strong>Right</strong>
                                                            <span>Damage present, position, severity, notes, photo, readiness impact</span>
                                                        </div>
                                                        <div class="schematic-view-card">
                                                            <strong>Front</strong>
                                                            <span>Damage present, position, severity, notes, photo, readiness impact</span>
                                                        </div>
                                                        <div class="schematic-view-card">
                                                            <strong>Rear</strong>
                                                            <span>Damage present, position, severity, notes, photo, readiness impact</span>
                                                        </div>
                                                    </div>
                                                    <p class="schematic-component-note">This single builder row saves as one Unit Schematic block with four crew-facing views.</p>
                                                </div>
                                            </div>

                                            <div class="field-rule-row compact-rule-row" role="cell">
                                                <label><input type="checkbox" data-field-name="IsRequired" name="VehicleChecklistSections[@sectionIndex].Fields[@fieldIndex].IsRequired" value="true" checked="@field.IsRequired" /> Required</label>
                                                <label><input type="checkbox" data-field-name="IsEditable" name="VehicleChecklistSections[@sectionIndex].Fields[@fieldIndex].IsEditable" value="true" checked="@field.IsEditable" /> Editable</label>
                                               <input type="hidden"
                                                       data-field-name="IsSystemLinked"
                                                       name="VehicleChecklistSections[@sectionIndex].Fields[@fieldIndex].IsSystemLinked"
                                                       value="@field.IsSystemLinked.ToString().ToLowerInvariant()" />
                                                <span data-field-link-status>@(field.IsSystemLinked ? "Linked source" : "Manual entry")</span>
                                            </div>

                                            <div class="field-row-actions" role="cell">
                                                <div>
                                                    <button type="button" data-action="move-field-up">Up</button>
                                                    <button type="button" data-action="move-field-down">Down</button>
                                                    <button type="button" data-action="remove-field">Remove</button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <button class="small-action inline-add" type="button" data-action="add-field-to-section">Add Field to @checklistSection.Title</button>
                            }

                            <div class="section-notes-builder" data-section-notes>
                                <div class="section-notes-heading">
                                    <div>
                                        <strong>Section notes</strong>
                                        <span>Free-text notes shown after this section, outside the row and column layout.</span>
                                    </div>
                                    <button class="small-action" type="button" data-action="add-section-note">Add Notes Field</button>
                                </div>
                                <div class="section-note-list" data-section-note-list>
                                    @for (var noteIndex = 0; noteIndex < checklistSection.Notes.Count; noteIndex++)
                                    {
                                        var note = checklistSection.Notes[noteIndex];
                                        <div class="section-note-config" data-section-note>
                                            <label>
                                                Notes label
                                                <input data-note-name="Label"
                                                       name="VehicleChecklistSections[@sectionIndex].Notes[@noteIndex].Label"
                                                       value="@note.Label"
                                                       placeholder="@checklistSection.Title notes" />
                                            </label>
                                            <span class="note-helper">Optional note only</span>
                                            <button class="small-action" type="button" data-action="remove-section-note">Remove</button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                }
                @if (Model.VehicleChecklistSections.Count == 0)
                {
                    <div class="empty-builder-state">
                        No checklist sections added yet. Use Add Section to create the first Vehicle, Equipment, Stock, Medication, or custom section.
                    </div>
                }

                <div class="builder-add-section-panel">
                    <label>
                        Section type
                        <select data-add-section-name aria-label="Section type to add">
                            <option>Vehicle</option>
                            <option selected>Equipment</option>
                            <option>Stock</option>
                            <option>Medication</option>
                            <option>Custom</option>
                        </select>
                    </label>
                    <label>
                        Custom section name
                        <input data-add-section-custom-name placeholder="Select Custom to type a section name" disabled />
                    </label>
                    <button class="small-action" type="button" data-action="add-matrix-section">Add Section</button>
                </div>
            </section>

            <section class="editor-section">
                <div class="section-heading">Publish Controls</div>
                <div class="current-live-use-panel">
                    <div class="live-use-heading">
                        <div>
                            <div class="source-label">Current live use</div>
                            <strong>Where this checklist is currently active</strong>
                        </div>
                        <span>@Model.CurrentLiveUses.Count active</span>
                    </div>

                    @if (Model.SelectedTemplateId is null)
                    {
                        <div class="live-use-empty">This new checklist is not active anywhere yet.</div>
                    }
                    else if (Model.CurrentLiveUses.Count == 0)
                    {
                        <div class="live-use-empty">This checklist is not currently active anywhere.</div>
                    }
                    else
                    {
                        <div class="live-use-list">
                            <div class="live-use-row live-use-header">
                                <span>Scope</span>
                                <span>Exact target</span>
                                <span>Published</span>
                                <span>Published by</span>
                            </div>
                            @foreach (var liveUse in Model.CurrentLiveUses)
                            {
                                <div class="live-use-row">
                                    <span>@liveUse.Scope</span>
                                    <strong>@liveUse.Target</strong>
                                    <span>@liveUse.PublishedAtUtc.ToString("yyyy-MM-dd HH:mm")</span>
                                    <span>@liveUse.PublishedBy</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(liveUse.PublishNote))
                                {
                                    <div class="live-use-note">@liveUse.PublishNote</div>
                                }
                            }
                        </div>
                    }
                </div>

                <div class="form-grid">
                    <label class="publish-scope-selector">
                        Publish target type
                        <select asp-for="AppliesTo" id="publishScopeSelect" data-skip-na>
                            <option value="All operational areas">All areas and all eligible vehicles</option>
                            <option value="Specific base">Specific base / operational area</option>
                            <option value="Vehicle function">Vehicle function</option>
                            <option value="Vehicle subtype">Vehicle subtype</option>
                            <option value="Specific vehicle registration">Specific callsign / registration</option>
                        </select>
                        <span class="field-hint">Choose the broad publish rule first, then choose the exact target below.</span>
                    </label>

                    <label class="publish-target" data-publish-target="Specific base">
                        Select exact base / operational area
                        <select asp-for="PublishOperationalAreaId" asp-items="Model.PublishAreaOptions" data-skip-na>
                            <option value="">Select base / area</option>
                        </select>
                        <span class="field-hint">Only vehicles and users linked to this area should receive this checklist.</span>
                    </label>

                    <label class="publish-target" data-publish-target="Vehicle function">
                        Select exact vehicle function
                        <select asp-for="PublishVehicleFunction" asp-items="Model.PublishVehicleFunctionOptions" data-skip-na>
                            <option value="">Select function</option>
                        </select>
                        <span class="field-hint">Examples: Ambulance, Response Vehicle.</span>
                    </label>

                    <label class="publish-target" data-publish-target="Vehicle subtype">
                        Select exact vehicle subtype
                        <select asp-for="PublishVehicleSubtype" asp-items="Model.PublishVehicleSubtypeOptions" data-skip-na>
                            <option value="">Select subtype</option>
                        </select>
                        <span class="field-hint">Examples: Ops Ambulance, Pickup RV, ICU Ambulance.</span>
                    </label>

                    <label class="publish-target" data-publish-target="Specific vehicle registration">
                        Select exact callsign / registration
                        <select asp-for="PublishVehicleId" asp-items="Model.PublishVehicleOptions" data-skip-na>
                            <option value="">Select callsign / registration</option>
                        </select>
                        <span class="field-hint">This overrides broader function, subtype, and area targeting for one registered unit.</span>
                    </label>

                    @if (!Model.CanApproveAndPublish)
                    {
                        <label>
                            Submit to senior manager
                            <select asp-for="SeniorApproverUserId" asp-items="Model.SeniorApproverOptions">
                                <option value="">Select senior manager</option>
                            </select>
                        </label>
                    }

                    <label>
                        @(Model.CanApproveAndPublish ? "Publish note" : "Approval note")
                        <textarea asp-for="PublishNote" rows="5" placeholder="Reason for edit, approval note, or version note"></textarea>
                    </label>
                </div>

                <div class="replacement-warning-list" aria-live="polite">
                    @foreach (var warning in Model.ConflictWarnings)
                    {
                        <div class="replacement-warning" data-conflict-key="@warning.ScopeKey" hidden>
                            @warning.Message
                        </div>
                    }
                </div>

                <div class="publish-note">
                    @(Model.CanApproveAndPublish
                        ? "This login can approve and publish the checklist for the selected live-use target."
                        : "Operational management can save drafts and submit checklist changes to a selected senior manager for approval.")
                </div>
            </section>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="submit-feedback" data-action-status data-submit-result>@Model.StatusMessage</div>
            }

            <div class="submit-feedback submit-feedback-pending" data-submit-progress hidden>
                Submitting checklist approval request...
            </div>

            <div class="action-row">
                <button class="menu-btn vehicle-btn" type="submit" name="ActionType" value="save-draft">Save Draft</button>
                @if (Model.CanApproveAndPublish)
                {
                    <button class="menu-btn equipment-btn" type="submit" name="ActionType" value="approve-publish">Approve and Publish</button>
                }
                else
                {
                    <button class="menu-btn equipment-btn" type="submit" name="ActionType" value="submit-approval">Submit for Approval</button>
                }
            </div>
        </form>
    </div>
</div>

<style>
