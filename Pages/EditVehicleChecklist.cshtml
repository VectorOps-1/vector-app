@@media (max-width: 860px) { .form-grid, .builder-toolbar, .visual-section-heading, .section-title-editor, .field-grid, .field-editor-grid, .previous-shift-editor, .action-row, .equipment-row-fields, .equipment-preview-header, .equipment-preview-row, .builder-add-section-panel, .section-note-config, .live-use-row { grid-template-columns: 1fr; } .section-notes-heading, .live-use-heading { align-items: flex-start; flex-direction: column; } .toolbar-actions, .section-controls, .equipment-config-heading, .row-config-toolbar, .equipment-subitem-heading { justify-content: flex-start; } .equipment-config-heading, .row-config-toolbar, .equipment-subitem-heading { align-items: flex-start; flex-direction: column; } .equipment-preview-header { display: none; } .equipment-preview-row { border: 1px solid rgba(66,84,102,.14); } .equipment-preview-row + .equipment-preview-row { margin-top: 8px; } .equipment-preview-row span { border-right: none; border-top: 1px solid rgba(66,84,102,.1); } .equipment-preview-row span:first-child { border-top: none; background: #f8fafc; } .axis-scroll-proxy.is-active { bottom: 92px; padding: 10px; } .axis-scroll-proxy-track { height: 22px; } }
</style>

<script>
    (function () {
        const vehicleToggle = document.getElementById("allowSameAsPreviousVehicleInspectionToggle");
        const equipmentToggle = document.getElementById("allowSameAsPreviousEquipmentCheckToggle");
        const tenantStoragePrefix = @Json.Serialize(Model.CompanyStorageKeyPrefix);
        const vehicleSameShiftSettingKey = tenantStoragePrefix + ":vectorAllowSameAsPreviousVehicleInspection";
        const equipmentSameShiftSettingKey = tenantStoragePrefix + ":vectorAllowSameAsPreviousEquipmentCheck";
        const layoutBuilder = document.querySelector(".layout-builder");
        const editorForm = document.querySelector("[data-checklist-editor-form]");
        const templateSelect = document.getElementById("templateSelect");
        const manualEntryToggles = document.querySelectorAll("[data-manual-toggle]");
        const publishScopeSelect = document.getElementById("publishScopeSelect");
        const publishAreaSelect = document.querySelector("[name='PublishOperationalAreaId']");
        const publishVehicleFunctionSelect = document.querySelector("[name='PublishVehicleFunction']");
        const publishVehicleSubtypeSelect = document.querySelector("[name='PublishVehicleSubtype']");
        const publishVehicleSelect = document.querySelector("[name='PublishVehicleId']");
        const replacementWarnings = document.querySelectorAll("[data-conflict-key]");
        const addSectionTypeSelect = document.querySelector("[data-add-section-name]");
        const addSectionCustomInput = document.querySelector("[data-add-section-custom-name]");
        const targetVehicleTypeValue = document.getElementById("targetVehicleTypeValue");
        const targetVehicleFunctionSelect = document.getElementById("targetVehicleFunctionSelect");
        const targetVehicleSubtypeSelect = document.getElementById("targetVehicleSubtypeSelect");
        const useCustomTargetVehicleTypeToggle = document.getElementById("useCustomTargetVehicleTypeToggle");
        const customTargetVehicleTypeInput = document.getElementById("customTargetVehicleTypeInput");
        const publishedSchematics = @Html.Raw(JsonSerializer.Serialize(schematicOptions));
        const defaultUnitSchematicKey = "@(Model.IsScratchBuildMode ? string.Empty : Model.DefaultUnitSchematicKey)";

        function syncTargetVehicleTypeValue() {
            if (!targetVehicleTypeValue) {
                return;
            }

            if (useCustomTargetVehicleTypeToggle?.checked) {
                targetVehicleTypeValue.value = customTargetVehicleTypeInput?.value?.trim() || "";
                return;
            }

            targetVehicleTypeValue.value =
                targetVehicleSubtypeSelect?.value ||
                targetVehicleFunctionSelect?.value ||
                "";
        }

        function syncTargetSubtypeOptions() {
            const selectedFunction = targetVehicleFunctionSelect?.value || "";
            const selectedSubtype = targetVehicleSubtypeSelect?.value || "";
            let selectedSubtypeVisible = !selectedSubtype;

            targetVehicleSubtypeSelect?.querySelectorAll("option").forEach(function (option) {
                const optionFunction = option.dataset.function || "";
                const shouldShow = !option.value || !selectedFunction || optionFunction === selectedFunction;
                option.hidden = !shouldShow;
                option.disabled = !shouldShow;
                if (shouldShow && option.value === selectedSubtype) {
                    selectedSubtypeVisible = true;
                }
            });

            if (!selectedSubtypeVisible && targetVehicleSubtypeSelect) {
                targetVehicleSubtypeSelect.value = "";
            }

            syncTargetVehicleTypeValue();
        }

        function setManualEntryState(toggle) {
            const group = toggle.dataset.manualToggle;
            const isManual = toggle.checked;
            const select = document.querySelector(`[data-manual-select="${group}"]`);
            const fields = document.querySelectorAll(`[data-manual-field="${group}"]`);

            if (select) {
                select.disabled = isManual;
            }

            fields.forEach(function (field) {
                field.classList.toggle("is-hidden", !isManual);
                field.querySelectorAll("input, select, textarea").forEach(function (input) {
                    input.disabled = !isManual;
                    if (isManual && !input.value && select) {
                        input.value = select.value;
                    }
                });
            });
        }

        manualEntryToggles.forEach(function (toggle) {
            setManualEntryState(toggle);
            toggle.addEventListener("change", function () {
                setManualEntryState(toggle);
                syncTargetVehicleTypeValue();
            });
        });

        syncTargetSubtypeOptions();
        targetVehicleFunctionSelect?.addEventListener("change", syncTargetSubtypeOptions);
        targetVehicleSubtypeSelect?.addEventListener("change", syncTargetVehicleTypeValue);
        customTargetVehicleTypeInput?.addEventListener("input", syncTargetVehicleTypeValue);

        function syncPublishTargets() {
            const selectedScope = publishScopeSelect?.value || "All operational areas";
            document.querySelectorAll("[data-publish-target]").forEach(function (target) {
                target.classList.toggle("is-hidden", target.dataset.publishTarget !== selectedScope);
            });

            const warningKey = selectedReplacementWarningKey(selectedScope);
            replacementWarnings.forEach(function (warning) {
                warning.hidden = warning.dataset.conflictKey !== warningKey;
            });
        }

        function selectedReplacementWarningKey(selectedScope) {
            if (selectedScope === "Specific base") {
                return publishAreaSelect?.value ? `OperationalArea:${publishAreaSelect.value}` : "";
            }

            if (selectedScope === "Vehicle function") {
                return publishVehicleFunctionSelect?.value ? `VehicleFunction:${publishVehicleFunctionSelect.value}` : "";
            }

            if (selectedScope === "Vehicle subtype") {
                return publishVehicleSubtypeSelect?.value ? `VehicleSubtype:${publishVehicleSubtypeSelect.value}` : "";
            }

            if (selectedScope === "Specific vehicle registration") {
                return publishVehicleSelect?.value ? `Vehicle:${publishVehicleSelect.value}` : "";
            }

            return "AllAreas";
        }

        syncPublishTargets();
        publishScopeSelect?.addEventListener("change", syncPublishTargets);
        publishAreaSelect?.addEventListener("change", syncPublishTargets);
        publishVehicleFunctionSelect?.addEventListener("change", syncPublishTargets);
        publishVehicleSubtypeSelect?.addEventListener("change", syncPublishTargets);
        publishVehicleSelect?.addEventListener("change", syncPublishTargets);

        const submitResult = editorForm?.querySelector("[data-submit-result]");
        if (submitResult) {
            window.setTimeout(function () {
                submitResult.scrollIntoView({ behavior: "smooth", block: "center" });
            }, 120);
        }

        editorForm?.addEventListener("submit", function (event) {
            const submitter = event.submitter;
            const pending = editorForm.querySelector("[data-submit-progress]");
            const action = submitter?.value || "";
            if (pending) {
                pending.textContent = action === "submit-approval"
                    ? "Submitting checklist approval request..."
                    : action === "approve-publish"
                        ? "Publishing checklist for live use..."
                        : "Saving checklist draft...";
                pending.hidden = false;
            }

            editorForm.classList.add("is-submitting");
            editorForm.querySelectorAll(".action-row button").forEach(function (button) {
                button.setAttribute("aria-disabled", "true");
            });
        });

        function syncAddSectionCustomName() {
            const isCustom = addSectionTypeSelect?.value === "Custom";
            if (addSectionCustomInput) {
                addSectionCustomInput.disabled = !isCustom;
                addSectionCustomInput.placeholder = isCustom
                    ? "Type custom section name"
                    : "Select Custom to type a section name";
            }
        }

        syncAddSectionCustomName();
        addSectionTypeSelect?.addEventListener("change", syncAddSectionCustomName);

        function renumberSections() {
            document.querySelectorAll(".checklist-section-editor").forEach(function (section, index) {
                const number = section.querySelector(".visual-section-heading > span");
                if (number) {
                    number.textContent = String(index + 1);
                }

                section.querySelectorAll("[data-section-name]").forEach(function (input) {
                    input.name = `VehicleChecklistSections[${index}].${input.dataset.sectionName}`;
                });

                renumberSectionFields(section, index);
                renumberSectionNotes(section, index);
                renumberEquipmentColumns(section, index);
                renumberEquipmentRows(section, index);
                syncSectionToggle(section);
            });
            syncEmptyBuilderState();
        }

        function syncEmptyBuilderState() {
            const emptyState = layoutBuilder?.querySelector(".empty-builder-state");
            if (!emptyState) {
                return;
            }

            const hasSections = layoutBuilder.querySelector(".checklist-section-editor") !== null;
            emptyState.hidden = hasSections;
        }

        function syncSectionToggle(section) {
            const toggle = section?.querySelector('[data-action="toggle-section"]');
            if (!toggle) {
                return;
            }

            const isCollapsed = section.classList.contains("is-collapsed");
            toggle.textContent = isCollapsed ? "Open Section" : "Close Section";
            toggle.setAttribute("aria-expanded", String(!isCollapsed));
        }

        function renumberSectionFields(section, sectionIndex) {
            section.querySelectorAll("[data-field-row]").forEach(function (fieldRow, fieldIndex) {
                fieldRow.querySelectorAll("[data-field-name]").forEach(function (input) {
                    input.name = `VehicleChecklistSections[${sectionIndex}].Fields[${fieldIndex}].${input.dataset.fieldName}`;
                });
            });
        }

        function renumberSectionNotes(section, sectionIndex) {
            section.querySelectorAll("[data-section-note]").forEach(function (noteRow, noteIndex) {
                noteRow.querySelectorAll("[data-note-name]").forEach(function (input) {
                    input.name = `VehicleChecklistSections[${sectionIndex}].Notes[${noteIndex}].${input.dataset.noteName}`;
                });
            });
        }

        function createChecklistFieldRow() {
            const row = document.createElement("div");
            row.className = "field-axis-row";
            row.dataset.fieldRow = "";
            row.setAttribute("role", "row");
            row.innerHTML = `
                <label role="cell">
                    Field name
                    <input data-field-name="Label" value="New field" aria-label="New field label" />
                </label>
                <label role="cell">
                    Input type
                    <select data-field-name="Type" aria-label="New field type">
                        <option selected>Text</option>
                        <option>Number</option>
                        <option>Date</option>
                        <option>Dropdown</option>
                        <option>Checkbox</option>
                        <option>Photo Upload</option>
                        <option>Schematic Markup</option>
                        <option>Permissioned Action</option>
                    </select>
                </label>
                <div class="field-source-cell" role="cell">
                    <input type="hidden" data-field-name="Source" value="Fresh entry" />
                    <select data-field-source-select aria-label="New field source">
                        <option selected>Fresh entry</option>
                        <option>Vehicle register</option>
                        <option>Equipment register</option>
                        <option>Stock register</option>
                        <option>Medication register</option>
                        <option>Staff register</option>
                        <option>Unit Schematic library</option>
                        <option>Senior setting</option>
                        <option>Custom</option>
                    </select>
