.template-note { margin-top: 12px; padding: 12px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.72); color: #52606d; font-size: 13px; font-weight: 800; }
.builder-toolbar { display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; margin-bottom: 16px; }
.builder-toolbar p { margin: 0; color: #6b7280; font-size: 13px; font-weight: 700; }
.toolbar-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }
.fixed-blocks-note span { min-height: 40px; display: inline-flex; align-items: center; padding: 0 12px; border: 1px solid rgba(14,94,122,.22); border-radius: 8px; background: rgba(14,94,122,.06); color: #0E5E7A; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: .7px; }
.small-action, .field-toolbar button, .section-controls button { min-height: 30px; border: 1px solid rgba(66,84,102,.2); border-radius: 7px; background: #ffffff; color: #334155; font-size: 11px; font-weight: 800; padding: 0 9px; }
.checklist-section-editor { margin-top: 8px; padding: 9px 10px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: #f8fafc; }
.visual-section-heading { display: grid; grid-template-columns: 28px minmax(0, 1fr) auto; gap: 8px; align-items: center; margin-bottom: 0; }
.visual-section-heading > span { width: 28px; height: 28px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; background: #334155; color: #ffffff; font-size: 12px; font-weight: 900; }
.section-title-editor { display: grid; grid-template-columns: minmax(140px, .75fr) minmax(180px, 1.25fr); gap: 8px; }
.section-title-editor label { gap: 4px; font-size: 11px; letter-spacing: .2px; }
.section-title-editor input { min-height: 34px; padding: 0 10px; font-size: 13px; }
.section-controls { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
.section-body { margin-top: 12px; }
.checklist-section-editor.is-collapsed .section-body { display: none; }
.empty-builder-state { margin-top: 10px; padding: 14px; border: 1px dashed rgba(66,84,102,.22); border-radius: 8px; background: rgba(255,255,255,.72); color: #64748b; font-size: 13px; font-weight: 850; text-align: center; }
.builder-add-section-panel { margin-top: 10px; display: grid; grid-template-columns: minmax(160px, .8fr) minmax(180px, 1fr) auto; gap: 8px; align-items: end; padding: 10px; border: 1px dashed rgba(14,94,122,.28); border-radius: 8px; background: rgba(14,94,122,.035); }
.builder-add-section-panel label { display: flex; flex-direction: column; gap: 5px; color: #52606d; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: .3px; }
.builder-add-section-panel input, .builder-add-section-panel select { width: 100%; min-height: 34px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 10px; background: #ffffff; color: #1f2937; font-size: 13px; font-weight: 750; box-sizing: border-box; text-transform: none; letter-spacing: 0; }
.builder-add-section-panel input:disabled { background: #f1f5f9; color: #94a3b8; cursor: not-allowed; }
.section-notes-builder { margin-top: 12px; padding: 10px; border: 1px solid rgba(66,84,102,.14); border-radius: 8px; background: rgba(255,255,255,.72); }
.section-notes-heading { display: flex; justify-content: space-between; gap: 10px; align-items: center; margin-bottom: 8px; }
.section-notes-heading strong { display: block; color: #334155; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: .5px; }
.section-notes-heading span { display: block; margin-top: 2px; color: #64748b; font-size: 12px; font-weight: 750; }
.section-note-list { display: grid; gap: 8px; }
.section-note-config { display: grid; grid-template-columns: minmax(180px, 1fr) auto auto; gap: 8px; align-items: end; padding: 8px; border: 1px dashed rgba(14,94,122,.18); border-radius: 8px; background: rgba(14,94,122,.035); }
.section-note-config label { display: flex; flex-direction: column; gap: 5px; color: #52606d; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: .3px; }
.section-note-config input[type="text"], .section-note-config input:not([type]) { width: 100%; min-height: 34px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 10px; background: #ffffff; color: #1f2937; font-size: 13px; font-weight: 750; box-sizing: border-box; text-transform: none; letter-spacing: 0; }
.note-helper { align-self: center; color: #64748b; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: .35px; white-space: nowrap; }
.field-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.schematic-field-grid { grid-template-columns: minmax(0, 1fr); }
.unit-schematic-options { margin-top: 12px; display: grid; grid-template-columns: minmax(0, 1fr); gap: 8px; }
.unit-schematic-options label { display: flex; flex-direction: column; gap: 8px; color: #52606d; font-size: 13px; font-weight: 800; }
.unit-schematic-options select { width: 100%; min-height: 44px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 12px; background: #fff; color: #1f2937; font-size: 14px; box-sizing: border-box; }
.unit-schematic-options p { margin: 0; color: #64748b; font-size: 12px; font-weight: 800; }
.schematic-component-config { margin-top: 8px; padding: 8px; border: 1px solid rgba(14,94,122,.20); border-radius: 8px; background: rgba(14,94,122,.045); }
.schematic-component-config.is-hidden { display: none; }
.schematic-component-config label { display: flex; flex-direction: column; gap: 5px; color: #334155; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: .35px; }
.schematic-view-builder { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 6px; margin-top: 8px; }
.schematic-view-card { min-width: 0; padding: 7px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: #ffffff; }
.schematic-view-card strong { display: block; color: #0E5E7A; font-size: 12px; font-weight: 900; }
.schematic-view-card span { display: block; margin-top: 2px; color: #64748b; font-size: 10px; font-weight: 800; line-height: 1.25; }
.schematic-component-note { margin: 8px 0 0 0; color: #52606d; font-size: 11px; font-weight: 800; line-height: 1.35; }
.field-axis-table { border: 1px solid rgba(66,84,102,.18); border-radius: 8px; overflow: hidden; background: #ffffff; }
.field-axis-row { display: grid; grid-template-columns: minmax(220px, 1.1fr) 160px minmax(170px, .9fr) minmax(190px, 1fr) 190px; align-items: stretch; border-top: 1px solid rgba(66,84,102,.12); }
.field-axis-row:first-child { border-top: none; }
.field-axis-header { background: #334155; color: #ffffff; font-size: 11px; font-weight: 900; letter-spacing: .7px; text-transform: uppercase; }
