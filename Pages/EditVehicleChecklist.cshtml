            const selectedSource = sourceSelect?.value || "Fresh entry";
            const isCustom = selectedSource === "Custom";
            const effectiveSource = isCustom
                ? (customSource?.value?.trim() || "Custom")
                : selectedSource;
            const isLinked = isLinkedFieldSource(selectedSource);

            if (customSource) {
                customSource.hidden = !isCustom;
                customSource.disabled = !isCustom;
            }

            if (sourceInput) {
                sourceInput.value = effectiveSource || "Fresh entry";
            }

            if (systemLinkedInput) {
                systemLinkedInput.value = String(isLinked);
