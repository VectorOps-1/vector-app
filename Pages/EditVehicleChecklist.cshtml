.live-use-row:last-child { border-bottom: 0; }
.live-use-header { background: #334155; color: #ffffff; text-transform: uppercase; letter-spacing: .6px; font-size: 11px; font-weight: 900; }
.live-use-note { padding: 8px 10px; background: #f8fafc; border-bottom: 1px solid rgba(66,84,102,.10); font-size: 12px; font-weight: 750; color: #64748b; }
.manual-entry-toggle { min-height: 44px; flex-direction: row !important; align-items: center; align-self: end; gap: 10px !important; padding: 0 12px; border: 1px solid rgba(14,94,122,.18); border-radius: 8px; background: rgba(14,94,122,.04); color: #0E5E7A !important; }
.manual-entry-toggle input { width: 18px; min-height: 18px; padding: 0; }
