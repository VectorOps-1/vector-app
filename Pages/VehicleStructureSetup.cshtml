@page
@model VehicleStructureSetupModel
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Vehicle Structure Setup";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
}

<div class="vehicle-structure-screen">
    <div class="vehicle-structure-inner">
        <img class="page-logo" src="@branding.LogoPath" alt="Company Logo" />
        <div class="client-line">Client: @Model.ClientName</div>
        <div class="home-label">Setup Wizard</div>
        <h2 class="page-title">Vehicle Structure</h2>
        <p class="page-subtitle">Create the vehicle functions and subtypes this company uses. These values drive vehicle register dropdowns, checklist publish targets, and default schematic assignment.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message" data-action-status data-confirmation-duration="1800">@Model.StatusMessage</div>
        }

        <section class="setup-card">
            <div class="section-label">Vehicle functions</div>
            <p class="section-help">Examples: Ambulance, Response Vehicle. Do not add actual vehicles here.</p>
            <form method="post" asp-page-handler="AddFunction" class="setup-form">
                <label>
                    Function name
                    <input asp-for="FunctionName" type="text" placeholder="Example: Ambulance" />
                    <span asp-validation-for="FunctionName"></span>
                </label>
                <label>
                    Notes
                    <input asp-for="FunctionNotes" type="text" placeholder="Optional internal note" />
                </label>
                <button type="submit">Add Function</button>
            </form>
        </section>

        <section class="setup-card">
            <div class="section-label">Client-defined subtypes</div>
            <p class="section-help">Examples: Operational Ambulance, IFT Ambulance, Pickup RV, ALS Response Vehicle.</p>
            <form method="post" asp-page-handler="AddSubtype" class="setup-form">
                <label>
                    Parent function
                    <select asp-for="SubtypeFunctionSetupId" asp-items="Model.FunctionOptions">
                        <option value="">Select function</option>
                    </select>
                    <span asp-validation-for="SubtypeFunctionSetupId"></span>
                </label>
                <label>
                    Subtype name
                    <input asp-for="SubtypeName" type="text" placeholder="Example: IFT Ambulance" />
                    <span asp-validation-for="SubtypeName"></span>
                </label>
                <label>
                    Notes
                    <input asp-for="SubtypeNotes" type="text" placeholder="Optional internal note" />
                </label>
                <button type="submit">Add Subtype</button>
            </form>
        </section>

        <section class="setup-card">
            <div class="section-label">Optional default unit schematics</div>
            <p class="section-help">Product schematics stay global. These links are company-owned assignment rules and can be changed later in the Unit Schematic Library.</p>
            <div class="default-grid">
                <form method="post" asp-page-handler="SaveFunctionSchematic" class="setup-form compact">
                    <label>
                        Function
                        <select asp-for="DefaultFunctionSetupId" asp-items="Model.FunctionOptions">
                            <option value="">Select function</option>
                        </select>
                    </label>
                    <label>
                        Default schematic
                        <select asp-for="DefaultFunctionSchematicKey" asp-items="Model.SchematicOptions">
                            <option value="">No default schematic</option>
                        </select>
                    </label>
                    <button type="submit">Save Function Default</button>
                </form>

                <form method="post" asp-page-handler="SaveSubtypeSchematic" class="setup-form compact">
                    <label>
                        Subtype
                        <select asp-for="DefaultSubtypeSetupId" asp-items="Model.SubtypeOptions">
                            <option value="">Select subtype</option>
                        </select>
                    </label>
                    <label>
                        Default schematic
                        <select asp-for="DefaultSubtypeSchematicKey" asp-items="Model.SchematicOptions">
                            <option value="">No default schematic</option>
                        </select>
                    </label>
                    <button type="submit">Save Subtype Default</button>
                </form>
            </div>
        </section>

        <section class="setup-card">
            <div class="section-heading-row">
                <div>
                    <div class="section-label">Configured vehicle structure</div>
                    <p class="section-help">This is the current source list for vehicle functions and subtypes.</p>
                </div>
                <strong>@Model.FunctionRows.Count function@(Model.FunctionRows.Count == 1 ? "" : "s")</strong>
            </div>

            @if (Model.FunctionRows.Count == 0)
            {
                <div class="empty-state">No vehicle functions have been configured yet.</div>
            }
            else
            {
                <div class="structure-list">
                    @foreach (var function in Model.FunctionRows)
                    {
                        <details class="structure-group" open>
                            <summary>
                                <span>@function.Name</span>
                                <strong>@function.Subtypes.Count subtype@(function.Subtypes.Count == 1 ? "" : "s")</strong>
                            </summary>
                            <div class="default-line">Default schematic: @function.DefaultSchematic</div>
                            @if (function.Subtypes.Count == 0)
                            {
                                <div class="empty-subtype">No subtypes under this function yet.</div>
                            }
                            else
                            {
                                <div class="subtype-table">
                                    <div class="subtype-row heading">
                                        <span>Subtype</span>
                                        <span>Default schematic</span>
                                    </div>
                                    @foreach (var subtype in function.Subtypes)
                                    {
                                        <div class="subtype-row">
                                            <span>@subtype.Name</span>
                                            <span>@subtype.DefaultSchematic</span>
                                        </div>
                                    }
                                </div>
                            }
                        </details>
                    }
                </div>
            }
        </section>

        <form method="post" asp-page-handler="CompleteStep" class="complete-form">
            <a class="secondary-btn" asp-page="/SetupWizard">Back to Setup Wizard</a>
            <button class="primary-btn" type="submit">Complete Vehicle Structure Step</button>
        </form>
    </div>
</div>

<style>
.vehicle-structure-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.vehicle-structure-inner { width: 100%; max-width: 1120px; margin: 0 auto; padding: 36px 20px 70px; text-align: center; box-sizing: border-box; }
.page-logo { display: block; width: 260px; max-width: 72%; max-height: 150px; margin: 0 auto 12px; object-fit: contain; }
.client-line { margin-bottom: 14px; color: #6b7280; font-size: 12px; font-weight: 800; }
.home-label, .section-label { color: #52606d; font-size: 12px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
.home-label { margin-bottom: 10px; }
.page-title { margin: 0 0 8px; color: #10233f; font-size: 32px; font-weight: 900; }
.page-subtitle { width: min(820px, 96%); margin: 0 auto 22px; color: #5f6b7a; font-size: 16px; font-weight: 700; line-height: 1.45; }
.status-message { width: min(820px, 96%); margin: 0 auto 16px; padding: 12px 16px; border: 1px solid rgba(31,111,91,.24); border-radius: 8px; background: rgba(31,111,91,.08); color: #1f6f5b; font-weight: 900; }
.setup-card { margin: 0 auto 16px; padding: 18px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.8); text-align: left; box-sizing: border-box; }
.section-help { margin: 6px 0 14px; color: #64748b; font-size: 13px; font-weight: 800; line-height: 1.45; }
.setup-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)) auto; gap: 12px; align-items: end; }
.setup-form.compact { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto; }
.setup-form label { display: flex; flex-direction: column; gap: 7px; color: #52606d; font-size: 12px; font-weight: 900; }
.setup-form input, .setup-form select { width: 100%; min-height: 42px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 12px; color: #10233f; background: #fff; font-size: 14px; box-sizing: border-box; }
.setup-form button, .primary-btn, .secondary-btn { min-height: 42px; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; font-weight: 900; text-decoration: none; white-space: nowrap; }
.setup-form button, .primary-btn { border: none; background: #126C84; color: #fff; padding: 0 16px; }
.secondary-btn { border: 1px solid rgba(47,128,168,.24); background: #fff; color: #126C84; padding: 0 16px; }
.default-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
.section-heading-row { display: flex; justify-content: space-between; gap: 14px; align-items: flex-start; }
.section-heading-row strong { color: #52606d; font-size: 13px; font-weight: 900; }
.empty-state, .empty-subtype { border: 1px dashed rgba(66,84,102,.24); border-radius: 8px; padding: 14px; color: #64748b; font-weight: 900; text-align: center; }
.structure-list { display: grid; gap: 10px; }
.structure-group { border: 1px solid rgba(66,84,102,.16); border-radius: 8px; overflow: hidden; background: #fff; }
.structure-group summary { display: flex; justify-content: space-between; gap: 12px; padding: 12px 14px; cursor: pointer; color: #10233f; font-weight: 900; }
.structure-group summary strong { color: #52606d; font-size: 12px; text-transform: uppercase; }
.default-line { padding: 0 14px 12px; color: #52606d; font-size: 13px; font-weight: 800; }
.subtype-table { border-top: 1px solid rgba(66,84,102,.14); }
.subtype-row { display: grid; grid-template-columns: 1fr 1.3fr; gap: 10px; padding: 10px 14px; border-top: 1px solid rgba(66,84,102,.08); color: #10233f; font-size: 13px; font-weight: 800; }
.subtype-row.heading { background: #334155; color: #fff; font-size: 11px; font-weight: 900; letter-spacing: .6px; text-transform: uppercase; }
.complete-form { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 18px; }
@@media (max-width: 860px) {
    .setup-form,
    .setup-form.compact,
    .default-grid,
    .complete-form,
    .subtype-row { grid-template-columns: 1fr; }
    .setup-card { padding: 14px; }
}
</style>
