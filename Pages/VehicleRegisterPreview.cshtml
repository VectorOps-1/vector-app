@page
@model VehicleRegisterPreviewModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Vehicle Register Preview";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="preview-screen">
    <div class="preview-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Generated Vehicle Register Preview</div>
        <h2 class="page-title">Review Vehicle Records</h2>
        <p class="page-subtitle">Source file: @Model.FileName</p>

        <div class="preview-layout">
            <section class="register-panel">
                <div class="table-wrap">
                    <table class="register-table">
                        <thead>
                            <tr>
                                <th>Callsign</th>
                                <th>Registration</th>
                                <th>Make / Model</th>
                                <th>Location</th>
                                <th>Status</th>
                                <th>Next Service</th>
                                <th>Published Schematic</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><input value="A101" /></td>
                                <td><input value="123456" /></td>
                                <td><input value="Toyota HiAce" /></td>
                                <td><input value="Main Base" /></td>
                                <td><input value="Operational" /></td>
                                <td><input type="date" /></td>
                                <td>
                                    <select>
                                        @foreach (var schematic in Model.PublishedSchematics)
                                        {
                                            <option value="@schematic.Key">@schematic.DisplayName</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                            <tr>
                                <td><input value="A102" /></td>
                                <td><input value="654321" /></td>
                                <td><input value="Toyota Land Cruiser" /></td>
                                <td><input value="Standby Post" /></td>
                                <td><input value="Maintenance" /></td>
                                <td><input type="date" /></td>
                                <td>
                                    <select>
                                        @foreach (var schematic in Model.PublishedSchematics)
                                        {
                                            <option value="@schematic.Key">@schematic.DisplayName</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <aside class="mapping-panel">
                <div class="mapping-title">Detected fields</div>
                <div class="mapping-item">Callsign</div>
                <div class="mapping-item">Registration</div>
                <div class="mapping-item">Make / Model</div>
                <div class="mapping-item">Location</div>
                <div class="mapping-item">Status</div>
                <div class="mapping-item">Next Service Date</div>
                <div class="mapping-item">Linked Schematic</div>
            </aside>
        </div>

        <div class="action-row">
            <a class="menu-btn vehicle-btn" href="/UploadVehicleRegister">Upload Different File</a>
            <button class="menu-btn equipment-btn" type="button" data-action-confirmation data-confirmation-message="Vehicle register saved.">Save Vehicle Register</button>
        </div>
    </div>
</div>

<style>
.preview-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.preview-inner {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 300px;
    max-width: 72%;
    max-height: 170px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.preview-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 24px;
    align-items: start;
    text-align: left;
}

.register-panel,
.mapping-panel {
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.58);
    padding: 22px;
}

.table-wrap {
    overflow-x: auto;
}

.register-table {
    width: 100%;
    min-width: 840px;
    border-collapse: collapse;
}

.register-table th {
    padding: 12px 10px;
    border-bottom: 1px solid rgba(66, 84, 102, 0.24);
    font-size: 13px;
    font-weight: 800;
    color: #425466;
    text-align: left;
}

.register-table td {
    padding: 12px 10px;
    border-bottom: 1px solid rgba(66, 84, 102, 0.12);
}

.register-table input,
.register-table select {
    width: 100%;
    min-width: 120px;
    padding: 10px 12px;
    border: 1px solid rgba(66, 84, 102, 0.22);
    border-radius: 8px;
    font-size: 14px;
    color: #111827;
    box-sizing: border-box;
}

.mapping-title {
    margin-bottom: 14px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.mapping-item {
    padding: 12px 0;
    border-bottom: 1px solid rgba(66, 84, 102, 0.14);
    font-size: 14px;
    font-weight: 700;
    color: #425466;
}

.action-row {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    flex-wrap: wrap;
}

.action-row .menu-btn {
    min-width: 260px;
    border: none;
}

@@media (max-width: 860px) {
    .preview-layout {
        grid-template-columns: 1fr;
    }
}
</style>
