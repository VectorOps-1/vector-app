@page
@model VehicleSchematicLibraryModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Vehicle Schematic Library";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="schematic-library-screen">
    <div class="schematic-library-inner">
        <header class="library-header">
            <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
            <div class="client-line">Client: @companyName</div>
            <div class="home-label">Master Setup</div>
            <h2 class="page-title">Vehicle Schematic Library</h2>
            <p class="page-subtitle">Published schematics can be linked to registered vehicles for live inspections.</p>
        </header>

        <div class="library-summary">
            <div>
                <span>@Model.Schematics.Count</span>
                <p>Total schematics</p>
            </div>
            <div>
                <span>@Model.PublishedCount</span>
                <p>Published</p>
            </div>
            <div>
                <span>@(Model.Schematics.Select(schematic => schematic.Category).Distinct().Count())</span>
                <p>Categories</p>
            </div>
        </div>

        <div class="library-actions">
            <a class="menu-btn vehicle-btn" href="/VehicleRegister">Vehicle Register</a>
            <a class="menu-btn equipment-btn" href="/MasterSetup">Back to Master Setup</a>
        </div>

        @foreach (var category in Model.Schematics.GroupBy(schematic => schematic.Category))
        {
            <section class="category-section">
                <div class="category-heading">
                    <h3>@category.Key</h3>
                    <span>@category.Count() schematic types</span>
                </div>

                <div class="schematic-grid">
                    @foreach (var schematic in category)
                    {
                        <article class="schematic-card">
                            <div class="card-heading">
                                <div>
                                    <p>@schematic.Subtype</p>
                                    <h4>@schematic.DisplayName</h4>
                                </div>
                                <span class="status-pill @(schematic.IsPublished ? "published" : "draft")">@schematic.Status</span>
                            </div>

                            <div class="schematic-preview" data-schematic="@schematic.Key" aria-label="@schematic.DisplayName preview">
                                <div class="schematic-roof"></div>
                                <div class="schematic-body"></div>
                                <div class="schematic-cab"></div>
                                <div class="schematic-window front-window"></div>
                                <div class="schematic-window rear-window"></div>
                                <div class="schematic-wheel front-wheel"></div>
                                <div class="schematic-wheel rear-wheel"></div>
                            </div>

                            <dl class="schematic-meta">
                                <div>
                                    <dt>Body style</dt>
                                    <dd>@schematic.BodyStyle</dd>
                                </div>
                                <div>
                                    <dt>Make / model range</dt>
                                    <dd>@schematic.MakeModel</dd>
                                </div>
                                <div>
                                    <dt>Inspection views</dt>
                                    <dd>@(string.Join(", ", schematic.Views))</dd>
                                </div>
                                <div>
                                    <dt>Live use</dt>
                                    <dd>@schematic.LiveUse</dd>
                                </div>
                            </dl>
                        </article>
                    }
                </div>
            </section>
        }
    </div>
</div>

<style>
.schematic-library-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.schematic-library-inner { width: 100%; max-width: 1180px; margin: 0 auto; padding: 34px 20px 80px 20px; box-sizing: border-box; }
.library-header { text-align: center; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 28px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(720px, 94%); margin: 0 auto 22px auto; font-size: 15px; font-weight: 600; color: #6b7280; }
.library-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin: 0 auto 18px auto; max-width: 760px; }
.library-summary div { padding: 16px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.68); text-align: center; }
.library-summary span { display: block; margin-bottom: 4px; color: #0E5E7A; font-size: 26px; font-weight: 900; }
.library-summary p { margin: 0; color: #52606d; font-size: 13px; font-weight: 800; }
.library-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 14px; margin-bottom: 26px; }
.library-actions .menu-btn { min-width: 240px; }
.category-section { margin-top: 20px; }
.category-heading { display: flex; justify-content: space-between; gap: 16px; align-items: flex-end; margin-bottom: 12px; text-align: left; }
.category-heading h3 { margin: 0; color: #1f2937; font-size: 20px; font-weight: 900; }
.category-heading span { color: #64748b; font-size: 13px; font-weight: 800; }
.schematic-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
.schematic-card { padding: 16px; border: 1px solid rgba(66, 84, 102, 0.16); border-radius: 8px; background: rgba(255, 255, 255, 0.72); box-sizing: border-box; }
.card-heading { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
.card-heading p { margin: 0 0 4px 0; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; }
.card-heading h4 { margin: 0; color: #1f2937; font-size: 17px; font-weight: 900; }
.status-pill { display: inline-flex; align-items: center; min-height: 28px; padding: 0 10px; border-radius: 999px; font-size: 12px; font-weight: 900; white-space: nowrap; }
.status-pill.published { color: #1f6f5b; background: rgba(31, 111, 91, 0.12); border: 1px solid rgba(31, 111, 91, 0.24); }
.status-pill.draft { color: #7c5b16; background: rgba(154, 115, 28, 0.12); border: 1px solid rgba(154, 115, 28, 0.24); }
.schematic-preview { position: relative; height: 170px; margin-bottom: 14px; border: 1px dashed rgba(66, 84, 102, 0.34); border-radius: 8px; background: #f8fafc; overflow: hidden; }
.schematic-body { position: absolute; left: 9%; right: 8%; bottom: 46px; height: 50px; border: 4px solid #334155; border-radius: 22px 18px 14px 14px; background: #ffffff; }
.schematic-roof { position: absolute; left: 22%; right: 24%; bottom: 96px; height: 32px; border: 4px solid #334155; border-bottom: 0; border-radius: 30px 30px 0 0; }
.schematic-cab { position: absolute; right: 13%; bottom: 70px; width: 18%; height: 54px; border-left: 4px solid #334155; transform: skewX(-18deg); }
.schematic-window { position: absolute; bottom: 84px; height: 26px; border: 3px solid #52606d; border-radius: 8px; }
.front-window { right: 18%; width: 15%; transform: skewX(-14deg); }
.rear-window { left: 28%; width: 27%; }
.schematic-wheel { position: absolute; bottom: 28px; width: 34px; height: 34px; border: 5px solid #1f2937; border-radius: 50%; background: #ffffff; }
.front-wheel { right: 18%; }
.rear-wheel { left: 18%; }
.schematic-preview[data-schematic="ift-ambulance"] .schematic-roof { left: 27%; right: 30%; height: 28px; }
.schematic-preview[data-schematic="icu-ambulance"] .schematic-body { left: 7%; right: 6%; height: 58px; }
.schematic-preview[data-schematic="icu-ambulance"] .schematic-roof { left: 18%; right: 20%; height: 36px; }
.schematic-preview[data-schematic="response-pickup"] .schematic-body { left: 15%; right: 14%; bottom: 52px; height: 42px; border-radius: 28px 28px 14px 14px; }
.schematic-preview[data-schematic="response-pickup"] .schematic-roof { left: 35%; right: 34%; bottom: 94px; height: 28px; border-radius: 20px 20px 0 0; }
.schematic-preview[data-schematic="response-pickup"] .schematic-cab { right: 24%; bottom: 72px; width: 14%; height: 46px; }
.schematic-preview[data-schematic="response-pickup"] .rear-window { left: 39%; width: 15%; }
.schematic-preview[data-schematic="response-pickup"] .front-window { right: 29%; width: 11%; }
.schematic-preview[data-schematic="response-sedan"] .schematic-body { left: 16%; right: 14%; bottom: 54px; height: 36px; border-radius: 32px 32px 14px 14px; }
.schematic-preview[data-schematic="response-sedan"] .schematic-roof { left: 34%; right: 31%; bottom: 90px; height: 28px; border-radius: 24px 24px 0 0; }
.schematic-preview[data-schematic="response-sedan"] .schematic-cab { right: 21%; bottom: 72px; width: 16%; height: 42px; }
.schematic-preview[data-schematic="response-sedan"] .rear-window { left: 37%; width: 17%; }
.schematic-preview[data-schematic="response-sedan"] .front-window { right: 26%; width: 12%; }
.schematic-preview[data-schematic="rescue-vehicle"] .schematic-body { left: 8%; right: 8%; height: 60px; border-radius: 12px; }
.schematic-preview[data-schematic="rescue-vehicle"] .schematic-roof { left: 14%; right: 16%; height: 34px; border-radius: 8px 8px 0 0; }
.schematic-meta { display: grid; gap: 10px; margin: 0; text-align: left; }
.schematic-meta div { display: grid; grid-template-columns: 140px minmax(0, 1fr); gap: 10px; }
.schematic-meta dt { color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; }
.schematic-meta dd { margin: 0; color: #334155; font-size: 13px; font-weight: 700; }
@@media (max-width: 860px) { .library-summary, .schematic-grid { grid-template-columns: 1fr; } .category-heading { align-items: flex-start; flex-direction: column; } .schematic-meta div { grid-template-columns: 1fr; gap: 4px; } }
</style>
