@page
@model vector_app_local.Pages.EquipmentModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Equipment";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
}

<div class="module-screen">
    <div class="module-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Operations Module</div>
        <h2 class="page-title">Equipment</h2>
        <p class="page-subtitle">Choose the exact equipment action from one place.</p>

        <div class="module-grid">
            <a class="module-card primary" href="/EquipmentRegister?view=register">
                <strong>Equipment Register</strong>
                <span>Open the grouped register. Use the search field inside the register for name, S/N / asset ID, model, location, vehicle, movement, or status.</span>
            </a>

            <a class="module-card primary" href="/AddItem?type=equipment">
                <strong>Add New Equipment</strong>
                <span>Add one equipment item into the register</span>
            </a>

            <a class="module-card" href="/MoveAsset?asset=equipment" data-move-asset="equipment">
                <strong>Move / Reallocate</strong>
                <span>Move equipment between vehicles, bases, stores, or operational areas</span>
            </a>

            <a class="module-card" href="/EquipmentService">
                <strong>Update Service Dates</strong>
                <span>Update next service dates after maintenance, repairs, or returned service items</span>
            </a>

            <a class="module-card danger" href="/ReportIssue?module=equipment">
                <strong>Report Issue</strong>
                <span>Report faults, missing items, damaged equipment, or readiness problems</span>
            </a>
        </div>
    </div>
</div>

<style>
.module-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.module-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.module-grid {
    gap: 24px;
    row-gap: 24px;
}

.module-grid .menu-btn {
    min-width: 260px;
}
</style>
