@page
@model AllocateStockModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Allocate Stock";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="queue-screen">
    <div class="queue-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Stock Control</div>
        <h2 class="page-title">Allocate Stock</h2>
        <p class="page-subtitle">Allocate registered stock by item, batch, quantity, and location after the real-world stock move.</p>

        <div class="action-row">
            <a class="menu-btn vehicle-btn" href="/StockOrders">All Stock Orders</a>
            <a class="menu-btn equipment-btn" href="/EnterStockRegister">Enter Stock Into Register</a>
        </div>

        @if (!Model.Orders.Any())
        {
            <div class="empty-panel">No registered stock orders are ready for allocation.</div>
        }
        else
        {
            <div class="order-list">
                @foreach (var order in Model.Orders)
                {
                    <a class="order-card" href="/StockOrderAction?orderId=@order.Id">
                        <div class="order-title">Order #@order.Id - @order.SupplierName</div>
                        <div class="order-meta">
                            <div>Status: @order.Status</div>
                            <div>Requested by: @order.RequestedByName</div>
                            <div>Lines: @order.LineCount</div>
                            <div>Total quantity requested: @order.QuantityRequested</div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

<style>
.queue-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.queue-inner { width: 100%; max-width: 1000px; margin: 0 auto; text-align: center; padding: 40px 20px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 30px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(720px, 94%); margin: 0 auto 24px auto; font-size: 16px; font-weight: 600; color: #6b7280; }
.action-row { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; margin-bottom: 24px; }
.action-row .menu-btn { min-width: 230px; }
.empty-panel { width: min(760px, 94%); margin: 0 auto; padding: 22px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.68); font-weight: 800; color: #52606d; }
.order-list { display: grid; gap: 16px; width: min(860px, 94%); margin: 0 auto; text-align: left; }
.order-card { display: block; padding: 18px 20px; border: 1px solid rgba(47,128,168,.24); border-radius: 8px; background: rgba(255,255,255,.78); color: #1f2937; text-decoration: none; box-shadow: 0 14px 28px rgba(47,128,168,.10); }
.order-title { margin-bottom: 10px; font-size: 18px; font-weight: 900; }
.order-meta { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px 16px; font-size: 13px; font-weight: 700; color: #52606d; }
@@media (max-width: 760px) { .order-meta { grid-template-columns: 1fr; } .action-row .menu-btn { width: 100%; } }
</style>
