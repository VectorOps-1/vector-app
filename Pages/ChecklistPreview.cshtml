@page
@model ChecklistPreviewModel
@{
    ViewData["Title"] = "Checklist Source Uploaded";
}

<div class="source-review-screen">
    <div class="source-review-panel">
        <div class="home-label">Checklist Management</div>
        <h2 class="page-title">Checklist Source Uploaded</h2>
        <p class="page-subtitle">The uploaded file has been stored as setup source material. Build or edit the live checklist from Checklist Management.</p>

        <div class="source-summary">
            <strong>Source file</strong>
            <span>@Model.FileName</span>
        </div>

        <div class="action-row">
            <a class="menu-btn vehicle-btn" href="/EditChecklist">Open Checklist Management</a>
            <a class="menu-btn equipment-btn" href="/EditVehicleChecklist?checklist=daily-vehicle&mode=build">Build New Checklist</a>
        </div>
    </div>
</div>

<style>
.source-review-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: center; padding: 28px 16px; box-sizing: border-box; }
.source-review-panel { width: min(760px, 100%); padding: 28px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: rgba(255,255,255,.74); text-align: center; box-sizing: border-box; }
.home-label { margin-bottom: 10px; color: #5f6b7a; font-size: 13px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; }
.page-title { margin: 0 0 8px 0; color: #1f2937; font-size: 28px; font-weight: 900; }
.page-subtitle { margin: 0 auto 20px auto; max-width: 620px; color: #64748b; font-size: 15px; font-weight: 700; line-height: 1.45; }
.source-summary { display: grid; gap: 5px; margin: 0 auto 22px auto; padding: 14px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: #f8fafc; text-align: left; }
.source-summary strong { color: #334155; font-size: 12px; font-weight: 900; letter-spacing: .8px; text-transform: uppercase; }
.source-summary span { color: #0f172a; font-size: 15px; font-weight: 800; overflow-wrap: anywhere; }
.action-row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.action-row .menu-btn { width: 100%; border: none; }
@@media (max-width: 700px) { .action-row { grid-template-columns: 1fr; } }
</style>
