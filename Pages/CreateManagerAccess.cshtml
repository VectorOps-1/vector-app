.access-table th {
    padding: 11px 12px;
    background: #314258;
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .6px;
    text-align: left;
    text-transform: uppercase;
}

.access-table td {
    padding: 12px;
    border-top: 1px solid rgba(66, 84, 102, 0.12);
    color: #1f2937;
    font-weight: 800;
    vertical-align: top;
}

.access-table td strong,
.access-table td span,
.access-table td small {
    display: block;
}

.access-table td span,
.access-table td small {
