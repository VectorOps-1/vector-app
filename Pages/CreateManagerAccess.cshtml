button:disabled,
.menu-btn:disabled {
    cursor: not-allowed;
    opacity: .55;
}

.action-row {
    display: flex;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
}

.action-row .menu-btn {
    min-width: 240px;
    border: none;
}

.field-validation,
.validation-summary {
    color: #991b1b;
    font-size: 13px;
    font-weight: 700;
}

@@media (max-width: 820px) {
    .permission-setup-warning {
        align-items: stretch;
        flex-direction: column;
    }

    .permission-setup-warning .menu-btn {
        width: 100%;
    }

    .selector-grid,
    .form-grid,
    .profile-grid,
    .permission-overview-grid,
    .permission-grid {
        grid-template-columns: 1fr;
    }
}
</style>
