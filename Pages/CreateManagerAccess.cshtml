.status-pill.active {
    background: #dcefe9;
    color: #00684f !important;
}

.status-pill.inactive {
    background: #f6e3e3;
    color: #943939 !important;
}

.row-action {
    display: inline-flex;
    min-width: 70px;
    min-height: 34px;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
