@page
@model CreateManagerAccessModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Access Setup";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;

    static string TextOrDefault(string? value, string fallback = "Not set")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    static string DateOrDefault(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("yyyy-MM-dd") : "Not set";
    }
}

<div class="access-screen">
    <div class="access-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Area / Manager Control</div>
        <h2 class="page-title">Access Setup</h2>
        <p class="page-subtitle">Select an existing staff profile from the register, then assign access level, area control, and granular action permissions.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message" data-action-status>@Model.StatusMessage</div>
        }

        <section class="form-panel permission-setup-warning">
            <div>
                <div class="section-label">Saved Permission Baseline</div>
                @if (Model.ProfilesMissingSavedPermissionsCount > 0)
                {
                    <h3>@Model.ProfilesMissingSavedPermissionsCount profile@(Model.ProfilesMissingSavedPermissionsCount == 1 ? string.Empty : "s") need saved action permissions</h3>
                    <p class="source-note">Permission-sensitive testing uses saved permission rows only. Initialize missing profiles before testing role access.</p>
                }
                else
                {
                    <h3>Saved action permissions are initialized for editable profiles</h3>
                    <p class="source-note">Use force defaults only when you need a clean role-default baseline before testing permissions again.</p>
                }
            </div>
            <div class="permission-baseline-actions">
                @if (Model.ProfilesMissingSavedPermissionsCount > 0)
                {
                    <form method="post" asp-page-handler="InitializePermissionDefaults">
                        <button class="menu-btn equipment-btn" type="submit">Initialize Missing Defaults</button>
                    </form>
                }
                <form method="post" asp-page-handler="ForcePermissionDefaults">
                    <button class="menu-btn vehicle-btn" type="submit">Force Role Defaults</button>
                </form>
            </div>
        </section>

        <form method="get" class="access-form selector-form" data-staff-profile-form>
            <section class="form-panel">
                <div class="section-label">Select Existing Staff Profile</div>
                <div class="selector-grid">
                    <div class="field-group">
                        <label class="field-label" asp-for="StaffUserId">Staff register source</label>
                        <select class="text-input" asp-for="StaffUserId" asp-items="Model.StaffOptions" data-skip-na data-staff-profile-select>
                            <option value="">Select staff member</option>
                        </select>
                    </div>
                    <input type="hidden" asp-for="AccessLevel" />
                    <button class="menu-btn equipment-btn selector-button" type="submit">Open Access Assignment</button>
                </div>
                <p class="source-note">The dropdown only shows profiles you are allowed to edit. Names, email addresses, staff IDs, clinical qualification / scope, practitioner numbers, licensing, CPD, and current area are pulled from the staff register.</p>
            </section>
        </form>

        <div id="accessAssignment" class="assignment-anchor">
            @if (Model.SelectedStaff is null)
            {
                <section class="form-panel empty-panel">
                    <div class="section-label">Access Assignment</div>
                    <p>Select a staff member above before changing access. This prevents creating manager logins that do not belong to a real staff profile.</p>
                    <div class="permission-overview">
                        <div class="section-label">Granular Permission Controls</div>
                        <div class="permission-overview-grid">
                            @foreach (var permissionGroup in Model.PermissionGroups)
                            {
                                <div class="permission-overview-item">
                                    <strong>@permissionGroup.Name</strong>
                                    <span>@permissionGroup.Options.Count action control@(permissionGroup.Options.Count == 1 ? string.Empty : "s")</span>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            }
            else
            {
                var staff = Model.SelectedStaff;
                <form method="post" class="access-form">
                    <input type="hidden" asp-for="StaffUserId" />

                    <section class="form-panel">
                        <div class="section-label">Register-Controlled Identity</div>
                        <div class="profile-grid">
                            <div><span>Full name</span><strong>@staff.FullName</strong></div>
                            <div><span>Email</span><strong>@staff.Email</strong></div>
                            <div><span>Cell number</span><strong>@TextOrDefault(staff.CellNumber)</strong></div>
                            <div><span>Staff ID</span><strong>@TextOrDefault(staff.StaffIdentifier)</strong></div>
                            <div><span>National ID</span><strong>@TextOrDefault(staff.NationalId)</strong></div>
                            <div><span>Clinical qualification / scope</span><strong>@TextOrDefault(staff.QualificationFunction)</strong></div>
                            <div><span>Practitioner Number</span><strong>@TextOrDefault(staff.PractitionerNumber)</strong></div>
                            <div><span>Annual licence expiry</span><strong data-date-status-field="licence">@DateOrDefault(staff.AnnualLicenseExpiryDate)</strong></div>
                            <div><span>CPD status</span><strong>@TextOrDefault(staff.CpdComplianceStatus, "N/A")</strong></div>
                            <div><span>CPD valid until</span><strong data-date-status-field="cpd">@DateOrDefault(staff.CpdComplianceExpiryDate)</strong></div>
                            <div><span>Current access role</span><strong>@staff.RoleName</strong></div>
                            <div><span>Current assigned area</span><strong>@staff.AssignedArea</strong></div>
                        </div>
                    </section>

                    <section class="form-panel">
                        <div class="section-label">Access Assignment</div>
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
                        <div class="form-grid">
                            <div class="field-group">
                                <label class="field-label" asp-for="AccessLevel">Access level</label>
                                <select class="text-input" asp-for="AccessLevel" asp-items="Model.AccessLevelOptions" data-skip-na></select>
                                <span asp-validation-for="AccessLevel" class="field-validation"></span>
                            </div>

                            <div class="field-group">
                                <label class="field-label" asp-for="AssignedOperationalAreaId">Assigned area / base</label>
                                <select class="text-input" asp-for="AssignedOperationalAreaId" asp-items="Model.AreaOptions" data-skip-na>
                                    <option value="">No assigned area</option>
                                </select>
                                <span asp-validation-for="AssignedOperationalAreaId" class="field-validation"></span>
                            </div>

                            <label class="toggle-row">
                                <input asp-for="AccountActive" />
                                <span>Account active</span>
                            </label>
                        </div>
                        <p class="source-note">The access level sets the broad login route. The granular permission controls below decide which actions this person may perform inside that route.</p>
                    </section>

                    <section class="form-panel permissions-panel">
                        <div class="section-label">Granular Access Permission Controls</div>
                        <h3 class="panel-heading">Choose exactly what @staff.FullName may do</h3>
                        <p class="source-note">Access level controls the broad login route. These permissions control individual app actions such as register editing, checklist publishing, task management, and setup access.</p>
                        @if (!Model.SelectedStaffHasSavedPermissions)
                        {
                            <div class="locked-notice">This profile does not yet have saved action permissions. The checked boxes below are suggested defaults and only become active after you save access or initialize defaults.</div>
                        }
                        @if (!Model.CanEditSelectedStaff)
                        {
                            <div class="locked-notice">This profile is above or equal to your current access level, so its permissions are shown for reference only.</div>
                        }

                        @foreach (var permissionGroup in Model.PermissionGroups)
                        {
                            <div class="permission-group">
                                <h4>@permissionGroup.Name</h4>
                                <div class="permission-grid">
                                    @foreach (var permission in permissionGroup.Options)
                                    {
                                        <label class="permission-item">
                                            <input type="checkbox"
                                                   name="SelectedPermissionKeys"
                                                   value="@permission.Key"
                                                   checked="@Model.SelectedPermissionKeySet.Contains(permission.Key)"
                                                   disabled="@(!Model.CanEditSelectedStaff)" />
                                            <span>
                                                <strong>@permission.Name</strong>
                                                <small>@permission.Description</small>
                                            </span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    </section>

                    <div class="action-row">
                        <a class="menu-btn vehicle-btn" href="/AreaManagerControl">Back to Area / Manager Control</a>
                        <button class="menu-btn equipment-btn" type="submit" disabled="@(!Model.CanEditSelectedStaff)">Save Access</button>
                    </div>
                </form>
            }
        </div>

        <details class="form-panel access-register-panel">
            <summary class="register-heading">
                <div>
                    <div class="section-label">Access Register</div>
                    <h3>Current users, access, and assignments</h3>
                </div>
                <span>@Model.AccessRows.Count profile@(Model.AccessRows.Count == 1 ? string.Empty : "s") - open register</span>
            </summary>
            <div class="access-table-wrap">
                <table class="access-table">
                    <thead>
                        <tr>
                            <th>Person</th>
                            <th>Access permission</th>
                            <th>Assigned area</th>
                            <th>Manager scope</th>
                            <th>Action permissions</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.AccessRows)
                        {
                            <tr>
                                <td>
                                    <strong>@row.FullName</strong>
                                    <span>@TextOrDefault(row.StaffIdentifier, "Staff ID not set")</span>
                                    <small>@row.Email</small>
                                </td>
                                <td>@row.AccessRole</td>
                                <td>@row.AssignedArea</td>
                                <td>@row.ManagerScope</td>
                                <td>
                                    <strong>@row.PermissionCount permission@(row.PermissionCount == 1 ? string.Empty : "s")</strong>
                                    <span>@row.PermissionSummary</span>
                                    @if (!row.HasSavedPermissionRows)
                                    {
                                        <small class="permission-missing">Setup required before testing</small>
                                    }
                                </td>
                                <td><span class="status-pill @(row.Status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? "active" : "inactive")">@row.Status</span></td>
                                <td>
                                    @if (row.CanEdit)
                                    {
                                        <a class="row-action" href="/CreateManagerAccess?staffUserId=@row.StaffUserId&accessLevel=@row.EditAccessLevel#accessAssignment">Edit Access</a>
                                    }
                                    else
                                    {
                                        <span class="row-locked">Locked</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="source-note">Access permission is the app login role. Assigned area is the staff register assignment. Manager scope is the active area-control assignment used for operational management views.</p>
        </details>
    </div>
</div>

<script>
(() => {
    const form = document.querySelector("[data-staff-profile-form]");
    const select = document.querySelector("[data-staff-profile-select]");
    if (!form || !select) {
        return;
    }

    function buildStaffProfileUrl() {
        if (!select.value) {
            return null;
        }

        const params = new URLSearchParams(window.location.search);
        const accessLevel = form.querySelector("input[name='AccessLevel']")?.value || params.get("accessLevel");
        params.set("staffUserId", select.value);
        if (accessLevel) {
            params.set("accessLevel", accessLevel);
        }

        return window.location.pathname + "?" + params.toString() + "#accessAssignment";
    }

    function openSelectedStaff(event) {
        const targetUrl = buildStaffProfileUrl();
        if (!targetUrl) {
            event?.preventDefault();
            select.focus();
            return;
        }

        event?.preventDefault();
        window.location.assign(targetUrl);
    }

    select.addEventListener("change", openSelectedStaff);
    form.addEventListener("submit", openSelectedStaff);
})();
</script>

<style>
.access-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.access-inner {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 240px;
    max-width: 70%;
    max-height: 130px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 30px;
    font-weight: 800;
    color: #111827;
}

.page-subtitle {
    max-width: 760px;
    margin: 0 auto 24px auto;
    font-size: 16px;
    font-weight: 600;
    color: #6b7280;
}

.access-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-bottom: 18px;
}

.assignment-anchor {
    scroll-margin-top: 90px;
}

.form-panel {
    padding: 20px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.68);
    text-align: left;
}

.permission-setup-warning {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
    border-color: rgba(146, 64, 14, .24);
    background: #fff7ed;
}

.permission-setup-warning h3 {
    margin: 0 0 4px 0;
    color: #7c2d12;
    font-size: 18px;
    font-weight: 900;
}

.permission-setup-warning form {
    flex: 0 0 auto;
}

.permission-baseline-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
}

.permission-setup-warning .menu-btn {
    min-width: 230px;
    border: none;
}

.empty-panel {
    color: #5f6b7a;
    font-weight: 700;
}

.section-label {
    margin-bottom: 14px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.panel-heading {
    margin: 0 0 6px 0;
    color: #102a3a;
    font-size: 20px;
    font-weight: 900;
}

.selector-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 240px);
    gap: 14px;
    align-items: end;
}

.form-grid,
.profile-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 18px;
}

.profile-grid > div {
    min-height: 70px;
    padding: 12px;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-radius: 8px;
    background: #fff;
}

.profile-grid span {
    display: block;
    margin-bottom: 6px;
    color: #64748b;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .5px;
    text-transform: uppercase;
}

.profile-grid strong {
    color: #0f172a;
    font-size: 15px;
}

.field-group {
    text-align: left;
}

.field-label {
    display: block;
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 800;
    color: #425466;
}

.text-input {
    width: 100%;
    padding: 13px 14px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #ffffff;
    font-size: 16px;
    color: #111827;
    box-sizing: border-box;
}

.selector-button {
    width: 100%;
    min-height: 50px;
    border: none;
}

.source-note {
    margin: 12px 0 0 0;
    color: #5f6b7a;
    font-size: 13px;
    font-weight: 700;
}

.access-register-panel {
    margin-bottom: 18px;
}

.access-register-panel[open] .register-heading {
    margin-bottom: 12px;
}

.register-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 0;
    cursor: pointer;
    list-style: none;
}

.register-heading::-webkit-details-marker {
    display: none;
}

.register-heading .section-label {
    margin-bottom: 4px;
}

.register-heading h3 {
    margin: 0;
    color: #102a3a;
    font-size: 20px;
    font-weight: 900;
}

.register-heading span {
    color: #52606d;
    font-size: 13px;
    font-weight: 900;
    white-space: nowrap;
}

.access-table-wrap {
    width: 100%;
    overflow-x: auto;
    border: 1px solid rgba(66, 84, 102, 0.14);
    border-radius: 8px;
    background: #fff;
}

.access-table {
    width: 100%;
    min-width: 1060px;
