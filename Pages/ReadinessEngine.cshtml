.engine-scroll-proxy { display: none; pointer-events: none; }
.engine-scroll-proxy.is-active { display: block; position: fixed; z-index: 40; bottom: 78px; padding: 8px 10px; border: 1px solid rgba(66,84,102,.18); border-radius: 10px; background: rgba(248,250,252,.96); box-shadow: 0 10px 26px rgba(31,41,55,.18); pointer-events: auto; }
.engine-scroll-track { width: 100%; height: 18px; overflow-x: auto; overflow-y: hidden; scrollbar-width: auto; }
.engine-scroll-spacer { height: 1px; min-width: 100%; }
.engine-table { width: 1500px; border-collapse: collapse; table-layout: fixed; }
.scoring-table { width: 2520px; }
.rule-col-on { width: 56px; }
.rule-col-asset { width: 150px; }
.rule-col-section { width: 160px; }
.rule-col-item { width: 230px; }
.rule-col-field { width: 180px; }
.rule-col-trigger { width: 220px; }
.rule-col-applies { width: 240px; }
.rule-col-scope { width: 160px; }
.rule-col-severity { width: 140px; }
.rule-col-percent { width: 96px; }
.rule-col-check { width: 78px; }
.rule-col-notes { width: 250px; }
.rule-col-order { width: 82px; }
.rule-col-source { width: 150px; }
.rule-col-actions { width: 160px; }
.engine-table th { position: sticky; top: 0; z-index: 3; padding: 9px 8px; background: #334155; color: #fff; font-size: 11px; font-weight: 900; letter-spacing: .6px; text-transform: uppercase; text-align: left; }
.engine-table td { padding: 7px 8px; border-top: 1px solid rgba(66,84,102,.12); vertical-align: top; }
.engine-table input, .engine-table select, .new-rule-grid input, .new-rule-grid select, .request-form input, .request-form select, .request-row input { width: 100%; min-height: 34px; padding: 7px 8px; border: 1px solid rgba(66,84,102,.22); border-radius: 7px; background: #fff; color: #102a3a; font-size: 12px; font-weight: 800; box-sizing: border-box; }
.engine-table .sub-input { margin-top: 5px; }
.engine-table .compact-check { width: 18px; height: 18px; min-height: 18px; padding: 0; accent-color: #126C84; }
.percent-input, .order-input { max-width: 82px; }
.source-pill { display: inline-flex; align-items: center; justify-content: center; min-height: 26px; padding: 0 8px; border-radius: 999px; background: #eef2f7; color: #334155; font-size: 11px; font-weight: 900; }
.auto-pill { background: rgba(18,108,132,.12); color: #0e5e7a; }
.engine-table small, .request-row small { display: block; margin-top: 4px; color: #64748b; font-weight: 800; }
.row-actions { display: flex; gap: 6px; }
.row-actions form { display: inline; }
.engine-btn, .icon-action { display: inline-flex; min-height: 34px; align-items: center; justify-content: center; padding: 7px 12px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: #fff; color: #102a3a; font-size: 12px; font-weight: 900; text-decoration: none; cursor: pointer; }
.engine-btn.primary { background: #126C84; border-color: #126C84; color: #fff; }
.engine-btn.secondary { background: #f8fafc; color: #0e5e7a; }
.engine-btn.danger, .icon-action.danger { background: #f9eeee; border-color: rgba(155,59,59,.26); color: #8a2c2c; }
.new-rule-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; align-items: end; }
.new-rule-field { display: grid; gap: 5px; margin: 0; color: #52606d; font-size: 11px; font-weight: 900; letter-spacing: .4px; text-transform: uppercase; }
.new-rule-field span, .new-rule-check span { color: #52606d; }
.new-rule-check { display: flex; min-height: 34px; align-items: center; gap: 8px; margin: 0; padding: 7px 8px; border: 1px solid rgba(66,84,102,.22); border-radius: 7px; background: #fff; color: #102a3a; font-size: 12px; font-weight: 900; box-sizing: border-box; }
.new-rule-check input[type="checkbox"] { width: 18px; height: 18px; min-height: 18px; accent-color: #126C84; }
.new-rule-field.wide-field { grid-column: span 2; }
.compact-number input { max-width: 100%; }
.new-rule-grid .engine-btn { min-height: 34px; }
.request-list { display: grid; gap: 10px; }
.request-row { display: grid; grid-template-columns: minmax(260px, 1fr) 260px 220px 180px; gap: 10px; align-items: start; padding: 12px; border: 1px solid rgba(66,84,102,.14); border-radius: 8px; background: #fff; }
.request-row.simple { grid-template-columns: 1fr; }
.request-row strong { display: block; color: #102a3a; font-weight: 900; }
.request-row span { display: block; margin-top: 3px; color: #52606d; font-weight: 800; }
.request-form { display: grid; grid-template-columns: 160px 86px 90px minmax(220px, 1fr) 96px; gap: 8px; align-items: center; }
.inline-check { display: flex; align-items: center; gap: 6px; color: #52606d; font-size: 12px; font-weight: 900; }
.inline-check input { width: 16px; min-height: 16px; }
.empty-state { padding: 18px; border: 1px dashed rgba(66,84,102,.24); border-radius: 8px; color: #64748b; font-weight: 900; text-align: center; }
.ops-table { width: 1320px; }
@@media (max-width: 960px) {
    .engine-summary { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .term-list { grid-template-columns: 1fr; }
    .new-rule-grid, .request-row, .request-form { grid-template-columns: 1fr; }
    .new-rule-field.wide-field { grid-column: auto; }
    .engine-actions { justify-content: stretch; flex-direction: column; }
    .engine-actions .engine-btn { width: 100%; }
}
@@media (max-width: 620px) {
    .engine-summary { grid-template-columns: 1fr; }
    .term-reference-wrap { justify-content: stretch; }
    .term-reference-toggle { width: 100%; }
    .panel-head { align-items: stretch; flex-direction: column; }
    .panel-head .engine-btn { width: 100%; }
    .scoring-engine-panel { max-height: calc(100vh - 70px); }
    .scoring-table-shell { min-height: 320px; }
    .engine-scroll-proxy.is-active { bottom: 92px; padding: 10px; }
    .engine-scroll-track { height: 22px; }
}
</style>

<script>
    (() => {
        const toggle = document.querySelector("[data-term-reference-toggle]");
        const panel = document.getElementById("termReferencePanel");
        if (!toggle || !panel) {
            return;
        }

        toggle.addEventListener("click", function () {
            const willOpen = panel.hidden;
            panel.hidden = !willOpen;
            toggle.setAttribute("aria-expanded", String(willOpen));
            toggle.textContent = willOpen ? "Hide Term Meanings" : "What Every Term Means";
        });
    })();

    (() => {
        const toggle = document.querySelector("[data-score-reference-toggle]");
        const panel = document.getElementById("scoreReferencePanel");
        if (!toggle || !panel) {
            return;
        }

        toggle.addEventListener("click", function () {
            const willOpen = panel.hidden;
            panel.hidden = !willOpen;
            toggle.setAttribute("aria-expanded", String(willOpen));
            toggle.textContent = willOpen ? "Hide Score Explanation" : "How Readiness Scores Are Compiled";
        });
    })();

    (() => {
        const toggle = document.querySelector("[data-request-queue-toggle]");
        const panel = document.getElementById("scoringRequests");
        if (!toggle || !panel) {
            return;
        }

        const closedText = toggle.textContent.trim();
        toggle.addEventListener("click", function () {
            const willOpen = panel.hidden;
            panel.hidden = !willOpen;
            toggle.setAttribute("aria-expanded", String(willOpen));
            toggle.textContent = willOpen ? "Hide Pending Requests" : closedText;

            if (willOpen) {
                panel.scrollIntoView({ behavior: "smooth", block: "start" });
            }
        });
    })();

    (() => {
        const severityToPercent = {
            "No impact": 0,
            "Minor": 2,
            "Moderate": 10,
            "Major": 20,
            "Critical": 40,
            "Hard blocker": 100
        };

        function severityFromPercent(value) {
            const percent = Math.max(0, Math.min(100, Number(value || 0)));
            if (percent <= 0) {
                return "No impact";
            }
            if (percent >= 100) {
                return "Hard blocker";
            }
            if (percent >= 40) {
                return "Critical";
            }
            if (percent >= 20) {
                return "Major";
            }
            if (percent >= 10) {
                return "Moderate";
            }
            return "Minor";
        }

        function findRuleContainer(element) {
            return element.closest("tr, .new-rule-grid");
        }

        function syncHardBlocker(container, severity) {
            const hardBlockerInput = container?.querySelector(".hard-blocker-input");
            if (hardBlockerInput) {
                hardBlockerInput.checked = severity === "Hard blocker";
            }
        }

        document.addEventListener("change", function (event) {
            const severity = event.target.closest(".severity-select");
            if (severity) {
                const container = findRuleContainer(severity);
                const defaultImpact = container?.querySelector(".default-impact-input");
                const suggested = severityToPercent[severity.value];
                if (defaultImpact && suggested !== undefined) {
                    defaultImpact.value = String(suggested);
                    syncHardBlocker(container, severity.value);
                }
                return;
            }

            const defaultImpact = event.target.closest(".default-impact-input");
            if (defaultImpact) {
                const container = findRuleContainer(defaultImpact);
                const severitySelect = container?.querySelector(".severity-select");
                const severityValue = severityFromPercent(defaultImpact.value);
                if (severitySelect) {
                    severitySelect.value = severityValue;
                }
                syncHardBlocker(container, severityValue);
            }
        });
    })();

    (() => {
        const shells = Array.from(document.querySelectorAll(".engine-table-shell"));
        if (!shells.length) {
            return;
        }

        let activeShell = null;
        let isSyncing = false;

        const proxy = document.createElement("div");
        proxy.className = "engine-scroll-proxy";
        proxy.setAttribute("aria-label", "Readiness engine horizontal scroll");

        const track = document.createElement("div");
        track.className = "engine-scroll-track";
        track.tabIndex = 0;

        const spacer = document.createElement("div");
        spacer.className = "engine-scroll-spacer";

        track.appendChild(spacer);
        proxy.appendChild(track);
        document.body.appendChild(proxy);

        function visibleShell() {
            return shells.find((shell) => {
                const hasOverflow = shell.scrollWidth > shell.clientWidth + 2;
                const rect = shell.getBoundingClientRect();
                return hasOverflow && rect.top < window.innerHeight - 106 && rect.bottom > 112;
            }) || null;
        }

        function updateProxy() {
            const shell = visibleShell();
            activeShell = shell;

            if (!shell) {
                proxy.classList.remove("is-active");
                return;
            }

            const rect = shell.getBoundingClientRect();
            const left = Math.max(12, rect.left);
            const right = Math.min(window.innerWidth - 12, rect.right);

            proxy.style.left = `${left}px`;
            proxy.style.width = `${Math.max(180, right - left)}px`;
            spacer.style.width = `${shell.scrollWidth}px`;
            proxy.classList.add("is-active");

            if (Math.abs(track.scrollLeft - shell.scrollLeft) > 1) {
                track.scrollLeft = shell.scrollLeft;
            }
        }

        shells.forEach((shell) => {
            shell.addEventListener("scroll", () => {
                if (isSyncing) {
                    return;
                }

                isSyncing = true;
                if (activeShell === shell) {
                    track.scrollLeft = shell.scrollLeft;
                }
                isSyncing = false;
                updateProxy();
            }, { passive: true });
        });

        track.addEventListener("scroll", () => {
            if (isSyncing || !activeShell) {
                return;
            }

            isSyncing = true;
            activeShell.scrollLeft = track.scrollLeft;
            isSyncing = false;
        }, { passive: true });

        window.addEventListener("scroll", updateProxy, { passive: true });
        window.addEventListener("resize", updateProxy);
        updateProxy();
    })();
</script>
