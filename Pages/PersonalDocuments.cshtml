@page
@model PersonalDocumentsModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Profile Documents";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
    var shouldOpenUpload = !string.IsNullOrWhiteSpace(Model.StatusMessage) && !Model.ActionSaved;
}

<div class="staff-upload-screen">
    <div class="staff-upload-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Operational Staff Actions</div>
        <h2 class="page-title">Profile Documents</h2>
        <p class="page-subtitle">Personal files, certificates, and accreditation linked to your signed-in staff profile</p>

        <div class="profile-link-panel">
            <span>Linked profile</span>
            <strong>@Model.SignedInStaffName</strong>
            <small>@Model.SignedInStaffIdentifier</small>
            <small>@Model.SignedInClinicalScope</small>
            <small>@Model.SignedInPractitionerNumber</small>
            <small>Licence expiry: @(Model.SignedInAnnualLicenseExpiryDate?.ToString("yyyy-MM-dd") ?? "N/A")</small>
            <small>CPD: @Model.SignedInCpdComplianceStatus / @(Model.SignedInCpdComplianceExpiryDate?.ToString("yyyy-MM-dd") ?? "N/A")</small>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <div class="home-label">Current Documents</div>
        @if (!Model.DocumentGroups.Any())
        {
            <div class="empty-panel">No personal documents uploaded yet.</div>
        }
        else
        {
            <div class="document-list">
            @foreach (var group in Model.DocumentGroups)
            {
                <section class="document-group">
                    <div class="document-group-heading">
                        <strong>@group.Type</strong>
                        <span>@group.Documents.Count file@(group.Documents.Count == 1 ? string.Empty : "s")</span>
                    </div>

                    @foreach (var document in group.Documents)
                    {
                        <div class="document-row">
                            <div>
                                <strong>@document.FileName</strong>
                                <span>@document.SizeLabel | Uploaded @document.UploadedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                @if (!string.IsNullOrWhiteSpace(document.Notes))
                                {
                                    <span>@document.Notes</span>
                                }
                            </div>
                            <a asp-page-handler="Download" asp-route-fileId="@document.Id">Download</a>
                        </div>
                    }
                </section>
            }
            </div>
        }

        <details class="upload-document-panel" @(shouldOpenUpload ? "open" : null)>
            <summary class="upload-toggle">Upload New Document</summary>

            <form method="post" enctype="multipart/form-data" class="staff-upload-form">
                <div class="form-grid">
                    <label>Staff name<input asp-for="StaffName" type="text" readonly /></label>
                    <label>Staff ID / employee number<input asp-for="StaffIdentifier" type="text" readonly /></label>
                    <label>
                        Document type
                        <select asp-for="DocumentType" asp-items="Model.DocumentTypeOptions" data-other-select="personal-document-type">
                            <option value="">Select document type</option>
                        </select>
                    </label>
                    <label class="other-option-field is-hidden" data-other-field="personal-document-type" hidden>
                        Name this document type
                        <input asp-for="DocumentTypeOther" type="text" placeholder="Example: Vaccination Record" />
                    </label>
                    <label>Certificate / accreditation name<input asp-for="CertificateName" type="text" placeholder="Manual name, if applicable" /></label>
                    <label>Expiry date<input asp-for="ExpiryDate" type="date" /></label>
                </div>

                <label class="upload-box" for="personalFiles">
                    <span class="upload-title">Select Personal Documents</span>
                    <span class="upload-help">Accepted: PDF, images, Word, Excel, CSV, RTF, TXT</span>
                    <input id="personalFiles" asp-for="PersonalFiles" type="file" multiple accept=".pdf,.png,.jpg,.jpeg,.webp,.gif,.bmp,.tif,.tiff,.doc,.docx,.rtf,.txt,.xls,.xlsx,.csv" />
                </label>

                <label class="notes-field">Notes<textarea asp-for="Notes" rows="4" placeholder="Optional note for management"></textarea></label>

                <button class="menu-btn staff-btn continue-btn" type="submit">Submit Personal Documents</button>
            </form>
        </details>
    </div>
</div>

<style>
.staff-upload-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: center; }
.staff-upload-inner { width: 100%; max-width: 920px; margin: 0 auto; text-align: center; padding: 40px 20px 30px 20px; box-sizing: border-box; }
.page-logo { width: 320px; max-width: 72%; max-height: 180px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 28px; font-weight: 700; color: #2f2f2f; }
.page-subtitle { margin: 0 0 22px 0; font-size: 16px; font-weight: 500; color: #6b7280; }
.profile-link-panel { width: min(720px, 94%); margin: 0 auto 22px auto; padding: 14px 18px; border: 1px solid rgba(66, 84, 102, 0.18); border-radius: 8px; background: rgba(255, 255, 255, 0.62); display: flex; flex-direction: column; gap: 4px; text-align: left; }
.profile-link-panel span, .profile-link-panel small { color: #6b7280; font-weight: 700; }
.profile-link-panel strong { color: #2f2f2f; font-size: 18px; }
.status-message { width: min(620px, 92%); margin: 0 auto 20px auto; padding: 12px 16px; border: 1px solid rgba(66, 84, 102, 0.22); border-radius: 8px; background: rgba(14, 94, 122, 0.08); color: #0E5E7A; font-weight: 700; }
.upload-document-panel { width: min(720px, 94%); margin: 22px auto 0 auto; text-align: center; }
.upload-toggle { display: inline-flex; min-height: 46px; align-items: center; justify-content: center; padding: 0 20px; border: 1px solid #334155; border-radius: 8px; background: #334155; color: #ffffff; font-size: 14px; font-weight: 900; cursor: pointer; list-style: none; }
.upload-toggle::-webkit-details-marker { display: none; }
.upload-toggle:hover { background: #24364a; }
.staff-upload-form { display: flex; flex-direction: column; align-items: center; gap: 22px; }
.upload-document-panel .staff-upload-form { margin-top: 18px; padding: 18px 0 0 0; border-top: 1px solid rgba(66, 84, 102, 0.18); }
.form-grid { width: min(720px, 94%); display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
.form-grid label, .notes-field { display: flex; flex-direction: column; gap: 8px; text-align: left; font-size: 13px; font-weight: 700; color: #52606d; }
.form-grid input, .form-grid select, .notes-field textarea { width: 100%; min-height: 46px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 14px; font-size: 15px; background: #ffffff; color: #1f2937; box-sizing: border-box; }
.form-grid input[readonly] { background: #eef2f7; color: #52606d; }
.notes-field { width: min(720px, 94%); }
.notes-field textarea { padding-top: 12px; resize: vertical; }
.upload-box { width: min(720px, 94%); min-height: 150px; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 8px; padding: 26px; border: 1px dashed rgba(66, 84, 102, 0.42); border-radius: 8px; background: rgba(255, 255, 255, 0.58); cursor: pointer; box-sizing: border-box; }
.upload-title { font-size: 20px; font-weight: 800; color: #2f2f2f; }
.upload-help { font-size: 14px; font-weight: 600; color: #6b7280; }
.upload-box input { margin-top: 10px; max-width: 100%; }
.continue-btn { border: none; }
.empty-panel { width: min(720px, 94%); margin: 0 auto; padding: 18px; border: 1px solid rgba(66, 84, 102, 0.18); border-radius: 8px; background: rgba(255, 255, 255, 0.62); color: #52606d; font-weight: 800; }
.document-list { width: min(720px, 94%); margin: 0 auto; display: flex; flex-direction: column; gap: 10px; }
.document-group { display: flex; flex-direction: column; gap: 8px; }
.document-group-heading { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 8px; background: #334155; color: #fff; text-align: left; }
.document-group-heading strong { font-size: 14px; font-weight: 900; }
.document-group-heading span { font-size: 12px; font-weight: 800; color: rgba(255, 255, 255, 0.78); }
.document-row { display: flex; justify-content: space-between; gap: 16px; align-items: center; padding: 14px 16px; border: 1px solid rgba(66, 84, 102, 0.18); border-radius: 8px; background: rgba(255, 255, 255, 0.62); text-align: left; }
.document-row div { display: flex; flex-direction: column; gap: 4px; }
.document-row span { color: #6b7280; font-size: 13px; font-weight: 600; }
.document-row a { color: #0E5E7A; font-size: 13px; font-weight: 800; text-decoration: none; }
@@media (max-width: 700px) { .form-grid { grid-template-columns: 1fr; } .document-row { flex-direction: column; align-items: flex-start; } }
</style>

@if (Model.ActionSaved)
{
    <script>
        window.VectorActionConfirmation?.show({
            message: @Json.Serialize(Model.StatusMessage ?? "Personal documents saved against your profile."),
            redirectUrl: window.VectorActionConfirmation.getReturnUrl(),
            delay: 1300
        });
    </script>
}
