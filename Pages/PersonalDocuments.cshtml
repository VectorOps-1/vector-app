@page
@model PersonalDocumentsModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Personal Documents";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="staff-upload-screen">
    <div class="staff-upload-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Operational Staff Actions</div>
        <h2 class="page-title">Upload Personal Documents</h2>
        <p class="page-subtitle">Upload personal files, certificates, and accreditation linked to your signed-in staff profile</p>

        <div class="profile-link-panel">
            <span>Linked profile</span>
            <strong>@Model.SignedInStaffName</strong>
            <small>@Model.SignedInStaffIdentifier</small>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <form method="post" enctype="multipart/form-data" class="staff-upload-form">
            <div class="form-grid">
                <label>
                    Staff name
                    <input asp-for="StaffName" type="text" readonly />
                </label>

                <label>
                    Staff ID / employee number
                    <input asp-for="StaffIdentifier" type="text" readonly />
                </label>

                <label>
                    Document type
                    <select asp-for="DocumentType">
                        <option value="">Select document type</option>
                        <option>ID / Passport</option>
                        <option>Driver's License</option>
                        <option>Medical Fitness</option>
                        <option>Certificate</option>
                        <option>Accreditation</option>
                        <option>Professional Registration</option>
                        <option>Training Record</option>
                        <option>Employment Document</option>
                        <option>Other Personal Document</option>
                    </select>
                </label>

                <label>
                    Certificate / accreditation name
                    <input asp-for="CertificateName" type="text" placeholder="Manual name, if applicable" />
                </label>

                <label>
                    Expiry date
                    <input asp-for="ExpiryDate" type="date" />
                </label>
            </div>

            <label class="upload-box" for="personalFiles">
                <span class="upload-title">Select Personal Documents</span>
                <span class="upload-help">Accepted: PDF, images, Word, Excel, CSV, RTF, TXT</span>
                <input id="personalFiles" asp-for="PersonalFiles" type="file" multiple accept=".pdf,.png,.jpg,.jpeg,.webp,.gif,.bmp,.tif,.tiff,.doc,.docx,.rtf,.txt,.xls,.xlsx,.csv" />
            </label>

            <label class="notes-field">
                Notes
                <textarea asp-for="Notes" rows="4" placeholder="Optional note for management"></textarea>
            </label>

            <div class="format-list">
                <span>ID / passport</span>
                <span>Driver's license</span>
                <span>Medical fitness</span>
                <span>Certificates</span>
                <span>Accreditation</span>
                <span>Training records</span>
                <span>Employment files</span>
            </div>

            <button class="menu-btn staff-btn continue-btn" type="submit">Submit Personal Documents</button>
        </form>

        <div class="document-divider"></div>
        <div class="home-label">View / Edit Own Documents</div>
        <div class="document-list">
            @foreach (var document in Model.ExistingDocuments)
            {
                <div class="document-row">
                    <div>
                        <strong>@document.Type</strong>
                        <span>@document.ProfileLink</span>
                    </div>
                    <a href="#">@document.Status</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
.staff-upload-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.staff-upload-inner {
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 22px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.profile-link-panel {
    width: min(720px, 94%);
    margin: 0 auto 22px auto;
    padding: 14px 18px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: left;
}

.profile-link-panel span,
.profile-link-panel small {
    color: #6b7280;
    font-weight: 700;
}

.profile-link-panel strong {
    color: #2f2f2f;
    font-size: 18px;
}

.status-message {
    width: min(620px, 92%);
    margin: 0 auto 20px auto;
    padding: 12px 16px;
    border: 1px solid rgba(66, 84, 102, 0.22);
    border-radius: 8px;
    background: rgba(14, 94, 122, 0.08);
    color: #0E5E7A;
    font-weight: 700;
}

.staff-upload-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
}

.form-grid {
    width: min(720px, 94%);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
}

.form-grid label,
.notes-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
    font-size: 13px;
    font-weight: 700;
    color: #52606d;
}

.form-grid input,
.form-grid select,
.notes-field textarea {
    width: 100%;
    min-height: 46px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 0 14px;
    font-size: 15px;
    background: #ffffff;
    color: #1f2937;
    box-sizing: border-box;
}

.form-grid input[readonly] {
    background: #eef2f7;
    color: #52606d;
}

.notes-field {
    width: min(720px, 94%);
}

.notes-field textarea {
    padding-top: 12px;
    resize: vertical;
}

.upload-box {
    width: min(720px, 94%);
    min-height: 150px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding: 26px;
    border: 1px dashed rgba(66, 84, 102, 0.42);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.58);
    cursor: pointer;
    box-sizing: border-box;
}

.upload-title {
    font-size: 20px;
    font-weight: 800;
    color: #2f2f2f;
}

.upload-help {
    font-size: 14px;
    font-weight: 600;
    color: #6b7280;
}

.upload-box input {
    margin-top: 10px;
    max-width: 100%;
}

.format-list {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    width: min(720px, 94%);
}

.format-list span {
    padding: 8px 12px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    font-size: 13px;
    font-weight: 700;
    color: #425466;
}

.continue-btn {
    border: none;
}

.document-divider {
    width: min(720px, 94%);
    height: 1px;
    margin: 34px auto 18px auto;
    background: rgba(66, 84, 102, 0.24);
}

.document-list {
    width: min(720px, 94%);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.document-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    padding: 14px 16px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    text-align: left;
}

.document-row div {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.document-row span {
    color: #6b7280;
    font-size: 13px;
    font-weight: 600;
}

.document-row a {
    color: #0E5E7A;
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
}

@@media (max-width: 700px) {
    .form-grid {
        grid-template-columns: 1fr;
    }

    .document-row {
        flex-direction: column;
        align-items: flex-start;
    }
}
</style>
