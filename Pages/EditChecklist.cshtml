.source-secondary-btn { padding: 12px 14px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: #f8fafc; color: #0E5E7A; text-decoration: none; font-size: 13px; font-weight: 900; white-space: nowrap; }
.empty-template-state { display: grid; gap: 8px; justify-items: center; padding: 16px; border: 1px dashed rgba(66,84,102,.24); border-radius: 8px; background: rgba(248,250,252,.8); color: #64748b; font-size: 13px; font-weight: 800; text-align: center; }
.empty-template-state strong { color: #102a3a; font-size: 15px; }
.empty-template-state span { max-width: 560px; line-height: 1.4; }
.empty-template-action { display: inline-flex; min-height: 36px; align-items: center; justify-content: center; padding: 0 14px; border-radius: 8px; background: #126C84; color: #fff; text-decoration: none; font-size: 12px; font-weight: 900; }
.register-list { display: grid; gap: 7px; }
.register-item { display: grid; grid-template-columns: minmax(220px, 1.35fr) minmax(250px, 1.2fr) minmax(125px, .6fr) auto; gap: 10px; align-items: center; min-height: 58px; padding: 9px 10px 9px 12px; border: 1px solid rgba(66,84,102,.14); border-left: 4px solid #0E5E7A; border-radius: 8px; background: #ffffff; color: #334155; }
