@@media (max-width: 980px) { .register-item { grid-template-columns: 1fr; align-items: stretch; } .template-actions { justify-content: flex-start; flex-wrap: wrap; } }
@@media (max-width: 900px) { .publish-grid { grid-template-columns: 1fr; } .publish-form-grid { grid-template-columns: 1fr; } }
@@media (max-width: 900px) { .checklist-path-grid { grid-template-columns: 1fr; } }
@@media (max-width: 760px) { .path-card { min-height: 140px; } .source-header, .publish-register-header { align-items: stretch; flex-direction: column; } .source-actions, .publish-actions { flex-direction: column; justify-content: stretch; } .source-upload-btn, .source-secondary-btn, .publish-button { text-align: center; width: 100%; } }
</style>
