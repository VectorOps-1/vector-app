@page
@model EditChecklistModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Edit Checklist";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="checklist-type-screen">
    <div class="checklist-type-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Management Action</div>
        <h2 class="page-title">Edit Checklist</h2>
        <p class="page-subtitle">Choose which checklist type to edit.</p>

        <div class="type-grid">
            <a class="type-card vehicle-card" href="/EditVehicleChecklist?checklist=daily-vehicle">
                <span>Vehicle</span>
                <strong>Vehicle Checklists</strong>
                <p>Daily and monthly vehicle inspection layouts, operational checks, schematic section, and same-as-previous controls.</p>
            </a>

            <a class="type-card equipment-card" href="/EditEquipmentChecklist">
                <span>Equipment</span>
                <strong>Equipment Checklists</strong>
                <p>Equipment checklist editing is separate from vehicle checklist editing and will use its own layout builder.</p>
            </a>
        </div>
    </div>
</div>

<style>
.checklist-type-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: center; }
.checklist-type-inner { width: 100%; max-width: 980px; margin: 0 auto; text-align: center; padding: 40px 20px 50px 20px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 28px; font-weight: 800; color: #1f2937; }
.page-subtitle { margin: 0 0 26px 0; font-size: 16px; font-weight: 600; color: #6b7280; }
.type-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; text-align: left; }
.type-card { display: flex; flex-direction: column; min-height: 210px; padding: 22px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.72); color: #1f2937; text-decoration: none; box-sizing: border-box; }
.type-card:hover { transform: translateY(-1px); box-shadow: 0 16px 34px rgba(15, 23, 42, 0.10); }
.type-card span { margin-bottom: 28px; font-size: 12px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
.type-card strong { margin-bottom: 10px; font-size: 22px; font-weight: 900; }
.type-card p { margin: 0; color: #52606d; font-size: 14px; line-height: 1.45; font-weight: 700; }
.vehicle-card span { color: #0E5E7A; }
.equipment-card span { color: #555B7A; }
@@media (max-width: 760px) { .type-grid { grid-template-columns: 1fr; } .type-card { min-height: 180px; } }
</style>
