.template-delete-confirm[hidden] { display: none; }
.template-delete-confirm div { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 5px; }
.template-confirm-delete, .template-cancel-delete { min-height: 28px; border-radius: 8px; cursor: pointer; font-size: 11px; font-weight: 900; }
.template-confirm-delete { border: 1px solid rgba(148,57,57,.36); background: #943939; color: #ffffff; }
.template-cancel-delete { border: 1px solid rgba(66,84,102,.18); background: #ffffff; color: #425466; }
.publish-register-panel { margin-top: 16px; padding: 16px; border: 1px solid rgba(14,94,122,.22); border-radius: 8px; background: rgba(14,94,122,.04); scroll-margin-top: 88px; }
.publish-register-header { display: flex; justify-content: space-between; gap: 14px; align-items: flex-start; margin-bottom: 14px; }
.publish-register-header h3 { margin: 0 0 4px 0; color: #1f2937; font-size: 18px; line-height: 1.2; font-weight: 900; }
.publish-register-header p, .plain-warning { margin: 0; color: #52606d; font-size: 12px; line-height: 1.42; font-weight: 800; }
.publish-grid { display: grid; grid-template-columns: minmax(0, .95fr) minmax(0, 1.05fr); gap: 12px; }
.publish-subpanel { padding: 14px; border: 1px solid rgba(66,84,102,.14); border-radius: 8px; background: #ffffff; }
.panel-heading.compact { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 10px; }
.panel-heading.compact h4 { margin: 0; color: #1f2937; font-size: 15px; font-weight: 900; }
.panel-heading.compact span { color: #64748b; font-size: 10px; font-weight: 900; letter-spacing: .7px; text-transform: uppercase; }
.usage-list { border: 1px solid rgba(66,84,102,.14); border-radius: 8px; overflow-x: auto; }
.usage-row { display: grid; grid-template-columns: 130px minmax(170px, 1fr) 130px 130px; gap: 8px; align-items: center; min-width: 560px; min-height: 36px; padding: 7px 9px; border-top: 1px solid rgba(66,84,102,.1); color: #334155; font-size: 11px; font-weight: 800; }
.usage-row:first-child { border-top: none; }
.usage-header { background: #334155; color: #ffffff; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: .7px; }
.publish-form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; margin-top: 12px; }
.publish-form-grid label { display: flex; flex-direction: column; gap: 7px; color: #52606d; font-size: 11px; font-weight: 900; }
.publish-form-grid select, .publish-form-grid textarea { width: 100%; min-height: 40px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 10px; background: #ffffff; color: #1f2937; font-size: 13px; font-weight: 750; box-sizing: border-box; }
.publish-form-grid textarea { padding-top: 10px; resize: vertical; }
.target-field[hidden] { display: none; }
.replacement-warning-list { margin-top: 12px; }
.replacement-warning { padding: 10px 12px; border: 1px solid rgba(148,57,57,.28); border-radius: 8px; background: rgba(148,57,57,.08); color: #7f2f2f; font-size: 12px; font-weight: 900; line-height: 1.42; }
.replacement-warning[hidden] { display: none; }
.authority-warning { margin-top: 12px; padding: 10px 12px; border: 1px solid rgba(180,113,28,.26); border-radius: 8px; background: rgba(180,113,28,.08); color: #8a4f10; font-size: 12px; font-weight: 900; }
.publish-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 14px; }
.publish-button { min-height: 38px; padding: 0 16px; border: 0; border-radius: 8px; background: #0E5E7A; color: #ffffff; font-size: 12px; font-weight: 900; cursor: pointer; }
