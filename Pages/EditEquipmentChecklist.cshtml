@page
@model EditEquipmentChecklistModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Edit Equipment Check";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
}

<div class="redirect-screen">
    <div class="redirect-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Management Action</div>
        <h2 class="page-title">Edit Equipment Check</h2>
        <p class="page-subtitle">Equipment checklist sections are managed inside Checklist Management.</p>

        <div class="redirect-panel">
            <strong>Checklist builder</strong>
            <p>Use the checklist builder to add equipment, stock, medication, notes, rows, columns, and subitems to the active checklist structure.</p>
        </div>

        <div class="action-row">
            <a class="menu-btn vehicle-btn" href="/EditChecklist">Back to Checklist Management</a>
            <a class="menu-btn equipment-btn" href="/EditVehicleChecklist?checklist=daily-vehicle">Edit Vehicle Check</a>
        </div>
    </div>
</div>

<style>
.redirect-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: center; }
.redirect-inner { width: 100%; max-width: 820px; margin: 0 auto; text-align: center; padding: 40px 20px 50px 20px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px auto; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px 0; font-size: 28px; font-weight: 800; color: #1f2937; }
.page-subtitle { width: min(680px, 94%); margin: 0 auto 22px auto; font-size: 16px; font-weight: 600; color: #6b7280; }
.redirect-panel { margin: 0 auto 24px auto; padding: 18px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.72); text-align: left; }
.redirect-panel strong { display: block; margin-bottom: 8px; color: #1f2937; font-size: 18px; font-weight: 900; }
.redirect-panel p { margin: 0; color: #52606d; font-size: 14px; font-weight: 700; line-height: 1.45; }
.action-row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.action-row .menu-btn { width: 100%; }
@@media (max-width: 700px) { .action-row { grid-template-columns: 1fr; } }
</style>
