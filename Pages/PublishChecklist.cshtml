@page
@model PublishChecklistModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Publish Checklist";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
    var template = Model.Template;
}

<div class="publish-screen">
    <div class="publish-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Checklist Management</div>
        <h2 class="page-title">Publish Checklist</h2>
        <p class="page-subtitle">Choose where this saved checklist becomes the live daily check.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        @if (template is null)
        {
            <div class="empty-state">Checklist template not found.</div>
        }
        else
        {
            <section class="summary-panel">
                <div>
                    <div class="source-label">Selected checklist</div>
                    <h3>@template.TargetVehicleType - @template.Name</h3>
                    <p>Version @template.Version | @template.ChecklistType | @template.SourceType</p>
                </div>
                <a class="secondary-link" href="/EditChecklist?view=register">Back to Checklist Register</a>
            </section>

            <section class="usage-panel">
                <div class="panel-heading">
                    <div>
                        <div class="source-label">Current live use</div>
                        <h3>Where this checklist is currently used</h3>
                    </div>
                    <span>@Model.CurrentUses.Count active</span>
                </div>

                @if (Model.CurrentUses.Count == 0)
                {
                    <div class="empty-state">This checklist is not currently being used live.</div>
                }
                else
                {
                    <div class="usage-list">
                        <div class="usage-row usage-header">
                            <span>Scope</span>
                            <span>Target</span>
                            <span>Published</span>
                            <span>Published by</span>
                        </div>
                        @foreach (var use in Model.CurrentUses)
                        {
                            <div class="usage-row">
                                <span>@use.ScopeType</span>
                                <strong>@use.Target</strong>
                                <span>@use.PublishedAtUtc.ToString("yyyy-MM-dd HH:mm")</span>
                                <span>@use.PublishedBy</span>
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="publish-panel">
                <div class="source-label">Publish target</div>
                <h3>Set live use</h3>
                <p class="plain-warning">
                    Publishing creates the live checklist crews will use for the selected target. If another daily check already covers that target, this checklist will replace it for daily use at that target.
                </p>

                <form method="post" asp-page-handler="Publish" class="publish-form">
                    <input asp-for="TemplateId" type="hidden" />
                    <input asp-for="TaskAccess" type="hidden" />
                    <input asp-for="TaskId" type="hidden" />

                    <div class="form-grid">
                        <label>
                            Publish for
                            <select asp-for="ScopeType" id="scopeTypeSelect">
                                <option value="VehicleCategory">Vehicle type: @template.TargetVehicleType</option>
                                <option value="OperationalArea">Specific area / base</option>
                                <option value="Vehicle">Specific callsign / registration</option>
                                <option value="AllAreas">All operational areas</option>
                            </select>
                        </label>

                        <label class="target-field" data-target-field="OperationalArea">
                            Area / base
                            <select asp-for="OperationalAreaId" id="operationalAreaSelect">
                                <option value="">Select area / base</option>
                                @foreach (var area in Model.OperationalAreaOptions)
                                {
                                    <option value="@area.Id">@area.Name (@area.Type)</option>
                                }
                            </select>
                        </label>

                        <label class="target-field" data-target-field="Vehicle">
                            Callsign / registration
                            <select asp-for="VehicleId" id="vehicleSelect">
                                <option value="">Select callsign / registration</option>
                                @foreach (var vehicle in Model.VehicleOptions)
                                {
                                    <option value="@vehicle.Id">@vehicle.Callsign / @vehicle.Registration - @vehicle.VehicleType - @vehicle.AreaName</option>
                                }
                            </select>
                        </label>

                        <label>
                            Publish note
                            <textarea asp-for="PublishNote" rows="4" placeholder="Reason for publishing, replacement note, or instruction for managers"></textarea>
                        </label>
                    </div>

                    <div class="replacement-warning-list" aria-live="polite">
                        @foreach (var warning in Model.ConflictWarnings)
                        {
                            <div class="replacement-warning" data-conflict-key="@warning.ScopeKey" hidden>
                                @warning.Message
                            </div>
                        }
                    </div>

                    @if (!Model.CanPublishChecklist)
                    {
                        <div class="authority-warning">Only senior management, or an operational manager with a delegated publish task, can publish a checklist for live operational use.</div>
                    }

                    <div class="action-row">
                        <a class="secondary-link" href="/EditChecklist?view=register">Cancel</a>
                        <button class="publish-button" type="submit" disabled="@(!Model.CanPublishChecklist)">Publish for Live Use</button>
                    </div>
                </form>
            </section>
        }
    </div>
</div>

<script>
(function () {
    const scopeSelect = document.getElementById("scopeTypeSelect");
    const areaSelect = document.getElementById("operationalAreaSelect");
    const vehicleSelect = document.getElementById("vehicleSelect");
    const targetFields = document.querySelectorAll("[data-target-field]");
    const warnings = document.querySelectorAll("[data-conflict-key]");

    function selectedConflictKey() {
        if (!scopeSelect) {
            return "";
        }

        if (scopeSelect.value === "OperationalArea") {
            return areaSelect?.value ? `OperationalArea:${areaSelect.value}` : "";
        }

        if (scopeSelect.value === "Vehicle") {
            return vehicleSelect?.value ? `Vehicle:${vehicleSelect.value}` : "";
        }

        if (scopeSelect.value === "VehicleCategory") {
            return "VehicleCategory:@template?.TargetVehicleType";
        }

        return "AllAreas";
    }

    function syncPublishTargetUi() {
        const scope = scopeSelect?.value || "VehicleCategory";
        targetFields.forEach(function (field) {
            const isVisible = field.dataset.targetField === scope;
            field.hidden = !isVisible;
            field.querySelectorAll("select, input, textarea").forEach(function (input) {
                input.disabled = !isVisible;
            });
        });

        const key = selectedConflictKey();
        warnings.forEach(function (warning) {
            warning.hidden = warning.dataset.conflictKey !== key;
        });
    }

    scopeSelect?.addEventListener("change", syncPublishTargetUi);
    areaSelect?.addEventListener("change", syncPublishTargetUi);
    vehicleSelect?.addEventListener("change", syncPublishTargetUi);
    syncPublishTargetUi();
})();
</script>

<style>
.publish-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: flex-start; }
.publish-inner { width: 100%; max-width: 980px; margin: 0 auto; text-align: center; padding: 40px 20px 60px; box-sizing: border-box; }
.page-logo { width: 300px; max-width: 72%; max-height: 170px; object-fit: contain; margin: 0 auto 12px; display: block; }
.client-line { margin-bottom: 14px; font-size: 12px; font-weight: 700; color: #6b7280; }
.home-label { margin-bottom: 10px; font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: #5f6b7a; }
.page-title { margin: 0 0 8px; font-size: 28px; font-weight: 900; color: #1f2937; }
.page-subtitle { margin: 0 0 22px; color: #6b7280; font-size: 16px; font-weight: 700; }
.status-message { margin: 0 auto 18px; padding: 12px 16px; border: 1px solid rgba(31,111,91,.26); border-radius: 8px; background: rgba(31,111,91,.08); color: #1f6f5b; font-size: 14px; font-weight: 900; }
.summary-panel, .usage-panel, .publish-panel { margin-top: 16px; padding: 18px; border: 1px solid rgba(66,84,102,.16); border-radius: 8px; background: rgba(255,255,255,.76); text-align: left; }
.summary-panel { display: flex; justify-content: space-between; gap: 16px; align-items: center; }
.source-label { margin-bottom: 4px; color: #5f6b7a; font-size: 12px; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
.summary-panel h3, .usage-panel h3, .publish-panel h3 { margin: 0 0 4px; color: #1f2937; font-size: 20px; font-weight: 900; }
.summary-panel p, .plain-warning { margin: 0; color: #52606d; font-size: 13px; font-weight: 800; line-height: 1.42; }
.secondary-link { display: inline-flex; align-items: center; justify-content: center; min-height: 36px; padding: 0 14px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: #f8fafc; color: #0E5E7A; font-size: 12px; font-weight: 900; text-decoration: none; white-space: nowrap; }
.panel-heading { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 12px; }
.panel-heading span { color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: .7px; }
.empty-state { padding: 14px; border: 1px dashed rgba(66,84,102,.24); border-radius: 8px; background: rgba(248,250,252,.82); color: #64748b; font-size: 13px; font-weight: 900; text-align: center; }
.usage-list { border: 1px solid rgba(66,84,102,.14); border-radius: 8px; overflow: hidden; }
.usage-row { display: grid; grid-template-columns: 150px minmax(180px, 1fr) 160px 160px; gap: 10px; align-items: center; min-height: 40px; padding: 8px 10px; border-top: 1px solid rgba(66,84,102,.1); color: #334155; font-size: 12px; font-weight: 800; }
.usage-row:first-child { border-top: none; }
.usage-header { background: #334155; color: #ffffff; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: .7px; }
.form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin-top: 14px; }
.form-grid label { display: flex; flex-direction: column; gap: 8px; color: #52606d; font-size: 12px; font-weight: 900; }
.form-grid select, .form-grid textarea { width: 100%; min-height: 44px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 0 12px; background: #ffffff; color: #1f2937; font-size: 14px; font-weight: 750; box-sizing: border-box; }
.form-grid textarea { padding-top: 12px; resize: vertical; }
.target-field[hidden] { display: none; }
.replacement-warning-list { margin-top: 14px; }
.replacement-warning { padding: 12px 14px; border: 1px solid rgba(148,57,57,.28); border-radius: 8px; background: rgba(148,57,57,.08); color: #7f2f2f; font-size: 13px; font-weight: 900; line-height: 1.42; }
.replacement-warning[hidden] { display: none; }
.authority-warning { margin-top: 14px; padding: 12px 14px; border: 1px solid rgba(180,113,28,.26); border-radius: 8px; background: rgba(180,113,28,.08); color: #8a4f10; font-size: 13px; font-weight: 900; }
.action-row { display: flex; justify-content: flex-end; gap: 10px; margin-top: 16px; }
.publish-button { min-height: 38px; padding: 0 18px; border: 0; border-radius: 8px; background: #0E5E7A; color: #ffffff; font-size: 13px; font-weight: 900; cursor: pointer; }
.publish-button:disabled { opacity: .48; cursor: not-allowed; }
@@media (max-width: 820px) { .summary-panel, .panel-heading { flex-direction: column; align-items: stretch; } .form-grid, .usage-row { grid-template-columns: 1fr; } .usage-header { display: none; } .action-row { flex-direction: column; } .secondary-link, .publish-button { width: 100%; } }
</style>
