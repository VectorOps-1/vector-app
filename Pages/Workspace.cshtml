@page "{workspaceSlug?}"
@model WorkspaceModel
@{
    Layout = null;
    ViewData["Title"] = "AcuityOps";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AcuityOps</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <style>
        html,
        body {
            margin: 0;
            min-height: 100%;
            background: #000000;
            overflow: hidden;
        }

        .workspace-splash {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #000000;
            color: #ffffff;
            opacity: 1;
            transition: opacity 0.9s ease;
        }

        .workspace-splash.hide {
            opacity: 0;
        }

        .splash-content {
            display: flex;
            min-height: 100vh;
            width: 100%;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            padding: 36px 24px;
            box-sizing: border-box;
        }

        .splash-logo {
            width: min(54vw, 520px);
            min-width: 210px;
            max-height: 56vh;
            object-fit: contain;
            opacity: 0;
            transform: scale(0.95);
            animation: logoFadeIn 1.5s ease-out forwards;
        }

        .splash-brand {
            margin-top: 14px;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 35px;
            font-weight: 800;
            color: #ffffff;
            opacity: 0;
            animation: brandFadeIn 0.8s ease-out 0.7s forwards;
        }

        .splash-company {
            margin-top: 6px;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.72);
            opacity: 0;
            animation: brandFadeIn 0.8s ease-out 0.9s forwards;
        }

        @@keyframes logoFadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        @@keyframes brandFadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <div id="workspaceSplash" class="workspace-splash">
        <div class="splash-content">
            <img class="splash-logo" src="/acuityops-app-icon-splash.png" alt="AcuityOps" />
            <div class="splash-brand">AcuityOps</div>
            <div class="splash-company">by Vector Ops Group Pty Ltd</div>
        </div>
    </div>

    <script>
        (function () {
            const splash = document.getElementById("workspaceSplash");
            const targetUrl = "@Model.CompanyLoginUrl";

            window.setTimeout(function () {
                splash?.classList.add("hide");
            }, 3000);

            window.setTimeout(function () {
                window.location.href = targetUrl;
            }, 3900);
        })();
    </script>
</body>
</html>
