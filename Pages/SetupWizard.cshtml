@page
@model SetupWizardModel
@{
    ViewData["Title"] = "Setup Wizard";
}

<div class="setup-wizard-screen">
    <div class="setup-wizard-inner">
        <img class="page-logo" src="@Model.CompanyLogoPath" alt="Company logo" />
        <div class="client-line">Client: @Model.ClientName</div>
        <div class="home-label">Company Setup</div>
        <h2 class="page-title">Setup Wizard</h2>
        <p class="page-subtitle">Complete the company setup before normal app use starts.</p>

        <div class="setup-status-panel">
            <div>
                <span class="status-label">Setup status</span>
                <strong>@Model.SetupStatus</strong>
                <span>@Model.CompletedStepKeys.Count completed step(s)</span>
            </div>
            <div>
                <span class="status-label">Signed in</span>
                <strong>@Model.SignedInName</strong>
                <span>@Model.SignedInRole</span>
            </div>
        </div>

        <div class="setup-step-card">
            <div class="step-number">@Model.CurrentStep.Number</div>
            <div class="step-copy">
                <span class="status-label">Resume setup here</span>
                <h3>@Model.CurrentStep.Title</h3>
                <p>@Model.CurrentStep.Description Normal Home access remains locked until the company record is configured.</p>
            </div>
            @if (Model.CanManageSetup)
            {
                <div class="step-actions">
                    <a class="menu-btn equipment-btn" asp-page="/CompanyName">Open Company Identity</a>
                    <a class="menu-btn" asp-page="/LogoUpload">Logo Upload</a>
                </div>
            }
            else
            {
                <div class="setup-locked-note">
                    A company owner or senior manager must complete setup.
                </div>
            }
        </div>
    </div>
</div>

<style>
.setup-wizard-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.setup-wizard-inner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    padding: 40px 20px 30px;
    text-align: center;
    box-sizing: border-box;
}

.page-logo {
    display: block;
    width: 220px;
    max-width: 70%;
    max-height: 150px;
    margin: 0 auto 12px;
    object-fit: contain;
}

.client-line,
.status-label {
    color: #5f6b7a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.home-label {
    margin: 18px 0 10px;
    color: #5f6b7a;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.2px;
    text-transform: uppercase;
}

.page-title {
    margin: 0 0 8px;
    color: #10233f;
    font-size: 32px;
    font-weight: 900;
}

.page-subtitle {
    margin: 0 0 24px;
    color: #5f6b7a;
    font-size: 17px;
    font-weight: 700;
}

.setup-status-panel,
.setup-step-card {
    width: min(860px, 96%);
    margin: 0 auto 16px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
}

.setup-status-panel {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    text-align: left;
}

.setup-status-panel div {
    padding: 16px;
}

.setup-status-panel strong,
.setup-status-panel span {
    display: block;
}

.setup-status-panel strong {
    margin-top: 5px;
    color: #10233f;
    font-size: 18px;
}

.setup-step-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    padding: 18px;
    text-align: left;
}

.step-number {
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #334155;
    color: #fff;
    font-weight: 900;
}

.step-copy h3 {
    margin: 4px 0;
    color: #10233f;
    font-size: 22px;
}

.step-copy p {
    margin: 0;
    color: #5f6b7a;
    font-weight: 700;
    line-height: 1.45;
}

.step-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 210px;
}

.setup-locked-note {
    max-width: 220px;
    color: #7c2d12;
    font-weight: 900;
}

@@media (max-width: 820px) {
    .setup-status-panel,
    .setup-step-card {
        grid-template-columns: 1fr;
    }

    .step-actions {
        min-width: 0;
    }
}
</style>
