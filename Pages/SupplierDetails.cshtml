@page
@model SupplierDetailsModel
@{
    ViewData["Title"] = "Stock Orders & Distribution";
}

<div class="source-review-screen">
    <div class="source-review-panel">
        <div class="home-label">Stock Orders & Distribution</div>
        <h2 class="page-title">Supplier Workflow Moved</h2>
        <p class="page-subtitle">Supplier names, emails, confirmations, received stock, and allocations are handled inside Stock Orders & Distribution.</p>
        <a class="menu-btn equipment-btn" href="/StockOrders">Open Stock Orders & Distribution</a>
    </div>
</div>

<style>
.source-review-screen { display: flex; width: 100%; min-height: calc(100vh - 70px); justify-content: center; align-items: center; padding: 28px 16px; box-sizing: border-box; }
.source-review-panel { width: min(720px, 100%); padding: 28px; border: 1px solid rgba(66,84,102,.18); border-radius: 8px; background: rgba(255,255,255,.74); text-align: center; box-sizing: border-box; }
.home-label { margin-bottom: 10px; color: #5f6b7a; font-size: 13px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; }
.page-title { margin: 0 0 8px 0; color: #1f2937; font-size: 28px; font-weight: 900; }
.page-subtitle { margin: 0 auto 22px auto; max-width: 600px; color: #64748b; font-size: 15px; font-weight: 700; line-height: 1.45; }
.menu-btn { width: min(360px, 100%); border: none; }
</style>
