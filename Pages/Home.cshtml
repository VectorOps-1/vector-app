@page
@model HomeModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Home";
    var isStaff = Model.AccessView == "staff";
    var isSeniorManagement = Model.AccessView == "senior-management";
    var viewName = isStaff ? "Staff View" : isSeniorManagement ? "Senior Management View" : "Operational Management View";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
}

<div class="home-screen ready show">
    <div class="home-inner">
        <div class="home-label">Operations Dashboard</div>

        <div class="company-logo-frame">
            <img src="@companyLogoPath" class="home-logo" alt="Company Logo" />
        </div>

        <div class="home-context">Client: @ViewData["ClientName"]</div>
        <div class="signed-in-line">Signed in: @Model.SignedInName (@Model.SignedInRole)</div>
        <div class="view-badge">@viewName</div>

        <section class="dashboard-section">
            <div class="management-section-label">Operational Work</div>

            <div class="workflow-grid">
                <a class="workflow-action primary-action" href="/DailyVehicleChecklist">Daily Vehicle Readiness</a>
                <a class="workflow-action" href="/TaskInbox">My Tasks</a>
                @if (!isStaff)
                {
                    <a class="workflow-action" href="/IssueInbox">My Assigned Issues</a>
                }
                <a class="workflow-action" href="/PersonalDocuments">My Documents</a>
                <a class="workflow-action" href="/TaskFeedback">Task Feedback</a>
                <a class="workflow-action danger" href="/ReportIssue?module=general">Report Issue</a>
            </div>
        </section>

        @if (!isStaff)
        {
            <div class="section-divider"></div>
            <section class="management-dashboard dashboard-section">
                <div class="management-section-label">Management Oversight</div>

                <div class="management-category-grid">
                    <section class="category-card category-vehicles">
                        <div class="category-heading">
                            <h2>Vehicles</h2>
                            <span class="category-index">01</span>
                        </div>
                        <div class="category-actions">
                            <a class="category-action primary" href="/Vehicles">Open Vehicles</a>
                            <a class="category-action" href="/VehicleRegister">Search / Register</a>
                            <a class="category-action" href="/MoveAsset?asset=vehicle" data-move-asset="vehicle">Move / Reallocate</a>
                        </div>
                    </section>

                    <section class="category-card category-equipment">
                        <div class="category-heading">
                            <h2>Equipment</h2>
                            <span class="category-index">02</span>
                        </div>
                        <div class="category-actions">
                            <a class="category-action primary" href="/Equipment">Open Equipment</a>
                            <a class="category-action" href="/MoveAsset?asset=equipment" data-move-asset="equipment">Move / Reallocate</a>
                        </div>
                    </section>

                    <section class="category-card category-staff">
                        <div class="category-heading">
                            <h2>Staff</h2>
                            <span class="category-index">03</span>
                        </div>
                        <div class="category-actions single-action">
                            <a class="category-action primary" href="/Staff">Open Staff</a>
                        </div>
                    </section>

                    <section class="category-card category-stock">
                        <div class="category-heading">
                            <h2>Stock</h2>
                            <span class="category-index">04</span>
                        </div>
                        <div class="category-actions">
                            <a class="category-action primary" href="/Stock">Open Stock</a>
                            <a class="category-action" href="/MoveAsset?asset=stock" data-move-asset="stock">Move / Reallocate</a>
                        </div>
                    </section>

                    <section class="category-card category-medication">
                        <div class="category-heading">
                            <h2>Medication</h2>
                            <span class="category-index">05</span>
                        </div>
                        <div class="category-actions">
                            <a class="category-action primary" href="/Medication">Open Medication</a>
                            <a class="category-action" href="/MoveAsset?asset=medication" data-move-asset="medication">Move / Reallocate</a>
                        </div>
                    </section>

                    <section class="category-card category-workflow">
                        <div class="category-heading">
                            <h2>Tasks & Issues</h2>
                            <span class="category-index">06</span>
                        </div>
                        <div class="category-actions">
                            <a class="category-action primary" href="/SendTask">Send Task</a>
                            <a class="category-action" href="/IssueReports">All Open Issues</a>
                        </div>
                    </section>
                </div>
            </section>

            @if (isSeniorManagement)
            {
                <div class="section-divider compact-divider"></div>
                <section class="dashboard-section">
                    <div class="management-section-label">System Setup</div>

                    <div class="workflow-grid">
                        <a class="workflow-action" href="/MasterSetup">Master Setup</a>
                        <a class="workflow-action" href="/OperationalAreas">Operational Areas</a>
                        <a class="workflow-action" href="/EditChecklist">Checklist Builder</a>
                        <a class="workflow-action" href="/CompanyProfile">Company Profile</a>
                        <a class="workflow-action" href="/VehicleSchematicLibrary">Schematic Library</a>
                        <a class="workflow-action" href="/CreateManagerAccess">Access Setup</a>
                        <a class="workflow-action" href="/TaskCommunicationSetup">Task Communication</a>
                        <a class="workflow-action" href="/AuditLog">Audit Log</a>
                    </div>
                </section>
            }
        }

        <div class="home-footer">Vector v0.1</div>
    </div>
</div>

<style>
.home-screen {
    position: relative;
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.home-inner {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.company-logo-frame {
    width: min(540px, 80%);
    height: 240px;
    margin: 0 auto 12px auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F4F7FB;
    overflow: hidden;
}

.home-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
}

.home-context {
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: 500;
    color: #6b7280;
}

.signed-in-line {
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 700;
    color: #425466;
}

.view-badge {
    margin-bottom: 18px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #425466;
}

.home-subtitle {
    margin-top: 0;
    margin-bottom: 26px;
    font-size: 24px;
    color: #2f2f2f;
}

.home-menu-row {
    gap: 24px;
    row-gap: 24px;
}

.section-divider {
    width: min(760px, 86%);
    height: 1px;
    margin: 36px auto 14px auto;
    background: rgba(66, 84, 102, 0.28);
}

.compact-divider {
    margin-top: 30px;
}

.section-label {
    margin-bottom: 18px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #6b7280;
}

.setup-action-row .menu-btn,
.staff-action-row .menu-btn {
    min-width: 240px;
}

.management-dashboard {
    margin-top: 8px;
}

.dashboard-section {
    width: 100%;
}

.management-section-label {
    margin-bottom: 16px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    color: #6b7280;
}

.management-category-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    text-align: left;
}

.category-card {
    min-height: 100%;
    padding: 18px;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-top: 6px solid #126C84;
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 14px 26px rgba(15, 23, 42, 0.08);
    box-sizing: border-box;
}

.category-vehicles {
    border-top-color: #334155;
}

.category-equipment {
    border-top-color: #126C84;
}

.category-staff {
    border-top-color: #207A63;
}

.category-stock {
    border-top-color: #53616F;
}

.category-medication {
    border-top-color: #9B3B3B;
}

.category-workflow {
    border-top-color: #4B5563;
}

.category-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
}

.category-heading h2 {
    margin: 0;
    font-size: 22px;
    line-height: 1.15;
    color: #1f2937;
}

.category-index {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.8px;
    color: #7a8491;
}

.category-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
}

.category-actions.single-action {
    grid-template-columns: 1fr;
}

.category-action,
.workflow-action {
    display: flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    padding: 10px 12px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: #f8fafc;
    color: #24364a;
    font-size: 14px;
    font-weight: 800;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    box-sizing: border-box;
}

.category-action:hover,
.workflow-action:hover {
    transform: translateY(-1px);
    background: #eef3f8;
    color: #111827;
}

.category-action.primary {
    background: #126C84;
    border-color: #126C84;
    color: #ffffff;
}

.workflow-action.primary-action {
    background: #126C84;
    border-color: #126C84;
    color: #ffffff;
}

.category-action.danger,
.workflow-action.danger {
    background: #F9F1F1;
    border-color: rgba(155, 59, 59, 0.22);
    color: #7f2f2f;
}

.workflow-grid {
    width: min(940px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(145px, 1fr));
    gap: 12px;
}

.home-footer {
    margin-top: 34px;
    font-size: 12px;
    font-weight: 500;
    color: #7a8491;
}

@@media (max-width: 900px) {
    .management-category-grid {
        grid-template-columns: 1fr;
    }

    .workflow-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@@media (max-width: 700px) {
    .home-screen {
        flex-direction: column;
    }

    .category-actions,
    .workflow-grid {
        grid-template-columns: 1fr;
    }
}
</style>
