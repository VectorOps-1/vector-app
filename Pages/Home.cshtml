@page
@model HomeModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Home";
    var isStaff = Model.AccessView == "staff";
    var isSeniorManagement = Model.AccessView == "senior-management";
    var viewName = isStaff ? "Staff View" : isSeniorManagement ? "Senior Management View" : "Operational Management View";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
}

<div class="home-screen ready show">
    @if (isSeniorManagement)
    {
        <a class="senior-company-login" href="/CompanyLogin">Company Login</a>
    }

    <div class="home-inner">
        <div class="home-label">Operations Dashboard</div>

        <div class="company-logo-frame">
            <img src="@companyLogoPath" class="home-logo" alt="Company Logo" />
        </div>

        @if (isSeniorManagement)
        {
            <div class="menu-row master-setup-row">
                <a class="menu-btn equipment-btn" href="/MasterSetup">Master Setup</a>
            </div>
        }

        <div class="home-context">Client: @ViewData["ClientName"]</div>
        <div class="view-badge">@viewName</div>

        @if (isStaff)
        {
            <p class="home-subtitle">Staff Actions</p>

            <div class="menu-row home-menu-row staff-action-row">
                <a class="menu-btn equipment-btn" href="/CompleteChecklist">Complete Checklist</a>
                <a class="menu-btn staff-btn" href="/PersonalDocuments">Upload Personal Documents</a>
                <a class="menu-btn report-btn" href="/ReportIssue?module=general">Report Issue</a>
                <a class="menu-btn stock-btn" href="#">Receive Action From Manager</a>
            </div>
        }
        else
        {
            <p class="home-subtitle">Equipment | Vehicles | Staff | Stock | Medication</p>

            <div class="menu-row home-menu-row">
                <a class="menu-btn vehicle-btn" href="/Vehicles">Vehicles</a>
                <a class="menu-btn equipment-btn" href="/Equipment">Equipment</a>
                <a class="menu-btn stock-btn" href="/Stock">Stock</a>
                <a class="menu-btn staff-btn" href="/Staff">Staff</a>
                <a class="menu-btn report-btn" href="/Medication">Medication</a>
            </div>

            <div class="section-divider"></div>
            <div class="section-label">Management Actions</div>

            <div class="menu-row home-menu-row setup-action-row">
                <a class="menu-btn equipment-btn" href="/EditChecklist">Edit Checklist</a>
                <a class="menu-btn staff-btn" href="/SendTask">Send Task</a>
            </div>

            <div class="section-divider compact-divider"></div>
            <div class="section-label">Operational Staff Actions</div>

            <div class="menu-row home-menu-row staff-action-row">
                <a class="menu-btn equipment-btn" href="/CompleteChecklist">Complete Checklist</a>
                <a class="menu-btn staff-btn" href="/PersonalDocuments">Upload Personal Documents</a>
                <a class="menu-btn report-btn" href="/ReportIssue?module=general">Report Issue</a>
                <a class="menu-btn stock-btn" href="#">Receive Action From Manager</a>
            </div>
        }

        <div class="home-footer">Vector v0.1</div>
    </div>
</div>

<style>
.home-screen {
    position: relative;
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.senior-company-login {
    position: absolute;
    top: 22px;
    left: 28px;
    padding: 10px 14px;
    border-radius: 8px;
    background: #334155;
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 12px 26px rgba(15, 23, 42, 0.14);
}

.senior-company-login:hover {
    color: #ffffff;
    opacity: 0.88;
}

.home-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.company-logo-frame {
    width: min(540px, 80%);
    height: 240px;
    margin: 0 auto 12px auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F4F7FB;
    overflow: hidden;
}

.home-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
}

.master-setup-row {
    margin-bottom: 18px;
}

.home-context {
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: 500;
    color: #6b7280;
}

.view-badge {
    margin-bottom: 18px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #425466;
}

.home-subtitle {
    margin-top: 0;
    margin-bottom: 26px;
    font-size: 24px;
    color: #2f2f2f;
}

.home-menu-row {
    gap: 24px;
    row-gap: 24px;
}

.section-divider {
    width: min(760px, 86%);
    height: 1px;
    margin: 36px auto 14px auto;
    background: rgba(66, 84, 102, 0.28);
}

.compact-divider {
    margin-top: 30px;
}

.section-label {
    margin-bottom: 18px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #6b7280;
}

.setup-action-row .menu-btn,
staff-action-row .menu-btn {
    min-width: 240px;
}

.home-footer {
    margin-top: 34px;
    font-size: 12px;
    font-weight: 500;
    color: #7a8491;
}

@@media (max-width: 700px) {
    .senior-company-login {
        position: static;
        margin: 18px auto 0 auto;
        display: inline-flex;
    }

    .home-screen {
        flex-direction: column;
    }
}
</style>
