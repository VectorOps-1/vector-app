@page
@model HomeModel
@{
    ViewData["Title"] = "Home";
    var isOperationalStaff = Model.AccessView == "operational-staff";
}

<div class="home-screen ready show">
    <div class="home-inner">
        <div class="home-label">Operations Dashboard</div>

        <img src="/vector-splash.png" class="home-logo" alt="Vector Logo" />

        <div class="home-context">Client: @ViewData["ClientName"]</div>
        <div class="view-badge">@(isOperationalStaff ? "Operational Staff View" : "Manager View")</div>

        @if (isOperationalStaff)
        {
            <p class="home-subtitle">Staff Actions</p>

            <div class="menu-row home-menu-row staff-action-row">
                <a class="menu-btn equipment-btn" href="#">Complete Checklist</a>
                <a class="menu-btn staff-btn" href="#">Upload Personal Documents</a>
                <a class="menu-btn vehicle-btn" href="#">Upload Accreditation/ Certification</a>
                <a class="menu-btn report-btn" href="#">Report Issue</a>
                <a class="menu-btn stock-btn" href="#">Receive Action From Manager</a>
            </div>
        }
        else
        {
            <p class="home-subtitle">Equipment | Vehicles | Staff | Stock</p>

            <div class="menu-row home-menu-row">
                <a class="menu-btn vehicle-btn" href="/Vehicles">Vehicles</a>
                <a class="menu-btn equipment-btn" href="/Equipment">Equipment</a>
                <a class="menu-btn stock-btn" href="/Stock">Stock</a>
                <a class="menu-btn staff-btn" href="#">Staff</a>
            </div>

            <div class="section-divider"></div>
            <div class="section-label">Manager Setup</div>

            <div class="menu-row home-menu-row setup-action-row">
                <a class="menu-btn equipment-btn" href="#">Upload Existing Data/ Template</a>
                <a class="menu-btn staff-btn" href="#">Send Task to Staff</a>
            </div>

            <div class="section-divider compact-divider"></div>
            <div class="section-label">Operational Staff Actions</div>

            <div class="menu-row home-menu-row staff-action-row">
                <a class="menu-btn equipment-btn" href="#">Complete Checklist</a>
                <a class="menu-btn staff-btn" href="#">Upload Personal Documents</a>
                <a class="menu-btn vehicle-btn" href="#">Upload Accreditation/ Certification</a>
                <a class="menu-btn report-btn" href="#">Report Issue</a>
                <a class="menu-btn stock-btn" href="#">Receive Action From Manager</a>
            </div>
        }

        <div class="home-footer">Vector v0.1</div>
    </div>
</div>

<style>
.home-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.home-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.home-logo {
    width: 540px;
    max-width: 80%;
    margin-bottom: 12px;
    display: block;
    margin-left: auto;
    margin-right: auto;
    mix-blend-mode: multiply;
}

.home-context {
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: 500;
    color: #6b7280;
}

.view-badge {
    margin-bottom: 18px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #425466;
}

.home-subtitle {
    margin-top: 0;
    margin-bottom: 26px;
    font-size: 24px;
    color: #2f2f2f;
}

.home-menu-row {
    gap: 24px;
    row-gap: 24px;
}

.section-divider {
    width: min(760px, 86%);
    height: 1px;
    margin: 36px auto 14px auto;
    background: rgba(66, 84, 102, 0.28);
}

.compact-divider {
    margin-top: 30px;
}

.section-label {
    margin-bottom: 18px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #6b7280;
}

.setup-action-row .menu-btn,
.staff-action-row .menu-btn {
    min-width: 240px;
}

.home-footer {
    margin-top: 34px;
    font-size: 12px;
    font-weight: 500;
    color: #7a8491;
}
</style>
