@page
@model CompanyNameModel
@{
    ViewData["Title"] = "Company Identity";
}

<div class="name-screen">
    <div class="name-inner">
        <div class="home-label">Company Profile</div>
        <h2 class="page-title">Company Identity</h2>
        <p class="page-subtitle">Master Setup is the source of truth for company identity, workspace, and branding settings.</p>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="status-message">@Model.StatusMessage</div>
        }

        <form method="post" class="name-form">
            <div class="identity-grid">
                <div class="field-block">
                    <label class="field-label" asp-for="CompanyName">Company name</label>
                    <input class="name-input" asp-for="CompanyName" maxlength="160" autocomplete="organization" />
                </div>

                <div class="field-block">
                    <label class="field-label" asp-for="TradingName">Trading name</label>
                    <input class="name-input" asp-for="TradingName" maxlength="160" autocomplete="organization" />
                </div>

                <div class="field-block">
                    <label class="field-label" asp-for="ContactEmail">Contact email</label>
                    <input class="name-input" asp-for="ContactEmail" type="email" maxlength="160" autocomplete="email" />
                </div>

                <div class="field-block">
                    <label class="field-label" asp-for="ContactPhone">Contact phone</label>
                    <input class="name-input" asp-for="ContactPhone" type="tel" maxlength="60" autocomplete="tel" />
                </div>

                <div class="field-block">
                    <label class="field-label" asp-for="Country">Country</label>
                    <input class="name-input" asp-for="Country" maxlength="80" autocomplete="country-name" />
                </div>

                <div class="field-block">
                    <label class="field-label" asp-for="Region">Region / province</label>
                    <input class="name-input" asp-for="Region" maxlength="120" autocomplete="address-level1" />
                </div>

                <div class="field-block">
                    <label class="field-label" asp-for="Timezone">Default timezone</label>
                    <input class="name-input" asp-for="Timezone" maxlength="80" list="timezone-options" placeholder="Africa/Johannesburg" />
                    <datalist id="timezone-options">
                        <option value="Africa/Johannesburg"></option>
                        <option value="Africa/Harare"></option>
                        <option value="Africa/Nairobi"></option>
                        <option value="Europe/London"></option>
                        <option value="Australia/Sydney"></option>
                        <option value="UTC"></option>
                    </datalist>
                </div>
            </div>

            <div class="logo-summary">
                <div>
                    <strong>Company logo</strong>
                    <span>Logo upload is stored against the same company identity record and appears after company login.</span>
                </div>
                <a class="menu-btn" asp-page="/LogoUpload">Open Logo Upload</a>
            </div>

            <div class="settings-summary">
                <div>
                    <strong>Workspace slug</strong>
                    <span>@Model.WorkspaceSlug</span>
                </div>
                <div>
                    <strong>Company access code</strong>
                    <span>@Model.WorkspaceAccessCode</span>
                </div>
                <div>
                    <strong>Branding status</strong>
                    <span>@Model.BrandingStatus</span>
                </div>
            </div>

            <button class="menu-btn equipment-btn save-name-btn" type="submit">Save Company Identity</button>
        </form>
    </div>
</div>

<style>
.name-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.name-inner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.status-message {
    width: min(520px, 90%);
    margin: 0 auto 22px auto;
    padding: 12px 16px;
    border: 1px solid rgba(31, 111, 91, 0.22);
    border-radius: 8px;
    background: rgba(31, 111, 91, 0.08);
    color: #1f6f5b;
    font-weight: 700;
}

.name-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
}

.identity-grid {
    width: min(860px, 96%);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
}

.field-block {
    min-width: 0;
}

.field-label {
    width: 100%;
    display: block;
    margin-bottom: 7px;
    text-align: left;
    font-size: 13px;
    font-weight: 700;
    color: #425466;
}

.name-input {
    width: 100%;
    box-sizing: border-box;
    padding: 14px 16px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #ffffff;
    font-size: 18px;
    color: #111827;
}

.settings-summary {
    width: min(860px, 96%);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
}

.logo-summary {
    width: min(860px, 96%);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    padding: 12px;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-radius: 8px;
    background: rgba(248, 250, 252, 0.9);
    text-align: left;
    box-sizing: border-box;
}

.logo-summary strong,
.logo-summary span {
    display: block;
}

.logo-summary strong {
    margin-bottom: 5px;
    color: #425466;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .7px;
    text-transform: uppercase;
}

.logo-summary span {
    color: #10233f;
    font-size: 13px;
    font-weight: 800;
    line-height: 1.4;
}

.settings-summary div {
    min-width: 0;
    padding: 12px;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.76);
    text-align: left;
}

.settings-summary strong,
.settings-summary span {
    display: block;
}

.settings-summary strong {
    margin-bottom: 5px;
    color: #425466;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .7px;
    text-transform: uppercase;
}

.settings-summary span {
    color: #10233f;
    font-size: 13px;
    font-weight: 800;
    overflow-wrap: anywhere;
}

.save-name-btn {
    margin-top: 8px;
    border: none;
}

@@media (max-width: 760px) {
    .identity-grid,
    .settings-summary,
    .logo-summary {
        grid-template-columns: 1fr;
    }
}
</style>

@if (Model.ActionSaved)
{
    <script>
        window.VectorActionConfirmation?.show({
            message: "Company identity saved.",
            redirectUrl: window.VectorActionConfirmation.getReturnUrl(),
            delay: 1300
        });
    </script>
}
