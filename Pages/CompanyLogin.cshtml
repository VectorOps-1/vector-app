@page "{workspaceSlug?}"
@model CompanyLoginModel
@{
    ViewData["Title"] = "Company Login";
}

<div class="company-login-screen">
    <div class="company-login-inner">
        <div class="home-label">AcuityOps Workspace</div>

        <img src="@Model.LogoPath" class="company-login-logo" alt="AcuityOps logo" />

        <div class="home-context">@Model.WorkspaceContext</div>

        <h2 class="page-title">Company Login</h2>
        <p class="page-subtitle">@Model.PageSubtitle</p>

        @if (!string.IsNullOrWhiteSpace(Model.LoginError))
        {
            <div class="login-error">@Model.LoginError</div>
        }

        @if (Model.ShowLoginForm)
        {
            <form class="workspace-form" method="post">
                <input type="hidden" asp-for="WorkspaceSlug" />

                <label asp-for="CompanyAccessCode">Company access code</label>
                <input asp-for="CompanyAccessCode"
                       type="password"
                       placeholder="Enter company access code"
                       autocomplete="off" />

                <button class="menu-btn equipment-btn" type="submit">Continue</button>
            </form>
        }
        else
        {
            <form class="workspace-form workspace-recovery-form" method="get">
                <label for="workspaceSlug">Company workspace link</label>
                <input id="workspaceSlug"
                       name="workspaceSlug"
                       type="text"
                       placeholder="Paste your workspace link or enter its workspace name"
                       autocomplete="url" />
                <button class="menu-btn equipment-btn" type="submit">Open Company Login</button>
            </form>
            <a class="button secondary company-login-start-link" href="/">Return to AcuityOps</a>
        }

        <p class="security-note">@Model.SecurityNote</p>
    </div>
</div>

<style>
.company-login-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.company-login-inner {
    width: 100%;
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.company-login-logo {
    width: 170px;
    max-width: 42%;
    margin: 0 auto 12px auto;
    display: block;
}

.home-context {
    margin-bottom: 10px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.workspace-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: min(100%, 460px);
    margin: 0 auto;
    text-align: left;
}

.workspace-form label {
    font-size: 13px;
    font-weight: 700;
    color: #52606d;
}

.workspace-form input {
    width: 100%;
    min-height: 48px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 0 14px;
    font-size: 15px;
    background: #ffffff;
    color: #1f2937;
    box-sizing: border-box;
}

.workspace-form .menu-btn {
    width: 100%;
    margin-top: 8px;
    border: 0;
}

.workspace-recovery-form {
    margin-top: 18px;
}

.company-login-start-link {
    display: inline-flex;
    margin-top: 14px;
}

.login-error {
    width: min(460px, 100%);
    margin: 0 auto 16px auto;
    padding: 12px 14px;
    border: 1px solid rgba(148, 57, 57, 0.22);
    border-radius: 8px;
    background: rgba(148, 57, 57, 0.07);
    color: #943939;
    font-size: 13px;
    font-weight: 800;
    text-align: left;
}

.security-note {
    margin: 22px auto 0 auto;
    max-width: 460px;
    font-size: 12px;
    line-height: 1.5;
    color: #6b7280;
}
</style>
