@page
@model CompanyLoginModel
@{
    ViewData["Title"] = "Company Login";
}

<div class="company-login-screen">
    <div class="company-login-inner">
        <div class="home-label">Vector Workspace</div>

        <img src="/vector-splash.png" class="company-login-logo" alt="Vector Logo" />

        <h2 class="page-title">Company Login</h2>
        <p class="page-subtitle">Enter the company ID linked to the subscription</p>

        @if (!string.IsNullOrWhiteSpace(Model.LoginError))
        {
            <div class="login-error">@Model.LoginError</div>
        }

        <form class="workspace-form" method="post">
            <label asp-for="CompanyId">Company ID</label>
            <input asp-for="CompanyId" type="text" inputmode="numeric" placeholder="Enter company ID" autocomplete="organization" />

            <button class="menu-btn equipment-btn" type="submit">Continue</button>
        </form>

        <p class="security-note">This selects the company workspace before staff, operational management, or senior management login.</p>
    </div>
</div>

<style>
.company-login-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: center;
}

.company-login-inner {
    width: 100%;
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.company-login-logo {
    width: 340px;
    max-width: 78%;
    margin: 0 auto 12px auto;
    display: block;
    mix-blend-mode: multiply;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.workspace-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: min(100%, 460px);
    margin: 0 auto;
    text-align: left;
}

.workspace-form label {
    font-size: 13px;
    font-weight: 700;
    color: #52606d;
}

.workspace-form input {
    width: 100%;
    min-height: 48px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 0 14px;
    font-size: 15px;
    background: #ffffff;
    color: #1f2937;
    box-sizing: border-box;
}

.workspace-form .menu-btn {
    width: 100%;
    margin-top: 8px;
    border: 0;
}

.login-error {
    width: min(460px, 100%);
    margin: 0 auto 16px auto;
    padding: 12px 14px;
    border: 1px solid rgba(148, 57, 57, 0.22);
    border-radius: 8px;
    background: rgba(148, 57, 57, 0.07);
    color: #943939;
    font-size: 13px;
    font-weight: 800;
    text-align: left;
}

.security-note {
    margin: 22px auto 0 auto;
    max-width: 460px;
    font-size: 12px;
    line-height: 1.5;
    color: #6b7280;
}
</style>
