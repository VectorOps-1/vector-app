@page
@model MedicationModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Medication";
    var branding = await CurrentUser.GetCurrentCompanyBrandingAsync(WebHostEnvironment);
    var companyLogoPath = branding.LogoPath;
    var companyName = branding.ClientName;
}

<div class="module-screen">
    <div class="module-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Operations Module</div>
        <h2 class="page-title">Medication</h2>
        <p class="page-subtitle">Choose the exact medication action from one place.</p>

        <div class="module-grid">
            <a class="module-card primary" href="/MedicationRegister?view=register">
                <strong>Medication Register</strong>
                <span>Open the full medication register by medicine, batch, quantity, location, and expiry. Use the search field inside the register when needed.</span>
            </a>

            <a class="module-card primary" href="/AddItem?type=medication">
                <strong>Add Medication</strong>
                <span>Add one medication item into the register</span>
            </a>

            <a class="module-card" href="/MoveAsset?asset=medication" data-move-asset="medication">
                <strong>Move / Reallocate</strong>
                <span>Move medication between stores, bases, vehicles, or operational areas</span>
            </a>

            <a class="module-card danger" href="/ReportIssue?module=medication">
                <strong>Report Issue</strong>
                <span>Report missing, expired, damaged, or stock-related medication issues</span>
            </a>

            <a class="module-card" href="/SendTask">
                <strong>Assign Medication Task</strong>
                <span>Send medication stock, batch, or expiry actions to a user</span>
            </a>
        </div>
    </div>
</div>

<style>
.module-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.module-inner {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 320px;
    max-width: 72%;
    max-height: 180px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.module-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    text-align: left;
}

.module-card {
    min-height: 116px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    padding: 18px;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
    color: #425466;
    text-decoration: none;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
}

.module-card:hover {
    color: #1f2937;
    border-color: rgba(155, 59, 59, 0.34);
}

.module-card strong {
    color: #1f2937;
    font-size: 18px;
    font-weight: 900;
}

.module-card span {
    color: #6b7280;
    font-size: 14px;
    font-weight: 700;
}

.module-card.primary {
    border-top: 6px solid #126C84;
}

@@media (max-width: 780px) {
    .module-grid {
        grid-template-columns: 1fr;
    }
}
</style>
