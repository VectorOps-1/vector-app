@page
@model CreateOperationalStaffAccessModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Create Operational Staff Access";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="access-screen">
    <div class="access-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Senior Management</div>
        <h2 class="page-title">Create Operational Staff Access</h2>
        <p class="page-subtitle">Create staff login details and assign operational actions</p>

        <form class="access-form">
            <section class="form-panel">
                <div class="section-label">Staff Details</div>
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label">Full name</label>
                        <input class="text-input" type="text" placeholder="Staff full name" />
                    </div>

                    <div class="field-group">
                        <label class="field-label">Email</label>
                        <input class="text-input" type="email" placeholder="staff@example.com" />
                    </div>

                    <div class="field-group">
                        <label class="field-label">Mobile number</label>
                        <input class="text-input" type="tel" placeholder="+974 0000 0000" />
                    </div>

                    <div class="field-group">
                        <label class="field-label">Role / title</label>
                        <input class="text-input" type="text" placeholder="Paramedic" />
                    </div>

                    <div class="field-group">
                        <label class="field-label">Department / base / location</label>
                        <input class="text-input" type="text" placeholder="Main Base" />
                    </div>

                    <div class="field-group">
                        <label class="field-label">Access level</label>
                        <select class="text-input">
                            <option>Operational Staff</option>
                        </select>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Temporary password</label>
                        <input class="text-input" type="password" placeholder="Set temporary password" />
                    </div>

                    <label class="toggle-row">
                        <input type="checkbox" checked />
                        <span>Account active</span>
                    </label>
                </div>
            </section>

            <section class="form-panel permissions-panel">
                <div class="section-label">Allowed Staff Actions</div>
                <div class="permission-grid">
                    <label class="permission-item"><input type="checkbox" checked /> Complete Checklist</label>
                    <label class="permission-item"><input type="checkbox" checked /> Upload Personal Documents</label>
                    <label class="permission-item"><input type="checkbox" checked /> Upload Accreditation / Certification</label>
                    <label class="permission-item"><input type="checkbox" checked /> Report Issue</label>
                    <label class="permission-item"><input type="checkbox" checked /> Receive Action From Manager</label>
                    <label class="permission-item"><input type="checkbox" /> View Own Profile</label>
                    <label class="permission-item"><input type="checkbox" /> View Assigned Vehicle</label>
                    <label class="permission-item"><input type="checkbox" /> View Assigned Equipment</label>
                </div>
            </section>

            <div class="action-row">
                <button class="menu-btn equipment-btn" type="button">Create Access</button>
                <button class="menu-btn vehicle-btn" type="button">Send Invite</button>
            </div>
        </form>
    </div>
</div>

<style>
.access-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.access-inner {
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 300px;
    max-width: 72%;
    max-height: 170px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.access-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
}

.form-panel {
    padding: 22px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.58);
    text-align: left;
}

.section-label {
    margin-bottom: 16px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.form-grid,
.permission-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px 24px;
}

.field-group {
    text-align: left;
}

.field-label {
    display: block;
    margin-bottom: 8px;
    font-size: 13px;
    font-weight: 700;
    color: #425466;
}

.text-input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #ffffff;
    font-size: 16px;
    color: #111827;
    box-sizing: border-box;
}

.toggle-row,
.permission-item {
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 48px;
    font-size: 15px;
    font-weight: 700;
    color: #425466;
}

.toggle-row input,
.permission-item input {
    width: 20px;
    height: 20px;
}

.action-row {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
}

.action-row .menu-btn {
    min-width: 260px;
    border: none;
}

@@media (max-width: 780px) {
    .form-grid,
    .permission-grid {
        grid-template-columns: 1fr;
    }
}
</style>
