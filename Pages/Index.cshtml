@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div id="splash">
    <img src="/vector-splash.png" alt="Vector Splash" />
</div>

<div id="mainContent" class="text-center">
    <h1 class="display-4">Vector Ops</h1>
    <p>Equipment | Vehicles | Staff | Stock</p>

    <br />

    <a class="btn btn-primary" href="/Equipment">Equipment</a>
    <a class="btn btn-secondary" href="#">Vehicles</a>
    <a class="btn btn-success" href="#">Staff</a>
    <a class="btn btn-warning" href="/Stock">Stock</a>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
    }

    #splash {
        position: fixed;
        inset: 0;
        background: black;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 1;
        transition: opacity 1.4s ease-in-out;
    }

    #splash img {
        width: 600px;
        max-width: 80vw;
        height: auto;
        display: block;
        opacity: 0;
        animation: logoFadeIn 1.4s ease-out forwards;
    }

    #splash.hide {
        opacity: 0;
        pointer-events: none;
    }

    #mainContent {
        min-height: 100vh;
        padding-top: 120px;
        opacity: 0;
        transition: opacity 1.0s ease-in-out;
    }

    #mainContent.show {
        opacity: 1;
    }

    @@keyframes logoFadeIn {
        from {
            opacity: 0;
            transform: scale(0.96);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<script>
    window.addEventListener("load", function () {
        setTimeout(function () {
            document.getElementById("splash").classList.add("hide");
            document.getElementById("mainContent").classList.add("show");
        }, 1800);

        setTimeout(function () {
            document.getElementById("splash").style.display = "none";
        }, 3200);
    });
</script>
