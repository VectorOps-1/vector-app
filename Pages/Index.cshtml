@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div id="splash">
    <img src="/Vector2.0.png" alt="Vector Logo" />
</div>

<div id="mainContent" class="text-center">
    <h1 class="display-4">Vector Ops</h1>
    <p>Equipment | Vehicles | Staff | Stock</p>

    <br />

    <a class="btn btn-primary" href="/Equipment">Equipment</a>
    <a class="btn btn-secondary" href="#">Vehicles</a>
    <a class="btn btn-success" href="#">Staff</a>
    <a class="btn btn-warning" href="/Stock">Stock</a>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
        background: black;
    }

    #splash {
        position: fixed;
        inset: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        background: black;
        opacity: 1;
        transition: opacity 1.2s ease-in-out;
        z-index: 9999;
    }

    #splash img {
        width: 180px;
        opacity: 0;
        transform: scale(0.96);
        animation: fadeLogo 1.4s ease-out forwards;
    }

    #mainContent {
        opacity: 0;
        transition: opacity 0.8s ease-in-out;
        padding-top: 120px;
        min-height: 100vh;
        background: white;
    }

    #mainContent.show {
        opacity: 1;
    }

    #splash.hide {
        opacity: 0;
        pointer-events: none;
    }

    @@keyframes fadeLogo {
        from {
            opacity: 0;
            transform: scale(0.96);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<script>
    window.addEventListener("load", function () {
        setTimeout(function () {
            document.getElementById("splash").classList.add("hide");
            document.getElementById("mainContent").classList.add("show");
        }, 1600);

        setTimeout(function () {
            document.getElementById("splash").style.display = "none";
        }, 2800);
    });
</script>
</script>
</script>
