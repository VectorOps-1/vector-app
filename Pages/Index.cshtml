@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<script>
    sessionStorage.removeItem("splashShown");

    if (sessionStorage.getItem("splashShown") === "true") {
        document.documentElement.classList.add("skip-splash");
    }
</script>

<div id="splash">
    <div class="splash-content">
        <img src="/vector-splash.png" alt="Vector Splash" />
        <div class="tagline">Create Order</div>
    </div>
</div>

<div id="mainContent" class="home-screen">
    <div class="home-inner">
        <h1 class="home-title">Vector</h1>
        <p class="home-subtitle">Equipment | Vehicles | Staff | Stock</p>

        <div class="menu-row">
            <a class="menu-btn vehicle-btn" href="/Vehicles">Vehicles</a>
            <a class="menu-btn equipment-btn" href="/Equipment">Equipment</a>
            <a class="menu-btn stock-btn" href="/Stock">Stock</a>
            <a class="menu-btn staff-btn" href="#">Staff</a>
        </div>
    </div>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
    }

    #splash {
        position: fixed;
        inset: 0;
        background: #000;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 1;
        transition: opacity 1s ease;
    }

    .splash-content {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* SLOWER + VISIBLE FADE */
    #splash img {
        width: 80vw;
        max-width: 950px;
        min-width: 260px;
        opacity: 0;
        transform: scale(0.95);
        animation: logoFadeIn 1.6s ease-out forwards;
    }

.tagline {
    margin-top: 26px;
    font-family: "Engravers MT", serif;
    font-size: 36px;
    font-weight: 700;
    color: #4da3ff;
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid rgba(77,163,255,0.8);
    width: 0;
    opacity: 0;

    animation:
        taglineAppear 0.01s linear 0.8s forwards,
        typing 1.6s steps(12, end) 0.8s forwards,
        blink 0.7s step-end 0.8s 6,
        hideCursor 0.01s linear 2.4s forwards;
}

    #splash.hide {
        opacity: 0;
        pointer-events: none;
    }

    .home-screen {
        display: none;
        min-height: 100vh;
        background: #ffffff;
        opacity: 0;
        transition: opacity 0.7s ease;
    }

    .home-screen.show {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        opacity: 1;
    }

    .home-inner {
        text-align: center;
        padding-top: 110px;
    }

    .home-title {
        font-size: 72px;
        font-weight: 300;
        color: #111;
    }

    .home-subtitle {
        margin-top: 14px;
        margin-bottom: 34px;
        font-size: 24px;
        color: #2f2f2f;
    }

    .menu-row {
        display: flex;
        justify-content: center;
        gap: 18px;
        flex-wrap: wrap;
    }

    .menu-btn {
        min-width: 165px;
        padding: 16px 28px;
        border-radius: 14px;
        text-decoration: none;
        font-size: 18px;
        font-weight: 700;
        border: none;
        box-shadow: 0 12px 26px rgba(0,0,0,0.18);
        transition: all 0.15s ease;
    }

    .menu-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 16px 32px rgba(0,0,0,0.22);
    }

    .menu-btn:active {
        transform: translateY(1px);
        box-shadow: 0 6px 14px rgba(0,0,0,0.16);
    }

    .vehicle-btn { background: #7b848d; color: white; }
    .equipment-btn { background: #1976ff; color: white; }
    .stock-btn { background: #f4bf06; color: black; }
    .staff-btn { background: #189255; color: white; }

    html.skip-splash #splash {
        display: none !important;
    }

    html.skip-splash .home-screen {
        display: flex !important;
        opacity: 1 !important;
    }

    @@keyframes logoFadeIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }

    @@keyframes taglineAppear {
        to { opacity: 1; }
    }

    @@keyframes typing {
        from { width: 0; }
        to { width: 12ch; }
    }

    @@keyframes blink {
        50% { border-color: transparent; }
    }
@@keyframes hideCursor {
    to { border-right-color: transparent; }
}
</style>

<script>
    window.addEventListener("load", function () {
        const splash = document.getElementById("splash");
        const mainContent = document.getElementById("mainContent");

        if (document.documentElement.classList.contains("skip-splash")) {
            return;
        }

        // SHOW SPLASH LONG ENOUGH TO SEE FADE
        setTimeout(function () {
            splash.classList.add("hide");

            setTimeout(function () {
                mainContent.classList.add("show");
                sessionStorage.setItem("splashShown", "true");
            }, 1000);

        }, 2500); // <-- THIS IS THE KEY (VISIBLE TIME)

        setTimeout(function () {
            splash.style.display = "none";
        }, 3800);
    });
</script>
