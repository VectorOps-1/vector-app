@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div id="splash">
    <img src="/vector-splash.png" alt="Vector Splash" />
</div>

<div id="mainContent" class="container text-center mt-5">
    <h1 class="display-4">Vector</h1>
    <p>Equipment | Vehicles | Staff | Stock</p>

    <br />

    <div class="menu-row">
        <a class="menu-btn equipment-btn" href="/Equipment">Equipment</a>
        <a class="menu-btn vehicle-btn" href="/Vehicles">Vehicles</a>
        <a class="menu-btn staff-btn" href="#">Staff</a>
        <a class="menu-btn stock-btn" href="/Stock">Stock</a>
    </div>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
    }

    #splash {
        position: fixed;
        inset: 0;
        background: black;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 1;
        transition: opacity 1.4s ease-in-out;
    }

    #splash img {
        width: 72vw;
        max-width: 840px;
        min-width: 220px;
        height: auto;
        display: block;
        margin: 0 auto;
        opacity: 0;
        animation: logoFadeIn 1.4s ease-out forwards;
    }

    #splash.hide {
        opacity: 0;
        pointer-events: none;
    }

    #mainContent {
        display: none;
        min-height: 100vh;
        padding-top: 140px;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    #mainContent.show {
        display: block;
        opacity: 1;
    }

    .menu-row {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .menu-btn {
        display: inline-block;
        padding: 14px 26px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 18px;
        font-weight: 600;
        background: white;
        border: 2px solid transparent;
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18);
        transition: transform 0.12s ease, box-shadow 0.12s ease;
    }

    .menu-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.22);
    }

    .menu-btn:active {
        transform: translateY(1px);
        box-shadow: 0 3px 8px rgba(0, 0, 0, 0.16);
    }

    .equipment-btn {
        color: #0d6efd;
        border-color: #86b7fe;
    }

    .vehicle-btn {
        color: #6c757d;
        border-color: #adb5bd;
    }

    .staff-btn {
        color: #198754;
        border-color: #75d7a4;
    }

    .stock-btn {
        color: #d39e00;
        border-color: #ffd454;
    }

    @@keyframes logoFadeIn {
        from {
            opacity: 0;
            transform: scale(0.96);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<script>
    if (!sessionStorage.getItem("splashShown")) {

        window.addEventListener("load", function () {

            setTimeout(function () {
                document.getElementById("splash").classList.add("hide");
                document.getElementById("mainContent").classList.add("show");
                sessionStorage.setItem("splashShown", "true");
            }, 1800);

            setTimeout(function () {
                document.getElementById("splash").style.display = "none";
            }, 3200);

        });

    } else {
        document.getElementById("splash").style.display = "none";
        document.getElementById("mainContent").classList.add("show");
    }
</script>
