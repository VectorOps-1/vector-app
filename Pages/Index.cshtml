@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<script>
    (function () {
        try {
            if (sessionStorage.getItem("homeSplashDone") === "true") {
                document.documentElement.classList.add("skip-splash");
            }
        } catch (e) { }
    })();
</script>

<div id="splash">
    <div class="splash-content">
        <img src="/vector-splash.png" alt="Vector Splash" />
        <div class="tagline">Create Order</div>
    </div>
</div>

<div id="mainContent" class="container text-center">
    <h1 class="display-4">Vector</h1>
    <p>Equipment | Vehicles | Staff | Stock</p>

    <div class="menu-row">
        <a class="menu-btn vehicle-btn" href="/Vehicles">Vehicles</a>
        <a class="menu-btn equipment-btn" href="/Equipment">Equipment</a>
        <a class="menu-btn stock-btn" href="/Stock">Stock</a>
        <a class="menu-btn staff-btn" href="#">Staff</a>
    </div>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
        background: black;
    }

    #splash {
        position: fixed;
        inset: 0;
        background: black;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 1;
        transition: opacity 1.2s ease;
    }

    .splash-content {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    #splash img {
        width: 80vw;
        max-width: 900px;
        min-width: 240px;
        opacity: 0;
        animation: logoFadeIn 1.2s ease forwards;
    }

    .tagline {
        margin-top: 20px;
        font-size: 34px;
        font-weight: 700;
        color: #4da3ff;
        overflow: hidden;
        white-space: nowrap;
        border-right: 2px solid rgba(77,163,255,0.7);
        width: 0;
        animation:
            typing 1.6s steps(12, end) 0.5s forwards,
            blink 0.7s step-end infinite;
    }

    #splash.hide {
        opacity: 0;
        pointer-events: none;
    }

    #mainContent {
        display: none;
        min-height: 100vh;
        padding-top: 120px;
        opacity: 0;
        transition: opacity 0.8s ease;
        color: white;
    }

    #mainContent.show {
        display: block;
        opacity: 1;
    }

    .menu-row {
        display: flex;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-top: 30px;
    }

    .menu-btn {
        padding: 14px 28px;
        border-radius: 10px;
        font-size: 18px;
        font-weight: 600;
        text-decoration: none;
        color: white;
        box-shadow: 0 6px 14px rgba(0,0,0,0.4);
        transition: all 0.15s ease;
    }

    .menu-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 22px rgba(0,0,0,0.5);
    }

    .menu-btn:active {
        transform: translateY(1px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.4);
    }

    .vehicle-btn { background: #6c757d; }
    .equipment-btn { background: #0d6efd; }
    .stock-btn { background: #ffc107; color: black; }
    .staff-btn { background: #198754; }

    html.skip-splash #splash {
        display: none !important;
    }

    html.skip-splash #mainContent {
        display: block !important;
        opacity: 1 !important;
    }

    @@keyframes logoFadeIn {
        from { opacity: 0; transform: scale(0.96); }
        to { opacity: 1; transform: scale(1); }
    }

    @@keyframes typing {
        from { width: 0; }
        to { width: 12ch; }
    }

    @@keyframes blink {
        50% { border-color: transparent; }
    }
</style>

<script>
    window.addEventListener("load", function () {
        const splash = document.getElementById("splash");
        const mainContent = document.getElementById("mainContent");

        if (document.documentElement.classList.contains("skip-splash")) return;

        setTimeout(() => {
            splash.classList.add("hide");
            mainContent.classList.add("show");
            sessionStorage.setItem("homeSplashDone", "true");
        }, 1800);

        setTimeout(() => {
            splash.style.display = "none";
        }, 3000);
    });
</script>
