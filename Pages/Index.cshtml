@page
@model IndexModel
@{
    ViewData["Title"] = "Company Login";
}

<script>
    if (sessionStorage.getItem("splashShown") === "true") {
        document.documentElement.classList.add("skip-splash");
    }
</script>

<div id="splash">
    <div class="splash-content">
        <img src="/vector-splash.png" alt="Vector Splash" />
        <div class="splash-brand">VECTOR - EMS</div>
        <div class="tagline" aria-label="Create Order">
            <span id="taglineText" class="tagline-text"></span><span id="taglineCursor" class="tagline-cursor"></span>
        </div>
    </div>
</div>

<div id="mainContent" class="workspace-screen">
    <div class="workspace-inner">
        <div class="home-label">Vector Workspace</div>

        <img src="/vector-splash.png" class="workspace-logo" alt="Vector Logo" />

        <p class="workspace-title">Company Login</p>
        <p class="workspace-subtitle">Enter the client workspace before selecting user access</p>

        <form class="workspace-form" method="get" action="/Access">
            <label class="field-label" for="workspaceCode">Company workspace code</label>
            <input id="workspaceCode" class="workspace-input" name="workspace" type="text" placeholder="Example: client-ems" autocomplete="organization" />

            <label class="field-label" for="companyPassword">Company access password</label>
            <input id="companyPassword" class="workspace-input" name="companyAccess" type="password" placeholder="Senior management company access" autocomplete="current-password" />

            <button class="menu-btn equipment-btn continue-btn" type="submit">Continue</button>
        </form>

        <div class="workspace-note">Company selection identifies the workspace. User role access is selected on the next screen.</div>
        <div class="home-footer">Vector v0.1</div>
    </div>
</div>

<style>
html, body {
    margin: 0;
    padding: 0;
}

#splash {
    position: fixed;
    inset: 0;
    background: #000;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    opacity: 1;
    transition: opacity 1s ease;
}

.splash-content {
    display: flex;
    flex-direction: column;
    align-items: center;
}

#splash img {
    width: 80vw;
    max-width: 950px;
    min-width: 260px;
    opacity: 0;
    transform: scale(0.95);
    animation: logoFadeIn 1.5s ease-out forwards;
}

.splash-brand {
    margin-top: 18px;
    font-family: "Engravers MT", serif;
    font-size: 35px;
    font-weight: 700;
    background: linear-gradient(90deg, #d8dde4 0%, #9fb8cc 36%, #f05a55 72%, #f2f4f7 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0;
    animation: brandFadeIn 0.8s ease-out 0.7s forwards;
}

.tagline {
    margin-top: 18px;
    font-family: "Engravers MT", serif;
    font-size: 36px;
    font-weight: 700;
    color: #ffffff;
    white-space: nowrap;
    opacity: 0;
    text-transform: uppercase;
    animation: taglineAppear 0.01s linear 1.45s forwards;
}

.tagline-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    margin-left: 2px;
    background: rgba(255,255,255,0.85);
    vertical-align: -0.08em;
    opacity: 0;
    animation:
        cursorAppear 0.01s linear 1.45s forwards,
        blinkCursor 0.7s step-end 1.45s 3,
        hideTypedCursor 0.01s linear 2.85s forwards;
}

#splash.hide {
    opacity: 0;
    pointer-events: none;
}

.workspace-screen {
    display: none;
    width: 100%;
    min-height: calc(100vh - 70px);
    opacity: 0;
    transition: opacity 0.7s ease;
}

.workspace-screen.ready {
    display: flex;
    justify-content: center;
    align-items: center;
}

.workspace-screen.show {
    opacity: 1;
}

.workspace-inner {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.workspace-logo {
    width: 420px;
    max-width: 78%;
    margin-bottom: 12px;
    display: block;
    margin-left: auto;
    margin-right: auto;
    mix-blend-mode: multiply;
}

.workspace-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.workspace-subtitle {
    margin: 0 0 24px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.workspace-form {
    width: min(520px, 94%);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: left;
}

.field-label {
    font-size: 13px;
    font-weight: 700;
    color: #425466;
}

.workspace-input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #ffffff;
    font-size: 16px;
    color: #111827;
    box-sizing: border-box;
}

.continue-btn {
    align-self: center;
    margin-top: 10px;
    min-width: 240px;
    border: none;
}

.workspace-note {
    width: min(560px, 92%);
    margin: 22px auto 0 auto;
    padding: 12px 14px;
    border: 1px solid rgba(66, 84, 102, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.58);
    font-size: 13px;
    font-weight: 700;
    color: #5f6b7a;
}

.home-footer {
    margin-top: 34px;
    font-size: 12px;
    font-weight: 500;
    color: #7a8491;
}

html.skip-splash #splash {
    display: none !important;
}

html.skip-splash .workspace-screen {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    opacity: 1 !important;
}

@@keyframes logoFadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}

@@keyframes brandFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
}

@@keyframes taglineAppear {
    to { opacity: 1; }
}

@@keyframes cursorAppear {
    to { opacity: 1; }
}

@@keyframes blinkCursor {
    50% { opacity: 0; }
}

@@keyframes hideTypedCursor {
    to { opacity: 0; }
}
</style>

<script>
window.addEventListener("load", function () {
    const splash = document.getElementById("splash");
    const mainContent = document.getElementById("mainContent");
    const taglineText = document.getElementById("taglineText");
    const phrase = "Create Order";

    if (document.documentElement.classList.contains("skip-splash")) {
        return;
    }

    setTimeout(function () {
        let index = 0;
        const typeNextCharacter = function () {
            taglineText.textContent = phrase.slice(0, index);
            index += 1;

            if (index <= phrase.length) {
                setTimeout(typeNextCharacter, 90);
            }
        };

        typeNextCharacter();
    }, 1450);

    setTimeout(function () {
        mainContent.classList.add("ready");
        splash.classList.add("hide");

        requestAnimationFrame(function () {
            mainContent.classList.add("show");
        });

        sessionStorage.setItem("splashShown", "true");
    }, 4300);

    setTimeout(function () {
        splash.style.display = "none";
    }, 5300);
});
</script>
