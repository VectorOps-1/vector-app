@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!-- Splash -->
<div id="splash">
    <img src="/vector-splash.png" alt="Vector Splash" />
</div>

<!-- Main -->
<div id="mainContent" class="container text-center">
    <h1 class="display-4">Vector Ops</h1>
    <p>Equipment | Vehicles | Staff | Stock</p>

    <br />

    <a class="btn btn-primary" href="/Equipment">Equipment</a>
    <a class="btn btn-secondary" href="/Vehicles">Vehicles</a>
    <a class="btn btn-success" href="#">Staff</a>
    <a class="btn btn-warning" href="/Stock">Stock</a>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
    }

    /* SPLASH */
    #splash {
        position: fixed;
        inset: 0;
        background: black;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 1;
        transition: opacity 1.4s ease-in-out;
    }

    #splash img {
        width: 1800px;
        max-width: none;
        height: auto;
        display: block;
        opacity: 0;
        animation: logoFadeIn 1.4s ease-out forwards;
    }

    #splash.hide {
        opacity: 0;
        pointer-events: none;
    }

    /* MAIN CONTENT */
    #mainContent {
        display: none;
        min-height: 100vh;
        padding-top: 140px;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    #mainContent.show {
        display: block;
        opacity: 1;
    }

    @@keyframes logoFadeIn {
        from {
            opacity: 0;
            transform: scale(0.96);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<script>
    window.addEventListener("load", function () {

        setTimeout(function () {
            document.getElementById("splash").classList.add("hide");
            document.getElementById("mainContent").classList.add("show");
        }, 1800);

        setTimeout(function () {
            document.getElementById("splash").style.display = "none";
        }, 3200);

    });
</script>
