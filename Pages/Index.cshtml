@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<script>
    if (sessionStorage.getItem("splashShown") === "true") {
        document.documentElement.classList.add("skip-splash");
    }
</script>

<div id="splash">
    <div class="splash-content">
        <img src="/vector-splash.png" alt="Vector Splash" />
        <div class="tagline">Create Order</div>
    </div>
</div>

<div id="mainContent" class="home-screen">
    <div class="home-inner">
        <div class="home-label">Operations Dashboard</div>

        <img src="/vector-splash.png" class="home-logo" alt="Vector Logo" />

        <div class="home-context">Client: @ViewData["ClientName"]</div>

        <p class="home-subtitle">Equipment | Vehicles | Staff | Stock</p>

        <div class="menu-row">
            <a class="menu-btn vehicle-btn" href="/Vehicles">Vehicles</a>
            <a class="menu-btn equipment-btn" href="/Equipment">Equipment</a>
            <a class="menu-btn stock-btn" href="/Stock">Stock</a>
            <a class="menu-btn staff-btn" href="#">Staff</a>
        </div>

        <div class="home-footer">Vector v0.1</div>
    </div>
</div>

<style>
html, body {
    margin: 0;
    padding: 0;
}

/* SPLASH */
#splash {
    position: fixed;
    inset: 0;
    background: #000;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    opacity: 1;
    transition: opacity 1s ease;
}

.splash-content {
    display: flex;
    flex-direction: column;
    align-items: center;
}

#splash img {
    width: 80vw;
    max-width: 950px;
    min-width: 260px;
    opacity: 0;
    transform: scale(0.95);
    animation: logoFadeIn 2.6s ease-out forwards;
}

.tagline {
    margin-top: 26px;
    font-family: "Engravers MT", serif;
    font-size: 36px;
    font-weight: 700;
    color: #ffffff;
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid rgba(255,255,255,0.85);
    width: 0;
    opacity: 0;

    animation:
        taglineAppear 0.01s linear 1s forwards,
        typing 0.5s steps(12, end) 1s forwards,
        blink 0.7s step-end 1s 4,
        hideCursor 0.01s linear 2s forwards;
}

#splash.hide {
    opacity: 0;
    pointer-events: none;
}

/* HOME */
.home-screen {
    display: none;
    min-height: 100vh;
    opacity: 0;
    transition: opacity 0.7s ease;
}

.home-screen.show {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    opacity: 1;
}

.home-inner {
    text-align: center;
    padding-top: 86px;
    padding-bottom: 30px;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.home-logo {
    width: 420px;
    max-width: 80%;
    margin-bottom: 12px;
    display: block;
    margin-left: auto;
    margin-right: auto;
    mix-blend-mode: multiply;
}

.home-context {
    margin-bottom: 10px;
    font-size: 12px;
    font-weight: 500;
    color: #6b7280;
}

.home-subtitle {
    margin-top: 0;
    margin-bottom: 26px;
    font-size: 24px;
    color: #2f2f2f;
}

.menu-row {
    display: flex;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
}

/* ONLY COLORS HERE (structure is global now) */
.vehicle-btn { background: #7b848d; color: black; }
.equipment-btn { background: #1976ff; color: black; }
.stock-btn { background: #f4bf06; color: black; }
.staff-btn { background: #189255; color: black; }

.home-footer {
    margin-top: 34px;
    font-size: 12px;
    font-weight: 500;
    color: #7a8491;
}

/* SPLASH CONTROL */
html.skip-splash #splash {
    display: none !important;
}

html.skip-splash .home-screen {
    display: flex !important;
    opacity: 1 !important;
}

/* ANIMATIONS */
@@keyframes logoFadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}

@@keyframes taglineAppear {
    to { opacity: 1; }
}

@@keyframes typing {
    from { width: 0; }
    to { width: 16ch; }
}

@@keyframes blink {
    50% { border-color: transparent; }
}

@@keyframes hideCursor {
    to { border-right-color: transparent; }
}
</style>

<script>
window.addEventListener("load", function () {
    const splash = document.getElementById("splash");
    const mainContent = document.getElementById("mainContent");

    if (document.documentElement.classList.contains("skip-splash")) {
        return;
    }

    setTimeout(function () {
        splash.classList.add("hide");

        setTimeout(function () {
            mainContent.classList.add("show");
            sessionStorage.setItem("splashShown", "true");
        }, 1000);

    }, 2000);

    setTimeout(function () {
        splash.style.display = "none";
    }, 3200);
});
</script>
