@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!-- Splash Screen -->
<div id="splash" style="height:100vh; display:flex; justify-content:center; align-items:center; background:black;">
    <img src="/images/Vector2.0.png" style="width:150px; opacity:0; animation: fadeIn 2s forwards;" />
</div>

<!-- Main Content -->
<div id="mainContent" style="display:none;" class="text-center">
    <h1 class="display-4">Vector Ops</h1>
    <p>Equipment | Vehicles | Staff | Stock</p>

    <br />

    <a class="btn btn-primary" href="/Equipment">Equipment</a>
    <a class="btn btn-secondary" href="#">Vehicles</a>
    <a class="btn btn-success" href="#">Staff</a>
    <a class="btn btn-warning" href="/Stock">Stock</a>
</div>

<style>
@keyframes fadeIn {
    to { opacity: 1; }
}
</style>

<script>
    setTimeout(function () {
        document.getElementById("splash").style.display = "none";
        document.getElementById("mainContent").style.display = "block";
    }, 2500);
</script>
