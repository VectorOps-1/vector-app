@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div id="splash">
    <div class="splash-content">
        <img src="/vector-splash.png" alt="Vector Splash" />

        <div class="tagline">Create Order</div>
    </div>
</div>

<div id="mainContent" class="container text-center mt-5">
    <h1 class="display-4">Vector</h1>
    <p>Equipment | Vehicles | Staff | Stock</p>

    <br />

    <div class="menu-row">
        <a class="menu-btn equipment-btn" href="/Equipment">Equipment</a>
        <a class="menu-btn vehicle-btn" href="/Vehicles">Vehicles</a>
        <a class="menu-btn staff-btn" href="#">Staff</a>
        <a class="menu-btn stock-btn" href="/Stock">Stock</a>
    </div>
</div>

<style>
    html, body {
        margin: 0;
        padding: 0;
    }

    #splash {
        position: fixed;
        inset: 0;
        background: black;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 1;
        transition: opacity 1.4s ease-in-out;
    }

    .splash-content {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    #splash img {
        width: 80vw;
        max-width: 1000px;
        min-width: 260px;
        height: auto;
        display: block;
        margin: 0 auto;
        opacity: 0;
        animation: logoFadeIn 1.4s ease-out forwards;
    }

    /* TAGLINE - TYPING EFFECT */
    .tagline {
        margin-top: 10mm;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 36px;
        font-weight: 700;
        letter-spacing: 1px;
        color: #4da3ff;

        overflow: hidden;
        white-space: nowrap;
        border-right: 2px solid rgba(77,163,255,0.7);

        width: 0;
        animation: typing 1.8s steps(13, end) forwards, blink 0.7s step-end infinite;

        text-shadow:
            0 1px 0 #1a4f99,
            0 2px 0 #143f7a,
            0 3px 0 #0f325f,
            0 4px 10px rgba(0, 0, 0, 0.7),
            0 0 10px rgba(77, 163, 255, 0.25);
    }

    #splash.hide {
        opacity: 0;
        pointer-events: none;
    }

    #mainContent {
        display: none;
        min-height: 100vh;
        padding-top: 140px;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    #mainContent.show {
        display: block;
        opacity: 1;
    }

    .menu-row {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .menu-btn {
        display: inline-block;
        padding: 14px 26px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 18px;
        font-weight: 600;
        border: 2px solid;
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18);
        transition: transform 0.12s ease, box-shadow 0.12s ease;
    }

    .menu-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.22);
    }

    .menu-btn:active {
        transform: translateY(1px);
        box-shadow: 0 3px 8px rgba(0, 0, 0, 0.16);
    }

    .equipment-btn {
        background: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }

    .vehicle-btn {
        background: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .staff-btn {
        background: #198754;
        border-color: #198754;
        color: white;
    }

    .stock-btn {
        background: #ffc107;
        border-color: #ffc107;
        color: black;
    }

    @@keyframes logoFadeIn {
        from {
            opacity: 0;
            transform: scale(0.96);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes typing {
        from { width: 0 }
        to { width: 12ch }
    }

    @@keyframes blink {
        50% { border-color: transparent }
    }
</style>

<script>
    window.addEventListener("load", function () {
        const splash = document.getElementById("splash");
        const mainContent = document.getElementById("mainContent");

        if (sessionStorage.getItem("homeSplashDone") === "true") {
            splash.style.display = "none";
            mainContent.classList.add("show");
            return;
        }

        setTimeout(function () {
            splash.classList.add("hide");
            mainContent.classList.add("show");
            sessionStorage.setItem("homeSplashDone", "true");
        }, 2000);

        setTimeout(function () {
            splash.style.display = "none";
        }, 3500);
    });
</script>
