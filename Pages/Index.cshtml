@page
@model IndexModel
@{
    ViewData["Title"] = "AcuityOps Workspace";
    var selectorScreenClass = Model.ShowSplash ? "selector-screen" : "selector-screen ready show";
}

@if (Model.ShowSplash)
{
    <div id="splash">
        <div class="splash-content">
            <img src="/acuityops-app-icon-splash.png" alt="AcuityOps" />
            <div class="splash-brand">AcuityOps</div>
            <div class="splash-company">by Vector Ops Group Pty Ltd</div>
        </div>
    </div>
}

<div id="mainContent" class="@selectorScreenClass">
    <div class="selector-inner">
        <div class="home-label">AcuityOps Workspace</div>

        <img src="@Model.LogoPath" class="selector-logo" alt="AcuityOps logo" />

        <div class="home-context">Secure EMS operations platform</div>

        <p class="selector-title">@(Model.HasRememberedWorkspace ? "Continue to your company login" : "Open your company workspace")</p>

        <p class="workspace-entry-note">
            @if (Model.HasRememberedWorkspace)
            {
                <text>Your previously opened workspace is ready. Continue to the company access gate.</text>
            }
            else
            {
                <text>Enter the workspace link issued during onboarding. Staff and managers sign in after the workspace opens.</text>
            }
        </p>

        <a class="menu-btn equipment-btn workspace-entry-link" href="@Model.WorkspaceEntryUrl">@Model.WorkspaceEntryLabel</a>

        <div class="home-footer">AcuityOps v0.1</div>
    </div>
</div>

<style>
html, body {
    margin: 0;
    padding: 0;
}

#splash {
    position: fixed;
    inset: 0;
    background: #000000;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    opacity: 1;
    transition: opacity 1s ease;
}

.splash-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 100%;
    padding: 36px 24px;
    box-sizing: border-box;
}

#splash img {
    width: min(58vw, 560px);
    min-width: 210px;
    max-height: 58vh;
    object-fit: contain;
    opacity: 0;
    transform: scale(0.95);
    animation: logoFadeIn 1.5s ease-out forwards;
}

.splash-brand {
    margin-top: 14px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 35px;
    font-weight: 800;
    color: #ffffff;
    opacity: 0;
    animation: brandFadeIn 0.8s ease-out 0.7s forwards;
}

.splash-company {
    margin-top: 6px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: rgba(255,255,255,0.72);
    opacity: 0;
    animation: brandFadeIn 0.8s ease-out 0.9s forwards;
}

#splash.hide {
    opacity: 0;
    pointer-events: none;
}

.selector-screen {
    display: none;
    width: 100%;
    min-height: calc(100vh - 70px);
    opacity: 0;
    transition: opacity 0.7s ease;
}

.selector-screen.ready {
    display: flex;
    justify-content: center;
    align-items: center;
}

.selector-screen.show {
    opacity: 1;
}

.selector-inner {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.selector-logo {
    width: 210px;
    max-width: 42%;
    margin-bottom: 12px;
    display: block;
    margin-left: auto;
    margin-right: auto;
}

.home-context {
    margin-bottom: 10px;
    font-size: 12px;
    font-weight: 500;
    color: #6b7280;
}

.selector-title {
    margin-top: 0;
    margin-bottom: 12px;
    font-size: 24px;
    color: #2f2f2f;
}

.workspace-entry-note {
    max-width: 520px;
    margin: 0 auto 22px auto;
    font-size: 14px;
    line-height: 1.55;
    font-weight: 600;
    color: #6b7280;
}

.workspace-entry-link {
    width: min(100%, 360px);
}

.home-footer {
    margin-top: 34px;
    font-size: 12px;
    font-weight: 500;
    color: #7a8491;
}

@@keyframes logoFadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}

@@keyframes brandFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
}

</style>

@if (Model.ShowSplash)
{
<script>
(function () {
    const splashSessionKey = "acuityopsSplashShown";
    const splash = document.getElementById("splash");
    const mainContent = document.getElementById("mainContent");
    let splashAlreadyShown = false;

    try {
        splashAlreadyShown = sessionStorage.getItem(splashSessionKey) === "true";
    } catch {
        splashAlreadyShown = false;
    }

    if (splashAlreadyShown) {
        splash.style.display = "none";
        mainContent.classList.add("ready", "show");
        return;
    }

    try {
        sessionStorage.setItem(splashSessionKey, "true");
    } catch {
        // If browser storage is unavailable, fall back to the normal splash animation.
    }

    setTimeout(function () {
        mainContent.classList.add("ready");
        splash.classList.add("hide");

        requestAnimationFrame(function () {
            mainContent.classList.add("show");
        });
    }, 4300);

    setTimeout(function () {
        splash.style.display = "none";
    }, 5300);
})();
</script>
}
