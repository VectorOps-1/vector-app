@page
@model StaffFilesPreviewModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Staff Files Preview";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="preview-screen">
    <div class="preview-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Staff Files Review</div>
        <h2 class="page-title">Review Staff File Upload</h2>
        <p class="page-subtitle">Files selected: @Model.FileCount</p>

        <div class="review-panel" id="staffFileList">
            <div class="folder-toolbar">
                <button class="small-action add-folder" type="button" onclick="addFolder()">Add Folder</button>
            </div>

            <section class="folder-block">
                <div class="folder-header">
                    <input class="folder-name" type="text" value="Staff Documents" />
                    <button class="small-action remove-folder" type="button" onclick="removeFolder(this)">Remove Folder</button>
                </div>

                <div class="review-row">
                    <input class="text-input" type="text" value="Uploaded file 1" aria-label="File name" />
                    <input class="text-input" type="text" placeholder="Assign to staff member" />
                    <input class="text-input" type="text" placeholder="Document type, e.g. CV or certification" />
                    <button class="small-action remove-file" type="button" onclick="removeFile(this)">Remove</button>
                </div>

                <div class="review-row">
                    <input class="text-input" type="text" value="Uploaded file 2" aria-label="File name" />
                    <input class="text-input" type="text" placeholder="Assign to staff member" />
                    <input class="text-input" type="text" placeholder="Document type" />
                    <button class="small-action remove-file" type="button" onclick="removeFile(this)">Remove</button>
                </div>
            </section>
        </div>

        <div class="action-row">
            <a class="menu-btn vehicle-btn" href="/UploadStaffFiles">Upload More Files</a>
            <button class="menu-btn equipment-btn" type="button">Save Staff Files</button>
        </div>
    </div>
</div>

<style>
.preview-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.preview-inner {
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 300px;
    max-width: 72%;
    max-height: 170px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.review-panel {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 22px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.58);
}

.folder-toolbar {
    display: flex;
    justify-content: flex-end;
}

.folder-block {
    padding: 18px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.64);
}

.folder-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 150px;
    gap: 14px;
    margin-bottom: 16px;
}

.folder-name {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #ffffff;
    font-size: 16px;
    font-weight: 800;
    color: #2f2f2f;
    box-sizing: border-box;
}

.review-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr) 110px;
    gap: 14px;
    align-items: center;
    margin-top: 12px;
}

.text-input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #ffffff;
    font-size: 15px;
    color: #111827;
    box-sizing: border-box;
}

.small-action {
    min-width: 110px;
    padding: 10px 14px;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
}

.add-folder {
    background: #1b7894;
    color: #ffffff;
}

.remove-folder,
.remove-file {
    background: #a43a3a;
    color: #ffffff;
}

.action-row {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    flex-wrap: wrap;
}

.action-row .menu-btn {
    min-width: 260px;
    border: none;
}

@@media (max-width: 880px) {
    .folder-toolbar,
    .folder-header,
    .review-row {
        display: flex;
        flex-direction: column;
        align-items: stretch;
    }

    .small-action {
        width: 100%;
    }
}
</style>

<script>
function addFolder() {
    const list = document.getElementById("staffFileList");
    const firstFolder = list.querySelector(".folder-block");
    const newFolder = firstFolder.cloneNode(true);

    newFolder.querySelector(".folder-name").value = "New Folder";
    newFolder.querySelectorAll(".review-row").forEach(function (row, index) {
        if (index > 0) {
            row.remove();
            return;
        }

        row.querySelectorAll("input").forEach(function (input, inputIndex) {
            input.value = inputIndex === 0 ? "Uploaded file" : "";
        });
    });

    list.appendChild(newFolder);
}

function removeFolder(button) {
    const list = document.getElementById("staffFileList");
    const folders = list.querySelectorAll(".folder-block");

    if (folders.length === 1) {
        folders[0].querySelector(".folder-name").value = "Staff Documents";
        folders[0].querySelectorAll(".review-row input").forEach(function (input) {
            input.value = "";
        });
        return;
    }

    button.closest(".folder-block").remove();
}

function removeFile(button) {
    const folder = button.closest(".folder-block");
    const rows = folder.querySelectorAll(".review-row");

    if (rows.length === 1) {
        rows[0].querySelectorAll("input").forEach(function (input) {
            input.value = "";
        });
        return;
    }

    button.closest(".review-row").remove();
}
</script>
