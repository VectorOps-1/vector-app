@page
@model StaffFilesPreviewModel
@using vector_app_local.Services
@inject IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "Staff Files Preview";
    var companyLogoPath = CompanyBranding.GetLogoPath(WebHostEnvironment);
    var companyName = CompanyBranding.GetCompanyName(WebHostEnvironment);
}

<div class="preview-screen">
    <div class="preview-inner">
        <img class="page-logo" src="@companyLogoPath" alt="Company Logo" />
        <div class="client-line">Client: @companyName</div>
        <div class="home-label">Staff Files Review</div>
        <h2 class="page-title">Review Staff File Upload</h2>
        <p class="page-subtitle">Files selected: @Model.FileCount</p>

        <div class="review-panel">
            <div class="review-row">
                <span class="file-type">PDF / Image / Document</span>
                <input class="text-input" type="text" placeholder="Assign to staff member" />
                <input class="text-input" type="text" placeholder="Document type, e.g. CV or certification" />
            </div>

            <div class="review-row">
                <span class="file-type">Additional file</span>
                <input class="text-input" type="text" placeholder="Assign to staff member" />
                <input class="text-input" type="text" placeholder="Document type" />
            </div>
        </div>

        <div class="action-row">
            <a class="menu-btn vehicle-btn" href="/UploadStaffFiles">Upload More Files</a>
            <button class="menu-btn equipment-btn" type="button">Save Staff Files</button>
        </div>
    </div>
</div>

<style>
.preview-screen {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    justify-content: center;
    align-items: flex-start;
}

.preview-inner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 20px 30px 20px;
    box-sizing: border-box;
}

.page-logo {
    width: 300px;
    max-width: 72%;
    max-height: 170px;
    object-fit: contain;
    margin: 0 auto 12px auto;
    display: block;
}

.client-line {
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 700;
    color: #6b7280;
}

.home-label {
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #5f6b7a;
}

.page-title {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 700;
    color: #2f2f2f;
}

.page-subtitle {
    margin: 0 0 28px 0;
    font-size: 16px;
    font-weight: 500;
    color: #6b7280;
}

.review-panel {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 22px;
    border: 1px solid rgba(66, 84, 102, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.58);
}

.review-row {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr) minmax(0, 1fr);
    gap: 14px;
    align-items: center;
}

.file-type {
    font-size: 13px;
    font-weight: 800;
    color: #425466;
    text-align: left;
}

.text-input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid rgba(66, 84, 102, 0.24);
    border-radius: 8px;
    background: #ffffff;
    font-size: 15px;
    color: #111827;
    box-sizing: border-box;
}

.action-row {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 28px;
    flex-wrap: wrap;
}

.action-row .menu-btn {
    min-width: 260px;
    border: none;
}

@@media (max-width: 820px) {
    .review-row {
        grid-template-columns: 1fr;
    }
}
</style>
